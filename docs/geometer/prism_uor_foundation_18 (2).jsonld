        "@id": "https://uor.foundation/op/AD_1"
      },
      "pop:ruleEffect": {
        "@id": "https://prism.uor.foundation/op/effect_grounding"
      },
      "cascade:sourcePhaseAngle": 30,
      "cascade:targetPhaseAngle": 60
    },
    {
      "@id": "https://prism.uor.foundation/op/rule_factorize",
      "@type": [
        "owl:NamedIndividual",
        "https://prism.uor.foundation/op/PipelineTransitionRule"
      ],
      "rdfs:label": "rule_factorize",
      "rdfs:comment": "Transition rule: E(2) Factorize → E(3) Resolve. Operator: Π (resolutionComponent of ι). Phase gate: state vector = Ω² (60°). Failure: ConvergenceStall or ContradictionDetected. The third phase rotation reaches the orthogonal axis: state vector advances from e^(iπ/3) to i.",
      "pop:ruleSourceStage": {
        "@id": "https://prism.uor.foundation/op/Factorize"
      },
      "pop:ruleOperator": {
        "@id": "https://prism.uor.foundation/op/infer"
      },
      "pop:ruleGuard": {
        "@id": "https://prism.uor.foundation/gate/gate_factorize"
      },
      "pop:ruleSuccessTarget": {
        "@id": "https://prism.uor.foundation/op/Resolve"
      },
      "pop:ruleFailureMode": [
        {
          "@id": "https://prism.uor.foundation/op/ConvergenceStall"
        },
        {
          "@id": "https://prism.uor.foundation/op/ContradictionDetected"
        }
      ],
      "pop:ruleGroundingIdentity": {
        "@id": "https://prism.uor.foundation/op/PM_2"
      },
      "pop:ruleEffect": {
        "@id": "https://prism.uor.foundation/op/effect_resolving"
      },
      "cascade:sourcePhaseAngle": 60,
      "cascade:targetPhaseAngle": 90
    },
    {
      "@id": "https://prism.uor.foundation/op/rule_resolve",
      "@type": [
        "owl:NamedIndividual",
        "https://prism.uor.foundation/op/PipelineTransitionRule"
      ],
      "rdfs:label": "rule_resolve",
      "rdfs:comment": "Transition rule: E(3) Resolve → E(4) Attest. Operator: α (accumulation). Phase gate: state vector = i (90°). Failure: ContradictionDetected. The fourth phase rotation begins the ascent: state vector advances from i to e^(i2π/3). The accumulation appends the resolved binding and the attestation trace is generated.",
      "pop:ruleSourceStage": {
        "@id": "https://prism.uor.foundation/op/Resolve"
      },
      "pop:ruleOperator": {
        "@id": "https://prism.uor.foundation/op/accumulate"
      },
      "pop:ruleGuard": {
        "@id": "https://prism.uor.foundation/gate/gate_resolve"
      },
      "pop:ruleSuccessTarget": {
        "@id": "https://prism.uor.foundation/op/Attest"
      },
      "pop:ruleFailureMode": {
        "@id": "https://prism.uor.foundation/op/ContradictionDetected"
      },
      "pop:ruleGroundingIdentity": {
        "@id": "https://uor.foundation/op/SR_1"
      },
      "pop:ruleEffect": {
        "@id": "https://prism.uor.foundation/op/effect_accumulating"
      },
      "cascade:sourcePhaseAngle": 90,
      "cascade:targetPhaseAngle": 120
    },
    {
      "@id": "https://prism.uor.foundation/op/rule_attest",
      "@type": [
        "owl:NamedIndividual",
        "https://prism.uor.foundation/op/PipelineTransitionRule"
      ],
      "rdfs:label": "rule_attest",
      "rdfs:comment": "Transition rule: E(4) Attest → E(5) Extract. Operator: P (projectionComponent of ι). Phase gate: state vector = Ω⁴ (120°). Failure: CoherenceViolation. The fifth phase rotation projects the resolved partition back to surface symbols: state vector advances from e^(i2π/3) to e^(i5π/6).",
      "pop:ruleSourceStage": {
        "@id": "https://prism.uor.foundation/op/Attest"
      },
      "pop:ruleOperator": {
        "@id": "https://prism.uor.foundation/op/infer"
      },
      "pop:ruleGuard": {
        "@id": "https://prism.uor.foundation/gate/gate_attest"
      },
      "pop:ruleSuccessTarget": {
        "@id": "https://prism.uor.foundation/op/Extract"
      },
      "pop:ruleFailureMode": {
        "@id": "https://prism.uor.foundation/op/CoherenceViolation"
      },
      "pop:ruleGroundingIdentity": {
        "@id": "https://prism.uor.foundation/op/PI_5"
      },
      "pop:ruleEffect": {
        "@id": "https://prism.uor.foundation/op/effect_projecting"
      },
      "cascade:sourcePhaseAngle": 120,
      "cascade:targetPhaseAngle": 150
    },
    {
      "@id": "https://prism.uor.foundation/op/rule_extract",
      "@type": [
        "owl:NamedIndividual",
        "https://prism.uor.foundation/op/PipelineTransitionRule"
      ],
      "rdfs:label": "rule_extract",
      "rdfs:comment": "Transition rule: E(5) Extract → E(6) Convergence. Operator: κ (composition). Phase gate: state vector = Ω⁵ (150°). Failure: CompositionFailure. The final phase rotation completes the topological half-circle: state vector advances from e^(i5π/6) to e^(iπ) = −1. Convergence at Euler's Identity proves the full 180° transformation.",
      "pop:ruleSourceStage": {
        "@id": "https://prism.uor.foundation/op/Extract"
      },
      "pop:ruleOperator": {
        "@id": "https://prism.uor.foundation/op/compose"
      },
      "pop:ruleGuard": {
        "@id": "https://prism.uor.foundation/gate/gate_extract"
      },
      "pop:ruleSuccessTarget": {
        "@id": "https://prism.uor.foundation/op/Convergence"
      },
      "pop:ruleFailureMode": {
        "@id": "https://prism.uor.foundation/op/CoherenceViolation"
      },
      "pop:ruleGroundingIdentity": {
        "@id": "https://prism.uor.foundation/op/EC_1"
      },
      "pop:ruleEffect": {
        "@id": "https://prism.uor.foundation/op/effect_projecting"
      },
      "cascade:sourcePhaseAngle": 150,
      "cascade:targetPhaseAngle": 180
    },
    {
