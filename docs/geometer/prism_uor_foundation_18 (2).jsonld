        }
      ]
    },
    {
      "@id": "https://prism.uor.foundation/constraint/CoherenceConstraint",
      "@type": "owl:Class",
      "rdfs:label": "CoherenceConstraint",
      "rdfs:comment": "A constraint requiring round-trip coherence on the grounding boundary. The operational form of the Surface Symmetry Theorem: roundTripCoherence = true on every ProjectionMap.",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/type/Constraint"
        }
      ],
      "owl:disjointWith": [
