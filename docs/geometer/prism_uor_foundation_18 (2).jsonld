          },
          "sh:minCount": 1,
          "sh:maxCount": 1,
          "sh:datatype": {
            "@id": "http://www.w3.org/2001/XMLSchema#nonNegativeInteger"
          }
        }
      ]
    },
    {
      "@id": "https://prism.uor.foundation/shape/InfeasibilityWitnessShape",
      "@type": "sh:NodeShape",
      "sh:targetClass": {
        "@id": "https://prism.uor.foundation/op/InfeasibilityWitness"
      },
      "rdfs:label": "InfeasibilityWitnessShape",
      "rdfs:comment": "Validates that an InfeasibilityWitness carries the typed infeasibility reason and the conditional evidence fields. When Contradictory: requires conflictingConstraints (≥1). When Insufficient: requires uncoveredFiber (≥1). Encoded as sh:or over two mutually exclusive branches.",
      "sh:property": [
        {
          "sh:path": {
            "@id": "https://prism.uor.foundation/op/infeasibilityKind"
          },
          "sh:minCount": 1,
          "sh:maxCount": 1,
          "sh:class": {
            "@id": "https://prism.uor.foundation/op/InfeasibilityKind"
          }
        }
      ],
      "sh:or": {
        "@list": [
          {
            "@type": "sh:NodeShape",
            "rdfs:comment": "Contradictory branch: kind is Contradictory and at least one conflicting constraint pair is identified.",
            "sh:property": [
              {
                "sh:path": {
                  "@id": "https://prism.uor.foundation/op/infeasibilityKind"
                },
                "sh:hasValue": {
                  "@id": "https://prism.uor.foundation/op/Contradictory"
                }
              },
              {
                "sh:path": {
                  "@id": "https://prism.uor.foundation/op/conflictingConstraints"
                },
                "sh:minCount": 1
              }
            ]
          },
          {
            "@type": "sh:NodeShape",
            "rdfs:comment": "Insufficient branch: kind is Insufficient and at least one uncovered fiber is identified.",
            "sh:property": [
              {
                "sh:path": {
                  "@id": "https://prism.uor.foundation/op/infeasibilityKind"
                },
                "sh:hasValue": {
                  "@id": "https://prism.uor.foundation/op/Insufficient"
                }
              },
              {
                "sh:path": {
                  "@id": "https://prism.uor.foundation/op/uncoveredFiber"
                },
                "sh:minCount": 1
              }
            ]
          }
        ]
      }
    },
    {
      "@id": "https://prism.uor.foundation/shape/ResolverContractShape",
      "@type": "sh:NodeShape",
      "sh:targetClass": {
        "@id": "https://prism.uor.foundation/op/ResolverContract"
