      },
      "pop:ruleGroundingIdentity": {
        "@id": "https://prism.uor.foundation/op/PD_1"
      },
      "pop:ruleEffect": {
        "@id": "https://prism.uor.foundation/op/effect_dispatch"
      },
      "cascade:sourcePhaseAngle": 0,
      "cascade:targetPhaseAngle": 30
    },
    {
      "@id": "https://prism.uor.foundation/op/rule_declare",
      "@type": [
        "owl:NamedIndividual",
        "https://prism.uor.foundation/op/PipelineTransitionRule"
      ],
      "rdfs:label": "rule_declare",
      "rdfs:comment": "Transition rule: E(1) Declare → E(2) Factorize. Operator: G (groundingComponent of ι). Phase gate: state vector = Ω (30°). Failure: GroundingFailure. The second phase rotation advances the state vector from e^(iπ/6) to e^(iπ/3).",
      "pop:ruleSourceStage": {
        "@id": "https://prism.uor.foundation/op/Declare"
      },
      "pop:ruleOperator": {
        "@id": "https://prism.uor.foundation/op/infer"
      },
      "pop:ruleGuard": {
