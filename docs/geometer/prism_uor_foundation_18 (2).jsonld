    {
      "@id": "https://prism.uor.foundation/proof/prf_TJ_1",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/proof/AxiomaticDerivation"
      ],
      "rdfs:label": "prf_TJ_1",
      "rdfs:comment": "Proof of TJ_1: Success judgment. Combines PE evaluation with ER reduction. Determinism from PX_1 + PD_1.",
      "proof:provesIdentity": {
        "@id": "https://prism.uor.foundation/op/TJ_1"
      },
      "proof:universalScope": true,
      "proof:verified": true
    },
    {
      "@id": "https://prism.uor.foundation/proof/prf_TJ_2",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/proof/AxiomaticDerivation"
      ],
      "rdfs:label": "prf_TJ_2",
      "rdfs:comment": "Proof of TJ_2: Failure judgment. Guard failure produces terminal state. Determinism from the guard being a total function.",
      "proof:provesIdentity": {
        "@id": "https://prism.uor.foundation/op/TJ_2"
      },
      "proof:universalScope": true,
      "proof:verified": true
    },
    {
      "@id": "https://prism.uor.foundation/proof/prf_TJ_3",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/proof/AxiomaticDerivation"
      ],
      "rdfs:label": "prf_TJ_3",
      "rdfs:comment": "Proof of TJ_3: Pipeline closure. Bounded termination from PM_7. Determinism from PX_1 (unique rule per stage).",
      "proof:provesIdentity": {
        "@id": "https://prism.uor.foundation/op/TJ_3"
      },
      "proof:universalScope": true,
      "proof:verified": true
    },
    {
      "@id": "https://prism.uor.foundation/proof/prf_MT_1",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/proof/AxiomaticDerivation"
      ],
      "rdfs:label": "prf_MT_1",
      "rdfs:comment": "Proof of MT_1: determinism. PX_1 unique rule per cascade ordinal + PE totality + ER functional updates → partial function.",
      "proof:provesIdentity": {
        "@id": "https://prism.uor.foundation/op/MT_1"
      },
      "proof:universalScope": true,
      "proof:verified": true
    },
    {
      "@id": "https://prism.uor.foundation/proof/prf_MT_2",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/proof/AxiomaticDerivation"
      ],
      "rdfs:label": "prf_MT_2",
      "rdfs:comment": "Proof of MT_2: trace identity. Immediate corollary of MT_1 by induction on trace length.",
      "proof:provesIdentity": {
        "@id": "https://prism.uor.foundation/op/MT_2"
      },
      "proof:universalScope": true,
      "proof:verified": true
    },
    {
      "@id": "https://prism.uor.foundation/proof/prf_MT_3",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/proof/AxiomaticDerivation"
      ],
      "rdfs:label": "prf_MT_3",
      "rdfs:comment": "Proof of MT_3: simulation correctness. Induction on trace length ≤6 (PM_7). Each step determined by PE+ER rules.",
      "proof:provesIdentity": {
        "@id": "https://prism.uor.foundation/op/MT_3"
      },
      "proof:universalScope": true,
      "proof:verified": true
    },
    {
      "@id": "https://prism.uor.foundation/proof/prf_OE_1",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/proof/AxiomaticDerivation"
      ],
      "rdfs:label": "prf_OE_1",
      "rdfs:comment": "Proof of OE_1: observation function definition. The four observed properties are the externally visible pipeline state by construction — they are the properties referenced by PipelineCertificate and PipelineTrace.",
      "proof:provesIdentity": {
        "@id": "https://prism.uor.foundation/op/OE_1"
      },
      "proof:universalScope": true,
      "proof:verified": true
    },
    {
      "@id": "https://prism.uor.foundation/proof/prf_OE_2",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/proof/AxiomaticDerivation"
      ],
      "rdfs:label": "prf_OE_2",
      "rdfs:comment": "Proof of OE_2: terminal equivalence. Follows from OE_1 — two executions reaching observe-equal terminal states satisfy the criterion. Necessary for certificate issuance.",
      "proof:provesIdentity": {
        "@id": "https://prism.uor.foundation/op/OE_2"
      },
      "proof:universalScope": true,
      "proof:verified": true
    },
    {
      "@id": "https://prism.uor.foundation/proof/prf_OE_3",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/proof/AxiomaticDerivation"
      ],
      "rdfs:label": "prf_OE_3",
      "rdfs:comment": "Proof of OE_3: bisimulation well-definedness. The four conditions define a standard bisimulation relation extended with Prism failure preservation. MT_3 is the special case where R = identity.",
      "proof:provesIdentity": {
        "@id": "https://prism.uor.foundation/op/OE_3"
      },
      "proof:universalScope": true,
      "proof:verified": true
    },
    {
      "@id": "https://prism.uor.foundation/proof/prf_OE_4a",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/proof/AxiomaticDerivation"
      ],
      "rdfs:label": "prf_OE_4a",
      "rdfs:comment": "Proof of OE_4a: stage fusion soundness. Guard composition preserves evaluation order. Effect composition is ER_3 sequential application. Terminal state is observe-equal by induction on the two fused steps.",
      "proof:provesIdentity": {
        "@id": "https://prism.uor.foundation/op/OE_4a"
      },
      "proof:universalScope": true,
      "proof:verified": true
    },
    {
      "@id": "https://prism.uor.foundation/proof/prf_OE_4b",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/proof/AxiomaticDerivation"
      ],
      "rdfs:label": "prf_OE_4b",
      "rdfs:comment": "Proof of OE_4b: effect commutation soundness. Disjoint functional updates commute — standard property of functional state update. Verified for all existing effect step pairs.",
      "proof:provesIdentity": {
        "@id": "https://prism.uor.foundation/op/OE_4b"
      },
      "proof:universalScope": true,
      "proof:verified": true
    },
    {
      "@id": "https://prism.uor.foundation/proof/prf_OE_4c",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/proof/AxiomaticDerivation"
      ],
      "rdfs:label": "prf_OE_4c",
      "rdfs:comment": "Proof of OE_4c: lease parallelism soundness. PL_2 fiber disjointness + PK_1 tower consistency + PK_2 O(1) resolution → composed state is order-independent.",
      "proof:provesIdentity": {
        "@id": "https://prism.uor.foundation/op/OE_4c"
      },
      "proof:universalScope": true,
      "proof:verified": true
    },
    {
      "@id": "https://prism.uor.foundation/proof/prf_CS_1",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/proof/AxiomaticDerivation"
      ],
      "rdfs:label": "prf_CS_1",
      "rdfs:comment": "Proof of CS_1: cost function. ER_2 steps are the only fiber-mutating operations. PE_ and ER_1 are read-only/control-flow. Cost = Σ fiberDelta is well-defined and total.",
      "proof:provesIdentity": {
        "@id": "https://prism.uor.foundation/op/CS_1"
      },
      "proof:universalScope": true,
      "proof:verified": true
    },
    {
      "@id": "https://prism.uor.foundation/proof/prf_CS_2",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/proof/AxiomaticDerivation"
      ],
      "rdfs:label": "prf_CS_2",
      "rdfs:comment": "Proof of CS_2: fusion cost neutrality. OE_4a fusion preserves the ER_2 step multiset. Sequential composition (ER_3) of two effect lists produces the union of their steps. Cost is additive over disjoint step sets.",
      "proof:provesIdentity": {
        "@id": "https://prism.uor.foundation/op/CS_2"
      },
      "proof:universalScope": true,
      "proof:verified": true
    },
    {
      "@id": "https://prism.uor.foundation/proof/prf_CS_3",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/proof/AxiomaticDerivation"
      ],
      "rdfs:label": "prf_CS_3",
      "rdfs:comment": "Proof of CS_3: parallel cost. PL_2 disjointness → no contention. Concurrent execution completes when the last lease completes → wall-clock = max.",
      "proof:provesIdentity": {
        "@id": "https://prism.uor.foundation/op/CS_3"
      },
      "proof:universalScope": true,
      "proof:verified": true
    },
    {
      "@id": "https://prism.uor.foundation/proof/prf_CS_4",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/proof/AxiomaticDerivation"
      ],
      "rdfs:label": "prf_CS_4",
      "rdfs:comment": "Proof of CS_4: speedup bound. PK_3 gives ⌈n/k⌉ per uniform lease. max_i ⌈n/k⌉ = ⌈n/k⌉. speedup = n/⌈n/k⌉ ≈ k.",
      "proof:provesIdentity": {
        "@id": "https://prism.uor.foundation/op/CS_4"
      },
      "proof:universalScope": true,
      "proof:verified": true
    },
    {
      "@id": "https://prism.uor.foundation/proof/prf_CS_5",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/proof/AxiomaticDerivation"
      ],
      "rdfs:label": "prf_CS_5",
      "rdfs:comment": "Proof of CS_5: asymptotic preservation. OE_3 bisimulation preserves the ER_2 step multiset (possibly reordered). Total fiber work = |ER_2 steps| × avg fiberDelta. Multiset preserved → total work preserved → O(n) preserved.",
      "proof:provesIdentity": {
        "@id": "https://prism.uor.foundation/op/CS_5"
      },
      "proof:universalScope": true,
      "proof:verified": true
    },
    {
      "@id": "https://prism.uor.foundation/proof/prf_SF_1",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/proof/AxiomaticDerivation"
      ],
      "rdfs:label": "prf_SF_1",
      "rdfs:comment": "Proof of SF_1: finite activation. λ produces k leases. ExecutionPolicy produces a permutation. Every element of a finite permutation is visited in ≤ k steps.",
      "proof:provesIdentity": {
        "@id": "https://prism.uor.foundation/op/SF_1"
      },
      "proof:universalScope": true,
      "proof:verified": true
    },
    {
      "@id": "https://prism.uor.foundation/proof/prf_SF_2",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/proof/AxiomaticDerivation"
      ],
      "rdfs:label": "prf_SF_2",
      "rdfs:comment": "Proof of SF_2: policy ordering. Each ExecutionPolicyKind defines a total order on the k leases. A total order on a finite set is a permutation. All four policies are total.",
      "proof:provesIdentity": {
        "@id": "https://prism.uor.foundation/op/SF_2"
      },
      "proof:universalScope": true,
      "proof:verified": true
    },
    {
      "@id": "https://prism.uor.foundation/proof/prf_SF_3",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/proof/AxiomaticDerivation"
      ],
      "rdfs:label": "prf_SF_3",
      "rdfs:comment": "Proof of SF_3: progress. PM_2 bounds resolver iterations. PM_7 bounds pipeline transitions. Bounded pipeline → lease eventually Released. Timeout → Expired. Both are terminal lease states.",
      "proof:provesIdentity": {
        "@id": "https://prism.uor.foundation/op/SF_3"
      },
      "proof:universalScope": true,
      "proof:verified": true
    },
    {
      "@id": "https://prism.uor.foundation/proof/prf_EA_1",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/proof/AxiomaticDerivation"
      ],
      "rdfs:label": "prf_EA_1",
      "rdfs:comment": "Proof of EA_1: epoch isolation. The DeferredQuerySet is write-only during execution. The pipeline reads only the epochContext and epochLeases — neither references the deferred set.",
      "proof:provesIdentity": {
        "@id": "https://prism.uor.foundation/op/EA_1"
      },
      "proof:universalScope": true,
      "proof:verified": true
    },
    {
      "@id": "https://prism.uor.foundation/proof/prf_EA_2",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/proof/AxiomaticDerivation"
      ],
      "rdfs:label": "prf_EA_2",
      "rdfs:comment": "Proof of EA_2: deferred completeness. The EpochBoundary drains the entire DeferredQuerySet into admittedQueries. No partial drain. admittedEpoch = arrivalEpoch + 1 by construction.",
      "proof:provesIdentity": {
        "@id": "https://prism.uor.foundation/op/EA_2"
      },
      "proof:universalScope": true,
      "proof:verified": true
    },
    {
      "@id": "https://prism.uor.foundation/proof/prf_EA_3",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/proof/AxiomaticDerivation"
      ],
      "rdfs:label": "prf_EA_3",
      "rdfs:comment": "Proof of EA_3: epoch composition. carriedContext = epochResult(preceding). epochContext(succeeding) = carriedContext. PA_1 associativity + SR_1 monotonicity → composition is well-defined.",
      "proof:provesIdentity": {
        "@id": "https://prism.uor.foundation/op/EA_3"
      },
      "proof:universalScope": true,
      "proof:verified": true
    },
    {
      "@id": "https://prism.uor.foundation/proof/prf_EA_4",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/proof/AxiomaticDerivation"
      ],
      "rdfs:label": "prf_EA_4",
      "rdfs:comment": "Proof of EA_4: epoch termination. PM_7 bounds each epoch. Cross-epoch convergence: each epoch reduces aggregate freeCount (SR_1). CB_5 sufficiency on the aggregate → finite epoch count.",
      "proof:provesIdentity": {
        "@id": "https://prism.uor.foundation/op/EA_4"
      },
      "proof:universalScope": true,
      "proof:verified": true
    },
    {
      "@id": "https://prism.uor.foundation/proof/prf_LS_1",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/proof/AxiomaticDerivation"
      ],
      "rdfs:label": "prf_LS_1",
      "rdfs:comment": "Proof of LS_1: checkpoint fidelity. Pinned fibers are irreversible (SR_1). The checkpoint captures all pinned state. Only freeCount fibers are released — they were never pinned.",
      "proof:provesIdentity": {
        "@id": "https://prism.uor.foundation/op/LS_1"
      },
      "proof:universalScope": true,
      "proof:verified": true
    },
    {
      "@id": "https://prism.uor.foundation/proof/prf_LS_2",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/proof/AxiomaticDerivation"
      ],
      "rdfs:label": "prf_LS_2",
      "rdfs:comment": "Proof of LS_2: suspension monotonicity. The context at resume time includes the checkpoint's pins plus any pins from other leases' work. PA_1 associativity → additional bindings are additive. SR_1 → pinnedCount cannot decrease.",
      "proof:provesIdentity": {
        "@id": "https://prism.uor.foundation/op/LS_2"
      },
      "proof:universalScope": true,
      "proof:verified": true
    },
    {
      "@id": "https://prism.uor.foundation/proof/prf_LS_3",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/proof/AxiomaticDerivation"
      ],
      "rdfs:label": "prf_LS_3",
      "rdfs:comment": "Proof of LS_3: repartition disjointness. Transferred fibers ⊆ checkpoint.freeCount. freeCount fibers are unclaimed by any Active lease (PL_2 pre-transfer). Target receives only unclaimed fibers → PL_2 post-transfer.",
      "proof:provesIdentity": {
        "@id": "https://prism.uor.foundation/op/LS_3"
      },
      "proof:universalScope": true,
      "proof:verified": true
    },
    {
      "@id": "https://prism.uor.foundation/proof/prf_LS_4",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/proof/AxiomaticDerivation"
      ],
      "rdfs:label": "prf_LS_4",
      "rdfs:comment": "Proof of LS_4: resume equivalence. OE_3 bisimulation with R = checkpoint mapping. LS_1 (same pinned fibers) + LS_2 (monotone progress) → guards evaluate same/better. Same guards + same effects → observe-equal terminal state (OE_2).",
      "proof:provesIdentity": {
        "@id": "https://prism.uor.foundation/op/LS_4"
      },
      "proof:universalScope": true,
      "proof:verified": true
    },
    {
      "@id": "https://prism.uor.foundation/proof/prf_AP_1",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/proof/AxiomaticDerivation"
      ],
      "rdfs:label": "prf_AP_1",
      "rdfs:comment": "Proof of AP_1: phase-rotation scheduling ordering. The PhaseRotationScheduler defines a total order on the deferred set by ascending (estimatedPhaseCost − accumulatedPhaseCredit). A total order on a finite set produces a permutation. The first m elements fitting within angularCapacity are admitted; the rest are spilled.",
      "proof:provesIdentity": {
        "@id": "https://prism.uor.foundation/op/AP_1"
      },
      "proof:universalScope": true,
      "proof:verified": true
    },
    {
      "@id": "https://prism.uor.foundation/proof/prf_AP_2",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/proof/AxiomaticDerivation"
      ],
      "rdfs:label": "prf_AP_2",
      "rdfs:comment": "Proof of AP_2: bounded deferral. Under PhaseRotationScheduler, effective priority = estimatedPhaseCost − accumulatedPhaseCredit. After K = ceil(maxPhaseCost / 30°) + 1 epochs, effective priority < 0. Since fresh arrivals have effective priority ≥ 0, the aged query is admitted first. Bounded by K. Derived from D_{2n} reflection symmetry.",
      "proof:provesIdentity": {
        "@id": "https://prism.uor.foundation/op/AP_2"
      },
      "proof:universalScope": true,
      "proof:verified": true
    },
    {
      "@id": "https://prism.uor.foundation/proof/prf_AP_3",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/proof/AxiomaticDerivation"
      ],
      "rdfs:label": "prf_AP_3",
      "rdfs:comment": "Proof of AP_3: angular capacity. freeCount × 30° / avgPhaseCost gives the number of queries whose phase rotation fits within the epoch's angular budget. PM_7 guarantees each admitted query's pipeline terminates. Therefore the epoch can process angularCapacity queries.",
      "proof:provesIdentity": {
        "@id": "https://prism.uor.foundation/op/AP_3"
      },
      "proof:universalScope": true,
      "proof:verified": true
    },
    {
      "@id": "https://prism.uor.foundation/proof/prf_SW_1",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/proof/AxiomaticDerivation"
      ],
      "rdfs:label": "prf_SW_1",
      "rdfs:comment": "Proof of SW_1: rolling guarantee. AP_2 bounds deferral to K epochs. Within those K epochs, PM_7 bounds per-epoch work. CS_1 cost ≤ freeCount. Therefore each query reaches σ ≥ minResolutionQuality within maxQueryLatency epochs.",
      "proof:provesIdentity": {
        "@id": "https://prism.uor.foundation/op/SW_1"
      },
      "proof:universalScope": true,
      "proof:verified": true
    },
    {
      "@id": "https://prism.uor.foundation/proof/prf_SW_2",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/proof/AxiomaticDerivation"
      ],
      "rdfs:label": "prf_SW_2",
      "rdfs:comment": "Proof of SW_2: window monotonicity. SR_1 per query → per-query σ is non-decreasing. AP_3 bounds angular capacity → epoch is not overloaded. Non-decreasing per-query quality → non-decreasing window average.",
      "proof:provesIdentity": {
        "@id": "https://prism.uor.foundation/op/SW_2"
      },
      "proof:universalScope": true,
      "proof:verified": true
    },
    {
      "@id": "https://prism.uor.foundation/proof/prf_SW_3",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/proof/AxiomaticDerivation"
      ],
      "rdfs:label": "prf_SW_3",
      "rdfs:comment": "Proof of SW_3: back-pressure. By definition: signal emitted iff currentWindowQuality < minResolutionQuality. The signal is a deterministic function of the window state. recommendedRateReduction is proportional to the shortfall.",
      "proof:provesIdentity": {
        "@id": "https://prism.uor.foundation/op/SW_3"
      },
      "proof:universalScope": true,
      "proof:verified": true
    },
    {
      "@id": "https://prism.uor.foundation/proof/prf_SW_4",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/proof/AxiomaticDerivation"
      ],
      "rdfs:label": "prf_SW_4",
      "rdfs:comment": "Proof of SW_4: steady-state. r ≤ c → AP_3 admits all queries per epoch → no spillover → accumulatedPhaseCredit stays 0° → SW_1 holds per query → window quality ≥ minResolutionQuality. r > c → spillover → accumulatedPhaseCredit increases → SW_3 fires.",
      "proof:provesIdentity": {
        "@id": "https://prism.uor.foundation/op/SW_4"
      },
      "proof:universalScope": true,
      "proof:verified": true
    },
    {
      "@id": "https://prism.uor.foundation/trace/",
      "@type": "owl:Ontology",
      "rdfs:label": "Prism Traces",
      "rdfs:comment": "Pipeline-level execution traces recording the progression through Prism operators. Extends the foundation trace/ taxonomy with composed-operation-level step recording.",
      "prism:space": "bridge",
      "owl:imports": [
        {
          "@id": "https://uor.foundation/trace/"
        },
        {
          "@id": "https://uor.foundation/partition/"
        },
        {
          "@id": "https://prism.uor.foundation/op/"
        },
        {
          "@id": "https://prism.uor.foundation/observable/"
        }
      ]
    },
    {
      "@id": "https://prism.uor.foundation/trace/PipelineTrace",
      "@type": "owl:Class",
      "rdfs:label": "PipelineTrace",
      "rdfs:comment": "A complete record of a pipeline execution: the PrismInstance it ran on, every PipelineStep in stage order, and the pipeline-level observables at each transition. Subclasses foundation ComputationTrace — every PipelineTrace is also a valid ComputationTrace with input/output datums and certification linkage.",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/trace/ComputationTrace"
        }
      ]
    },
    {
      "@id": "https://prism.uor.foundation/trace/PipelineStep",
      "@type": "owl:Class",
      "rdfs:label": "PipelineStep",
      "rdfs:comment": "A single stage transition in a pipeline execution. Records which operator ran, the PipelineStage at entry and exit, the FiberBudget snapshot, and the pipeline-level observable readings. Subclasses foundation ComputationStep — every PipelineStep is also a valid ComputationStep with input/output datums and operation linkage.",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/trace/ComputationStep"
        }
      ]
    },
    {
      "@id": "https://prism.uor.foundation/trace/tracedInstance",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "tracedInstance",
      "rdfs:comment": "The PrismInstance this pipeline trace records an execution of.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/trace/PipelineTrace"
      },
      "rdfs:range": {
        "@id": "https://prism.uor.foundation/op/PrismInstance"
      }
    },
    {
      "@id": "https://prism.uor.foundation/trace/pipelineStep",
      "@type": "owl:ObjectProperty",
      "rdfs:label": "pipelineStep",
      "rdfs:comment": "A PipelineStep in this trace. Non-functional: one step per operator stage (5 for a Complete pipeline, fewer for Failed).",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/trace/PipelineTrace"
      },
      "rdfs:range": {
        "@id": "https://prism.uor.foundation/trace/PipelineStep"
      }
    },
    {
      "@id": "https://prism.uor.foundation/trace/stageAtStep",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "stageAtStep",
      "rdfs:comment": "The PipelineStage that was active when this step executed.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/trace/PipelineStep"
      },
      "rdfs:range": {
        "@id": "https://prism.uor.foundation/op/PipelineStage"
      }
    },
    {
      "@id": "https://prism.uor.foundation/trace/appliedOperator",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "appliedOperator",
      "rdfs:comment": "The Prism composed operation (infer, accumulate, partition, dispatch, or compose) that executed at this step.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/trace/PipelineStep"
      },
      "rdfs:range": {
        "@id": "https://prism.uor.foundation/op/ComposedOperation"
      }
    },
    {
      "@id": "https://prism.uor.foundation/trace/budgetAtStep",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "budgetAtStep",
      "rdfs:comment": "The FiberBudget snapshot at the completion of this pipeline step. Records the fiber state after the operator executed.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/trace/PipelineStep"
      },
      "rdfs:range": {
        "@id": "https://uor.foundation/partition/FiberBudget"
      }
    },
    {
      "@id": "https://prism.uor.foundation/trace/entryStage",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "entryStage",
      "rdfs:comment": "The PipelineStage at entry to this step (before the operator executes).",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/trace/PipelineStep"
      },
      "rdfs:range": {
        "@id": "https://prism.uor.foundation/op/PipelineStage"
      }
    },
    {
      "@id": "https://prism.uor.foundation/trace/exitStage",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "exitStage",
      "rdfs:comment": "The PipelineStage at exit from this step (after the operator executes). On success, this is the successor stage in the PX_1 ordering. On failure, this is PipelineFailed.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/trace/PipelineStep"
      },
      "rdfs:range": {
        "@id": "https://prism.uor.foundation/op/PipelineStage"
      }
    },
    {
      "@id": "https://prism.uor.foundation/trace/stepIndex",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "stepIndex",
      "rdfs:comment": "Zero-based sequential index of this step within the PipelineTrace. For a Complete pipeline, indices are 0–4 corresponding to δ, G, Π, α, P.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/trace/PipelineStep"
      },
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#nonNegativeInteger"
      }
    },
    {
      "@id": "https://prism.uor.foundation/trace/stepFailureReason",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "stepFailureReason",
      "rdfs:comment": "The PipelineFailureReason if this step failed. Absent on successful steps. When present, exitStage = PipelineFailed.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/trace/PipelineStep"
      },
      "rdfs:range": {
        "@id": "https://prism.uor.foundation/op/PipelineFailureReason"
      }
    },
    {
      "@id": "https://prism.uor.foundation/trace/stepDuration",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "stepDuration",
      "rdfs:comment": "The duration of this pipeline step in FiberTransitions (algebraic latency). Not wall-clock time — the count of fiber-state changes during this step's operator execution.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/trace/PipelineStep"
      },
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#nonNegativeInteger"
      }
    },
    {
      "@id": "https://prism.uor.foundation/trace/stepObservables",
      "@type": "owl:ObjectProperty",
      "rdfs:label": "stepObservables",
      "rdfs:comment": "A PipelineObservable measured at this step. Non-functional: multiple observables may be sampled. InferenceObservable at Factorize/Extract, AccumulationObservable at Attest, etc.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/trace/PipelineStep"
      },
      "rdfs:range": {
        "@id": "https://prism.uor.foundation/observable/PipelineObservable"
      }
    },
    {
      "@id": "https://prism.uor.foundation/trace/terminationReason",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "terminationReason",
      "rdfs:comment": "For a Complete trace: PipelineSuccess (FullSaturationSuccess). For a Failed trace: one of the PipelineFailureReason individuals. Provides a single typed termination record on the trace itself.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/trace/PipelineTrace"
      },
      "rdfs:range": {
        "@id": "https://prism.uor.foundation/op/PipelineTermination"
      }
    },
    {
      "@id": "https://prism.uor.foundation/cert/",
      "@type": "owl:Ontology",
      "rdfs:label": "Prism Certificates",
      "rdfs:comment": "Pipeline-level attestation certificates. Extends the foundation cert/ taxonomy with composed-operation-level certification.",
      "prism:space": "bridge",
      "owl:imports": [
        {
          "@id": "https://uor.foundation/cert/"
        },
        {
          "@id": "https://prism.uor.foundation/op/"
        },
        {
          "@id": "https://prism.uor.foundation/trace/"
        }
      ]
    },
    {
      "@id": "https://prism.uor.foundation/cert/PipelineCertificate",
      "@type": "owl:Class",
      "rdfs:label": "PipelineCertificate",
      "rdfs:comment": "A certificate attesting that a complete pipeline execution satisfied the Prism identity algebra: PP_1 pipeline equivalence, PI_5 round-trip coherence, PA_4 base preservation, EC_1 Euler cascade closure. Issued when PipelineState reaches Convergence (E(6) = e^(iπ) = −1) with σ = 1. The unified proof artifact for enterprise supply chain deployments — certifies that the same accumulation sequence succeeded against the declared TargetConvergenceAngle.",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/cert/Certificate"
        }
      ]
    },
    {
      "@id": "https://prism.uor.foundation/cert/certifiedPipeline",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "certifiedPipeline",
      "rdfs:comment": "The PipelineTrace this certificate attests to.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/cert/PipelineCertificate"
      },
      "rdfs:range": {
        "@id": "https://prism.uor.foundation/trace/PipelineTrace"
      }
    },
    {
      "@id": "https://prism.uor.foundation/cert/certifiedBase",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "certifiedBase",
      "rdfs:comment": "The BaseContext the pipeline started from. Links the certificate to the initial state for audit.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/cert/PipelineCertificate"
      },
      "rdfs:range": {
        "@id": "https://prism.uor.foundation/op/BaseContext"
      }
    },
    {
      "@id": "https://prism.uor.foundation/cert/certifiedTarget",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "certifiedTarget",
      "rdfs:comment": "The TargetConvergenceAngle the pipeline executed toward. Links the certificate to the declared target for audit.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/cert/PipelineCertificate"
      },
      "rdfs:range": {
        "@id": "https://prism.uor.foundation/cascade/TargetConvergenceAngle"
      }
    },
    {
      "@id": "https://prism.uor.foundation/cert/saturationAchieved",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "saturationAchieved",
      "rdfs:comment": "Whether the pipeline reached σ = 1 (full saturation). True iff the accumulated context's freeCount = 0 and isClosed = true.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/cert/PipelineCertificate"
      },
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#boolean"
      }
    },
    {
      "@id": "https://prism.uor.foundation/cert/basePreserved",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "basePreserved",
      "rdfs:comment": "Whether PA_4 (base binding preservation) held throughout the pipeline execution. True iff no base-layer binding was overwritten.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/cert/PipelineCertificate"
      },
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#boolean"
      }
    },
    {
      "@id": "https://prism.uor.foundation/cert/coherenceVerified",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "coherenceVerified",
      "rdfs:comment": "Whether PI_5 (round-trip coherence) held at the grounding boundary. True iff roundTripCoherence = true on the ProjectionMap.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/cert/PipelineCertificate"
      },
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#boolean"
      }
    },
    {
      "@id": "https://prism.uor.foundation/cert/attestedIdentity",
      "@type": "owl:ObjectProperty",
      "rdfs:label": "attestedIdentity",
      "rdfs:comment": "An op:Identity that this certificate attests held during the pipeline execution. Non-functional: a PipelineCertificate attests PP_1 (pipeline equivalence), PI_5 (coherence), PA_4 (base preservation), and potentially PX_1 (stage ordering) and PX_2 (trace completeness).",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/cert/PipelineCertificate"
      },
      "rdfs:range": {
        "@id": "https://uor.foundation/op/Identity"
      }
    },
    {
      "@id": "https://prism.uor.foundation/cert/justifyingProof",
      "@type": "owl:ObjectProperty",
      "rdfs:label": "justifyingProof",
      "rdfs:comment": "A proof:AxiomaticDerivation that justifies this certificate's claims. Non-functional: one proof per attested identity. Links the certificate to the formal proof chain back to foundation axioms.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/cert/PipelineCertificate"
      },
      "rdfs:range": {
        "@id": "https://uor.foundation/proof/AxiomaticDerivation"
      }
    },
    {
      "@id": "https://prism.uor.foundation/cert/issuingInstance",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "issuingInstance",
      "rdfs:comment": "The PrismInstance that issued this certificate. Identifies the deployment configuration under which the pipeline executed, enabling certificate verification against a known instance.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/cert/PipelineCertificate"
      },
      "rdfs:range": {
        "@id": "https://prism.uor.foundation/op/PrismInstance"
      }
    },
    {
      "@id": "https://prism.uor.foundation/cert/verificationChain",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "verificationChain",
      "rdfs:comment": "The derivation:Derivation linking the certificate's attested identities back to foundation axioms. Enables independent verification: any party with access to the foundation ontology can replay the derivation chain to confirm the certificate's claims.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/cert/PipelineCertificate"
      },
      "rdfs:range": {
        "@id": "https://uor.foundation/derivation/Derivation"
      }
    },
    {
      "@id": "https://prism.uor.foundation/cert/OptimizationCertificate",
      "@type": "owl:Class",
      "rdfs:label": "OptimizationCertificate",
      "rdfs:comment": "Witnesses that a specific optimization transformation applied to a specific pipeline instance satisfies OE_3 bisimulation. Emitted by each optimization pass (stage fusion, effect commutation, lease parallelism). Links to the PipelineTrace of the actual optimized execution, the OE_4 identity justifying the transformation, and the bisimulation witness data. Machine-checkable: a conformance validator traverses the witness to verify disjointness (OE_4b), fiber mask disjointness (OE_4c), or guard conjunction (OE_4a).",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/cert/Certificate"
        }
      ]
    },
    {
      "@id": "https://prism.uor.foundation/cert/optimizedTrace",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "optimizedTrace",
      "rdfs:comment": "The PipelineTrace of the actual optimized execution. May have fewer steps than the abstract 5-step trace (stage fusion) or different step ordering (effect commutation).",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/cert/OptimizationCertificate"
      },
      "rdfs:range": {
        "@id": "https://prism.uor.foundation/trace/PipelineTrace"
      }
    },
    {
      "@id": "https://prism.uor.foundation/cert/abstractTrace",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "abstractTrace",
      "rdfs:comment": "The reference PipelineTrace that TJ_3 would produce for the same initial state. The bisimulation witness relates this trace to the optimized trace.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/cert/OptimizationCertificate"
      },
      "rdfs:range": {
        "@id": "https://prism.uor.foundation/trace/PipelineTrace"
      }
    },
    {
      "@id": "https://prism.uor.foundation/cert/appliedOptimization",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "appliedOptimization",
      "rdfs:comment": "The OE_4 sub-identity (OE_4a, OE_4b, or OE_4c) that justifies this optimization. Links the specific transformation to its soundness proof.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/cert/OptimizationCertificate"
      },
      "rdfs:range": {
        "@id": "https://uor.foundation/op/Identity"
      }
    },
    {
      "@id": "https://prism.uor.foundation/cert/bisimulationWitness",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "bisimulationWitness",
      "rdfs:comment": "The specific evidence that the optimized execution bisimulates the abstract execution. For OE_4a: the conjunction of fused guards. For OE_4b: the proof that reordered target properties are disjoint. For OE_4c: the proof that lease fiber masks are disjoint (AND = 0). Structured as a JSON object encoding the witness data.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/cert/OptimizationCertificate"
      },
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#string"
      }
    },
    {
      "@id": "https://prism.uor.foundation/cert/terminalEquivalenceVerified",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "terminalEquivalenceVerified",
      "rdfs:comment": "Whether OE_2 terminal equivalence was verified: observe(optimized terminal) = observe(abstract terminal).",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/cert/OptimizationCertificate"
      },
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#boolean"
      }
    },
    {
      "@id": "https://prism.uor.foundation/cert/optimizationEvidence",
      "@type": "owl:ObjectProperty",
      "rdfs:label": "optimizationEvidence",
      "rdfs:comment": "Links a PipelineCertificate to the OptimizationCertificates that witness the soundness of any applied optimizations. Non-functional: multiple optimizations may be applied (e.g., fusion + parallelism). Absent when no optimizations were applied (reference execution).",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/cert/PipelineCertificate"
      },
      "rdfs:range": {
        "@id": "https://prism.uor.foundation/cert/OptimizationCertificate"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/pred_dispatch_nonnull",
      "@type": [
        "owl:NamedIndividual",
        "https://prism.uor.foundation/op/NonNullPredicate"
      ],
      "rdfs:label": "pred_dispatch_nonnull",
      "rdfs:comment": "Predicate: selectedResolver is bound (δ produced a result).",
      "pop:targetProperty": {
        "@id": "https://prism.uor.foundation/op/selectedResolver"
      },
      "pop:evaluationRule": {
        "@id": "https://prism.uor.foundation/op/PE_1"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/pred_grounding_member",
      "@type": [
        "owl:NamedIndividual",
        "https://prism.uor.foundation/op/MembershipPredicate"
      ],
      "rdfs:label": "pred_grounding_member",
      "rdfs:comment": "Predicate: grounded address is an instance of the ring's Address class.",
      "pop:targetProperty": {
        "@id": "https://uor.foundation/state/address"
      },
      "pop:requiredMemberClass": {
        "@id": "https://uor.foundation/address/Address"
      },
      "pop:evaluationRule": {
        "@id": "https://prism.uor.foundation/op/PE_4"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/pred_resolve_complete",
      "@type": [
        "owl:NamedIndividual",
        "https://prism.uor.foundation/op/EqualsPredicate"
      ],
      "rdfs:label": "pred_resolve_complete",
      "rdfs:comment": "Predicate: resolver isComplete = true.",
      "pop:targetProperty": {
        "@id": "https://uor.foundation/resolver/isComplete"
      },
      "pop:expectedValue": true,
      "pop:evaluationRule": {
        "@id": "https://prism.uor.foundation/op/PE_2"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/pred_resolve_suggestion",
      "@type": [
        "owl:NamedIndividual",
        "https://prism.uor.foundation/op/NonNullPredicate"
      ],
      "rdfs:label": "pred_resolve_suggestion",
      "rdfs:comment": "Predicate: resolver suggestion is bound (a RefinementSuggestion was produced).",
      "pop:targetProperty": {
        "@id": "https://uor.foundation/resolver/suggestion"
      },
      "pop:evaluationRule": {
        "@id": "https://prism.uor.foundation/op/PE_1"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/pred_resolve_disjunction",
      "@type": [
        "owl:NamedIndividual",
        "https://prism.uor.foundation/op/DisjunctionPredicate"
      ],
      "rdfs:label": "pred_resolve_disjunction",
      "rdfs:comment": "Compound predicate: isComplete = true ∨ suggestion ≠ null.",
      "pop:leftOperand": {
        "@id": "https://prism.uor.foundation/op/pred_resolve_complete"
      },
      "pop:rightOperand": {
        "@id": "https://prism.uor.foundation/op/pred_resolve_suggestion"
      },
      "pop:evaluationRule": {
        "@id": "https://prism.uor.foundation/op/PE_5"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/pred_resolve_no_contradiction",
      "@type": [
        "owl:NamedIndividual",
        "https://prism.uor.foundation/op/NegationPredicate"
      ],
      "rdfs:label": "pred_resolve_no_contradiction",
      "rdfs:comment": "Compound predicate: ¬(terminationReason is ContradictionBoundary).",
      "pop:negatedOperand": {
        "@id": "https://prism.uor.foundation/op/pred_resolve_contradiction_check"
      },
      "pop:evaluationRule": {
        "@id": "https://prism.uor.foundation/op/PE_7"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/pred_resolve_conjunction",
      "@type": [
        "owl:NamedIndividual",
        "https://prism.uor.foundation/op/ConjunctionPredicate"
      ],
      "rdfs:label": "pred_resolve_conjunction",
      "rdfs:comment": "Conjunction: (isComplete=true ∨ suggestion≠null) ∧ ¬ContradictionBoundary. The complete resolving guard predicate.",
      "pop:leftOperand": {
        "@id": "https://prism.uor.foundation/op/pred_resolve_disjunction"
      },
      "pop:rightOperand": {
        "@id": "https://prism.uor.foundation/op/pred_resolve_no_contradiction"
      },
      "pop:evaluationRule": {
        "@id": "https://prism.uor.foundation/op/PE_6"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/pred_resolve_contradiction_check",
      "@type": [
        "owl:NamedIndividual",
        "https://prism.uor.foundation/op/MembershipPredicate"
      ],
      "rdfs:label": "pred_resolve_contradiction_check",
      "rdfs:comment": "Predicate: terminationReason is an instance of ContradictionBoundary (SR_5 fired).",
      "pop:targetProperty": {
        "@id": "https://prism.uor.foundation/trace/terminationReason"
      },
      "pop:requiredMemberClass": {
        "@id": "https://uor.foundation/state/ContradictionBoundary"
      },
      "pop:evaluationRule": {
        "@id": "https://prism.uor.foundation/op/PE_4"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/pred_accumulate_monotone",
      "@type": [
        "owl:NamedIndividual",
        "https://prism.uor.foundation/op/ComparisonPredicate"
      ],
      "rdfs:label": "pred_accumulate_monotone",
      "rdfs:comment": "Predicate: freeCount(outputContext) ≤ freeCount(inputContext) — SR_1 monotonicity.",
      "pop:lhsProperty": {
        "@id": "https://prism.uor.foundation/op/outputContext"
      },
      "pop:rhsProperty": {
        "@id": "https://prism.uor.foundation/op/inputContext"
      },
      "pop:comparator": "≤",
      "pop:evaluationRule": {
        "@id": "https://prism.uor.foundation/op/PE_3"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/pred_project_coherence",
      "@type": [
        "owl:NamedIndividual",
        "https://prism.uor.foundation/op/EqualsPredicate"
      ],
      "rdfs:label": "pred_project_coherence",
      "rdfs:comment": "Predicate: roundTripCoherence = true on the ProjectionMap.",
      "pop:targetProperty": {
        "@id": "https://uor.foundation/morphism/roundTripCoherence"
      },
      "pop:expectedValue": true,
      "pop:evaluationRule": {
        "@id": "https://prism.uor.foundation/op/PE_2"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/guard_dispatch",
      "@type": [
        "owl:NamedIndividual",
