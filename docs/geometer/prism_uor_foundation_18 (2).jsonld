      "@id": "https://prism.uor.foundation/constraint/LatencyConstraint",
      "@type": "owl:Class",
      "rdfs:label": "LatencyConstraint",
      "rdfs:comment": "A constraint bounding wall-clock time for resolution. Operationally equivalent to bounding iteration count via CB_6: iterations ≤ min(k, n).",
