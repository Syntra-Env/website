  "@graph": [
    {
      "@id": "https://prism.uor.foundation/",
      "@type": "owl:Ontology",
      "rdfs:label": "Prism Ontology",
      "rdfs:comment": "Polymorphic Resolution and Isometric Symmetry Machine — the algebraic runtime layer extending the UOR Foundation operations graph. Every Prism operation is a composition of foundation operations; every Prism identity derives from foundation identities. v1.4.0: Euler Cascade integration replaces arbitrary DevOps abstractions with geometrically determined state transitions parameterized by Ω = e^(iπ/6).",
      "owl:versionInfo": "1.4.0",
      "owl:imports": [
        {
          "@id": "https://uor.foundation/"
        }
      ]
    },
    {
      "@id": "https://prism.uor.foundation/cascade/EulerCascade",
      "@type": "owl:Class",
      "rdfs:label": "EulerCascade",
      "rdfs:comment": "The geometric progression governing Prism lifecycle state transitions. Parameterized by the complex 12th root of unity Ω = e^(iπ/6), which establishes a 30° phase shift per discrete transition. The cascade function E(k) = Ω^k maps each pipeline stage to a point on the upper half of the complex unit circle. E(0) = 1 (initialization) through E(6) = e^(iπ) = −1 (convergence) traces a 180° topological half-circle. Pipeline states are mathematically bound to their phase angle rather than assigned by arbitrary sequential indexing. Natively compatible with the UOR Foundation's Z/(2^n)Z algebraic structure and D_{2n} factorization.",
      "rdfs:subClassOf": {
        "@id": "https://uor.foundation/op/Operation"
      },
      "cascade:rootOfUnity": "e^(iπ/6)",
      "cascade:phaseIncrement": "30",
      "cascade:convergenceIdentity": "e^(iπ) = −1",
      "cascade:totalPhaseSpan": "180",
      "cascade:stageCount": 7
    },
    {
      "@id": "https://prism.uor.foundation/cascade/phaseAngle",
      "@type": "owl:DatatypeProperty",
      "rdfs:label": "phaseAngle",
      "rdfs:comment": "The phase angle in degrees at a given pipeline stage, determined by E(k) = Ω^k. Range [0, 180]. Each stage's phase angle is k × 30° where k is the stage ordinal. The phase angle geometrically encodes the object's depth of descent into the Substrate (0°–90°) and its ascent back to User Space (90°–180°).",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/PipelineStage"
      },
      "rdfs:range": {
        "@id": "xsd:decimal"
      }
    },
    {
      "@id": "https://prism.uor.foundation/cascade/stageOrdinal",
      "@type": "owl:DatatypeProperty",
      "rdfs:label": "stageOrdinal",
      "rdfs:comment": "The integer ordinal k of a pipeline stage in the Euler Cascade, where E(k) = Ω^k. Range [0, 6]. A geometrically determined position in the cascade function.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/PipelineStage"
      },
      "rdfs:range": {
        "@id": "xsd:integer"
      }
    },
    {
      "@id": "https://prism.uor.foundation/cascade/ComplexConjugateRollback",
      "@type": "owl:Class",
      "rdfs:label": "ComplexConjugateRollback",
      "rdfs:comment": "The rollback operator for the Euler Cascade pipeline. Applies the complex conjugate e^(−iπ/6) to reverse a phase rotation, decrementing the state vector by one cascade step. Mirrors the reflection symmetries of the Substrate's D_{2n} factorization, creating a natively reversible computation pipeline. A sequence of k conjugate applications returns the state from E(k) to E(0).",
      "rdfs:subClassOf": {
        "@id": "https://uor.foundation/op/Operation"
      },
      "cascade:conjugateOperator": "e^(−iπ/6)",
      "cascade:conjugatePhaseIncrement": "-30"
    },
    {
      "@id": "https://prism.uor.foundation/cascade/cascadeFunction",
      "@type": "owl:ObjectProperty",
      "rdfs:label": "cascadeFunction",
      "rdfs:comment": "Links a PipelineState to its position in the Euler Cascade. The cascade function E(k) = Ω^k determines the complex-valued state vector for the current stage ordinal k. The state vector must equal Ω^k for the state to be valid at stage k — this is the basis for Phase Gate Attestation.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/PipelineState"
      },
      "rdfs:range": {
        "@id": "https://prism.uor.foundation/cascade/EulerCascade"
      }
    },
    {
      "@id": "https://prism.uor.foundation/space",
      "@type": "owl:AnnotationProperty",
      "rdfs:label": "space",
      "rdfs:comment": "Prism-layer space classification: kernel (deployment-immutable), bridge (Prism-computed), or user (application-configurable).",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#string"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/",
      "@type": "owl:Ontology",
      "rdfs:label": "Prism Operations",
      "rdfs:comment": "Composed operations extending the foundation op/ graph. Each Prism operation decomposes into foundation operations via explicit composition laws.",
      "prism:space": "kernel",
      "owl:imports": [
        {
          "@id": "https://uor.foundation/op/"
        },
        {
          "@id": "https://uor.foundation/morphism/"
        },
        {
          "@id": "https://uor.foundation/resolver/"
        },
        {
          "@id": "https://uor.foundation/state/"
        },
        {
          "@id": "https://uor.foundation/partition/"
        },
        {
          "@id": "https://uor.foundation/query/"
        }
      ]
    },
    {
      "@id": "https://prism.uor.foundation/proof/",
      "@type": "owl:Ontology",
      "rdfs:label": "Prism Proofs",
      "rdfs:comment": "Proof individuals for Prism identities. Each proof traces back to foundation axioms through the derivation chain.",
      "prism:space": "bridge",
      "owl:imports": [
        {
          "@id": "https://uor.foundation/proof/"
        },
        {
          "@id": "https://prism.uor.foundation/op/"
        }
      ]
    },
    {
      "@id": "https://prism.uor.foundation/derivation/",
      "@type": "owl:Ontology",
      "rdfs:label": "Prism Derivations",
      "rdfs:comment": "Derivation chains connecting Prism identities to foundation identities via derivation:follows links.",
      "prism:space": "bridge",
      "owl:imports": [
        {
          "@id": "https://uor.foundation/derivation/"
        },
        {
          "@id": "https://prism.uor.foundation/op/"
        },
        {
          "@id": "https://prism.uor.foundation/proof/"
        }
      ]
    },
    {
      "@id": "https://prism.uor.foundation/derivation/deriv_PP_1",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/derivation/Derivation"
      ],
      "rdfs:label": "deriv_PP_1",
      "rdfs:comment": "Derivation chain for PP_1 (pipeline unification). Traces the composition κ(λ_k(α*(ι(s,·))),C) = resolve(s,C) back to four foundation identity families.",
      "derivation:step": [
        {
          "@id": "https://prism.uor.foundation/derivation/deriv_PP_1_s0"
        },
        {
          "@id": "https://prism.uor.foundation/derivation/deriv_PP_1_s1"
        },
        {
          "@id": "https://prism.uor.foundation/derivation/deriv_PP_1_s2"
        },
        {
          "@id": "https://prism.uor.foundation/derivation/deriv_PP_1_s3"
        }
      ]
    },
    {
      "@id": "https://prism.uor.foundation/derivation/deriv_PP_1_s0",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/derivation/DerivationStep"
      ],
      "rdfs:label": "deriv_PP_1_s0",
      "rdfs:comment": "Step 0: PI_3 (inference monotonicity) guarantees each ι application reduces freeCount, establishing the accumulation sequence converges.",
      "derivation:follows": {
        "@id": "https://prism.uor.foundation/op/PI_3"
      }
    },
    {
      "@id": "https://prism.uor.foundation/derivation/deriv_PP_1_s1",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/derivation/DerivationStep"
      ],
      "rdfs:label": "deriv_PP_1_s1",
      "rdfs:comment": "Step 1: PA_1 (accumulation associativity at convergence) guarantees the iterated α* produces the same final state regardless of binding order.",
      "derivation:follows": {
        "@id": "https://prism.uor.foundation/op/PA_1"
      }
    },
    {
      "@id": "https://prism.uor.foundation/derivation/deriv_PP_1_s2",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/derivation/DerivationStep"
      ],
      "rdfs:label": "deriv_PP_1_s2",
      "rdfs:comment": "Step 2: PL_3 (lease completeness recovery via MC_6) guarantees that composing all leased sub-sessions recovers σ=1.",
      "derivation:follows": {
        "@id": "https://prism.uor.foundation/op/PL_3"
      }
    },
    {
      "@id": "https://prism.uor.foundation/derivation/deriv_PP_1_s3",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/derivation/DerivationStep"
      ],
      "rdfs:label": "deriv_PP_1_s3",
      "rdfs:comment": "Step 3: PK_2 (composition O(1) resolution via MC_7) guarantees the composed result is immediately available without re-resolution.",
      "derivation:follows": {
        "@id": "https://prism.uor.foundation/op/PK_2"
      }
    },
    {
      "@id": "https://prism.uor.foundation/derivation/deriv_PA_4",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/derivation/Derivation"
      ],
      "rdfs:label": "deriv_PA_4",
      "rdfs:comment": "Derivation chain for PA_4 (base binding preservation). Traces immutability back to SR_1 monotonicity and fiber pinning irreversibility.",
      "derivation:step": [
        {
          "@id": "https://prism.uor.foundation/derivation/deriv_PA_4_s0"
        },
        {
          "@id": "https://prism.uor.foundation/derivation/deriv_PA_4_s1"
        }
      ]
    },
    {
      "@id": "https://prism.uor.foundation/derivation/deriv_PA_4_s0",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/derivation/DerivationStep"
      ],
      "rdfs:label": "deriv_PA_4_s0",
      "rdfs:comment": "Step 0: SR_1 (binding monotonicity) — freeCount never increases, so pinned fibers are never unpinned.",
      "derivation:follows": {
        "@id": "https://uor.foundation/op/SR_1"
      }
    },
    {
      "@id": "https://prism.uor.foundation/derivation/deriv_PA_4_s1",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/derivation/DerivationStep"
      ],
      "rdfs:label": "deriv_PA_4_s1",
      "rdfs:comment": "Step 1: Fiber pinning irreversibility (structural property of OR on bitmasks) — aggregate |= new never clears existing bits.",
      "derivation:follows": {
        "@id": "https://uor.foundation/op/B_3"
      }
    },
    {
      "@id": "https://prism.uor.foundation/derivation/deriv_PA_5",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/derivation/Derivation"
      ],
      "rdfs:label": "deriv_PA_5",
      "rdfs:comment": "Derivation chain for PA_5 (domain agnosticism). Traces domain-independence back to AD_1 (addressing bijection).",
      "derivation:step": [
        {
          "@id": "https://prism.uor.foundation/derivation/deriv_PA_5_s0"
        }
      ]
    },
    {
      "@id": "https://prism.uor.foundation/derivation/deriv_PA_5_s0",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/derivation/DerivationStep"
      ],
      "rdfs:label": "deriv_PA_5_s0",
      "rdfs:comment": "Step 0: AD_1 (addressing bijection) — addresses(glyph(d)) = d. The content-addressing map is domain-independent by construction.",
      "derivation:follows": {
        "@id": "https://uor.foundation/op/AD_1"
      }
    },
    {
      "@id": "https://prism.uor.foundation/derivation/deriv_PX_3",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/derivation/Derivation"
      ],
      "rdfs:label": "deriv_PX_3",
      "rdfs:comment": "Derivation chain for PX_3 (certificate issuance). Traces the issuance guarantee back to CIC_ coverage and PP_1 unification.",
      "derivation:step": [
        {
          "@id": "https://prism.uor.foundation/derivation/deriv_PX_3_s0"
        },
        {
          "@id": "https://prism.uor.foundation/derivation/deriv_PX_3_s1"
        }
      ]
    },
    {
      "@id": "https://prism.uor.foundation/derivation/deriv_PX_3_s0",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/derivation/DerivationStep"
      ],
      "rdfs:label": "deriv_PX_3_s0",
      "rdfs:comment": "Step 0: CIC_1 (every valid Transform admits a TransformCertificate) generalised to the pipeline level.",
      "derivation:follows": {
        "@id": "https://uor.foundation/op/CIC_1"
      }
    },
    {
      "@id": "https://prism.uor.foundation/derivation/deriv_PX_3_s1",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/derivation/DerivationStep"
      ],
      "rdfs:label": "deriv_PX_3_s1",
      "rdfs:comment": "Step 1: PP_1 (pipeline unification) — the composed pipeline is algebraically equivalent to a single resolution, so the resolution's certificate covers the pipeline.",
      "derivation:follows": {
        "@id": "https://prism.uor.foundation/op/PP_1"
      }
    },
    {
      "@id": "https://prism.uor.foundation/derivation/deriv_PI_1",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/derivation/Derivation"
      ],
      "rdfs:label": "deriv_PI_1",
      "rdfs:comment": "Derivation chain for PI_1 (inference idempotence). CC_1 gives O(1) resolution on CompleteType; SC_5 gives O(1) on SaturatedContext. Composed: repeated inference on a saturated context yields no state change.",
      "derivation:step": [
        {
          "@id": "https://prism.uor.foundation/derivation/deriv_PI_1_s0"
        },
        {
          "@id": "https://prism.uor.foundation/derivation/deriv_PI_1_s1"
        }
      ]
    },
    {
      "@id": "https://prism.uor.foundation/derivation/deriv_PI_1_s0",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/derivation/DerivationStep"
      ],
      "rdfs:label": "deriv_PI_1_s0",
      "rdfs:comment": "CC_1: CompleteType resolves in O(1).",
      "derivation:follows": {
        "@id": "https://uor.foundation/op/CC_1"
      }
    },
    {
      "@id": "https://prism.uor.foundation/derivation/deriv_PI_1_s1",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/derivation/DerivationStep"
      ],
      "rdfs:label": "deriv_PI_1_s1",
      "rdfs:comment": "SC_5: SaturatedContext resolves subsequent queries in O(1).",
      "derivation:follows": {
        "@id": "https://uor.foundation/op/SC_5"
      }
    },
    {
      "@id": "https://prism.uor.foundation/derivation/deriv_PI_2",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/derivation/Derivation"
      ],
      "rdfs:label": "deriv_PI_2",
      "rdfs:comment": "Derivation chain for PI_2 (inference well-typedness). Direct from the Surface Symmetry Theorem.",
      "derivation:step": [
        {
          "@id": "https://prism.uor.foundation/derivation/deriv_PI_2_s0"
        }
      ]
    },
    {
      "@id": "https://prism.uor.foundation/derivation/deriv_PI_2_s0",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/derivation/DerivationStep"
      ],
      "rdfs:label": "deriv_PI_2_s0",
      "rdfs:comment": "surfaceSymmetry: P∘Π∘G well-typed iff shared-frame condition holds.",
      "derivation:follows": {
        "@id": "https://uor.foundation/op/surfaceSymmetry"
      }
    },
    {
      "@id": "https://prism.uor.foundation/derivation/deriv_PI_3",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/derivation/Derivation"
      ],
      "rdfs:label": "deriv_PI_3",
      "rdfs:comment": "Derivation chain for PI_3 (inference monotonicity). Direct from SR_1 binding monotonicity.",
      "derivation:step": [
        {
          "@id": "https://prism.uor.foundation/derivation/deriv_PI_3_s0"
        }
      ]
    },
    {
      "@id": "https://prism.uor.foundation/derivation/deriv_PI_3_s0",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/derivation/DerivationStep"
      ],
      "rdfs:label": "deriv_PI_3_s0",
      "rdfs:comment": "SR_1: freeCount(B_{i+1}) ≤ freeCount(B_i) — binding monotonicity.",
      "derivation:follows": {
        "@id": "https://uor.foundation/op/SR_1"
      }
    },
    {
      "@id": "https://prism.uor.foundation/derivation/deriv_PI_4",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/derivation/Derivation"
      ],
      "rdfs:label": "deriv_PI_4",
      "rdfs:comment": "Derivation chain for PI_4 (inference embedding commutativity). AD_2 gives addressing diagram commutativity; QL_1 gives critical identity universality.",
      "derivation:step": [
        {
          "@id": "https://prism.uor.foundation/derivation/deriv_PI_4_s0"
        },
        {
          "@id": "https://prism.uor.foundation/derivation/deriv_PI_4_s1"
        }
      ]
    },
    {
      "@id": "https://prism.uor.foundation/derivation/deriv_PI_4_s0",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/derivation/DerivationStep"
      ],
      "rdfs:label": "deriv_PI_4_s0",
      "rdfs:comment": "AD_2: addressing diagram commutes through embeddings.",
      "derivation:follows": {
        "@id": "https://uor.foundation/op/AD_2"
      }
    },
    {
      "@id": "https://prism.uor.foundation/derivation/deriv_PI_4_s1",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/derivation/DerivationStep"
      ],
      "rdfs:label": "deriv_PI_4_s1",
      "rdfs:comment": "QL_1: critical identity holds at all quantum levels.",
      "derivation:follows": {
        "@id": "https://uor.foundation/op/QL_1"
      }
    },
    {
      "@id": "https://prism.uor.foundation/derivation/deriv_PI_5",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/derivation/Derivation"
      ],
      "rdfs:label": "deriv_PI_5",
      "rdfs:comment": "Derivation chain for PI_5 (inference round-trip coherence). GC_1 gives certificate issuance for shared-frame grounding; surfaceSymmetry gives the type-equivalence guarantee.",
      "derivation:step": [
        {
          "@id": "https://prism.uor.foundation/derivation/deriv_PI_5_s0"
        },
        {
          "@id": "https://prism.uor.foundation/derivation/deriv_PI_5_s1"
        }
      ]
    },
    {
      "@id": "https://prism.uor.foundation/derivation/deriv_PI_5_s0",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/derivation/DerivationStep"
      ],
      "rdfs:label": "deriv_PI_5_s0",
      "rdfs:comment": "GC_1: shared-frame grounding admits a GroundingCertificate.",
      "derivation:follows": {
        "@id": "https://uor.foundation/op/GC_1"
      }
    },
    {
      "@id": "https://prism.uor.foundation/derivation/deriv_PI_5_s1",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/derivation/DerivationStep"
      ],
      "rdfs:label": "deriv_PI_5_s1",
      "rdfs:comment": "surfaceSymmetry: P∘Π∘G lands in type-equivalent neighbourhood.",
      "derivation:follows": {
        "@id": "https://uor.foundation/op/surfaceSymmetry"
      }
    },
    {
      "@id": "https://prism.uor.foundation/derivation/deriv_PA_1",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/derivation/Derivation"
      ],
      "rdfs:label": "deriv_PA_1",
      "rdfs:comment": "Derivation chain for PA_1 (accumulation associativity). Direct from SR_10 Church-Rosser confluence.",
      "derivation:step": [
        {
          "@id": "https://prism.uor.foundation/derivation/deriv_PA_1_s0"
        }
      ]
    },
    {
      "@id": "https://prism.uor.foundation/derivation/deriv_PA_1_s0",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/derivation/DerivationStep"
      ],
      "rdfs:label": "deriv_PA_1_s0",
      "rdfs:comment": "SR_10: different execution policies produce the same final resolved state.",
      "derivation:follows": {
        "@id": "https://uor.foundation/op/SR_10"
      }
    },
    {
