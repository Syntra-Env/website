        },
        {
          "@id": "https://prism.uor.foundation/observable/DispatchObservable"
        },
        {
          "@id": "https://prism.uor.foundation/observable/CompositionObservable"
        }
      ]
    },
    {
      "@id": "https://prism.uor.foundation/observable/DispatchObservable",
      "@type": "owl:Class",
      "rdfs:label": "DispatchObservable",
      "rdfs:comment": "An observable measuring properties of the dispatch operator δ: dispatch coverage (fraction of query types handled) and dispatch specificity (constraint surface match tightness).",
      "rdfs:subClassOf": [
        {
          "@id": "https://prism.uor.foundation/observable/PipelineObservable"
        }
      ],
      "owl:disjointWith": [
        {
          "@id": "https://prism.uor.foundation/observable/InferenceObservable"
        },
        {
          "@id": "https://prism.uor.foundation/observable/AccumulationObservable"
        },
        {
          "@id": "https://prism.uor.foundation/observable/LeaseObservable"
        },
        {
          "@id": "https://prism.uor.foundation/observable/CompositionObservable"
        }
      ]
    },
    {
      "@id": "https://prism.uor.foundation/observable/CompositionObservable",
      "@type": "owl:Class",
      "rdfs:label": "CompositionObservable",
      "rdfs:comment": "An observable measuring properties of the session composition operator κ: composition gain (σ increase beyond max input σ), composition overhead (SR_8 verification cost), and distributed speedup (sequential/parallel work ratio).",
      "rdfs:subClassOf": [
        {
          "@id": "https://prism.uor.foundation/observable/PipelineObservable"
        }
      ],
      "owl:disjointWith": [
        {
          "@id": "https://prism.uor.foundation/observable/InferenceObservable"
        },
        {
          "@id": "https://prism.uor.foundation/observable/AccumulationObservable"
        },
        {
          "@id": "https://prism.uor.foundation/observable/LeaseObservable"
        },
        {
          "@id": "https://prism.uor.foundation/observable/DispatchObservable"
        }
      ]
    },
    {
      "@id": "https://prism.uor.foundation/observable/observedOperation",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "observedOperation",
      "rdfs:comment": "The Prism composed operation instance that this observable measures.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/observable/PipelineObservable"
      },
      "rdfs:range": {
        "@id": "https://prism.uor.foundation/op/ComposedOperation"
      }
    },
    {
      "@id": "https://prism.uor.foundation/observable/FiberTransitions",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/observable/MeasurementUnit"
      ],
      "rdfs:label": "FiberTransitions",
      "rdfs:comment": "Count of fiber-state changes (pinned ← free). The natural unit for algebraic latency of Prism operations."
    },
    {
      "@id": "https://prism.uor.foundation/observable/BindingSteps",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/observable/MeasurementUnit"
      ],
      "rdfs:label": "BindingSteps",
      "rdfs:comment": "Count of binding applications to a session. The natural unit for accumulation observables."
    },
    {
      "@id": "https://prism.uor.foundation/observable/LeaseUnits",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/observable/MeasurementUnit"
      ],
      "rdfs:label": "LeaseUnits",
      "rdfs:comment": "Count of lease sub-domains. The natural unit for lease partition observables. k in MC_8 is measured in LeaseUnits."
    },
    {
      "@id": "https://prism.uor.foundation/op/Initialization",
      "@type": [
        "owl:NamedIndividual",
        "https://prism.uor.foundation/op/PipelineStage"
      ],
      "rdfs:label": "Initialization",
      "rdfs:comment": "E(0) = 1 (0°). The object exists in User Space (Layer 4) prior to declaration. The identity element of the cascade — no phase rotation has been applied. The pipeline's initial state.",
      "cascade:stageOrdinal": 0,
      "cascade:phaseAngle": 0,
      "cascade:complexValue": "1",
      "pop:guardCondition": {
        "@id": "https://prism.uor.foundation/gate/gate_initialization"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/Declare",
      "@type": [
        "owl:NamedIndividual",
        "https://prism.uor.foundation/op/PipelineStage"
      ],
      "rdfs:label": "Declare",
      "rdfs:comment": "E(1) = Ω (30°). Prism writes the type declaration. The object initiates its topological descent from User Space toward the Substrate. The first application of the unitary operator Ω rotates the state vector by 30°.",
      "cascade:stageOrdinal": 1,
      "cascade:phaseAngle": 30,
      "cascade:complexValue": "e^(iπ/6)",
      "pop:stageOperator": {
        "@id": "https://prism.uor.foundation/op/dispatch"
      },
      "pop:guardCondition": {
        "@id": "https://prism.uor.foundation/gate/gate_declare"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/Factorize",
      "@type": [
        "owl:NamedIndividual",
        "https://prism.uor.foundation/op/PipelineStage"
      ],
      "rdfs:label": "Factorize",
      "rdfs:comment": "E(2) = Ω² (60°). The object descends toward the Substrate for D_{2n} factorization. The grounding map G translates the surface symbol into a ring address. The 60° phase reflects partial descent — the object is between User Space and the Substrate.",
      "cascade:stageOrdinal": 2,
      "cascade:phaseAngle": 60,
      "cascade:complexValue": "e^(iπ/3)",
      "pop:stageOperator": {
        "@id": "https://prism.uor.foundation/op/infer"
      },
      "pop:guardCondition": {
        "@id": "https://prism.uor.foundation/gate/gate_factorize"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/Resolve",
      "@type": [
        "owl:NamedIndividual",
        "https://prism.uor.foundation/op/PipelineStage"
      ],
      "rdfs:label": "Resolve",
      "rdfs:comment": "E(3) = Ω³ = i (90°). The object reaches maximum depth in the Substrate (Layer 1). The Engine translates the type into a mathematical Partition. The orthogonality (90°) reflects the pure abstract nature of the Substrate relative to User Space — the imaginary axis is perpendicular to the real axis of initialization.",
      "cascade:stageOrdinal": 3,
      "cascade:phaseAngle": 90,
      "cascade:complexValue": "i",
      "pop:stageOperator": {
        "@id": "https://prism.uor.foundation/op/infer"
      },
      "pop:guardCondition": {
        "@id": "https://prism.uor.foundation/gate/gate_resolve"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/Attest",
      "@type": [
        "owl:NamedIndividual",
        "https://prism.uor.foundation/op/PipelineStage"
      ],
      "rdfs:label": "Attest",
      "rdfs:comment": "E(4) = Ω⁴ (120°). The Verification layer generates a computation trace and cryptographic Certificate. Ascent begins. The accumulation operator α appends the resolved binding, and the attestation proves the binding is valid. The 120° phase marks the transition from pure Substrate operations back toward User Space.",
      "cascade:stageOrdinal": 4,
      "cascade:phaseAngle": 120,
      "cascade:complexValue": "e^(i2π/3)",
      "pop:stageOperator": {
        "@id": "https://prism.uor.foundation/op/accumulate"
      },
      "pop:guardCondition": {
        "@id": "https://prism.uor.foundation/gate/gate_attest"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/Extract",
      "@type": [
        "owl:NamedIndividual",
        "https://prism.uor.foundation/op/PipelineStage"
      ],
      "rdfs:label": "Extract",
      "rdfs:comment": "E(5) = Ω⁵ (150°). The validated object state is prepared for return via Query. The projection map P translates the resolved partition back to surface symbols. The 150° phase places the object near the completion of its topological half-circle.",
      "cascade:stageOrdinal": 5,
      "cascade:phaseAngle": 150,
      "cascade:complexValue": "e^(i5π/6)",
      "pop:stageOperator": {
        "@id": "https://prism.uor.foundation/op/infer"
      },
      "pop:guardCondition": {
        "@id": "https://prism.uor.foundation/gate/gate_extract"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/Convergence",
      "@type": [
        "owl:NamedIndividual",
        "https://prism.uor.foundation/op/PipelineStage"
      ],
      "rdfs:label": "Convergence",
      "rdfs:comment": "E(6) = e^(iπ) = −1 (180°). The cycle is complete. The object is returned to Layer 4. The −1 state mathematically proves that the object has undergone the full 180° transformation through the Substrate and is a validated, post-lifecycle mirror of its initial E(0) = 1 state. Convergence at Euler's Identity replaces the arbitrary 'PipelineComplete' terminal. σ = 1, freeCount = 0, all target constraints satisfied.",
      "cascade:stageOrdinal": 6,
      "cascade:phaseAngle": 180,
      "cascade:complexValue": "-1"
    },
    {
      "@id": "https://prism.uor.foundation/op/PipelineFailed",
      "@type": [
        "owl:NamedIndividual",
        "https://prism.uor.foundation/op/PipelineStage"
      ],
      "rdfs:label": "PipelineFailed",
      "rdfs:comment": "Terminal failure stage: a phase gate attestation failed, meaning the state vector does not equal the expected Ω^k at the transition boundary. Records the failing stage ordinal, the actual vs expected phase angle, and the typed failure reason. No phase angle is assigned — failure is outside the cascade's geometric progression."
    },
    {
      "@id": "https://prism.uor.foundation/op/PipelineTermination",
      "@type": "owl:Class",
      "rdfs:label": "PipelineTermination",
      "rdfs:comment": "The abstract result of pipeline termination. Exactly one of its two disjoint subclasses: PipelineSuccess (saturation achieved) or PipelineFailureReason (a typed failure). Serves as the typed union for the terminationReason property on PipelineTrace.",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ],
      "owl:disjointUnionOf": {
        "@list": [
          {
            "@id": "https://prism.uor.foundation/op/PipelineSuccess"
          },
          {
            "@id": "https://prism.uor.foundation/op/PipelineFailureReason"
          }
        ]
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/PipelineSuccess",
      "@type": "owl:Class",
      "rdfs:label": "PipelineSuccess",
      "rdfs:comment": "Successful pipeline termination. The pipeline reached Convergence (E(6) = e^(iπ) = −1) with σ = 1 (FullSaturation). Links to the foundation SaturationPhase that ended the session.",
      "rdfs:subClassOf": [
        {
          "@id": "https://prism.uor.foundation/op/PipelineTermination"
        }
      ],
      "owl:disjointWith": [
        {
          "@id": "https://prism.uor.foundation/op/PipelineFailureReason"
        }
      ]
    },
    {
      "@id": "https://prism.uor.foundation/op/PipelineFailureReason",
      "@type": "owl:Class",
      "rdfs:label": "PipelineFailureReason",
      "rdfs:comment": "A typed controlled vocabulary for pipeline failure modes. Each individual names a specific failure category with semantics for recoverability.",
      "rdfs:subClassOf": [
        {
          "@id": "https://prism.uor.foundation/op/PipelineTermination"
        }
      ],
      "owl:disjointWith": [
        {
          "@id": "https://prism.uor.foundation/op/PipelineSuccess"
        }
      ]
    },
    {
      "@id": "https://prism.uor.foundation/op/successSaturationPhase",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "successSaturationPhase",
      "rdfs:comment": "The foundation SaturationPhase (FullSaturation) that the pipeline achieved on successful termination.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/PipelineSuccess"
      },
      "rdfs:range": {
        "@id": "https://uor.foundation/state/SaturationPhase"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/FullSaturationSuccess",
      "@type": [
        "owl:NamedIndividual",
        "https://prism.uor.foundation/op/PipelineSuccess"
      ],
      "rdfs:label": "FullSaturationSuccess",
      "rdfs:comment": "The canonical successful termination: pipeline reached σ = 1, freeCount = 0, all desired constraints satisfied."
    },
    {
      "@id": "https://prism.uor.foundation/op/DispatchMiss",
      "@type": [
        "owl:NamedIndividual",
        "https://prism.uor.foundation/op/PipelineFailureReason"
      ],
      "rdfs:label": "DispatchMiss",
      "rdfs:comment": "No ResolverBinding in the registry matches the incoming query type. Terminal: the query cannot be routed. Remedy: register a binding for the query type.",
      "pop:failureTiming": {
        "@id": "https://prism.uor.foundation/op/PreflightTiming"
      },
      "pop:isResumable": false
    },
    {
      "@id": "https://prism.uor.foundation/op/GroundingFailure",
      "@type": [
        "owl:NamedIndividual",
        "https://prism.uor.foundation/op/PipelineFailureReason"
      ],
      "rdfs:label": "GroundingFailure",
      "rdfs:comment": "The GroundingMap could not produce a valid ring address for the surface symbol. Terminal for this symbol: the symbol is outside the DomainPackage's vocabulary. Remedy: extend the domain package.",
      "pop:failureTiming": {
        "@id": "https://prism.uor.foundation/op/RuntimeTiming"
      },
      "pop:isResumable": false
    },
    {
      "@id": "https://prism.uor.foundation/op/ConvergenceStall",
      "@type": [
        "owl:NamedIndividual",
        "https://prism.uor.foundation/op/PipelineFailureReason"
      ],
      "rdfs:label": "ConvergenceStall",
      "rdfs:comment": "Resolution convergenceRate < 1 for 2+ iterations (CB_4 stall detection). Resumable: additional constraints may break the stall. The ConstraintNerve's Betti numbers diagnose the topological obstruction.",
      "pop:failureTiming": {
        "@id": "https://prism.uor.foundation/op/RuntimeTiming"
      },
      "pop:isResumable": true
    },
    {
      "@id": "https://prism.uor.foundation/op/ContradictionDetected",
      "@type": [
        "owl:NamedIndividual",
        "https://prism.uor.foundation/op/PipelineFailureReason"
      ],
      "rdfs:label": "ContradictionDetected",
      "rdfs:comment": "A binding contradicts an existing binding at the same address (SR_5). Terminal for this session: triggers ContradictionBoundary. Remedy: reset context via SessionBoundary and retry.",
      "pop:failureTiming": {
        "@id": "https://prism.uor.foundation/op/RuntimeTiming"
      },
      "pop:isResumable": false
    },
    {
      "@id": "https://prism.uor.foundation/op/CoherenceViolation",
      "@type": [
        "owl:NamedIndividual",
        "https://prism.uor.foundation/op/PipelineFailureReason"
      ],
      "rdfs:label": "CoherenceViolation",
      "rdfs:comment": "The ProjectionMap's roundTripCoherence = false (PI_5 violated). Terminal: the output cannot be trusted. Indicates a DomainPackage defect — the shared-frame condition does not hold.",
      "pop:failureTiming": {
        "@id": "https://prism.uor.foundation/op/PreflightTiming"
      },
      "pop:isResumable": false
    },
    {
      "@id": "https://prism.uor.foundation/op/failureReason",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "failureReason",
      "rdfs:comment": "The typed failure reason for a pipeline that reached PipelineFailed.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/PipelineState"
      },
      "rdfs:range": {
        "@id": "https://prism.uor.foundation/op/PipelineFailureReason"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/failedAtStage",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "failedAtStage",
      "rdfs:comment": "The PipelineStage at which the failure occurred. Present only when currentStage = PipelineFailed.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/PipelineState"
      },
      "rdfs:range": {
        "@id": "https://prism.uor.foundation/op/PipelineStage"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/failureResumable",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "failureResumable",
      "rdfs:comment": "Whether the failed pipeline can be resumed after corrective action (e.g., adding constraints for ConvergenceStall) or is terminally failed (e.g., DispatchMiss, CoherenceViolation).",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/PipelineState"
      },
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#boolean"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/MachineAlgebraic",
      "@type": [
        "owl:NamedIndividual",
        "https://prism.uor.foundation/op/PrismVerificationDomain"
      ],
      "rdfs:label": "MachineAlgebraic",
      "rdfs:comment": "Verification domain for machine semantics identities: transition legality, contract compliance, preflight completeness, lease exclusivity, transaction atomicity, recovery determinism, and machine completeness (PM_1–PM_7)."
    },
    {
      "@id": "https://prism.uor.foundation/op/ReductionAlgebraic",
      "@type": [
        "owl:NamedIndividual",
        "https://prism.uor.foundation/op/PrismVerificationDomain"
      ],
      "rdfs:label": "ReductionAlgebraic",
      "rdfs:comment": "Verification domain for operational semantics identities: predicate evaluation (PE_1–PE_7), effect reduction (ER_1–ER_4), and transition judgments (TJ_1–TJ_3). Together these 14 identities form the complete small-step operational semantics of the Prism pipeline state machine."
    },
    {
      "@id": "https://prism.uor.foundation/op/MetaTheoretic",
      "@type": [
        "owl:NamedIndividual",
        "https://prism.uor.foundation/op/PrismVerificationDomain"
      ],
      "rdfs:label": "MetaTheoretic",
      "rdfs:comment": "Verification domain for metatheoretic properties of the transition system: determinism (MT_1), trace identity (MT_2), and simulation correctness (MT_3). These are theorems about the operational semantics, not components of it."
    },
    {
      "@id": "https://prism.uor.foundation/op/ObservationalEquivalence",
      "@type": [
        "owl:NamedIndividual",
        "https://prism.uor.foundation/op/PrismVerificationDomain"
      ],
      "rdfs:label": "ObservationalEquivalence",
      "rdfs:comment": "Verification domain for observational equivalence and bisimulation identities: observation function (OE_1), terminal equivalence (OE_2), bisimulation (OE_3), and optimization soundness (OE_4a–OE_4c). These identities define the correctness criterion for optimized implementations that deviate from the step-for-step abstract trace while preserving observable outcomes."
    },
    {
      "@id": "https://prism.uor.foundation/op/CostSemantics",
      "@type": [
        "owl:NamedIndividual",
        "https://prism.uor.foundation/op/PrismVerificationDomain"
      ],
      "rdfs:label": "CostSemantics",
      "rdfs:comment": "Verification domain for cost model identities: cost function definition (CS_1), fusion cost neutrality (CS_2), parallel cost model (CS_3), speedup bound (CS_4), and asymptotic preservation (CS_5). These identities define the quantitative performance theory for Prism pipeline optimization."
    },
    {
      "@id": "https://prism.uor.foundation/op/SchedulerFairness",
      "@type": [
        "owl:NamedIndividual",
        "https://prism.uor.foundation/op/PrismVerificationDomain"
      ],
      "rdfs:label": "SchedulerFairness",
      "rdfs:comment": "Verification domain for scheduler liveness identities: finite activation (SF_1), policy ordering (SF_2), and progress (SF_3). These identities guarantee that the ExecutionPolicy scheduling discipline is live — no lease is starved."
    },
    {
      "@id": "https://prism.uor.foundation/op/EpochalAdmission",
      "@type": [
        "owl:NamedIndividual",
        "https://prism.uor.foundation/op/PrismVerificationDomain"
      ],
      "rdfs:label": "EpochalAdmission",
      "rdfs:comment": "Verification domain for epochal phase-rotation scheduling identities: epoch isolation (EA_1), deferred completeness (EA_2), epoch composition (EA_3), and epoch termination (EA_4). Defines the dynamic query arrival semantics as an outer scheduling loop around the static lease model. Under the Euler Cascade, epoch admission is determined by phase budget: each epoch processes queries whose cumulative phase rotation fits within the epoch's angular capacity."
    },
    {
      "@id": "https://prism.uor.foundation/op/LeaseSuspension",
      "@type": [
        "owl:NamedIndividual",
        "https://prism.uor.foundation/op/PrismVerificationDomain"
      ],
      "rdfs:label": "LeaseSuspension",
      "rdfs:comment": "Verification domain for bounded suspension identities: checkpoint fidelity (LS_1), suspension monotonicity (LS_2), repartition disjointness (LS_3), and resume equivalence (LS_4). Defines the advanced scheduler mechanism for mid-epoch preemption with formal checkpointing."
    },
    {
      "@id": "https://prism.uor.foundation/cascade/PhaseSchedulingDomain",
      "@type": [
        "owl:NamedIndividual",
        "https://prism.uor.foundation/op/PrismVerificationDomain"
      ],
      "rdfs:label": "PhaseSchedulingDomain",
      "rdfs:comment": "Verification domain for phase-rotation scheduling identities: ordering (AP_1), bounded deferral (AP_2), and angular capacity (AP_3). Defines the scheduling discipline within the DeferredQuerySet. Scheduling is determined by phase budget: queries ordered by (estimatedPhaseCost − accumulatedPhaseCredit), admitted until angularCapacity is exhausted."
    },
    {
      "@id": "https://prism.uor.foundation/op/ServiceWindowDomain",
      "@type": [
        "owl:NamedIndividual",
        "https://prism.uor.foundation/op/PrismVerificationDomain"
      ],
      "rdfs:label": "ServiceWindowDomain",
      "rdfs:comment": "Verification domain for service window identities: rolling guarantee (SW_1), window monotonicity (SW_2), back-pressure signal (SW_3), and steady-state theorem (SW_4). Defines the external service contract for open-ended arrival streams where global saturation may be unreachable."
    },
    {
      "@id": "https://prism.uor.foundation/gate/PhaseGateAttestation",
      "@type": "owl:Class",
      "rdfs:label": "PhaseGateAttestation",
      "rdfs:comment": "A phase gate attestation validates that the pipeline's state vector equals the expected Ω^k before a transition fires. An object cannot proceed to stage k+1 unless its cryptographic trace proves application of the correct unitary operator Ω. If an object claims to be at stage k but its state vector does not equal Ω^k, the attestation fails and the object is inherently invalid. The gate carries the required phase angle, the unitary operator, and the cryptographic trace proving the rotation was correctly applied.",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/type/Constraint"
        }
      ],
      "owl:disjointWith": [
        {
          "@id": "https://prism.uor.foundation/constraint/LatencyConstraint"
        },
        {
          "@id": "https://prism.uor.foundation/constraint/ThroughputConstraint"
        },
        {
          "@id": "https://prism.uor.foundation/constraint/CoherenceConstraint"
        },
        {
          "@id": "https://prism.uor.foundation/op/DispatchPredicate"
        }
      ]
    },
    {
      "@id": "https://prism.uor.foundation/gate/requiredPhaseAngle",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "requiredPhaseAngle",
      "rdfs:comment": "The phase angle in degrees that the state vector must match for this gate to pass. Computed as k × 30° where k is the source stage ordinal.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/gate/PhaseGateAttestation"
      },
      "rdfs:range": {
        "@id": "xsd:decimal"
      }
    },
    {
      "@id": "https://prism.uor.foundation/gate/unitaryOperator",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "unitaryOperator",
      "rdfs:comment": "The unitary operator Ω = e^(iπ/6) that must have been applied to advance from the source stage. The cryptographic trace must prove this operator was correctly applied to the state vector.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/gate/PhaseGateAttestation"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      }
    },
    {
      "@id": "https://prism.uor.foundation/gate/phaseTrace",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "phaseTrace",
      "rdfs:comment": "The cryptographic trace proving that the unitary operator was correctly applied at this phase gate. Links to the foundation's ComputationTrace for audit verification.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/gate/PhaseGateAttestation"
      },
      "rdfs:range": {
        "@id": "https://uor.foundation/trace/ComputationTrace"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/guardStage",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "guardStage",
      "rdfs:comment": "The PipelineStage this phase gate attestation gates entry to.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/gate/PhaseGateAttestation"
      },
      "rdfs:range": {
        "@id": "https://prism.uor.foundation/op/PipelineStage"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/guardPrecondition",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "guardPrecondition",
      "rdfs:comment": "The condition that must hold on the PipelineState for this phase gate transition to fire. Includes both the phase angle match and any operator-specific preconditions.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/gate/PhaseGateAttestation"
      },
      "rdfs:range": {
        "@id": "https://uor.foundation/type/Constraint"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/guardSuccessTarget",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "guardSuccessTarget",
      "rdfs:comment": "The PipelineStage to transition to when the phase gate attestation succeeds.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/gate/PhaseGateAttestation"
      },
      "rdfs:range": {
        "@id": "https://prism.uor.foundation/op/PipelineStage"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/guardFailureTarget",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "guardFailureTarget",
      "rdfs:comment": "The PipelineStage to transition to when the phase gate attestation fails. Always PipelineFailed.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/gate/PhaseGateAttestation"
      },
      "rdfs:range": {
        "@id": "https://prism.uor.foundation/op/PipelineStage"
      }
    },
    {
      "@id": "https://prism.uor.foundation/gate/gate_initialization",
      "@type": [
        "owl:NamedIndividual",
        "https://prism.uor.foundation/gate/PhaseGateAttestation"
      ],
      "rdfs:label": "gate_initialization",
      "rdfs:comment": "Phase gate for E(0) → E(1): state vector must equal 1 (0°). Precondition: object exists in User Space, type declaration is pending. The identity element gate — no prior rotation required.",
      "gate:requiredPhaseAngle": 0,
      "gate:unitaryOperator": "Ω⁰ = 1",
      "pop:guardStage": {
        "@id": "https://prism.uor.foundation/op/Declare"
      },
      "pop:guardSuccessTarget": {
        "@id": "https://prism.uor.foundation/op/Declare"
      },
      "pop:guardFailureTarget": {
        "@id": "https://prism.uor.foundation/op/PipelineFailed"
      }
    },
    {
      "@id": "https://prism.uor.foundation/gate/gate_declare",
      "@type": [
        "owl:NamedIndividual",
        "https://prism.uor.foundation/gate/PhaseGateAttestation"
      ],
      "rdfs:label": "gate_declare",
      "rdfs:comment": "Phase gate for E(1) → E(2): state vector must equal Ω (30°). Precondition: δ must have selected a resolver (no DispatchMiss). The cryptographic trace proves the first unitary rotation was applied correctly.",
      "gate:requiredPhaseAngle": 30,
      "gate:unitaryOperator": "Ω¹ = e^(iπ/6)",
      "pop:guardStage": {
        "@id": "https://prism.uor.foundation/op/Factorize"
      },
      "pop:guardSuccessTarget": {
        "@id": "https://prism.uor.foundation/op/Factorize"
      },
      "pop:guardFailureTarget": {
        "@id": "https://prism.uor.foundation/op/PipelineFailed"
      }
    },
    {
      "@id": "https://prism.uor.foundation/gate/gate_factorize",
      "@type": [
        "owl:NamedIndividual",
        "https://prism.uor.foundation/gate/PhaseGateAttestation"
      ],
      "rdfs:label": "gate_factorize",
      "rdfs:comment": "Phase gate for E(2) → E(3): state vector must equal Ω² (60°). Precondition: G must have produced a valid ring address within the carrier set (no GroundingFailure). AD_1 bijection ensures deterministic content-addressing.",
      "gate:requiredPhaseAngle": 60,
      "gate:unitaryOperator": "Ω² = e^(iπ/3)",
      "pop:guardStage": {
        "@id": "https://prism.uor.foundation/op/Resolve"
      },
      "pop:guardSuccessTarget": {
        "@id": "https://prism.uor.foundation/op/Resolve"
      },
      "pop:guardFailureTarget": {
        "@id": "https://prism.uor.foundation/op/PipelineFailed"
      }
    },
    {
      "@id": "https://prism.uor.foundation/gate/gate_resolve",
      "@type": [
        "owl:NamedIndividual",
        "https://prism.uor.foundation/gate/PhaseGateAttestation"
      ],
      "rdfs:label": "gate_resolve",
      "rdfs:comment": "Phase gate for E(3) → E(4): state vector must equal i (90°). Precondition: Π must have terminated without ContradictionBoundary; isComplete = true or RefinementSuggestion produced. The orthogonal phase reflects maximum Substrate depth.",
      "gate:requiredPhaseAngle": 90,
      "gate:unitaryOperator": "Ω³ = i",
      "pop:guardStage": {
        "@id": "https://prism.uor.foundation/op/Attest"
      },
      "pop:guardSuccessTarget": {
        "@id": "https://prism.uor.foundation/op/Attest"
      },
      "pop:guardFailureTarget": {
        "@id": "https://prism.uor.foundation/op/PipelineFailed"
      }
    },
    {
      "@id": "https://prism.uor.foundation/gate/gate_attest",
      "@type": [
        "owl:NamedIndividual",
        "https://prism.uor.foundation/gate/PhaseGateAttestation"
      ],
      "rdfs:label": "gate_attest",
      "rdfs:comment": "Phase gate for E(4) → E(5): state vector must equal Ω⁴ (120°). Precondition: α must have appended the binding without contradiction; freeCount(out) ≤ freeCount(in) per SR_1. Attestation trace and certificate must be present.",
      "gate:requiredPhaseAngle": 120,
      "gate:unitaryOperator": "Ω⁴ = e^(i2π/3)",
      "pop:guardStage": {
        "@id": "https://prism.uor.foundation/op/Extract"
      },
      "pop:guardSuccessTarget": {
        "@id": "https://prism.uor.foundation/op/Extract"
      },
      "pop:guardFailureTarget": {
        "@id": "https://prism.uor.foundation/op/PipelineFailed"
      }
    },
    {
      "@id": "https://prism.uor.foundation/gate/gate_extract",
      "@type": [
        "owl:NamedIndividual",
        "https://prism.uor.foundation/gate/PhaseGateAttestation"
      ],
      "rdfs:label": "gate_extract",
      "rdfs:comment": "Phase gate for E(5) → E(6): state vector must equal Ω⁵ (150°). Precondition: P must have produced output with roundTripCoherence = true (PI_5). The final gate before convergence at Euler's Identity.",
      "gate:requiredPhaseAngle": 150,
      "gate:unitaryOperator": "Ω⁵ = e^(i5π/6)",
      "pop:guardStage": {
        "@id": "https://prism.uor.foundation/op/Convergence"
      },
      "pop:guardSuccessTarget": {
        "@id": "https://prism.uor.foundation/op/Convergence"
      },
      "pop:guardFailureTarget": {
        "@id": "https://prism.uor.foundation/op/PipelineFailed"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/ResolverContract",
      "@type": "owl:Class",
      "rdfs:label": "ResolverContract",
      "rdfs:comment": "The behavioral contract between the dispatch operator and a resolver. Formalizes the three exhaustive outcomes of resolver execution: (a) closed partition within CB_6 iterations, (b) RefinementSuggestion with isComplete=false, (c) ContradictionBoundary. A ResolverContract is attached to a ResolverBinding and verified at runtime by the pipeline's audit layer.",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://prism.uor.foundation/op/PreflightCheck",
      "@type": "owl:Class",
      "rdfs:label": "PreflightCheck",
      "rdfs:comment": "An individual check in the preflight validation sequence. Three canonical checks: feasibility assessment (PX_5), dispatch coverage (every expected query type has a registry binding), and domain package coherence (packageCoherent = true for all registered packages). The pipeline only advances to Initialization (E(0) = 1) if all preflight checks pass.",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://prism.uor.foundation/op/checkName",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "checkName",
      "rdfs:comment": "Human-readable identifier for this preflight check.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/PreflightCheck"
      },
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#string"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/checkPassed",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "checkPassed",
      "rdfs:comment": "Whether this individual preflight check passed.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/PreflightCheck"
      },
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#boolean"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/checkTarget",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "checkTarget",
      "rdfs:comment": "The entity this check validated: a FeasibilityResult, ResolverRegistry, or DomainPackage.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/PreflightCheck"
      },
      "rdfs:range": {
        "@id": "http://www.w3.org/2002/07/owl#Thing"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/FeasibilityCheck",
      "@type": [
        "owl:NamedIndividual",
        "https://prism.uor.foundation/op/PreflightCheck"
      ],
      "rdfs:label": "FeasibilityCheck",
      "rdfs:comment": "Preflight check: assess whether each TargetConvergenceAngle's constraint set is feasible (PX_5). Targets the FeasibilityResult.",
      "pop:checkName": "feasibility"
    },
    {
      "@id": "https://prism.uor.foundation/op/DispatchCoverageCheck",
      "@type": [
        "owl:NamedIndividual",
        "https://prism.uor.foundation/op/PreflightCheck"
      ],
      "rdfs:label": "DispatchCoverageCheck",
      "rdfs:comment": "Preflight check: verify that the ResolverRegistry has at least one binding for every expected query type. Targets the ResolverRegistry.",
      "pop:checkName": "dispatch_coverage"
    },
    {
      "@id": "https://prism.uor.foundation/op/PackageCoherenceCheck",
      "@type": [
        "owl:NamedIndividual",
        "https://prism.uor.foundation/op/PreflightCheck"
      ],
      "rdfs:label": "PackageCoherenceCheck",
      "rdfs:comment": "Preflight check: verify that all registered DomainPackages have packageCoherent = true. Targets each DomainPackage.",
      "pop:checkName": "package_coherence"
    },
    {
      "@id": "https://prism.uor.foundation/op/PreflightResult",
      "@type": "owl:Class",
      "rdfs:label": "PreflightResult",
      "rdfs:comment": "The aggregated result of all preflight checks for a PrismInstance. Carries the individual check results and a single go/no-go verdict. A pipeline that passes preflight (verdict = true) is guaranteed to not encounter DispatchMiss or CoherenceViolation at runtime (PM_3).",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://prism.uor.foundation/op/LeaseState",
      "@type": "owl:Class",
      "rdfs:label": "LeaseState",
      "rdfs:comment": "A typed controlled vocabulary for lease lifecycle stages: Pending (allocated but not yet active), Active (holding fibers, resolver executing), Released (fibers returned to SharedContext), Expired (timeout without explicit release). The lease lifecycle is Pending → Active → Released (normal) or Pending → Active → Expired (abnormal).",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://prism.uor.foundation/op/Pending",
      "@type": [
        "owl:NamedIndividual",
        "https://prism.uor.foundation/op/LeaseState"
      ],
      "rdfs:label": "Pending",
      "rdfs:comment": "Lease allocated with fiber mask assigned but resolver not yet executing."
    },
    {
      "@id": "https://prism.uor.foundation/op/Active",
      "@type": [
        "owl:NamedIndividual",
        "https://prism.uor.foundation/op/LeaseState"
      ],
      "rdfs:label": "Active",
      "rdfs:comment": "Lease holding fibers, resolver executing. PL_2 disjointness and PM_4 exclusivity enforced."
    },
    {
      "@id": "https://prism.uor.foundation/op/Released",
      "@type": [
        "owl:NamedIndividual",
        "https://prism.uor.foundation/op/LeaseState"
      ],
      "rdfs:label": "Released",
      "rdfs:comment": "Lease fibers returned to SharedContext. Composition via κ is now legal."
    },
    {
      "@id": "https://prism.uor.foundation/op/Expired",
      "@type": [
        "owl:NamedIndividual",
        "https://prism.uor.foundation/op/LeaseState"
      ],
      "rdfs:label": "Expired",
      "rdfs:comment": "Lease timed out without explicit release. Fibers are reclaimed. Any partial results are discarded."
    },
    {
      "@id": "https://prism.uor.foundation/op/Suspended",
      "@type": [
        "owl:NamedIndividual",
        "https://prism.uor.foundation/op/LeaseState"
      ],
      "rdfs:label": "Suspended",
      "rdfs:comment": "Lease suspended: partial progress checkpointed, unpinned fibers released back to SharedContext for repartition. Pinned fibers remain claimed (LS_1). The lease may be resumed from its checkpoint when fibers become available. Lifecycle: Active → Suspended → Active → Released (with suspension) or Active → Suspended → carried forward to next epoch."
    },
    {
      "@id": "https://prism.uor.foundation/op/EffectStepFailure",
      "@type": "owl:Class",
      "rdfs:label": "EffectStepFailure",
      "rdfs:comment": "A diagnostic controlled vocabulary classifying why an individual effect step in ER_4 becomes undefined. These failures indicate non-conformance (implementation defects or malformed ontology) rather than domain-level problems. They should never occur in a conforming system operating on a valid ontology — they exist to classify non-conformance when detected. Three individuals: SourceUnbound, TypeMismatch, InvariantViolation.",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://prism.uor.foundation/op/SourceUnbound",
      "@type": [
        "owl:NamedIndividual",
        "https://prism.uor.foundation/op/EffectStepFailure"
      ],
      "rdfs:label": "SourceUnbound",
      "rdfs:comment": "The bindSourceProperty on bindSourceObject has no value. The operator did not produce the expected output. Under PM_2 contract compliance, this should not occur for conforming resolvers."
    },
    {
      "@id": "https://prism.uor.foundation/op/TypeMismatch",
      "@type": [
        "owl:NamedIndividual",
        "https://prism.uor.foundation/op/EffectStepFailure"
      ],
      "rdfs:label": "TypeMismatch",
      "rdfs:comment": "The source value exists but is not of the expected type for the target property. Indicates a type error in the operator output graph. Under the typed property model, this should not occur."
    },
    {
      "@id": "https://prism.uor.foundation/op/InvariantViolation",
      "@type": [
        "owl:NamedIndividual",
        "https://prism.uor.foundation/op/EffectStepFailure"
      ],
      "rdfs:label": "InvariantViolation",
      "rdfs:comment": "The effect step would violate a pipeline invariant (e.g., a StageAdvance targeting a stage inconsistent with the transition rule). Indicates a malformed ontology or corrupted transition rule."
    },
    {
      "@id": "https://prism.uor.foundation/op/stepFailureKind",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "stepFailureKind",
      "rdfs:comment": "The diagnostic reason why this effect step failed. Present only when reduce(eᵢ, Sᵢ) is undefined in ER_4. Enables classification of non-conformance.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/EffectExpression"
      },
      "rdfs:range": {
        "@id": "https://prism.uor.foundation/op/EffectStepFailure"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/Epoch",
      "@type": "owl:Class",
      "rdfs:label": "Epoch",
      "rdfs:comment": "The outer scheduling unit for dynamic query arrival. A complete λ → execute → κ cycle. Queries arriving during epoch i are buffered in a DeferredQuerySet and admitted in epoch i+1. Within an epoch, the static lease model (SF_1–SF_3) holds. Across epochs, contexts compose via PA_1 accumulation associativity.",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://prism.uor.foundation/op/epochIndex",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "epochIndex",
      "rdfs:comment": "Sequential index of this epoch (0-based). Epoch 0 is the initial partition.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/Epoch"
      },
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#nonNegativeInteger"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/epochContext",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "epochContext",
      "rdfs:comment": "The SharedContext for this epoch's partition. For epoch 0: the PrismInstance's initial context. For epoch i>0: the composed output of epoch i-1 (EA_3).",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/Epoch"
      },
      "rdfs:range": {
        "@id": "https://uor.foundation/state/SharedContext"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/epochLeases",
      "@type": "owl:ObjectProperty",
      "rdfs:label": "epochLeases",
      "rdfs:comment": "The ManagedLeases produced by λ for this epoch. Non-functional: one per lease in the partition.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/Epoch"
      },
      "rdfs:range": {
        "@id": "https://prism.uor.foundation/op/ManagedLease"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/epochResult",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "epochResult",
      "rdfs:comment": "The composed context after κ merges all lease results for this epoch. Becomes epochContext of the next epoch (EA_3).",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/Epoch"
      },
      "rdfs:range": {
        "@id": "https://uor.foundation/state/Context"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/epochDeferredQueries",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "epochDeferredQueries",
      "rdfs:comment": "The DeferredQuerySet of queries admitted from the previous epoch. Absent on epoch 0.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/Epoch"
      },
      "rdfs:range": {
        "@id": "https://prism.uor.foundation/op/DeferredQuerySet"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/EpochBoundary",
      "@type": "owl:Class",
      "rdfs:label": "EpochBoundary",
      "rdfs:comment": "The transition between consecutive epochs. Records the context handoff and the deferred queries being admitted. The boundary is the point where EA_3 (epoch composition) fires: the preceding epoch's result becomes the succeeding epoch's context.",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://prism.uor.foundation/op/precedingEpoch",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "precedingEpoch",
      "rdfs:comment": "The epoch that completed, producing the carried context.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/EpochBoundary"
      },
      "rdfs:range": {
        "@id": "https://prism.uor.foundation/op/Epoch"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/succeedingEpoch",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "succeedingEpoch",
      "rdfs:comment": "The epoch beginning, receiving the carried context and admitted queries.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/EpochBoundary"
      },
      "rdfs:range": {
        "@id": "https://prism.uor.foundation/op/Epoch"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/carriedContext",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "carriedContext",
      "rdfs:comment": "The composed output of the preceding epoch, which becomes the succeeding epoch's input. EA_3: epochContext(i+1) = epochResult(i).",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/EpochBoundary"
      },
      "rdfs:range": {
        "@id": "https://uor.foundation/state/Context"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/admittedQueries",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "admittedQueries",
      "rdfs:comment": "The DeferredQuerySet being admitted at this boundary. EA_2: every deferred query is admitted exactly one epoch after arrival.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/EpochBoundary"
      },
      "rdfs:range": {
        "@id": "https://prism.uor.foundation/op/DeferredQuerySet"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/DeferredQuerySet",
      "@type": "owl:Class",
      "rdfs:label": "DeferredQuerySet",
      "rdfs:comment": "A set of queries that arrived during one epoch and are buffered for admission in the next. Append-only during the arrival epoch (EA_1: deferred queries do not affect the running epoch). Fully drained at the epoch boundary (EA_2: no query deferred beyond one epoch).",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://prism.uor.foundation/op/deferredQueries",
      "@type": "owl:ObjectProperty",
      "rdfs:label": "deferredQueries",
      "rdfs:comment": "A query in this deferred set. Non-functional: the set may contain multiple queries.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/DeferredQuerySet"
      },
      "rdfs:range": {
        "@id": "https://uor.foundation/query/Query"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/arrivalEpoch",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "arrivalEpoch",
      "rdfs:comment": "The epoch during which these queries arrived. They were buffered, not executed.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/DeferredQuerySet"
      },
      "rdfs:range": {
        "@id": "https://prism.uor.foundation/op/Epoch"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/admittedEpoch",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "admittedEpoch",
      "rdfs:comment": "The epoch in which these queries are admitted for execution. EA_2: admittedEpoch = arrivalEpoch + 1.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/DeferredQuerySet"
      },
      "rdfs:range": {
        "@id": "https://prism.uor.foundation/op/Epoch"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/LeaseCheckpoint",
      "@type": "owl:Class",
      "rdfs:label": "LeaseCheckpoint",
      "rdfs:comment": "An immutable snapshot of a lease's partial progress at the point of suspension. Captures accumulated bindings, fiber budget, and pipeline state. Sufficient for bit-exact resumption (LS_1). Taken between transitions (ER_4 atomicity: transitions cannot be interrupted mid-step). The checkpoint plus the original lease configuration enables resume from the exact suspension point.",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://prism.uor.foundation/op/checkpointedLease",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "checkpointedLease",
      "rdfs:comment": "The ManagedLease that was suspended to produce this checkpoint.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/LeaseCheckpoint"
      },
      "rdfs:range": {
        "@id": "https://prism.uor.foundation/op/ManagedLease"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/checkpointedBudget",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "checkpointedBudget",
      "rdfs:comment": "The FiberBudget at suspension. pinnedCount fibers are preserved; freeCount fibers are released for repartition.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/LeaseCheckpoint"
      },
      "rdfs:range": {
        "@id": "https://uor.foundation/partition/FiberBudget"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/checkpointedStage",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "checkpointedStage",
      "rdfs:comment": "The PipelineStage the lease was at when suspended. Must be a non-terminal stage boundary (between transitions, not mid-transition).",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/LeaseCheckpoint"
      },
      "rdfs:range": {
        "@id": "https://prism.uor.foundation/op/PipelineStage"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/checkpointedPipelineState",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "checkpointedPipelineState",
      "rdfs:comment": "The complete PipelineState snapshot at suspension. Used for bit-exact resume.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/LeaseCheckpoint"
      },
      "rdfs:range": {
        "@id": "https://prism.uor.foundation/op/PipelineState"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/SubleaseTransfer",
      "@type": "owl:Class",
      "rdfs:label": "SubleaseTransfer",
      "rdfs:comment": "A legal reassignment of fiber ownership from a suspended lease's unpinned fibers to another lease. The transfer must satisfy PL_2 post-repartition (LS_3): the transferred fibers must not overlap with any Active lease's claimed fibers. Only unpinned fibers from the suspended lease are transferable — pinned fibers remain claimed by the checkpoint.",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://prism.uor.foundation/op/sourceCheckpoint",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "sourceCheckpoint",
      "rdfs:comment": "The LeaseCheckpoint from which fibers are being released.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/SubleaseTransfer"
      },
      "rdfs:range": {
        "@id": "https://prism.uor.foundation/op/LeaseCheckpoint"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/targetLease",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "targetLease",
      "rdfs:comment": "The ManagedLease receiving the transferred fibers.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/SubleaseTransfer"
      },
      "rdfs:range": {
        "@id": "https://prism.uor.foundation/op/ManagedLease"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/transferredFibers",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "transferredFibers",
      "rdfs:comment": "The FiberBudget describing the fibers being transferred. Must be a subset of the checkpoint's freeCount fibers.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/SubleaseTransfer"
      },
      "rdfs:range": {
        "@id": "https://uor.foundation/partition/FiberBudget"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/postTransferDisjointnessVerified",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "postTransferDisjointnessVerified",
      "rdfs:comment": "Whether PL_2 disjointness holds for all Active leases after this transfer (LS_3). Must be true for the transfer to be legal.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/SubleaseTransfer"
      },
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#boolean"
      }
    },
    {
      "@id": "https://prism.uor.foundation/cascade/PhaseRotationScheduler",
      "@type": "owl:Class",
      "rdfs:label": "PhaseRotationScheduler",
      "rdfs:comment": "Epoch admission is determined by phase budget: each epoch processes queries whose cumulative phase rotation (sum of expected 180° full-cascade traversals) fits within the epoch's angular capacity. The scheduler computes angular capacity = totalFibers × 30° (one phase increment per fiber transition). Queries are ordered by estimated phase cost (number of cascade steps × 30°) and admitted until the angular budget is exhausted. Deferred queries accumulate phase credit proportional to their wait time, ensuring starvation freedom via the D_{2n} reflection symmetry: after K epochs, a deferred query's accumulated phase credit exceeds any fresh query's phase cost.",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://prism.uor.foundation/cascade/estimatedPhaseCost",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "estimatedPhaseCost",
      "rdfs:comment": "Estimated total phase rotation in degrees for resolving this query through the full Euler Cascade (up to 180°). Derived from the query's constraint nerve complexity × 30° per cascade step. Used by PhaseRotationScheduler to determine epoch admission order.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/query/Query"
      },
      "rdfs:range": {
        "@id": "xsd:decimal"
      }
    },
    {
      "@id": "https://prism.uor.foundation/cascade/accumulatedPhaseCredit",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "accumulatedPhaseCredit",
      "rdfs:comment": "Phase credit accumulated by a deferred query, measured in degrees. Incremented by 30° at each EpochBoundary where the query is not admitted. After K epochs, a query's accumulated credit (K × 30°) exceeds any fresh query's estimated phase cost, guaranteeing starvation freedom via the D_{2n} reflection symmetry.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/query/Query"
      },
      "rdfs:range": {
        "@id": "xsd:decimal"
      }
    },
    {
      "@id": "https://prism.uor.foundation/cascade/angularCapacity",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "angularCapacity",
      "rdfs:comment": "Maximum cumulative phase rotation in degrees this epoch can process. Computed as totalFibers × 30° (one phase increment per fiber transition). Queries whose cumulative estimated phase cost exceeds this capacity are deferred with incremented accumulatedPhaseCredit.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/Epoch"
      },
      "rdfs:range": {
        "@id": "xsd:decimal"
      }
    },
    {
      "@id": "https://prism.uor.foundation/cascade/epochScheduler",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "epochScheduler",
      "rdfs:comment": "The PhaseRotationScheduler governing deferred query ordering for this epoch.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/Epoch"
      },
      "rdfs:range": {
        "@id": "https://prism.uor.foundation/cascade/PhaseRotationScheduler"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/ServiceWindow",
      "@type": "owl:Class",
      "rdfs:label": "ServiceWindow",
      "rdfs:comment": "A sliding window of recent epochs over which the system guarantees minimum resolution quality. Replaces the global saturation target (EA_4) with a rolling partial saturation guarantee for open-ended arrival streams. The system maintains per-query resolution quality within the window even when global σ = 1 is unreachable.",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://prism.uor.foundation/op/windowSize",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "windowSize",
      "rdfs:comment": "Number of recent epochs the service window covers.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/ServiceWindow"
      },
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#positiveInteger"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/minResolutionQuality",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "minResolutionQuality",
      "rdfs:comment": "Minimum σ achieved for every query resolved within the window. Range [0, 1]. E.g., 0.8 means at least 80% of fibers are pinned for every query in the window.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/ServiceWindow"
      },
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#decimal"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/maxQueryLatency",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "maxQueryLatency",
      "rdfs:comment": "Maximum epochs between query arrival and completion within the service window guarantee. SW_1: every query arriving in epoch i is resolved by epoch i + maxQueryLatency.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/ServiceWindow"
      },
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#positiveInteger"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/currentWindowQuality",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "currentWindowQuality",
      "rdfs:comment": "The current average resolution quality across all queries in the window. When this drops below minResolutionQuality, a BackPressureSignal is emitted (SW_3).",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/ServiceWindow"
      },
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#decimal"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/BackPressureSignal",
      "@type": "owl:Class",
      "rdfs:label": "BackPressureSignal",
      "rdfs:comment": "Emitted when the ServiceWindow's currentWindowQuality drops below minResolutionQuality (SW_3). Carries the current quality, the shortfall, and the estimated arrival rate reduction needed to restore the guarantee. The feedback mechanism for open-ended streams — tells upstream producers to slow down.",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://prism.uor.foundation/op/signalCurrentQuality",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "signalCurrentQuality",
      "rdfs:comment": "The window quality at the time the signal was emitted.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/BackPressureSignal"
      },
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#decimal"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/qualityShortfall",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "qualityShortfall",
      "rdfs:comment": "minResolutionQuality - currentWindowQuality. The magnitude of the service guarantee violation.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/BackPressureSignal"
      },
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#decimal"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/recommendedRateReduction",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "recommendedRateReduction",
      "rdfs:comment": "Estimated fraction by which the arrival rate should decrease to restore the service guarantee. Range [0, 1]. E.g., 0.3 means reduce arrival rate by 30%.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/BackPressureSignal"
      },
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#decimal"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/serviceWindow",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "serviceWindow",
      "rdfs:comment": "The ServiceWindow governing this PrismInstance's rolling service guarantee. Absent for batch deployments (which use EA_4 global saturation instead).",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/PrismInstance"
      },
      "rdfs:range": {
        "@id": "https://prism.uor.foundation/op/ServiceWindow"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/PipelineTransaction",
      "@type": "owl:Class",
      "rdfs:label": "PipelineTransaction",
      "rdfs:comment": "An atomic group of pipeline executions across multiple TargetConvergenceAngle targets. Provides cross-domain consistency: under AllOrNothing policy, either all targets converge at E(6) = −1 (Committed) or none do (RolledBack). Under BestEffort policy, each target is independently committed or failed (PartialCommit).",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://prism.uor.foundation/op/TransactionPolicy",
      "@type": "owl:Class",
      "rdfs:label": "TransactionPolicy",
      "rdfs:comment": "A typed controlled vocabulary for transaction atomicity semantics: AllOrNothing (full atomicity — rollback all on any failure) or BestEffort (independent commitment per target).",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://prism.uor.foundation/op/AllOrNothing",
      "@type": [
        "owl:NamedIndividual",
        "https://prism.uor.foundation/op/TransactionPolicy"
      ],
      "rdfs:label": "AllOrNothing",
      "rdfs:comment": "Full atomicity: all TargetConvergenceAngle targets must reach convergence at E(6) = −1, or all accumulated bindings are rolled back via conjugate rotation (EC_2). The cross-domain analog of a database transaction."
    },
    {
      "@id": "https://prism.uor.foundation/op/BestEffort",
      "@type": [
        "owl:NamedIndividual",
        "https://prism.uor.foundation/op/TransactionPolicy"
      ],
      "rdfs:label": "BestEffort",
      "rdfs:comment": "Independent commitment: each TargetConvergenceAngle target is committed or failed independently. Successful targets issue PipelineCertificates; failed targets issue failure witnesses."
    },
    {
      "@id": "https://prism.uor.foundation/op/TransactionOutcome",
      "@type": "owl:Class",
      "rdfs:label": "TransactionOutcome",
      "rdfs:comment": "A typed controlled vocabulary for transaction terminal states: Committed (all targets satisfied under AllOrNothing, or at least one under BestEffort), RolledBack (all targets failed under AllOrNothing), PartialCommit (mixed results under BestEffort).",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://prism.uor.foundation/op/Committed",
      "@type": [
        "owl:NamedIndividual",
        "https://prism.uor.foundation/op/TransactionOutcome"
      ],
      "rdfs:label": "Committed",
      "rdfs:comment": "All targets reached saturation. PipelineCertificates issued for every TargetConvergenceAngle in the transaction scope."
    },
    {
      "@id": "https://prism.uor.foundation/op/RolledBack",
      "@type": [
        "owl:NamedIndividual",
        "https://prism.uor.foundation/op/TransactionOutcome"
      ],
      "rdfs:label": "RolledBack",
      "rdfs:comment": "At least one target failed under AllOrNothing policy. All accumulated bindings across all targets are reverted. No PipelineCertificates issued."
    },
    {
      "@id": "https://prism.uor.foundation/op/PartialCommit",
      "@type": [
        "owl:NamedIndividual",
        "https://prism.uor.foundation/op/TransactionOutcome"
      ],
      "rdfs:label": "PartialCommit",
      "rdfs:comment": "Mixed results under BestEffort policy. Some targets committed (with certificates), others failed (with failure witnesses). The TransactionOutcome links to both."
    },
    {
      "@id": "https://prism.uor.foundation/op/FailureTiming",
      "@type": "owl:Class",
      "rdfs:label": "FailureTiming",
      "rdfs:comment": "A typed controlled vocabulary classifying when a failure can be detected: Preflight (before pipeline execution — preventable) or Runtime (during execution — must be handled). PM_3 guarantees that all Preflight-classified failures are caught by PreflightCheck.",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://prism.uor.foundation/op/PreflightTiming",
      "@type": [
        "owl:NamedIndividual",
        "https://prism.uor.foundation/op/FailureTiming"
      ],
      "rdfs:label": "PreflightTiming",
      "rdfs:comment": "Failure detectable before pipeline execution. DispatchMiss and CoherenceViolation are Preflight-timed."
    },
    {
      "@id": "https://prism.uor.foundation/op/RuntimeTiming",
      "@type": [
        "owl:NamedIndividual",
        "https://prism.uor.foundation/op/FailureTiming"
      ],
      "rdfs:label": "RuntimeTiming",
      "rdfs:comment": "Failure detectable only during pipeline execution. ConvergenceStall, ContradictionDetected, and GroundingFailure are Runtime-timed."
    },
    {
      "@id": "https://prism.uor.foundation/op/PipelineTransitionRule",
      "@type": "owl:Class",
      "rdfs:label": "PipelineTransitionRule",
      "rdfs:comment": "A complete, machine-readable specification of a legal pipeline stage transition. Binds a source stage to the operator component that executes, a guard expression that must be satisfied, the success target stage, the failure mode(s) that fire on guard failure, and the foundation identity that grounds the guard. Five named individuals define the complete small-step transition relation for the pipeline state machine.",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://prism.uor.foundation/op/GuardExpression",
      "@type": "owl:Class",
      "rdfs:label": "GuardExpression",
      "rdfs:comment": "A structured, machine-readable predicate evaluated at a pipeline stage boundary. Contains a typed predicate tree (PredicateExpression) and the foundation identity that guarantees the check is sound. No string-valued semantic content — the predicate is fully expressed as typed OWL individuals.",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://prism.uor.foundation/op/TransitionEffect",
      "@type": "owl:Class",
      "rdfs:label": "TransitionEffect",
      "rdfs:comment": "The state changes applied to PipelineState on a successful stage transition. Contains a list of typed effect expressions (EffectExpression individuals). No string-valued semantic content — effects are fully expressed as typed OWL individuals.",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://prism.uor.foundation/op/PredicateExpression",
      "@type": "owl:Class",
      "rdfs:label": "PredicateExpression",
      "rdfs:comment": "Abstract superclass for typed predicate nodes in the guard expression tree. Six concrete subclasses: NonNullPredicate, EqualsPredicate, ComparisonPredicate, MembershipPredicate, DisjunctionPredicate, NegationPredicate. Evaluated against a PipelineState instance to produce a boolean.",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://prism.uor.foundation/op/NonNullPredicate",
      "@type": "owl:Class",
      "rdfs:label": "NonNullPredicate",
      "rdfs:comment": "Predicate: true iff the target property is bound (has a value) on the pipeline state. Evaluation rule: check that the property referenced by targetProperty has at least one value on the current PipelineState.",
      "rdfs:subClassOf": [
        {
          "@id": "https://prism.uor.foundation/op/PredicateExpression"
        }
      ],
      "owl:disjointWith": [
        {
          "@id": "https://prism.uor.foundation/op/EqualsPredicate"
        },
        {
          "@id": "https://prism.uor.foundation/op/ComparisonPredicate"
        },
        {
          "@id": "https://prism.uor.foundation/op/MembershipPredicate"
        },
        {
          "@id": "https://prism.uor.foundation/op/DisjunctionPredicate"
        },
        {
          "@id": "https://prism.uor.foundation/op/NegationPredicate"
        },
        {
          "@id": "https://prism.uor.foundation/op/ConjunctionPredicate"
        }
      ]
    },
    {
      "@id": "https://prism.uor.foundation/op/EqualsPredicate",
      "@type": "owl:Class",
      "rdfs:label": "EqualsPredicate",
      "rdfs:comment": "Predicate: true iff the target property equals the expected value. Evaluation rule: retrieve the value of targetProperty on the current PipelineState and compare with expectedValue.",
      "rdfs:subClassOf": [
        {
          "@id": "https://prism.uor.foundation/op/PredicateExpression"
        }
      ],
      "owl:disjointWith": [
        {
          "@id": "https://prism.uor.foundation/op/NonNullPredicate"
        },
        {
          "@id": "https://prism.uor.foundation/op/ComparisonPredicate"
        },
        {
          "@id": "https://prism.uor.foundation/op/MembershipPredicate"
        },
        {
          "@id": "https://prism.uor.foundation/op/DisjunctionPredicate"
        },
        {
          "@id": "https://prism.uor.foundation/op/NegationPredicate"
        },
        {
          "@id": "https://prism.uor.foundation/op/ConjunctionPredicate"
        }
      ]
    },
    {
      "@id": "https://prism.uor.foundation/op/ComparisonPredicate",
      "@type": "owl:Class",
      "rdfs:label": "ComparisonPredicate",
      "rdfs:comment": "Predicate: true iff lhsProperty comparator rhsProperty. Evaluation rule: retrieve numeric values of both property paths on the current PipelineState and apply the comparator.",
      "rdfs:subClassOf": [
        {
          "@id": "https://prism.uor.foundation/op/PredicateExpression"
        }
      ],
      "owl:disjointWith": [
        {
          "@id": "https://prism.uor.foundation/op/NonNullPredicate"
        },
        {
          "@id": "https://prism.uor.foundation/op/EqualsPredicate"
        },
        {
          "@id": "https://prism.uor.foundation/op/MembershipPredicate"
        },
        {
          "@id": "https://prism.uor.foundation/op/DisjunctionPredicate"
        },
        {
          "@id": "https://prism.uor.foundation/op/NegationPredicate"
        },
        {
          "@id": "https://prism.uor.foundation/op/ConjunctionPredicate"
        }
      ]
    },
    {
      "@id": "https://prism.uor.foundation/op/MembershipPredicate",
      "@type": "owl:Class",
      "rdfs:label": "MembershipPredicate",
      "rdfs:comment": "Predicate: true iff the value of the target property is an instance of the required class. Evaluation rule: retrieve the value of targetProperty on the current PipelineState and check rdf:type membership.",
      "rdfs:subClassOf": [
        {
          "@id": "https://prism.uor.foundation/op/PredicateExpression"
        }
      ],
      "owl:disjointWith": [
        {
          "@id": "https://prism.uor.foundation/op/NonNullPredicate"
        },
        {
          "@id": "https://prism.uor.foundation/op/EqualsPredicate"
        },
        {
          "@id": "https://prism.uor.foundation/op/ComparisonPredicate"
        },
        {
          "@id": "https://prism.uor.foundation/op/DisjunctionPredicate"
        },
        {
          "@id": "https://prism.uor.foundation/op/NegationPredicate"
        },
        {
          "@id": "https://prism.uor.foundation/op/ConjunctionPredicate"
        }
      ]
    },
    {
      "@id": "https://prism.uor.foundation/op/DisjunctionPredicate",
      "@type": "owl:Class",
      "rdfs:label": "DisjunctionPredicate",
      "rdfs:comment": "Compound predicate: true iff leftOperand ∨ rightOperand. Evaluation rule: evaluate both operand predicates and return their logical disjunction.",
      "rdfs:subClassOf": [
        {
          "@id": "https://prism.uor.foundation/op/PredicateExpression"
        }
      ],
      "owl:disjointWith": [
        {
          "@id": "https://prism.uor.foundation/op/NonNullPredicate"
        },
        {
          "@id": "https://prism.uor.foundation/op/EqualsPredicate"
        },
        {
          "@id": "https://prism.uor.foundation/op/ComparisonPredicate"
        },
        {
          "@id": "https://prism.uor.foundation/op/MembershipPredicate"
        },
        {
          "@id": "https://prism.uor.foundation/op/ConjunctionPredicate"
        },
        {
          "@id": "https://prism.uor.foundation/op/NegationPredicate"
        }
      ]
    },
    {
      "@id": "https://prism.uor.foundation/op/ConjunctionPredicate",
      "@type": "owl:Class",
      "rdfs:label": "ConjunctionPredicate",
      "rdfs:comment": "Compound predicate: true iff leftOperand ∧ rightOperand. Evaluation rule: evaluate both operand predicates and return their logical conjunction. Completes the Boolean algebra with DisjunctionPredicate and NegationPredicate.",
      "rdfs:subClassOf": [
        {
          "@id": "https://prism.uor.foundation/op/PredicateExpression"
        }
      ],
      "owl:disjointWith": [
        {
          "@id": "https://prism.uor.foundation/op/NonNullPredicate"
        },
        {
          "@id": "https://prism.uor.foundation/op/EqualsPredicate"
        },
        {
          "@id": "https://prism.uor.foundation/op/ComparisonPredicate"
        },
        {
          "@id": "https://prism.uor.foundation/op/MembershipPredicate"
        },
        {
          "@id": "https://prism.uor.foundation/op/DisjunctionPredicate"
        },
        {
          "@id": "https://prism.uor.foundation/op/NegationPredicate"
        }
      ]
    },
    {
      "@id": "https://prism.uor.foundation/op/NegationPredicate",
      "@type": "owl:Class",
      "rdfs:label": "NegationPredicate",
      "rdfs:comment": "Compound predicate: true iff ¬negatedOperand. Evaluation rule: evaluate the operand predicate and return its logical negation.",
      "rdfs:subClassOf": [
        {
          "@id": "https://prism.uor.foundation/op/PredicateExpression"
        }
      ],
      "owl:disjointWith": [
        {
          "@id": "https://prism.uor.foundation/op/NonNullPredicate"
        },
        {
          "@id": "https://prism.uor.foundation/op/EqualsPredicate"
        },
        {
          "@id": "https://prism.uor.foundation/op/ComparisonPredicate"
        },
        {
          "@id": "https://prism.uor.foundation/op/MembershipPredicate"
        },
        {
          "@id": "https://prism.uor.foundation/op/DisjunctionPredicate"
        },
        {
          "@id": "https://prism.uor.foundation/op/ConjunctionPredicate"
        }
      ]
    },
    {
      "@id": "https://prism.uor.foundation/op/EffectExpression",
      "@type": "owl:Class",
      "rdfs:label": "EffectExpression",
      "rdfs:comment": "Abstract superclass for typed effect nodes. Two concrete subclasses: StageAdvance (set currentStage) and PropertyBind (set a property from operator output). Carries a stepIndex for strict ordering within a TransitionEffect. Evaluated against PipelineState to produce a mutated state.",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://prism.uor.foundation/op/StageAdvance",
      "@type": "owl:Class",
      "rdfs:label": "StageAdvance",
      "rdfs:comment": "Effect: set currentStage to a specific PipelineStage. Every successful transition includes exactly one StageAdvance.",
      "rdfs:subClassOf": [
        {
          "@id": "https://prism.uor.foundation/op/EffectExpression"
        }
      ],
      "owl:disjointWith": [
        {
          "@id": "https://prism.uor.foundation/op/PropertyBind"
        }
      ]
    },
    {
      "@id": "https://prism.uor.foundation/op/PropertyBind",
      "@type": "owl:Class",
      "rdfs:label": "PropertyBind",
      "rdfs:comment": "Effect: set a property on PipelineState to a value from the operator's output. Evaluation rule: retrieve sourceProperty from sourceObject and set targetProperty on PipelineState.",
      "rdfs:subClassOf": [
        {
          "@id": "https://prism.uor.foundation/op/EffectExpression"
        }
      ],
      "owl:disjointWith": [
        {
          "@id": "https://prism.uor.foundation/op/StageAdvance"
        }
      ]
    },
    {
      "@id": "https://prism.uor.foundation/op/targetProperty",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "targetProperty",
      "rdfs:comment": "The OWL property this predicate evaluates or this effect mutates.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/PredicateExpression"
      },
      "rdfs:range": {
        "@id": "http://www.w3.org/1999/02/22-rdf-syntax-ns#Property"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/expectedValue",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "expectedValue",
      "rdfs:comment": "The value the target property must equal for an EqualsPredicate to hold. May be an individual or a typed literal wrapper.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/EqualsPredicate"
      },
      "rdfs:range": {
        "@id": "http://www.w3.org/2002/07/owl#Thing"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/lhsProperty",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "lhsProperty",
      "rdfs:comment": "The left-hand-side property path in a ComparisonPredicate.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/ComparisonPredicate"
      },
      "rdfs:range": {
        "@id": "http://www.w3.org/1999/02/22-rdf-syntax-ns#Property"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/rhsProperty",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "rhsProperty",
      "rdfs:comment": "The right-hand-side property path in a ComparisonPredicate.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/ComparisonPredicate"
      },
      "rdfs:range": {
        "@id": "http://www.w3.org/1999/02/22-rdf-syntax-ns#Property"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/comparator",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "comparator",
      "rdfs:comment": "The comparison operator: '≤', '<', '=', '≥', '>'.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/ComparisonPredicate"
      },
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#string"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/requiredMemberClass",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "requiredMemberClass",
      "rdfs:comment": "The OWL class the target property's value must be an instance of for a MembershipPredicate to hold.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/MembershipPredicate"
      },
      "rdfs:range": {
        "@id": "http://www.w3.org/2002/07/owl#Class"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/leftOperand",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "leftOperand",
      "rdfs:comment": "The left operand of a compound predicate (DisjunctionPredicate or ConjunctionPredicate).",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/PredicateExpression"
      },
      "rdfs:range": {
        "@id": "https://prism.uor.foundation/op/PredicateExpression"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/rightOperand",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "rightOperand",
      "rdfs:comment": "The right operand of a compound predicate (DisjunctionPredicate or ConjunctionPredicate).",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/PredicateExpression"
      },
      "rdfs:range": {
        "@id": "https://prism.uor.foundation/op/PredicateExpression"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/negatedOperand",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "negatedOperand",
      "rdfs:comment": "The operand of a NegationPredicate. The predicate holds iff this operand does not hold.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/NegationPredicate"
      },
      "rdfs:range": {
        "@id": "https://prism.uor.foundation/op/PredicateExpression"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/guardPredicate",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "guardPredicate",
      "rdfs:comment": "The root PredicateExpression of this guard. The guard holds iff this predicate evaluates to true.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/GuardExpression"
      },
      "rdfs:range": {
        "@id": "https://prism.uor.foundation/op/PredicateExpression"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/foundationBasis",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "foundationBasis",
      "rdfs:comment": "The foundation or Prism identity that guarantees this guard expression is sound.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/GuardExpression"
      },
      "rdfs:range": {
        "@id": "https://uor.foundation/op/Identity"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/effectSteps",
      "@type": "owl:ObjectProperty",
      "rdfs:label": "effectSteps",
      "rdfs:comment": "An EffectExpression step in this transition effect. Non-functional: a transition may have multiple effects (stage advance + property binds).",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/TransitionEffect"
      },
      "rdfs:range": {
        "@id": "https://prism.uor.foundation/op/EffectExpression"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/advanceTarget",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "advanceTarget",
      "rdfs:comment": "The PipelineStage to set currentStage to. Used by StageAdvance.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/StageAdvance"
      },
      "rdfs:range": {
        "@id": "https://prism.uor.foundation/op/PipelineStage"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/bindTargetProperty",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "bindTargetProperty",
      "rdfs:comment": "The PipelineState property being set by this PropertyBind effect.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/PropertyBind"
      },
      "rdfs:range": {
        "@id": "http://www.w3.org/1999/02/22-rdf-syntax-ns#Property"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/bindSourceObject",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "bindSourceObject",
      "rdfs:comment": "The object that produced the value (the operator result, the resolver output, etc.).",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/PropertyBind"
      },
      "rdfs:range": {
        "@id": "http://www.w3.org/2002/07/owl#Thing"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/bindSourceProperty",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "bindSourceProperty",
      "rdfs:comment": "The property on the source object that provides the value to bind.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/PropertyBind"
      },
      "rdfs:range": {
        "@id": "http://www.w3.org/1999/02/22-rdf-syntax-ns#Property"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/evaluationRule",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "evaluationRule",
      "rdfs:comment": "The PE_ identity that defines the evaluation function for this predicate type. Wires the predicate AST node to the formal evaluation rule in the identity algebra. Enforced by SHACL sh:hasValue on each predicate subclass shape.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/PredicateExpression"
      },
      "rdfs:range": {
        "@id": "https://uor.foundation/op/Identity"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/reductionRule",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "reductionRule",
      "rdfs:comment": "The ER_ identity that defines the reduction function for this effect type. Wires the effect AST node to the formal reduction rule in the identity algebra. Enforced by SHACL sh:hasValue on each effect subclass shape.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/EffectExpression"
      },
      "rdfs:range": {
        "@id": "https://uor.foundation/op/Identity"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/effectStepIndex",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "effectStepIndex",
      "rdfs:comment": "Zero-based index determining strict execution order within a TransitionEffect. Step 0 executes first. All steps execute atomically: if any step fails, no state mutation occurs.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/EffectExpression"
      },
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#nonNegativeInteger"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/effectAtomic",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "effectAtomic",
      "rdfs:comment": "Whether the effect steps execute atomically (all-or-nothing). True for all pipeline transitions: either all state mutations apply or none do. Rollback of individual transitions is not supported — rollback operates at the PipelineTransaction level via PM_5.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/TransitionEffect"
      },
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#boolean"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/ruleSourceStage",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "ruleSourceStage",
      "rdfs:comment": "The PipelineStage from which this transition rule fires.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/PipelineTransitionRule"
      },
      "rdfs:range": {
        "@id": "https://prism.uor.foundation/op/PipelineStage"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/ruleOperator",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "ruleOperator",
      "rdfs:comment": "The operator or operator component that executes during this transition. For Initialization→Declare: pop:dispatch. For Declare→Factorize / Factorize→Resolve / Attest→Extract: pop:infer (disambiguated by cascade ordinal). For Resolve→Attest: pop:accumulate.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/PipelineTransitionRule"
      },
      "rdfs:range": {
        "@id": "https://prism.uor.foundation/op/ComposedOperation"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/ruleGuard",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "ruleGuard",
      "rdfs:comment": "The GuardExpression that must evaluate to true for this transition to fire.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/PipelineTransitionRule"
      },
      "rdfs:range": {
        "@id": "https://prism.uor.foundation/op/GuardExpression"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/ruleSuccessTarget",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "ruleSuccessTarget",
      "rdfs:comment": "The PipelineStage to transition to when the guard is satisfied.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/PipelineTransitionRule"
      },
      "rdfs:range": {
        "@id": "https://prism.uor.foundation/op/PipelineStage"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/ruleFailureMode",
      "@type": "owl:ObjectProperty",
      "rdfs:label": "ruleFailureMode",
      "rdfs:comment": "A PipelineFailureReason that fires when this transition's phase gate attestation fails. Non-functional: the Factorize→Resolve transition (E(2)→E(3)) has two possible failure modes (ConvergenceStall, ContradictionDetected).",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/PipelineTransitionRule"
      },
      "rdfs:range": {
        "@id": "https://prism.uor.foundation/op/PipelineFailureReason"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/ruleGroundingIdentity",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "ruleGroundingIdentity",
      "rdfs:comment": "The Prism or foundation identity that guarantees this transition rule's guard is sound.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/PipelineTransitionRule"
      },
      "rdfs:range": {
        "@id": "https://uor.foundation/op/Identity"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/ruleEffect",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "ruleEffect",
      "rdfs:comment": "The TransitionEffect describing the state changes on successful transition.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/PipelineTransitionRule"
      },
      "rdfs:range": {
        "@id": "https://prism.uor.foundation/op/TransitionEffect"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/stageOperator",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "stageOperator",
      "rdfs:comment": "The operator or operator component that executes at this pipeline stage. Absent on terminal stages (Convergence, PipelineFailed).",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/PipelineStage"
      },
      "rdfs:range": {
        "@id": "https://prism.uor.foundation/op/ComposedOperation"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/isResumable",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "isResumable",
      "rdfs:comment": "Whether this failure mode permits pipeline recovery. True only for ConvergenceStall (add constraints to break the stall). False for all terminal failures.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/PipelineFailureReason"
      },
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#boolean"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/guardCondition",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "guardCondition",
      "rdfs:comment": "The PhaseGateAttestation that must be satisfied for a stage transition to fire.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/PipelineStage"
      },
      "rdfs:range": {
        "@id": "https://prism.uor.foundation/gate/PhaseGateAttestation"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/contractPrecondition",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "contractPrecondition",
      "rdfs:comment": "The precondition that must hold on the pipeline state before the resolver executes. Includes minimum σ, available fibers, and TargetConvergenceAngle constraint coverage.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/ResolverContract"
      },
      "rdfs:range": {
        "@id": "https://prism.uor.foundation/gate/PhaseGateAttestation"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/contractMaxIterations",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "contractMaxIterations",
      "rdfs:comment": "The maximum iterations this resolver may execute, derived from CB_6: ≤ min(k, n).",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/ResolverContract"
      },
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#nonNegativeInteger"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/contractGuaranteedProgress",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "contractGuaranteedProgress",
      "rdfs:comment": "The minimum fibers pinned per iteration, from CB_1. When the constraint set is sufficient, at least 1 fiber is pinned per iteration.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/ResolverContract"
      },
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#positiveInteger"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/bindingContract",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "bindingContract",
      "rdfs:comment": "The ResolverContract attached to this ResolverBinding. Verified at runtime by the pipeline audit layer.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/ResolverBinding"
      },
      "rdfs:range": {
        "@id": "https://prism.uor.foundation/op/ResolverContract"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/preflightChecks",
      "@type": "owl:ObjectProperty",
      "rdfs:label": "preflightChecks",
      "rdfs:comment": "A PreflightCheck in this preflight result. Non-functional: multiple checks.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/PreflightResult"
      },
      "rdfs:range": {
        "@id": "https://prism.uor.foundation/op/PreflightCheck"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/preflightVerdict",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "preflightVerdict",
      "rdfs:comment": "The aggregated go/no-go decision. True iff all preflight checks pass. The pipeline only advances to Initialization (E(0) = 1) when preflightVerdict = true.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/PreflightResult"
      },
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#boolean"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/instancePreflight",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "instancePreflight",
      "rdfs:comment": "The PreflightResult for this PrismInstance. Computed before pipeline execution begins.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/PrismInstance"
      },
      "rdfs:range": {
        "@id": "https://prism.uor.foundation/op/PreflightResult"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/executionPolicy",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "executionPolicy",
      "rdfs:comment": "The foundation ExecutionPolicy governing lease activation order for parallel execution. Determines the scheduling discipline when λ produces k leases: FifoPolicy (partition order), MinFreeCountFirst (greedy — most constrained first), MaxFreeCountFirst (broadest first), DisjointFirst (maximize parallelism).",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/PrismInstance"
      },
      "rdfs:range": {
        "@id": "https://uor.foundation/resolver/ExecutionPolicy"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/instanceTransaction",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "instanceTransaction",
      "rdfs:comment": "The PipelineTransaction grouping this instance's multi-target execution into an atomic unit. Absent for single-target instances.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/PrismInstance"
      },
      "rdfs:range": {
        "@id": "https://prism.uor.foundation/op/PipelineTransaction"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/ManagedLease",
      "@type": "owl:Class",
      "rdfs:label": "ManagedLease",
      "rdfs:comment": "A Prism-managed ContextLease carrying lifecycle state and timestamps. Subclasses the foundation's state:ContextLease to add the LeaseState lifecycle (Pending → Active → Released/Expired) without extending the foundation class directly.",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/state/ContextLease"
        }
      ]
    },
    {
      "@id": "https://prism.uor.foundation/op/currentLeaseState",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "currentLeaseState",
      "rdfs:comment": "The current lifecycle state of this managed lease: Pending, Active, Released, or Expired.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/ManagedLease"
      },
      "rdfs:range": {
        "@id": "https://prism.uor.foundation/op/LeaseState"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/leaseAcquiredAt",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "leaseAcquiredAt",
      "rdfs:comment": "Timestamp when this lease transitioned from Pending to Active.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/ManagedLease"
      },
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#dateTime"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/leaseReleasedAt",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "leaseReleasedAt",
      "rdfs:comment": "Timestamp when this lease transitioned from Active to Released or Expired.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/ManagedLease"
      },
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#dateTime"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/transactionScope",
      "@type": "owl:ObjectProperty",
      "rdfs:label": "transactionScope",
      "rdfs:comment": "A TargetConvergenceAngle target in this transaction. Non-functional: a transaction covers multiple targets.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/PipelineTransaction"
      },
      "rdfs:range": {
        "@id": "https://prism.uor.foundation/cascade/TargetConvergenceAngle"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/transactionPolicy",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "transactionPolicy",
      "rdfs:comment": "The atomicity policy for this transaction: AllOrNothing or BestEffort.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/PipelineTransaction"
      },
      "rdfs:range": {
        "@id": "https://prism.uor.foundation/op/TransactionPolicy"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/transactionOutcome",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "transactionOutcome",
      "rdfs:comment": "The terminal state of this transaction: Committed, RolledBack, or PartialCommit.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/PipelineTransaction"
      },
      "rdfs:range": {
        "@id": "https://prism.uor.foundation/op/TransactionOutcome"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/transactionCertificates",
      "@type": "owl:ObjectProperty",
      "rdfs:label": "transactionCertificates",
      "rdfs:comment": "PipelineCertificates issued for successfully committed targets. Non-functional: one per committed target.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/PipelineTransaction"
      },
      "rdfs:range": {
        "@id": "https://prism.uor.foundation/cert/PipelineCertificate"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/rollbackTarget",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "rollbackTarget",
      "rdfs:comment": "The BaseContext to restore on AllOrNothing rollback. PA_4 guarantees the base is intact. The PipelineTrace serves as the rollback journal — rollback discards all accumulated bindings and restores this BaseContext.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/PipelineTransaction"
      },
      "rdfs:range": {
        "@id": "https://prism.uor.foundation/op/BaseContext"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/failureTiming",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:label": "failureTiming",
      "rdfs:comment": "Whether this failure mode is detectable at Preflight or Runtime.",
      "rdfs:domain": {
        "@id": "https://prism.uor.foundation/op/PipelineFailureReason"
      },
      "rdfs:range": {
        "@id": "https://prism.uor.foundation/op/FailureTiming"
      }
    },
    {
      "@id": "https://prism.uor.foundation/op/PX_1",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "rdfs:label": "PX_1",
      "rdfs:comment": "Euler cascade phase ordering is deterministic: Initialization (0°) → Declare (30°) → Factorize (60°) → Resolve (90°) → Attest (120°) → Extract (150°) → Convergence (180°). No phase is skipped or reordered. Each transition applies the unitary operator Ω = e^(iπ/6), advancing the state vector by exactly 30°. Failed may occur at any phase gate but terminates the pipeline. Determinism follows from Ω being a fixed 12th root of unity.",
      "op:lhs": "E(k+1) = Ω × E(k)",
      "op:rhs": "successor phase angle = k × 30° + 30° in the fixed Euler Cascade [E(0)..E(6)]",
      "op:forAll": "PipelineState with cascade ordinal k, k ≠ Failed",
      "op:verificationDomain": {
        "@id": "https://prism.uor.foundation/op/PipelineAlgebraic"
      },
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationPathNote": "PD_1 (dispatch determinism) + PI_2 (inference well-typedness) + PA_4 (base preservation) → deterministic stage progression"
    },
    {
      "@id": "https://prism.uor.foundation/op/PX_2",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "rdfs:label": "PX_2",
      "rdfs:comment": "Pipeline trace completeness: every pipeline reaching Convergence (E(6) = −1) has exactly six PipelineSteps, one for each phase transition E(0)→E(1) through E(5)→E(6). The trace is a complete record of the six 30° rotations constituting the full 180° cascade.",
      "op:lhs": "|steps(trace)| for Converged pipeline",
      "op:rhs": "= 6 (one per phase transition in the Euler Cascade)",
      "op:forAll": "PipelineState with currentStage = Convergence",
      "op:verificationDomain": {
        "@id": "https://prism.uor.foundation/op/PipelineAlgebraic"
      },
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationPathNote": "PX_1 (Euler cascade phase ordering) → exactly 6 phase transitions → exactly 6 step records"
    },
    {
      "@id": "https://prism.uor.foundation/op/PX_3",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "rdfs:label": "PX_3",
      "rdfs:comment": "Certificate issuance: every pipeline reaching Convergence (E(6) = e^(iπ) = −1) with σ(outputContext) = 1 admits a PipelineCertificate. The certificate attests PP_1 equivalence, PI_5 coherence, PA_4 base preservation, and EC_1 Euler cascade closure for the execution.",
      "op:lhs": "Convergence ∧ σ = 1 ∧ E(6) = −1",
      "op:rhs": "∃ c: PipelineCertificate. certifiedPipeline(c, trace)",
      "op:forAll": "PipelineState reaching Convergence with saturated output",
      "op:verificationDomain": {
        "@id": "https://prism.uor.foundation/op/PipelineAlgebraic"
      },
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationPathNote": "CIC_1–CIC_7 (certificate issuance coverage) + PP_1 (pipeline unification) → certificate issuance"
    },
    {
      "@id": "https://prism.uor.foundation/op/PX_4",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "rdfs:label": "PX_4",
      "rdfs:comment": "Target convergence angle: if the TargetConvergenceAngle's constraint set is sufficient (CB_5) and the BaseContext's baseFiberMask leaves fibers for the convergence constraints to pin, then iterated phase rotation converges to E(6) = e^(iπ) = −1 (σ = 1) in at most n cascade iterations. The pipeline naturally executes recursive 30° rotations until the 180° target is achieved.",
      "op:lhs": "iterated cascade on TargetConvergenceAngle with sufficient constraints",
      "op:rhs": "E(k) → E(6) = −1, σ → 1 in ≤ n iterations",
      "op:forAll": "PrismInstance with sufficient TargetConvergenceAngle constraints (CB_5)",
      "op:verificationDomain": {
        "@id": "https://prism.uor.foundation/op/PipelineAlgebraic"
      },
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationPathNote": "PA_3 (saturation bound) + CB_5 (sufficiency) + PA_4 (base preservation) + EC_1 (cascade closure) → target convergence angle"
    },
    {
      "@id": "https://prism.uor.foundation/op/PX_5",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "rdfs:label": "PX_5",
      "rdfs:comment": "Infeasibility detection: if the TargetConvergenceAngle's constraint set fails CB_5 (insufficient fiber coverage) or triggers SR_5 (contradicting bindings), an InfeasibilityWitness is produced before pipeline execution begins. The witness carries the infeasibilityKind (Insufficient or Contradictory), the uncovered fibers or conflicting constraints, and the phase angle at which convergence would stall. Structurally disjoint from FeasibilityWitness.",
      "op:lhs": "feasibilityResult(T) when ¬CB_5(T) ∨ ∃SR_5-conflict(T)",
      "op:rhs": "InfeasibilityWitness with typed reason and stall phase angle",
      "op:forAll": "T: TargetConvergenceAngle with infeasible constraint set",
      "op:verificationDomain": {
        "@id": "https://prism.uor.foundation/op/PipelineAlgebraic"
      },
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationPathNote": "CB_5 (sufficiency criterion) + SR_5 (contradiction detection) → infeasibility witness production"
    },
    {
      "@id": "https://prism.uor.foundation/op/EC_1",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "rdfs:label": "EC_1",
      "rdfs:comment": "Euler cascade closure: E(6) = Ω⁶ = e^(iπ) = −1. The product of six successive applications of the unitary operator Ω = e^(iπ/6) converges at Euler's Identity. This proves the object has undergone the full 180° transformation through the Substrate and is a validated, post-lifecycle mirror of its initial E(0) = 1 state. The −1 convergence value is the algebraic proof of pipeline completion — it is not an arbitrary terminal flag but a mathematically necessary consequence of the cascade function.",
      "op:lhs": "E(6) = Ω⁶ = (e^(iπ/6))⁶",
      "op:rhs": "e^(iπ) = −1",
      "op:forAll": "Euler Cascade with Ω = e^(iπ/6), six phase rotations applied",
      "op:verificationDomain": {
        "@id": "https://prism.uor.foundation/op/PipelineAlgebraic"
      },
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationPathNote": "Direct from Euler's formula: e^(iπ) + 1 = 0. The cascade function E(k) = (e^(iπ/6))^k evaluated at k=6 yields e^(iπ) = −1. Compatibility with D_{2n}: the 180° rotation is a half-turn in the dihedral group, corresponding to the composition neg∘bnot in the foundation."
    },
    {
      "@id": "https://prism.uor.foundation/op/EC_2",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "rdfs:label": "EC_2",
      "rdfs:comment": "Conjugate reversibility: if an operation faults at stage E(k) and requires rollback, the pipeline applies the complex conjugate e^(−iπ/6) exactly k times to return to E(0) = 1. This mirrors the reflection symmetries of the Substrate's D_{2n} factorization: the conjugate operator is the inverse of Ω in the unitary group, and the rollback path E(k) → E(k−1) → ... → E(0) is the exact reversal of the forward cascade. The pipeline is natively reversible because Ω × Ω̄ = 1.",
      "op:lhs": "Ω^k × (Ω̄)^k = (e^(iπ/6))^k × (e^(−iπ/6))^k",
      "op:rhs": "1 = E(0)",
      "op:forAll": "PipelineState at cascade ordinal k requiring rollback",
      "op:verificationDomain": {
        "@id": "https://prism.uor.foundation/op/PipelineAlgebraic"
      },
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationPathNote": "Unitary group property: Ω × Ω̄ = |Ω|² = 1. D_{2n} compatibility: the conjugate rotation e^(−iπ/6) corresponds to the reflection generator of D_{2n}, making rollback a reflection symmetry operation rather than an arbitrary state restoration."
    },
    {
      "@id": "https://prism.uor.foundation/op/PM_1",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "rdfs:label": "PM_1",
      "rdfs:comment": "Transition legality: every transition in a valid PipelineTrace has its PhaseGateAttestation satisfied at the source PipelineState. No transition fires from a state where the state vector does not equal the expected Ω^k. The phase gate composition is conjunctive: sequential gates require the state vector to match at each 30° boundary.",
      "op:lhs": "transition(E(k), E(k+1)) in valid trace",
      "op:rhs": "phaseGate(E(k)).stateVector = Ω^k",
      "op:forAll": "PipelineTrace T, transition t ∈ T",
      "op:verificationDomain": {
        "@id": "https://prism.uor.foundation/op/MachineAlgebraic"
      },
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationPathNote": "PX_1 (Euler cascade phase ordering) + phase gate composition (state vector = Ω^k at each boundary) → legality"
    },
    {
      "@id": "https://prism.uor.foundation/op/PM_2",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "rdfs:label": "PM_2",
      "rdfs:comment": "Contract compliance: every resolver execution at the Resolve stage (E(3) = i, 90°) produces exactly one of three outcomes: (a) closed partition within contractMaxIterations, (b) RefinementSuggestion with isComplete=false, (c) ContradictionBoundary. These outcomes are exhaustive and mutually exclusive.",
      "op:lhs": "resolve(query, context) outcome",
      "op:rhs": "∈ {ClosedPartition, RefinementSuggestion, ContradictionBoundary}",
      "op:forAll": "ResolverBinding with ResolverContract, query matching boundQueryType",
      "op:verificationDomain": {
        "@id": "https://prism.uor.foundation/op/MachineAlgebraic"
      },
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationPathNote": "CB_1 (progress) + CB_5 (sufficiency) + CB_6 (bound) + SR_5 (contradiction) → exhaustive outcome trichotomy"
    },
    {
      "@id": "https://prism.uor.foundation/op/PM_3",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "rdfs:label": "PM_3",
      "rdfs:comment": "Preflight completeness: the set of preflight checks covers all Preflight-timed failures. A pipeline passing PreflightResult (verdict=true) cannot encounter DispatchMiss or CoherenceViolation at runtime. Runtime-timed failures (ConvergenceStall, ContradictionDetected, GroundingFailure) remain possible.",
      "op:lhs": "preflightVerdict(instance) = true",
      "op:rhs": "¬∃ Preflight-timed failure in pipeline execution",
      "op:forAll": "PrismInstance with preflightVerdict = true",
      "op:verificationDomain": {
        "@id": "https://prism.uor.foundation/op/MachineAlgebraic"
      },
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationPathNote": "PX_5 (infeasibility) + PD_1 (dispatch determinism) + PI_5 (coherence) → preflight covers preventable failures"
    },
    {
      "@id": "https://prism.uor.foundation/op/PM_4",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "rdfs:label": "PM_4",
      "rdfs:comment": "Lease exclusivity enforcement: for any two ContextLeases with currentLeaseState = Active on the same SharedContext, AND(leasedFibers_i, leasedFibers_j) = 0. This is PL_2 restated as a runtime invariant — holding at every point during concurrent execution, not just at partition construction.",
      "op:lhs": "AND(leasedFibers_i, leasedFibers_j) for Active leases i ≠ j",
      "op:rhs": "= 0",
      "op:forAll": "SharedContext with ≥2 Active ContextLeases",
      "op:verificationDomain": {
        "@id": "https://prism.uor.foundation/op/MachineAlgebraic"
      },
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationPathNote": "PL_2 (disjointness at construction) + LeaseState lifecycle (no fiber reassignment while Active) → runtime exclusivity"
    },
    {
      "@id": "https://prism.uor.foundation/op/PM_5",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "rdfs:label": "PM_5",
      "rdfs:comment": "Transaction atomicity: under AllOrNothing policy, transactionOutcome ∈ {Committed, RolledBack}. Committed iff all targets in transactionScope reached σ=1. RolledBack iff any target failed — all accumulated bindings across all targets are reverted. Under BestEffort, PartialCommit is additionally legal.",
      "op:lhs": "transactionOutcome(T) under AllOrNothing",
      "op:rhs": "∈ {Committed, RolledBack}; Committed iff ∀ targets σ=1",
      "op:forAll": "PipelineTransaction T with transactionPolicy = AllOrNothing",
      "op:verificationDomain": {
        "@id": "https://prism.uor.foundation/op/MachineAlgebraic"
      },
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationPathNote": "PA_4 (base preservation enables rollback) + SR_1 (monotonicity enables progress tracking) → atomic commit/rollback"
    },
    {
      "@id": "https://prism.uor.foundation/op/PM_6",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "rdfs:label": "PM_6",
      "rdfs:comment": "Recovery determinism: after a resumable failure (ConvergenceStall), the pipeline resumes from the Resolve stage (E(3) = i, 90°) with the existing fiber budget intact. The resumed execution satisfies PM_1–PM_5. Non-resumable failures (DispatchMiss, CoherenceViolation, ContradictionDetected) are terminal — no recovery path exists.",
      "op:lhs": "resume(PipelineState with failureResumable=true, additionalConstraints)",
      "op:rhs": "valid PipelineState at Resolve (E(3), 90°) with budget(original) ∪ pins(additionalConstraints)",
      "op:forAll": "PipelineState with currentStage=PipelineFailed, failureResumable=true",
      "op:verificationDomain": {
        "@id": "https://prism.uor.foundation/op/MachineAlgebraic"
      },
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationPathNote": "SR_1 (monotonicity preserves existing pins) + CB_4 (stall detection is non-destructive) → deterministic recovery"
    },
    {
      "@id": "https://prism.uor.foundation/op/PM_7",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "rdfs:label": "PM_7",
      "rdfs:comment": "Machine completeness: every PrismInstance passing preflight (PM_3) reaches a terminal state (Convergence or PipelineFailed per target) in at most Σ_t CB_6(t) phase transitions across all targets. The terminal state determines the TransactionOutcome per PM_5. This is the machine-level analog of PP_1: the complete machine produces a certified or witnessed result in bounded time. Convergence at E(6) = e^(iπ) = −1 is the algebraic proof of completion.",
      "op:lhs": "PrismInstance with preflightVerdict=true, k targets",
      "op:rhs": "terminal state in ≤ Σ_t min(k_t, n) transitions; TransactionOutcome determined",
      "op:forAll": "PrismInstance passing preflight",
      "op:verificationDomain": {
        "@id": "https://prism.uor.foundation/op/MachineAlgebraic"
      },
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationPathNote": "PM_1 (legality) + PM_2 (contracts) + PM_3 (preflight) + PM_5 (atomicity) + PX_4 (convergence) → bounded termination with determined outcome"
    },
    {
      "@id": "https://prism.uor.foundation/op/PE_1",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "rdfs:label": "PE_1",
      "rdfs:comment": "NonNull evaluation: eval(NonNull(p), S) = bound(p, S). The predicate holds iff property p has at least one value on pipeline state S. This is the base case for property-presence checks (e.g., selectedResolver ≠ null after dispatch).",
      "op:lhs": "eval(NonNullPredicate(targetProperty=p), S)",
      "op:rhs": "bound(p, S)",
      "op:forAll": "p: rdf:Property, S: PipelineState",
      "op:verificationDomain": {
        "@id": "https://prism.uor.foundation/op/ReductionAlgebraic"
      },
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationPathNote": "OWL open-world semantics: bound(p, S) iff ∃v. (S, p, v) ∈ graph"
    },
    {
      "@id": "https://prism.uor.foundation/op/PE_2",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "rdfs:label": "PE_2",
      "rdfs:comment": "Equals evaluation: eval(Equals(p, v), S) = (get(p, S) = v). The predicate holds iff property p on state S equals expected value v. Used for boolean checks (isComplete = true, roundTripCoherence = true).",
      "op:lhs": "eval(EqualsPredicate(targetProperty=p, expectedValue=v), S)",
      "op:rhs": "get(p, S) = v",
      "op:forAll": "p: rdf:Property, v: owl:Thing, S: PipelineState",
      "op:verificationDomain": {
        "@id": "https://prism.uor.foundation/op/ReductionAlgebraic"
      },
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationPathNote": "OWL equality: structural equality for literals, IRI identity for individuals"
    },
    {
      "@id": "https://prism.uor.foundation/op/PE_3",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "rdfs:label": "PE_3",
      "rdfs:comment": "Comparison evaluation: eval(Comparison(l, r, op), S) = (get(l, S) op get(r, S)). The predicate holds iff the numeric values of properties l and r on state S satisfy the comparator. Used for monotonicity checks (freeCount(out) ≤ freeCount(in)).",
      "op:lhs": "eval(ComparisonPredicate(lhsProperty=l, rhsProperty=r, comparator=op), S)",
      "op:rhs": "get(l, S) op get(r, S)",
      "op:forAll": "l, r: rdf:Property, op ∈ {≤, <, =, ≥, >}, S: PipelineState, get(l, S) and get(r, S) ∈ ℤ",
      "op:verificationDomain": {
        "@id": "https://prism.uor.foundation/op/ReductionAlgebraic"
      },
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationPathNote": "SR_1 monotonicity guarantees get(freeCount, S_out) ≤ get(freeCount, S_in)"
    },
    {
      "@id": "https://prism.uor.foundation/op/PE_4",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "rdfs:label": "PE_4",
      "rdfs:comment": "Membership evaluation: eval(Membership(p, C), S) = (get(p, S) rdf:type C). The predicate holds iff the value of property p on state S is an instance of class C. Used for type checks (address ∈ Address, terminationReason ∈ ContradictionBoundary).",
      "op:lhs": "eval(MembershipPredicate(targetProperty=p, requiredMemberClass=C), S)",
      "op:rhs": "get(p, S) rdf:type C",
      "op:forAll": "p: rdf:Property, C: owl:Class, S: PipelineState",
      "op:verificationDomain": {
        "@id": "https://prism.uor.foundation/op/ReductionAlgebraic"
      },
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationPathNote": "OWL class membership: entailment under the ontology's TBox"
    },
    {
      "@id": "https://prism.uor.foundation/op/PE_5",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "rdfs:label": "PE_5",
      "rdfs:comment": "Disjunction evaluation: eval(Disjunction(L, R), S) = eval(L, S) ∨ eval(R, S). Short-circuit: if eval(L, S) = true, R is not evaluated. The predicate tree is evaluated depth-first left-to-right.",
      "op:lhs": "eval(DisjunctionPredicate(leftOperand=L, rightOperand=R), S)",
      "op:rhs": "eval(L, S) ∨ eval(R, S)",
      "op:forAll": "L, R: PredicateExpression, S: PipelineState",
      "op:verificationDomain": {
        "@id": "https://prism.uor.foundation/op/ReductionAlgebraic"
      },
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationPathNote": "Boolean algebra: standard disjunction with short-circuit semantics"
    },
    {
      "@id": "https://prism.uor.foundation/op/PE_6",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "rdfs:label": "PE_6",
      "rdfs:comment": "Conjunction evaluation: eval(Conjunction(L, R), S) = eval(L, S) ∧ eval(R, S). Short-circuit: if eval(L, S) = false, R is not evaluated. This completes the Boolean predicate algebra.",
      "op:lhs": "eval(ConjunctionPredicate(leftOperand=L, rightOperand=R), S)",
      "op:rhs": "eval(L, S) ∧ eval(R, S)",
      "op:forAll": "L, R: PredicateExpression, S: PipelineState",
      "op:verificationDomain": {
        "@id": "https://prism.uor.foundation/op/ReductionAlgebraic"
      },
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationPathNote": "Boolean algebra: standard conjunction with short-circuit semantics"
    },
    {
      "@id": "https://prism.uor.foundation/op/PE_7",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "rdfs:label": "PE_7",
      "rdfs:comment": "Negation evaluation: eval(Negation(X), S) = ¬eval(X, S). Inverts the result of the operand predicate.",
      "op:lhs": "eval(NegationPredicate(negatedOperand=X), S)",
      "op:rhs": "¬eval(X, S)",
      "op:forAll": "X: PredicateExpression, S: PipelineState",
      "op:verificationDomain": {
        "@id": "https://prism.uor.foundation/op/ReductionAlgebraic"
      },
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationPathNote": "Boolean algebra: standard negation. Completes {∧, ∨, ¬} — functionally complete."
    },
    {
      "@id": "https://prism.uor.foundation/op/ER_1",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "rdfs:label": "ER_1",
      "rdfs:comment": "StageAdvance reduction: reduce(StageAdvance(t), S) = S[currentStage ← t]. Replaces the currentStage property on pipeline state S with target stage t. This is the only effect that modifies the control-flow state.",
      "op:lhs": "reduce(StageAdvance(advanceTarget=t), S)",
      "op:rhs": "S[currentStage ← t]",
      "op:forAll": "t: PipelineStage, S: PipelineState",
      "op:verificationDomain": {
        "@id": "https://prism.uor.foundation/op/ReductionAlgebraic"
      },
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationPathNote": "Functional update: S[p ← v] denotes S with property p replaced by value v"
    },
    {
      "@id": "https://prism.uor.foundation/op/ER_2",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "rdfs:label": "ER_2",
      "rdfs:comment": "PropertyBind reduction: reduce(PropertyBind(tp, so, sp), S) = S[tp ← get(sp, so)]. Reads property sp from source object so and writes the result to property tp on pipeline state S.",
      "op:lhs": "reduce(PropertyBind(bindTargetProperty=tp, bindSourceObject=so, bindSourceProperty=sp), S)",
      "op:rhs": "S[tp ← get(sp, so)]",
      "op:forAll": "tp, sp: rdf:Property, so: owl:Thing, S: PipelineState",
      "op:verificationDomain": {
        "@id": "https://prism.uor.foundation/op/ReductionAlgebraic"
      },
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationPathNote": "Functional update with indirection: source value is read from the operator output graph"
    },
    {
      "@id": "https://prism.uor.foundation/op/ER_3",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "rdfs:label": "ER_3",
      "rdfs:comment": "Sequential composition: reduce([e₀, e₁, ..., eₖ], S) = reduce(eₖ, ...reduce(e₁, reduce(e₀, S))...). Effect steps execute in effectStepIndex order. Each step receives the state produced by the previous step. The ordering is strict: step i sees the mutations of steps 0..i-1.",
      "op:lhs": "reduce([e₀, e₁, ..., eₖ] ordered by effectStepIndex, S)",
      "op:rhs": "reduce(eₖ, ...reduce(e₁, reduce(e₀, S))...)",
      "op:forAll": "e₀..eₖ: EffectExpression with effectStepIndex 0..k, S: PipelineState",
      "op:verificationDomain": {
        "@id": "https://prism.uor.foundation/op/ReductionAlgebraic"
      },
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationPathNote": "Left fold: the standard sequential composition of state transformers"
    },
    {
      "@id": "https://prism.uor.foundation/op/ER_4",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "rdfs:label": "ER_4",
      "rdfs:comment": "Atomicity: when effectAtomic = true, either all steps succeed and S' is returned, or any step failure (classified by EffectStepFailure: SourceUnbound, TypeMismatch, or InvariantViolation) reverts to S. atomic(reduce(steps, S)) = S' if all steps succeed; S with stepFailureKind set if any step is undefined. In a conforming system operating on a valid ontology, step failures should never occur (PM_2 contract compliance + SHACL shape validity).",
      "op:lhs": "atomic(reduce(steps, S)) when effectAtomic = true",
      "op:rhs": "S' if ∀i. reduce(eᵢ, Sᵢ) defined; S if ∃i. reduce(eᵢ, Sᵢ) undefined",
      "op:forAll": "steps: [EffectExpression], S: PipelineState, effectAtomic = true",
      "op:verificationDomain": {
        "@id": "https://prism.uor.foundation/op/ReductionAlgebraic"
      },
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationPathNote": "PM_5 composes atomic transitions into transactional rollback: rollback(T) = restore(T.rollbackTarget) iff transactionPolicy = AllOrNothing ∧ ∃ target failed"
    },
    {
      "@id": "https://prism.uor.foundation/op/TJ_1",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "rdfs:label": "TJ_1",
      "rdfs:comment": "Success judgment: ⟨S, rule⟩ →ₛ S' iff the PhaseGateAttestation at E(k) confirms the state vector equals Ω^k and S' = atomic(reduce(rule.effect.steps, S)). When the phase gate passes, the transition fires: the unitary operator Ω is applied, rotating the state vector by 30°, and effects are applied atomically producing the successor state at E(k+1).",
      "op:lhs": "⟨S, rule⟩ where phaseGateAttestation(E(k)).stateVector = Ω^k",
      "op:rhs": "S' = atomic(reduce(rule.ruleEffect.effectSteps sorted by effectStepIndex, S))",
      "op:forAll": "rule: PipelineTransitionRule, S: PipelineState with currentStage = rule.ruleSourceStage",
      "op:verificationDomain": {
        "@id": "https://prism.uor.foundation/op/ReductionAlgebraic"
      },
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationPathNote": "The success judgment produces the unique successor state. Determinism follows from PD_1 + PX_1 + the functional update semantics of ER_1/ER_2."
    },
    {
      "@id": "https://prism.uor.foundation/op/TJ_2",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "rdfs:label": "TJ_2",
      "rdfs:comment": "Failure judgment: ⟨S, rule⟩ →f S_fail iff the PhaseGateAttestation at E(k) determines the state vector does not equal the expected Ω^k. When the phase gate fails, the pipeline enters PipelineFailed with the typed failure reason, the actual vs expected phase angle, and the cascade ordinal at which the attestation failed. S_fail = S[currentStage ← PipelineFailed, failureReason ← rule.ruleFailureMode, failedAtStage ← S.currentStage, failedAtPhaseAngle ← k×30°, failureResumable ← rule.ruleFailureMode.isResumable].",
      "op:lhs": "⟨S, rule⟩ where phaseGateAttestation(E(k)).stateVector ≠ Ω^k",
      "op:rhs": "S[currentStage ← PipelineFailed, failureReason ← rule.ruleFailureMode, failedAtStage ← S.currentStage, failureResumable ← isResumable(rule.ruleFailureMode)]",
      "op:forAll": "rule: PipelineTransitionRule, S: PipelineState with currentStage = rule.ruleSourceStage",
      "op:verificationDomain": {
        "@id": "https://prism.uor.foundation/op/ReductionAlgebraic"
      },
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationPathNote": "The failure judgment produces a terminal state. PipelineFailed has no exit transition. PM_6 recovery starts a new judgment sequence from Resolve (E(3), 90°) if failureResumable = true."
    },
    {
      "@id": "https://prism.uor.foundation/op/TJ_3",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "rdfs:label": "TJ_3",
      "rdfs:comment": "Pipeline closure: the pipeline execution is the reflexive-transitive closure of TJ_1 from Initialization (E(0) = 1) to a terminal state (Convergence at E(6) = −1, or PipelineFailed). Formally: exec(S₀) = Sₙ where S₀.currentStage = Initialization, Sₙ.currentStage ∈ {Convergence, PipelineFailed}, and ∀i ∈ [0,n): ⟨Sᵢ, ruleFor(Sᵢ.currentStage)⟩ →ₛ Sᵢ₊₁ or ⟨Sᵢ, ruleFor(Sᵢ.currentStage)⟩ →f Sₙ. The execution terminates in ≤ 6 successful phase rotations (PM_7 via PX_4, EC_1).",
      "op:lhs": "exec(S₀) where S₀.currentStage = Initialization, E(0) = 1",
      "op:rhs": "Sₙ where Sₙ.currentStage ∈ {Convergence, PipelineFailed}, via ≤6 applications of TJ_1 or one application of TJ_2",
      "op:forAll": "S₀: PipelineState with currentStage = Initialization, preflightVerdict = true",
      "op:verificationDomain": {
        "@id": "https://prism.uor.foundation/op/ReductionAlgebraic"
      },
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationPathNote": "Bounded termination from PM_7 + EC_1 (cascade closure). Determinism from PX_1 (unique rule per cascade ordinal). The trace is the sequence [S₀, S₁, ..., Sₙ] — each PipelineStep records one TJ_1 phase rotation."
    },
    {
      "@id": "https://prism.uor.foundation/op/MT_1",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "rdfs:label": "MT_1",
      "rdfs:comment": "Determinism: the transition relation defined by TJ_1/TJ_2 is a partial function. Every non-terminal PipelineState has exactly one successor. This is stronger than confluence — there are no divergent paths. Proof: PX_1 assigns exactly one PipelineTransitionRule per non-terminal stage. PE_1–PE_7 are total functions (every well-formed predicate evaluates to exactly one boolean). ER_1–ER_2 are functional updates (each produces exactly one successor state). Therefore the composition TJ_1/TJ_2 is deterministic.",
      "op:lhs": "|{S' : ⟨S, ruleFor(S.currentStage)⟩ → S'}|",
      "op:rhs": "≤ 1 for all non-terminal S (= 0 for terminal S)",
      "op:forAll": "S: PipelineState",
      "op:verificationDomain": {
        "@id": "https://prism.uor.foundation/op/MetaTheoretic"
      },
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationPathNote": "PX_1 (unique rule per stage) + PE totality + ER functional updates → determinism"
    },
    {
      "@id": "https://prism.uor.foundation/op/MT_2",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "rdfs:label": "MT_2",
      "rdfs:comment": "Trace identity: two executions from the same initial state S₀ produce identical traces. Formally: exec(S₀) = [S₀, S₁, ..., Sₙ] is unique. This follows directly from MT_1 — if each step has at most one successor, the entire trace is determined by S₀. No two traces from the same starting state can differ at any step.",
      "op:lhs": "exec(S₀) and exec'(S₀) starting from the same S₀",
      "op:rhs": "exec(S₀) = exec'(S₀) (identical traces)",
      "op:forAll": "S₀: PipelineState with currentStage = Initialization (E(0) = 1)",
      "op:verificationDomain": {
        "@id": "https://prism.uor.foundation/op/MetaTheoretic"
      },
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationPathNote": "Immediate corollary of MT_1 determinism by induction on trace length"
    },
    {
      "@id": "https://prism.uor.foundation/op/MT_3",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "rdfs:label": "MT_3",
      "rdfs:comment": "Simulation correctness: any concrete interpreter I that implements PE_1–PE_7 (predicate evaluation) and ER_1–ER_4 (effect reduction) produces traces identical to the abstract TJ_3 execution. Formally: exec_I(S₀) = exec(S₀) for all valid S₀. This is the correctness criterion for implementations — an interpreter is correct iff it is a faithful simulation of the abstract transition system. Provable by induction on trace length (≤6 by PM_7), using the fact that each step is uniquely determined by the 9 evaluation/reduction rules.",
      "op:lhs": "exec_I(S₀) for interpreter I implementing PE_1–PE_7 + ER_1–ER_4",
      "op:rhs": "exec(S₀) (identical to abstract TJ_3 execution)",
      "op:forAll": "I: interpreter implementing all 9 rules, S₀: valid PipelineState",
      "op:verificationDomain": {
        "@id": "https://prism.uor.foundation/op/MetaTheoretic"
      },
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationPathNote": "Induction on trace length (≤6). Base: S₀ identical. Step: TJ_1/TJ_2 determined by PE+ER rules, which I implements faithfully. QED."
    },
    {
      "@id": "https://prism.uor.foundation/op/OE_1",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "rdfs:label": "OE_1",
      "rdfs:comment": "Observation function: observe(S) = (S.currentStage, S.pipelineBudget, S.failureReason, S.failedAtStage). Two PipelineStates are observationally equal iff observe(S₁) = observe(S₂). This defines the observable surface of pipeline state — the properties any correct execution must preserve. Internal implementation state (heap layout, thread scheduling, I/O buffers) is invisible to observe.",
      "op:lhs": "observe(S)",
      "op:rhs": "(S.currentStage, S.pipelineBudget, S.failureReason, S.failedAtStage)",
      "op:forAll": "S: PipelineState",
      "op:verificationDomain": {
        "@id": "https://prism.uor.foundation/op/ObservationalEquivalence"
      },
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationPathNote": "These four properties are the externally visible pipeline state. All other PipelineState properties are implementation-internal."
    },
    {
      "@id": "https://prism.uor.foundation/op/OE_2",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "rdfs:label": "OE_2",
      "rdfs:comment": "Terminal equivalence: two executions are terminally equivalent iff observe(exec(S₀)) = observe(exec'(S₀)). This is the weakest useful correctness guarantee for optimized implementations — the final observable state must match regardless of how many steps were taken or in what order. Every correct optimization must preserve terminal equivalence. The PipelineCertificate is issuable iff the terminal state is observationally equal to the abstract terminal state.",
      "op:lhs": "exec_opt(S₀) terminally equivalent to exec(S₀)",
      "op:rhs": "observe(exec_opt(S₀)) = observe(exec(S₀))",
      "op:forAll": "S₀: PipelineState with currentStage = Initialization (E(0) = 1), exec_opt: any optimized execution",
      "op:verificationDomain": {
        "@id": "https://prism.uor.foundation/op/ObservationalEquivalence"
      },
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationPathNote": "Terminal equivalence is necessary but not sufficient for certification — bisimulation (OE_3) is required for full evidence-chain preservation."
    },
    {
      "@id": "https://prism.uor.foundation/op/OE_3",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "rdfs:label": "OE_3",
      "rdfs:comment": "Bisimulation: a relation R between abstract states S_A and concrete states S_C is a Prism bisimulation iff: (a) related initial states: S₀_A R S₀_C when observe(S₀_A) = observe(S₀_C), (b) forward simulation: if S_A R S_C and ⟨S_A, rule⟩ →ₛ S_A', then S_C →*_C S_C' and S_A' R S_C', (c) backward simulation: if S_A R S_C and S_C →_C S_C', then S_A →*_A S_A' and S_A' R S_C', (d) failure preservation: if ⟨S_A, rule⟩ →f S_fail, then S_C →*_C S_C_fail and observe(S_fail) = observe(S_C_fail). Condition (d) ensures optimized runtimes preserve the failure taxonomy — a fused stage must report the correct PipelineFailureReason. MT_3 is OE_3 where R is the identity relation. Bisimulation is strictly weaker — it allows optimizations MT_3 forbids.",
      "op:lhs": "R is a Prism bisimulation between abstract and concrete state spaces",
      "op:rhs": "(a) S₀_A R S₀_C iff observe equal, (b) forward sim, (c) backward sim, (d) failure preservation",
      "op:forAll": "R: relation on PipelineState × ConcreteState",
      "op:verificationDomain": {
        "@id": "https://prism.uor.foundation/op/ObservationalEquivalence"
      },
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationPathNote": "Standard bisimulation from process algebra, extended with condition (d) for Prism failure taxonomy preservation. OE_3 is the correctness criterion for production implementations; MT_3 is the criterion for reference implementations."
    },
    {
      "@id": "https://prism.uor.foundation/op/OE_4a",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "rdfs:label": "OE_4a",
      "rdfs:comment": "Stage fusion soundness: fusing adjacent stages i and i+1 into a single macro-step is bisimilar to the two-step abstract execution. The fused guard is eval(guard_i, S) ∧ eval(guard_{i+1}, reduce(effect_i, S)) — the second guard evaluates against the post-first-effect state. The fused effect is reduce(effect_{i+1}, reduce(effect_i, S)) — sequential composition. Proof: the fused step produces observe-equal terminal state to two sequential TJ_1 applications because guard evaluation order and effect composition are preserved. The bisimulation R maps fused states to abstract post-second-stage states.",
      "op:lhs": "⟨S, fuse(rule_i, rule_{i+1})⟩ →ₛ S'",
      "op:rhs": "observe(S') = observe(reduce(effect_{i+1}, reduce(effect_i, S))) when both guards hold",
      "op:forAll": "rule_i, rule_{i+1}: adjacent PipelineTransitionRules, S: PipelineState",
      "op:verificationDomain": {
        "@id": "https://prism.uor.foundation/op/ObservationalEquivalence"
      },
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationPathNote": "Guard composition: conjunction of sequential guards. Effect composition: left fold. Failure: if guard_i fails → report rule_i.failureMode; if guard_{i+1} fails on post-effect state → report rule_{i+1}.failureMode."
    },
    {
      "@id": "https://prism.uor.foundation/op/OE_4b",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "rdfs:label": "OE_4b",
      "rdfs:comment": "Effect commutation soundness: two PropertyBind steps within the same TransitionEffect commute (may be reordered or parallelized) iff their target properties are disjoint: bindTargetProperty(e₁) ≠ bindTargetProperty(e₂). Proof: functional updates to disjoint properties commute — S[p₁ ← v₁][p₂ ← v₂] = S[p₂ ← v₂][p₁ ← v₁]. The bisimulation R is the identity on observe. This permits parallel execution of independent property bindings within a single transition's effect list.",
      "op:lhs": "reduce([..., e₁, e₂, ...], S) where bindTargetProperty(e₁) ≠ bindTargetProperty(e₂)",
      "op:rhs": "reduce([..., e₂, e₁, ...], S) (commuted order produces observe-equal state)",
      "op:forAll": "e₁, e₂: PropertyBind with disjoint bindTargetProperty, S: PipelineState",
      "op:verificationDomain": {
        "@id": "https://prism.uor.foundation/op/ObservationalEquivalence"
      },
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationPathNote": "Disjoint functional updates commute. Verified by inspection: effect_accumulating steps 1 and 2 (pipelineBudget vs accumulatedBinding) satisfy the disjointness condition."
    },
    {
      "@id": "https://prism.uor.foundation/op/OE_4c",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "rdfs:label": "OE_4c",
      "rdfs:comment": "Lease parallelism soundness: concurrent execution of complete pipelines on disjoint ContextLeases (PL_2: AND(mask_i, mask_j) = 0) is bisimilar to any sequential ordering. Proof: PL_2 guarantees the lease pipelines operate on disjoint fiber sub-domains. Disjoint sub-domain operations commute under κ composition (PK_1 + PK_2). The composed terminal state is observe-equal regardless of execution order or concurrency. The bisimulation R maps the concurrent interleaving to the sequential abstract trace.",
      "op:lhs": "κ(exec(S₀_lease_i) || exec(S₀_lease_j)) where PL_2 disjoint leases",
      "op:rhs": "κ(exec(S₀_lease_i), exec(S₀_lease_j)) sequential = observe-equal",
      "op:forAll": "lease_i, lease_j: ContextLease with disjoint leasedFibers",
      "op:verificationDomain": {
        "@id": "https://prism.uor.foundation/op/ObservationalEquivalence"
      },
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationPathNote": "PL_2 (fiber disjointness) + PK_1 (SR_8 tower consistency) + PK_2 (O(1) composed resolution) → concurrent execution is bisimilar to sequential."
    },
    {
      "@id": "https://prism.uor.foundation/op/CS_1",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "rdfs:label": "CS_1",
      "rdfs:comment": "Cost function: cost(exec(S₀)) = Σ fiberDelta(stepᵢ) for all ER_2 (PropertyBind) steps in the trace. Cost is measured in FiberTransitions — the count of fiber-state changes. PE_ evaluation has zero cost (read-only). ER_1 (StageAdvance) has zero cost (control flow only). Only ER_2 steps contribute cost, proportional to the fibers affected by the bound property. This defines the canonical work metric for pipeline execution.",
      "op:lhs": "cost(exec(S₀))",
      "op:rhs": "Σᵢ fiberDelta(stepᵢ) for all ER_2 steps in trace(exec(S₀))",
      "op:forAll": "S₀: PipelineState with currentStage = Initialization (E(0) = 1)",
      "op:verificationDomain": {
        "@id": "https://prism.uor.foundation/op/CostSemantics"
      },
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationPathNote": "FiberTransitions is the natural cost unit — it counts the atomic state changes in the ring. Aligns with the foundation's observable measurement units."
    },
    {
      "@id": "https://prism.uor.foundation/op/CS_2",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "rdfs:label": "CS_2",
      "rdfs:comment": "Fusion cost neutrality: cost(fused(rule_i, rule_{i+1})) = cost(rule_i) + cost(rule_{i+1}). Stage fusion (OE_4a) eliminates intermediate state materialization but does not change the fiber work. The same ER_2 steps execute in the same order — only the number of TJ_1 judgment applications is reduced (from 2 to 1). The performance benefit is in overhead reduction (fewer PipelineState snapshots), not in fiber-work reduction.",
      "op:lhs": "cost(fused(rule_i, rule_{i+1}))",
      "op:rhs": "cost(rule_i) + cost(rule_{i+1})",
      "op:forAll": "rule_i, rule_{i+1}: adjacent PipelineTransitionRules",
      "op:verificationDomain": {
        "@id": "https://prism.uor.foundation/op/CostSemantics"
      },
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationPathNote": "OE_4a preserves the ER_2 step set. Fusion is overhead reduction, not work reduction."
    },
    {
      "@id": "https://prism.uor.foundation/op/CS_3",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "rdfs:label": "CS_3",
      "rdfs:comment": "Parallel cost: cost_parallel(exec_lease₁ || ... || exec_leaseₖ) = max_i cost(exec_leaseᵢ). Under OE_4c lease parallelism, the wall-clock cost is the maximum cost of any single lease pipeline, not the sum. Total fiber work is conserved (Σ_i cost(lease_i) = cost(sequential)), but the critical path is the slowest lease.",
      "op:lhs": "cost_parallel(exec_lease₁ || ... || exec_leaseₖ)",
      "op:rhs": "max_i cost(exec_leaseᵢ)",
      "op:forAll": "k ContextLeases with disjoint leasedFibers (PL_2)",
      "op:verificationDomain": {
        "@id": "https://prism.uor.foundation/op/CostSemantics"
      },
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationPathNote": "PL_2 disjointness guarantees no contention. Work conservation follows from PL_1. The max arises because all leases execute concurrently and the parallel execution completes when the last lease completes."
    },
    {
      "@id": "https://prism.uor.foundation/op/CS_4",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "rdfs:label": "CS_4",
      "rdfs:comment": "Speedup bound: speedup(k, n) = cost_seq / cost_par. For k uniform leases on n fibers: speedup = k (perfect linear scaling). For non-uniform leases: 1 ≤ speedup ≤ k, with speedup = k iff all leases have equal cost. PK_3 gives per-lease work ≤ ⌈n/k⌉ for uniform partitions, so cost_par ≤ ⌈n/k⌉ and speedup ≥ k·cost_par/cost_seq = k for balanced loads.",
      "op:lhs": "speedup(k uniform leases, n fibers)",
      "op:rhs": "k for balanced loads; ∈ [1, k] for arbitrary loads",
      "op:forAll": "k: leaseCount, n: totalFibers, uniform partition via λ",
      "op:verificationDomain": {
        "@id": "https://prism.uor.foundation/op/CostSemantics"
      },
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationPathNote": "PK_3 (per-lease work bound) + PL_1 (conservation) → speedup. The bound is tight: k identical leases achieve exactly k× speedup."
    },
    {
      "@id": "https://prism.uor.foundation/op/CS_5",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "rdfs:label": "CS_5",
      "rdfs:comment": "Asymptotic preservation: every bisimilar optimization (OE_3) preserves the O(n) total fiber-work bound from PM_7. Formally: if exec_opt is bisimilar to exec, then cost(exec_opt) ∈ O(cost(exec)). The constant factor may differ (fusion removes per-transition overhead, parallelism reduces wall-clock time) but the asymptotic work class is preserved. No bisimilar optimization can increase the total fiber work beyond O(n).",
      "op:lhs": "cost(exec_opt(S₀)) for exec_opt bisimilar to exec (OE_3)",
      "op:rhs": "∈ O(cost(exec(S₀))) = O(n) per target",
      "op:forAll": "exec_opt: any bisimilar optimized execution, S₀: valid initial state",
      "op:verificationDomain": {
        "@id": "https://prism.uor.foundation/op/CostSemantics"
      },
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationPathNote": "OE_3 bisimulation preserves the observe-equal terminal state. CS_1 cost depends only on ER_2 steps. Bisimulation preserves the ER_2 step multiset (possibly reordered or parallelized). Therefore total work is preserved."
    },
    {
      "@id": "https://prism.uor.foundation/op/SF_1",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "rdfs:label": "SF_1",
      "rdfs:comment": "Finite activation: under any ExecutionPolicy, every Pending lease in a static partition (λ output) transitions to Active within k activation rounds, where k is the lease count. Formally: ∀ lease ∈ λ(C, k). ∃ t ≤ k. currentLeaseState(lease, t) = Active. In the Prism model, the lease set is fixed at partition time — no new leases arrive. All four ExecutionPolicyKind individuals (FifoPolicy, MinFreeCountFirst, MaxFreeCountFirst, DisjointFirst) produce a permutation of the k leases. No lease is omitted from any permutation.",
      "op:lhs": "∀ lease ∈ λ(C, k). ∃ t",
      "op:rhs": "t ≤ k ∧ currentLeaseState(lease, t) = Active",
      "op:forAll": "C: SharedContext, k: leaseCount, any ExecutionPolicy",
      "op:verificationDomain": {
        "@id": "https://prism.uor.foundation/op/SchedulerFairness"
      },
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationPathNote": "Static lease set (λ produces all k leases at once) + ExecutionPolicy produces a permutation → every lease activated in ≤ k rounds."
    },
    {
      "@id": "https://prism.uor.foundation/op/SF_2",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "rdfs:label": "SF_2",
      "rdfs:comment": "Policy ordering: the ExecutionPolicy determines activation order but not activation guarantee. FifoPolicy: partition index order. MinFreeCountFirst: ascending freeCount order (greedy — most constrained sub-domain first). MaxFreeCountFirst: descending freeCount order (broadest first). DisjointFirst: maximally non-adjacent fiber domains first (maximize parallelism). All four are total orderings over k leases — they differ in which lease activates first, not whether all leases activate.",
      "op:lhs": "order(policy, [lease₁, ..., leaseₖ])",
      "op:rhs": "permutation σ of [1..k] determined by policy kind",
      "op:forAll": "policy: ExecutionPolicy, k leases from λ(C, k)",
      "op:verificationDomain": {
        "@id": "https://prism.uor.foundation/op/SchedulerFairness"
      },
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationPathNote": "FifoPolicy: σ = identity. MinFreeCountFirst: σ sorts by ascending freeCount. MaxFreeCountFirst: σ sorts by descending freeCount. DisjointFirst: σ maximizes AND(mask_{σ(i)}, mask_{σ(i+1)}) = 0 for adjacent activations."
    },
    {
      "@id": "https://prism.uor.foundation/op/SF_3",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "rdfs:label": "SF_3",
      "rdfs:comment": "Progress: every Active lease either reaches Released (normal completion) or Expired (timeout). No lease remains Active indefinitely. Formally: ∀ lease. Active(lease) → ◇(Released(lease) ∨ Expired(lease)). Follows from PM_2 (resolver contract: bounded iterations) + PM_7 (bounded termination per target). Each Active lease executes a pipeline that terminates in bounded transitions, after which the lease is Released. Timeout (Expired) is the fallback if the pipeline stalls beyond a configured bound.",
      "op:lhs": "∀ lease. currentLeaseState(lease) = Active",
      "op:rhs": "→ ◇(currentLeaseState(lease) ∈ {Released, Expired})",
      "op:forAll": "lease: ManagedLease with currentLeaseState = Active",
      "op:verificationDomain": {
        "@id": "https://prism.uor.foundation/op/SchedulerFairness"
      },
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationPathNote": "PM_2 (contract compliance: resolver terminates) + PM_7 (machine completeness: pipeline terminates) → lease pipeline terminates → lease Released. Expired is the timeout fallback."
    },
    {
      "@id": "https://prism.uor.foundation/op/EA_1",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "rdfs:label": "EA_1",
      "rdfs:comment": "Epoch isolation: queries deferred during epoch i do not affect epoch i's execution. The DeferredQuerySet is append-only during execution — not read by the resolver, not visible to the pipeline, not factored into the fiber budget. Epoch i's leases operate on a frozen context. Formally: ∀ q deferred during epoch i. q ∉ inputs(exec(epoch_i)). This guarantees that the static lease model (SF_1–SF_3, PL_1–PL_3, PM_7) holds within each epoch without modification.",
      "op:lhs": "∀ q deferred during epoch i. q ∈ DeferredQuerySet(i)",
      "op:rhs": "q ∉ inputs(exec(epoch_i))",
      "op:forAll": "q: Query arriving during epoch i, epoch_i: Epoch",
      "op:verificationDomain": {
        "@id": "https://prism.uor.foundation/op/EpochalAdmission"
      },
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationPathNote": "The DeferredQuerySet is write-only during the epoch. The epoch's resolver and pipeline never read it."
    },
    {
      "@id": "https://prism.uor.foundation/op/EA_2",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "rdfs:label": "EA_2",
      "rdfs:comment": "Deferred completeness (conditional): every query deferred during epoch i is admitted in epoch i+1 when the deferred set fits within the epoch's angularCapacity (original single-epoch guarantee). When the deferred set exceeds capacity, the PhaseRotationScheduler determines which queries proceed and which spill. Accumulated phase credit ensures every query is admitted within a bounded number K of epochs (AP_2). The maximum deferral is min(1, K) depending on angular capacity.",
      "op:lhs": "admittedEpoch(DeferredQuerySet(i))",
      "op:rhs": "epochIndex(i) + 1",
      "op:forAll": "DeferredQuerySet accumulated during epoch i",
      "op:verificationDomain": {
        "@id": "https://prism.uor.foundation/op/EpochalAdmission"
      },
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationPathNote": "Single-epoch deferral. No query waits more than one epoch. The EpochBoundary drains the entire deferred set."
    },
    {
      "@id": "https://prism.uor.foundation/op/EA_3",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "rdfs:label": "EA_3",
      "rdfs:comment": "Epoch composition: sequential epochs compose via context accumulation. epochContext(i+1) = epochResult(i). The context monotonically accumulates across epoch boundaries — SR_1 holds across the boundary (freeCount never increases). Each epoch's contribution is additive. The EpochBoundary's carriedContext is the vehicle for this handoff.",
      "op:lhs": "epochContext(epoch_{i+1})",
      "op:rhs": "epochResult(epoch_i)",
      "op:forAll": "epoch_i, epoch_{i+1}: consecutive Epochs connected by EpochBoundary",
      "op:verificationDomain": {
        "@id": "https://prism.uor.foundation/op/EpochalAdmission"
      },
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationPathNote": "PA_1 (accumulation associativity) + SR_1 (monotonicity) → context accumulation across epochs is well-defined and monotone."
    },
    {
      "@id": "https://prism.uor.foundation/op/EA_4",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "rdfs:label": "EA_4",
      "rdfs:comment": "Epoch termination: each epoch terminates in bounded time (PM_7 applies per epoch). The system makes progress toward global saturation across epochs. If the total constraint set across all deferred query sets is finite and sufficient (CB_5), the system reaches σ = 1 in a finite number of epochs. Formally: ∃ N. epochResult(epoch_N).σ = 1 when ∪_i constraints(DeferredQuerySet(i)) satisfies CB_5.",
      "op:lhs": "each epoch_i terminates",
      "op:rhs": "in ≤ PM_7 transitions; ∃ N. σ(epochResult(epoch_N)) = 1 if globally sufficient",
      "op:forAll": "epoch_i: Epoch, global constraint set satisfying CB_5",
      "op:verificationDomain": {
        "@id": "https://prism.uor.foundation/op/EpochalAdmission"
      },
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationPathNote": "PM_7 bounds per-epoch termination. Cross-epoch convergence follows from SR_1 monotonicity + CB_5 sufficiency of the aggregate constraint set."
    },
    {
      "@id": "https://prism.uor.foundation/op/LS_1",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "rdfs:label": "LS_1",
      "rdfs:comment": "Checkpoint fidelity: pinnedFibers(checkpoint) = pinnedFibers(lease_at_suspension). The checkpoint preserves all accumulated bindings — no pinned fiber is lost at suspension. The checkpoint plus the original lease configuration is sufficient for bit-exact resumption. Only unpinned fibers (freeCount fibers) are released back to the SharedContext.",
      "op:lhs": "pinnedFibers(LeaseCheckpoint(lease))",
      "op:rhs": "pinnedFibers(lease) at moment of suspension",
      "op:forAll": "lease: ManagedLease transitioning Active → Suspended",
      "op:verificationDomain": {
        "@id": "https://prism.uor.foundation/op/LeaseSuspension"
      },
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationPathNote": "SR_1 monotonicity: pinned fibers are irreversible. The checkpoint captures the irreversible progress. Only reversible state (unpinned fibers) is released."
    },
    {
      "@id": "https://prism.uor.foundation/op/LS_2",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "rdfs:label": "LS_2",
      "rdfs:comment": "Suspension monotonicity: pinnedCount(resumed_state) ≥ pinnedCount(checkpoint). Resuming from a checkpoint enters a state with at least as many pinned fibers as the checkpoint, because pinned fibers are preserved and the context may have gained additional pins from other leases' work during the suspension period. Progress is monotone across suspension boundaries.",
      "op:lhs": "pinnedCount(resume(checkpoint, context_current))",
      "op:rhs": "≥ pinnedCount(checkpoint)",
      "op:forAll": "checkpoint: LeaseCheckpoint, context_current: Context at resume time",
      "op:verificationDomain": {
        "@id": "https://prism.uor.foundation/op/LeaseSuspension"
      },
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationPathNote": "SR_1 monotonicity holds across the suspension gap. The resumed context is a superset of the checkpointed context (PA_1 additional bindings from other leases)."
    },
    {
      "@id": "https://prism.uor.foundation/op/LS_3",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "rdfs:label": "LS_3",
      "rdfs:comment": "Repartition disjointness: after a SubleaseTransfer, all Active leases (including any new lease receiving transferred fibers) satisfy PL_2. The transfer only moves fibers that were unpinned in the suspended lease and unclaimed by any Active lease. Formally: ∀ active_i, active_j post-transfer. AND(mask_i, mask_j) = 0. The postTransferDisjointnessVerified flag must be true for the transfer to be legal.",
      "op:lhs": "∀ active_i, active_j after SubleaseTransfer",
      "op:rhs": "AND(leasedFibers_i, leasedFibers_j) = 0",
      "op:forAll": "SubleaseTransfer with postTransferDisjointnessVerified = true",
      "op:verificationDomain": {
        "@id": "https://prism.uor.foundation/op/LeaseSuspension"
      },
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationPathNote": "PL_2 is preserved because: (a) transferred fibers were unpinned in the suspended lease, (b) unpinned fibers are disjoint from all Active leases' claimed regions, (c) the target lease receives only these unclaimed fibers."
    },
    {
      "@id": "https://prism.uor.foundation/op/LS_4",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "rdfs:label": "LS_4",
      "rdfs:comment": "Resume equivalence: resuming a suspended lease from its checkpoint, on the same fiber sub-domain, produces an execution bisimilar (OE_3) to the counterfactual where the lease was never suspended. The resumed pipeline continues from the checkpointed PipelineState, evaluating the same guards, applying the same effects, on the same or superset of pinned fibers. The terminal state is observe-equal (OE_2). The bisimulation witness is the checkpoint itself — it maps the resumed state to the abstract unsuspended state.",
      "op:lhs": "observe(exec(resume(checkpoint)))",
      "op:rhs": "observe(exec(counterfactual_unsuspended))",
      "op:forAll": "checkpoint: LeaseCheckpoint, resume on same fiber sub-domain",
      "op:verificationDomain": {
        "@id": "https://prism.uor.foundation/op/LeaseSuspension"
      },
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationPathNote": "OE_3 bisimulation where R maps resumed states to abstract states via the checkpoint. LS_1 (fidelity) + LS_2 (monotonicity) → the resumed execution has at least as much information as the unsuspended execution."
    },
    {
      "@id": "https://prism.uor.foundation/op/AP_1",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "rdfs:label": "AP_1",
      "rdfs:comment": "Phase-rotation scheduling: the PhaseRotationScheduler produces a total ordering over the DeferredQuerySet by ascending (estimatedPhaseCost − accumulatedPhaseCredit). The first m queries (where m is determined by angularCapacity) enter the epoch. The remaining queries form the next epoch's deferred set with incremented accumulatedPhaseCredit.",
      "op:lhs": "order(PhaseRotationScheduler, DeferredQuerySet)",
      "op:rhs": "total ordering; first m queries admitted within angularCapacity, rest spilled with accumulatedPhaseCredit += 30°",
      "op:forAll": "PhaseRotationScheduler, DeferredQuerySet from preceding epoch",
      "op:verificationDomain": {
        "@id": "https://prism.uor.foundation/cascade/PhaseSchedulingDomain"
      },
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationPathNote": "Parallel to SF_2 (ExecutionPolicy ordering over leases). Each policy kind produces a permutation — no query is dropped, only reordered."
    },
    {
      "@id": "https://prism.uor.foundation/op/AP_2",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "rdfs:label": "AP_2",
      "rdfs:comment": "Bounded deferral: under the PhaseRotationScheduler, every query is admitted within K epochs, where K depends on the maximum arrival rate and angular capacity. Formally: ∃ K. ∀ q. admittedEpoch(q) ≤ arrivalEpoch(q) + K. The bound holds because accumulatedPhaseCredit increments by 30° each epoch, and after K epochs the query's effective priority (estimatedPhaseCost − accumulatedPhaseCredit) is lower than any fresh arrival's phase cost. This is the starvation-freedom guarantee, derived from the D_{2n} reflection symmetry.",
      "op:lhs": "∀ q under PhaseRotationScheduler. admittedEpoch(q)",
      "op:rhs": "≤ arrivalEpoch(q) + K, where K = maxPriority + 1",
      "op:forAll": "q: Query deferred under PhaseRotationScheduler",
      "op:verificationDomain": {
        "@id": "https://prism.uor.foundation/cascade/PhaseSchedulingDomain"
      },
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationPathNote": "After K epochs, effective priority = estimatedPhaseCost − K×30° < 0 < any fresh arrival's phase cost. The query must be admitted. K = ceil(maxPhaseCost / 30°) + 1 suffices."
    },
    {
      "@id": "https://prism.uor.foundation/op/AP_3",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "rdfs:label": "AP_3",
      "rdfs:comment": "Angular capacity: each epoch has angularCapacity = totalFibers × 30°. Queries whose cumulative estimatedPhaseCost exceeds this capacity are deferred. The capacity is computed at the EpochBoundary from the epochContext's freeCount and the deferred set's average estimatedPhaseCost. This bounds the per-epoch workload to what the partition can absorb.",
      "op:lhs": "angularCapacity(epoch)",
      "op:rhs": "epochContext.freeCount × 30° / avg(estimatedPhaseCost(deferredQueries))",
      "op:forAll": "epoch: Epoch at EpochBoundary",
      "op:verificationDomain": {
        "@id": "https://prism.uor.foundation/cascade/PhaseSchedulingDomain"
      },
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationPathNote": "Conservative estimate: actual capacity may be higher if queries share fiber domains. The bound ensures the epoch can converge (PM_7) for all admitted queries."
    },
    {
      "@id": "https://prism.uor.foundation/op/SW_1",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "rdfs:label": "SW_1",
      "rdfs:comment": "Rolling service guarantee: for a ServiceWindow of size w, every query arriving in epoch i is resolved to at least minResolutionQuality (σ ≥ threshold) by epoch i + maxQueryLatency. The system may not reach global σ = 1, but every individual query achieves its service target within the latency bound. Formally: ∀ q arriving in epoch i. σ(resolve(q)) ≥ minResolutionQuality ∧ completionEpoch(q) ≤ i + maxQueryLatency.",
      "op:lhs": "∀ q arriving in epoch i within ServiceWindow",
      "op:rhs": "σ(resolve(q)) ≥ minResolutionQuality ∧ completionEpoch(q) ≤ i + maxQueryLatency",
      "op:forAll": "q: Query, ServiceWindow with windowSize w, arrival rate ≤ epoch throughput (SW_4)",
      "op:verificationDomain": {
        "@id": "https://prism.uor.foundation/op/ServiceWindowDomain"
      },
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationPathNote": "Per-query guarantee replaces global saturation (EA_4) for open-ended streams. EA_4 is the special case where the stream is finite and minResolutionQuality = 1.0."
    },
    {
      "@id": "https://prism.uor.foundation/op/SW_2",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "rdfs:label": "SW_2",
      "rdfs:comment": "Window monotonicity: the average resolution quality within the ServiceWindow is non-decreasing over time, provided the arrival rate does not exceed epoch throughput capacity. Each epoch's contribution to the window either maintains or improves the rolling average (because each epoch makes monotone progress via SR_1). If arrival rate exceeds capacity, the average may decrease — triggering SW_3.",
      "op:lhs": "currentWindowQuality(epoch_{i+1}) when arrivalRate ≤ throughputCapacity",
      "op:rhs": "≥ currentWindowQuality(epoch_i)",
      "op:forAll": "consecutive epochs within the ServiceWindow, arrival rate ≤ capacity",
      "op:verificationDomain": {
        "@id": "https://prism.uor.foundation/op/ServiceWindowDomain"
      },
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationPathNote": "SR_1 monotonicity per query + angular capacity (AP_3) → per-epoch quality is non-decreasing. Window average inherits the property."
    },
    {
      "@id": "https://prism.uor.foundation/op/SW_3",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "rdfs:label": "SW_3",
      "rdfs:comment": "Back-pressure signal: when currentWindowQuality < minResolutionQuality, the system emits a BackPressureSignal carrying the current quality, the shortfall (minResolutionQuality - currentWindowQuality), and the recommended arrival rate reduction. This is the feedback mechanism for open-ended streams. The signal does not halt execution — it advises upstream producers to reduce query rate.",
      "op:lhs": "currentWindowQuality < minResolutionQuality",
      "op:rhs": "emit BackPressureSignal(currentQuality, shortfall, recommendedRateReduction)",
      "op:forAll": "ServiceWindow where currentWindowQuality drops below threshold",
      "op:verificationDomain": {
        "@id": "https://prism.uor.foundation/op/ServiceWindowDomain"
      },
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationPathNote": "recommendedRateReduction = shortfall / currentWindowQuality (proportional to the violation magnitude). The signal is advisory — enforcement is upstream's responsibility."
    },
    {
      "@id": "https://prism.uor.foundation/op/SW_4",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "rdfs:label": "SW_4",
      "rdfs:comment": "Steady-state theorem: under constant arrival rate r and epoch throughput capacity c, if r ≤ c then the ServiceWindow guarantee holds indefinitely: □(currentWindowQuality ≥ minResolutionQuality). If r > c, back-pressure fires (SW_3) and the guarantee is violated until r drops below c. EA_4 (global saturation for finite streams) is the special case where r eventually = 0 and minResolutionQuality = 1.0.",
      "op:lhs": "r ≤ c (arrival rate ≤ epoch throughput capacity)",
      "op:rhs": "□(currentWindowQuality ≥ minResolutionQuality)",
      "op:forAll": "PrismInstance with ServiceWindow, constant arrival rate r, throughput c",
      "op:verificationDomain": {
        "@id": "https://prism.uor.foundation/op/ServiceWindowDomain"
      },
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationPathNote": "PM_7 bounds per-epoch work. AP_3 bounds per-epoch angular capacity. CS_1 defines cost. When cost/epoch ≤ capacity/epoch, the window quality stabilizes."
    },
    {
      "@id": "https://prism.uor.foundation/proof/prf_PX_1",
