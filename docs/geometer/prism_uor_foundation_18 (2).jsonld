    {
      "@id": "https://prism.uor.foundation/op/rule_initialization",
      "@type": [
        "owl:NamedIndividual",
        "https://prism.uor.foundation/op/PipelineTransitionRule"
      ],
      "rdfs:label": "rule_initialization",
      "rdfs:comment": "Transition rule: E(0) Initialization → E(1) Declare. Operator: δ (dispatch). Phase gate: state vector = 1 (0°). Failure: DispatchMiss. The first phase rotation applies Ω, advancing the state vector from 1 to e^(iπ/6).",
      "pop:ruleSourceStage": {
        "@id": "https://prism.uor.foundation/op/Initialization"
      },
      "pop:ruleOperator": {
        "@id": "https://prism.uor.foundation/op/dispatch"
