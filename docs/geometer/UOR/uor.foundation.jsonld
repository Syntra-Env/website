      "op:rhs": "freeCount(C) = 0 ↔ S(C) = 0 ↔ T_ctx(C) = 0",
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Thermodynamic"
      },
      "op:verificationPathNote": "SC_2 + TH_1 + SC_1 → four equivalent ground-state conditions",
      "rdfs:comment": "Ground state equivalence: σ(C) = 1 ↔ freeCount(C) = 0 ↔ S(C) = 0 ↔ T_ctx(C) = 0.",
      "rdfs:label": "SC_4"
    },
    {
      "@id": "https://uor.foundation/op/SC_5",
