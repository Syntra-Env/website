      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Topological"
      },
      "op:verificationPathNote": "ψ-pipeline → ChainComplex → quantum-level-agnostic",
      "rdfs:comment": "The ψ-pipeline produces a valid ChainComplex for any ConstrainedType at any quantum level n ≥ 1.",
      "rdfs:label": "QL_7"
    },
    {
      "@id": "https://uor.foundation/op/SR_1",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "i in Session S",
      "op:lhs": "freeCount(B_{i+1})",
      "op:rhs": "≤ freeCount(B_i)",
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Algebraic"
      },
      "op:verificationPathNote": "BindingAccumulator → monotone freeCount → Session invariant",
      "rdfs:comment": "Binding monotonicity: freeCount(B_{i+1}) ≤ freeCount(B_i) for all i in a Session.",
      "rdfs:label": "SR_1"
    },
    {
      "@id": "https://uor.foundation/op/SR_2",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "b: Binding",
      "op:lhs": "b.datum resolves under b.constraint",
      "op:rhs": "in O(1) iff Binding b is sound",
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Pipeline"
      },
      "op:verificationPathNote": "Binding → constraint resolution → O(1) soundness",
      "rdfs:comment": "Binding soundness: a Binding b is sound iff b.datum resolves under b.constraint in O(1).",
      "rdfs:label": "SR_2"
    },
    {
      "@id": "https://uor.foundation/op/SR_3",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "Session S",
      "op:lhs": "∃ i: freeCount(B_i) = 0",
      "op:rhs": "Session S converges",
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Algebraic"
      },
      "op:verificationPathNote": "BindingAccumulator → zero freeCount → convergence",
      "rdfs:comment": "Session convergence: a Session S converges iff there exists i such that freeCount(B_i) = 0.",
      "rdfs:label": "SR_3"
    },
    {
      "@id": "https://uor.foundation/op/SR_4",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "C_prior, C_fresh: Context, SessionBoundary event",
      "op:lhs": "bindings(C_fresh) ∩ bindings(C_prior)",
      "op:rhs": "= ∅ after SessionBoundary",
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Algebraic"
      },
      "op:verificationPathNote": "SessionBoundary → priorContext/freshContext isolation",
      "rdfs:comment": "Context reset isolation: bindings in C_fresh are independent of bindings in C_prior after a SessionBoundary.",
      "rdfs:label": "SR_4"
    },
    {
      "@id": "https://uor.foundation/op/SR_5",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
