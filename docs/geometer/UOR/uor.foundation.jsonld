      },
      "op:verificationPathNote": "TS_7 formalisation → constraint nerve always connected",
      "rdfs:comment": "Connectivity lower bound: β₀(N(C)) ≥ 1 for all non-empty C.",
      "rdfs:label": "MS_1"
    },
    {
      "@id": "https://uor.foundation/op/MS_2",
