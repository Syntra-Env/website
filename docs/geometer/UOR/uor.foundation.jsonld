      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Algebraic"
      },
      "op:verificationPathNote": "Binding contradiction → SessionBoundary → ContradictionBoundary",
      "rdfs:comment": "Contradiction detection: ContradictionBoundary fires iff there exist bindings b, b' with the same address, different datum, under the same constraint.",
      "rdfs:label": "SR_5"
    },
    {
      "@id": "https://uor.foundation/op/TS_1",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "target: χ* ≤ n, β₀* = 1, β_k* = 0 for k ≥ 1",
      "op:lhs": "nerve(T, target)",
      "op:rhs": "∃ ConstrainedType T over R_n realising target",
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Pipeline"
      },
      "op:verificationPathNote": "TypeSynthesisResolver → ConstraintNerve → target signature",
      "rdfs:comment": "Nerve realisability: for any target (χ*, β₀* = 1, β_k* = 0 for k ≥ 1) with χ* ≤ n, there exists a ConstrainedType T over R_n whose constraint nerve realises the target.",
      "rdfs:label": "TS_1"
    },
    {
      "@id": "https://uor.foundation/op/TS_2",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "IT_7d target, n-fiber types",
      "op:lhs": "basisSize(T, IT_7d target)",
      "op:rhs": "n",
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Pipeline"
      },
      "op:verificationPathNote": "MinimalConstraintBasis → basisSize = n for IT_7d",
      "rdfs:comment": "Minimal basis bound: for the IT_7d target (χ* = n, all β* = 0), the MinimalConstraintBasis has size exactly n (one constraint per fiber position). No redundant constraints exist in the minimal basis.",
      "rdfs:label": "TS_2"
    },
    {
      "@id": "https://uor.foundation/op/TS_3",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "C: synthesis candidate constraint set",
      "op:lhs": "χ(N(C + constraint))",
      "op:rhs": "≥ χ(N(C))",
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Pipeline"
      },
      "op:verificationPathNote": "ConstraintNerve monotonicity under constraint addition",
      "rdfs:comment": "Synthesis monotonicity: adding a constraint to a synthesis candidate never decreases the Euler characteristic of the resulting nerve (χ is monotone non-decreasing under constraint addition).",
      "rdfs:label": "TS_3"
    },
    {
      "@id": "https://uor.foundation/op/TS_4",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "target: realisable n-fiber type synthesis goal",
      "op:lhs": "steps(TypeSynthesisResolver, target)",
      "op:rhs": "≤ n",
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Pipeline"
      },
      "op:verificationPathNote": "TypeSynthesisResolver terminates in ≤ n SynthesisStep additions",
      "rdfs:comment": "Synthesis convergence: the TypeSynthesisResolver terminates for any realisable target in at most n constraint additions (for n-fiber types).",
      "rdfs:label": "TS_4"
    },
    {
      "@id": "https://uor.foundation/op/TS_5",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "T: SynthesizedType",
      "op:lhs": "SynthesizedType achieves IT_7d",
      "op:rhs": "iff CompletenessResolver certifies CompleteType",
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Pipeline"
      },
      "op:verificationPathNote": "TypeSynthesisResolver ↔ CompletenessResolver duality",
      "rdfs:comment": "Synthesis–certification duality: a SynthesizedType T achieves the IT_7d target if and only if the CompletenessResolver certifies T as a CompleteType. The forward ψ-pipeline and the inverse TypeSynthesisResolver are dual computations.",
      "rdfs:label": "TS_5"
    },
    {
      "@id": "https://uor.foundation/op/TS_6",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "T: n-fiber type synthesis goal",
      "op:lhs": "E[steps, Jacobian-guided synthesis]",
      "op:rhs": "O(n log n) vs O(n²) uninformed",
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Pipeline"
      },
      "op:verificationPathNote": "Jacobian DC_10 → guided ConstraintSearchState exploration",
      "rdfs:comment": "Jacobian-guided synthesis efficiency: using the Jacobian (DC_10) to select the next constraint reduces the expected number of synthesis steps from O(n²) (uninformed) to O(n log n) (Jacobian-guided).",
      "rdfs:label": "TS_6"
    },
    {
      "@id": "https://uor.foundation/op/TS_7",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "C: non-empty constraint set",
      "op:lhs": "β₀(N(C)) for non-empty C",
      "op:rhs": "≥ 1",
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Pipeline"
      },
      "op:verificationPathNote": "non-empty ConstraintNerve → β₀ ≥ 1 (connected)",
      "rdfs:comment": "Unreachable signatures: a Betti profile with β₀ = 0 is unreachable by any non-empty ConstrainedType — the nerve of a non-empty constraint set is always connected (β₀ ≥ 1).",
      "rdfs:label": "TS_7"
    },
    {
      "@id": "https://uor.foundation/op/QLS_1",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "T: CompleteType at Q_n, T': QuantumLift to Q_{n+1}",
      "op:lhs": "QuantumLift T' is CompleteType",
      "op:rhs": "iff spectral sequence collapses at E_2",
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/IndexTheoretic"
      },
      "op:verificationPathNote": "SpectralSequencePage convergedAt = 2 → trivial LiftObstruction",
      "rdfs:comment": "Lift unobstructedness criterion: QuantumLift T' is a CompleteType iff the spectral sequence E_r^{p,q} collapses at E_2 (d_2 = 0 and all higher differentials zero).",
      "rdfs:label": "QLS_1"
    },
    {
      "@id": "https://uor.foundation/op/QLS_2",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "non-trivial LiftObstruction",
      "op:lhs": "non-trivial LiftObstruction location",
      "op:rhs": "specific fiber at bit position n+1",
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/IndexTheoretic"
      },
      "op:verificationPathNote": "LiftObstructionClass → obstructionFiber at Q_{n+1} position",
      "rdfs:comment": "Obstruction localisation: a non-trivial LiftObstruction is localised to a specific fiber at bit position n+1. The obstruction class lives in H²(N(C(T))) and is killed by adding one constraint involving the new fiber.",
      "rdfs:label": "QLS_2"
    },
    {
      "@id": "https://uor.foundation/op/QLS_3",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "T: CompleteType at Q_n with closed constraint set",
      "op:lhs": "basisSize(T') for trivial lift",
      "op:rhs": "basisSize(T) + 1",
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/IndexTheoretic"
      },
      "op:verificationPathNote": "obstructionTrivial = true → basisSize increases by exactly 1",
      "rdfs:comment": "Monotone lifting for trivially obstructed types: if T is a CompleteType at Q_n and its constraint set is closed under the Q_{n+1} extension map, then T' is a CompleteType at Q_{n+1} with basisSize(T') = basisSize(T) + 1.",
      "rdfs:label": "QLS_3"
    },
    {
      "@id": "https://uor.foundation/op/QLS_4",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "depth-d constraint configuration",
      "op:lhs": "spectral sequence convergence page",
      "op:rhs": "≤ E_{d+2}",
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/IndexTheoretic"
      },
      "op:verificationPathNote": "SpectralSequencePage convergedAt ≤ homological depth + 2",
      "rdfs:comment": "Spectral sequence convergence bound: for constraint configurations of homological depth d (H_k(N(C(T))) = 0 for k > d), the spectral sequence converges by page E_{d+2}.",
      "rdfs:label": "QLS_4"
    },
    {
      "@id": "https://uor.foundation/op/QLS_5",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "every op:universallyValid identity, QuantumLift T'",
      "op:lhs": "universallyValid identity in R_{n+1}",
      "op:rhs": "holds with lifted constraint set",
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/IndexTheoretic"
      },
      "op:verificationPathNote": "universallyValid identities preserved under QuantumLift extension",
      "rdfs:comment": "Universal identity preservation: every op:universallyValid identity holds in ℤ/(2^{n+1})ℤ with the lifted constraint set. The lift does not invalidate any certified universal identity.",
      "rdfs:label": "QLS_5"
    },
    {
      "@id": "https://uor.foundation/op/QLS_6",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "T': any QuantumLift of a CompleteType T",
      "op:lhs": "ψ-pipeline ChainComplex(T')",
      "op:rhs": "valid and restricts to ChainComplex(T) on base nerve",
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/IndexTheoretic"
      },
      "op:verificationPathNote": "ψ-pipeline → valid ChainComplex for any QuantumLift",
      "rdfs:comment": "ψ-pipeline universality for quantum lifts: the ψ-pipeline produces a valid ChainComplex for any QuantumLift T' — the chain complex of T' restricts to the chain complex of T on the base nerve, and the extension is well-formed by construction.",
      "rdfs:label": "QLS_6"
    },
    {
      "@id": "https://uor.foundation/op/MN_1",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "T: ConstrainedType over R_n",
      "op:lhs": "HolonomyGroup(T)",
      "op:rhs": "≤ D_{2^n}",
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Topological"
      },
      "op:verificationPathNote": "HolonomyGroup subgroup containment in D_{2^n}",
      "rdfs:comment": "Holonomy group containment: HolonomyGroup(T) ≤ D_{2^n} for all ConstrainedTypes T over R_n. The holonomy group is always a subgroup of the full dihedral group.",
      "rdfs:label": "MN_1"
    },
    {
      "@id": "https://uor.foundation/op/MN_2",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "T: all ResidueConstraint or DepthConstraint",
      "op:lhs": "HolonomyGroup(T) for additive constraints",
      "op:rhs": "{id} (trivial: T is FlatType)",
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Topological"
      },
      "op:verificationPathNote": "additive constraints → trivial monodromy → FlatType",
      "rdfs:comment": "Additive flatness (extends OB_H1): if all constraints in T are additive (ResidueConstraint or DepthConstraint type), then HolonomyGroup(T) = {id} — T is a FlatType.",
      "rdfs:label": "MN_2"
    },
    {
      "@id": "https://uor.foundation/op/MN_3",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "T: ConstrainedType with neg-related and bnot-related constraints in closed path",
      "op:lhs": "HolonomyGroup(T) with neg + bnot in closed path",
      "op:rhs": "D_{2^n} (full dihedral holonomy)",
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Topological"
      },
      "op:verificationPathNote": "neg + bnot generators in ClosedConstraintPath → full D_{2^n}",
      "rdfs:comment": "Dihedral generation: if T contains both a neg-related and a bnot-related constraint in a common closed path, then HolonomyGroup(T) = D_{2^n} — T has full dihedral holonomy.",
      "rdfs:label": "MN_3"
    },
    {
      "@id": "https://uor.foundation/op/MN_4",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "T: ConstrainedType",
      "op:lhs": "HolonomyGroup(T) ≠ {id}",
      "op:rhs": "⟹ β₁(N(C(T))) ≥ 1",
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Topological"
      },
      "op:verificationPathNote": "non-trivial HolonomyGroup → β₁ ≥ 1 in ConstraintNerve",
      "rdfs:comment": "Holonomy-Betti implication: HolonomyGroup(T) ≠ {id} ⟹ β₁(N(C(T))) ≥ 1. Non-trivial monodromy requires a topological loop. (Converse is false: β₁ ≥ 1 does not imply non-trivial holonomy.)",
      "rdfs:label": "MN_4"
    },
    {
      "@id": "https://uor.foundation/op/MN_5",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "T: CompleteType",
      "op:lhs": "CompleteType (IT_7d) ⟹ β₁ = 0 ⟹ holonomy",
      "op:rhs": "trivial ⟹ FlatType",
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Topological"
      },
      "op:verificationPathNote": "IT_7d → β₁ = 0 → trivial HolonomyGroup → FlatType",
      "rdfs:comment": "CompleteType holonomy: a CompleteType (IT_7d: χ = n, all β = 0) has trivial holonomy. IT_7d implies FlatType because IT_7d requires β₁ = 0, which by MN_4 implies trivial monodromy.",
      "rdfs:label": "MN_5"
    },
    {
      "@id": "https://uor.foundation/op/MN_6",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "p₁, p₂: ClosedConstraintPath",
      "op:lhs": "monodromy(p₁ · p₂)",
      "op:rhs": "monodromy(p₁) · monodromy(p₂) in D_{2^n}",
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Topological"
      },
      "op:verificationPathNote": "Monodromy composition homomorphism: π₁ → D_{2^n}",
      "rdfs:comment": "Monodromy composition: if p₁ and p₂ are closed constraint paths, then monodromy(p₁ · p₂) = monodromy(p₁) · monodromy(p₂) in D_{2^n} (group homomorphism from loops to dihedral elements).",
      "rdfs:label": "MN_6"
    },
    {
      "@id": "https://uor.foundation/op/MN_7",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "T': any QuantumLift of TwistedType T",
