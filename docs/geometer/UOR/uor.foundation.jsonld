{
  "@context": {
    "cert": "https://uor.foundation/cert/",
    "cohomology": "https://uor.foundation/cohomology/",
    "derivation": "https://uor.foundation/derivation/",
    "homology": "https://uor.foundation/homology/",
    "morphism": "https://uor.foundation/morphism/",
    "observable": "https://uor.foundation/observable/",
    "op": "https://uor.foundation/op/",
    "owl": "http://www.w3.org/2002/07/owl#",
    "partition": "https://uor.foundation/partition/",
    "proof": "https://uor.foundation/proof/",
    "query": "https://uor.foundation/query/",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "resolver": "https://uor.foundation/resolver/",
    "schema": "https://uor.foundation/schema/",
    "sh": "http://www.w3.org/ns/shacl#",
    "state": "https://uor.foundation/state/",
    "trace": "https://uor.foundation/trace/",
    "type": "https://uor.foundation/type/",
    "u": "https://uor.foundation/u/",
    "uor": "https://uor.foundation/",
    "xsd": "http://www.w3.org/2001/XMLSchema#"
  },
  "@graph": [
    {
      "@id": "https://uor.foundation/",
      "@type": "owl:Ontology",
      "owl:versionInfo": "6.3.0",
      "rdfs:comment": "Universal Object Reference Foundation Ontology — the complete vocabulary for the UOR kernel, type system, resolution pipeline, and state model.",
      "rdfs:label": "UOR Foundation"
    },
    {
      "@id": "https://uor.foundation/space",
      "@type": "owl:AnnotationProperty",
      "rdfs:comment": "Whether this module belongs to kernel-space (immutable, compiled), user-space (parameterizable, runtime), or bridge (kernel-computed, user-consumed). Values: 'kernel', 'user', 'bridge'.",
      "rdfs:label": "space",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#string"
      }
    },
    {
      "@id": "https://uor.foundation/u/",
      "@type": "owl:Ontology",
      "rdfs:comment": "Content-addressable identifiers represented as Braille strings. Each address is a sequence of Braille glyphs encoding a unique content-derived identifier.",
      "rdfs:label": "UOR Content Addressing",
      "uor:space": "kernel"
    },
    {
      "@id": "https://uor.foundation/u/Address",
      "@type": "owl:Class",
      "rdfs:comment": "A content-addressable identifier represented as a Braille string. Each Address uniquely identifies a piece of content via its Braille-encoded hash.",
      "rdfs:label": "Address",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/u/Glyph",
      "@type": "owl:Class",
      "rdfs:comment": "A single Braille cell encoding 6 bits of an address. The bijection between Braille cells and 6-bit values is the foundational encoding of the UOR content-addressing scheme.",
      "rdfs:label": "Glyph",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/u/glyph",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The Braille string representation of an address. Each character in the string is a Braille glyph (cell).",
      "rdfs:domain": {
        "@id": "https://uor.foundation/u/Address"
      },
      "rdfs:label": "glyph",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#string"
      }
    },
    {
      "@id": "https://uor.foundation/u/codepoint",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The Unicode codepoint of a Braille glyph. Braille glyphs occupy the range U+2800–U+28FF.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/u/Glyph"
      },
      "rdfs:label": "codepoint",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#nonNegativeInteger"
      }
    },
    {
      "@id": "https://uor.foundation/u/byteValue",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The 6-bit integer value (0–63) encoded by this Braille glyph. The bijection maps each of the 64 Braille patterns to a unique 6-bit value.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/u/Glyph"
      },
      "rdfs:label": "byteValue",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#nonNegativeInteger"
      }
    },
    {
      "@id": "https://uor.foundation/u/length",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The number of Braille glyphs in an address string.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/u/Address"
      },
      "rdfs:label": "length",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#nonNegativeInteger"
      }
    },
    {
      "@id": "https://uor.foundation/u/addresses",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The datum that this address references. Inverse of schema:glyph.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/u/Address"
      },
      "rdfs:label": "addresses",
      "rdfs:range": {
        "@id": "http://www.w3.org/2002/07/owl#Thing"
      }
    },
    {
      "@id": "https://uor.foundation/u/digest",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The content hash of this address. Format: (blake3|sha256) colon followed by 64 lowercase hex characters. The algorithm prefix must match u:digestAlgorithm.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/u/Address"
      },
      "rdfs:label": "digest",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#string"
      }
    },
    {
      "@id": "https://uor.foundation/u/digestAlgorithm",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The hash algorithm used to produce u:digest. Allowed values: 'blake3' (primary), 'sha256' (secondary).",
      "rdfs:domain": {
        "@id": "https://uor.foundation/u/Address"
      },
      "rdfs:label": "digestAlgorithm",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#string"
      }
    },
    {
      "@id": "https://uor.foundation/u/canonicalBytes",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The canonical byte serialisation of the addressed datum, per Amendment 43 section 2: header(k) || le_bytes(x, k+1). This is the exact byte string hashed to produce u:digest.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/u/Address"
      },
      "rdfs:label": "canonicalBytes",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#hexBinary"
      }
    },
    {
      "@id": "https://uor.foundation/u/quantum",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The quantum level n of this address. The address encodes a datum in R_n = Z/(2^n)Z.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/u/Address"
      },
      "rdfs:label": "quantum",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#positiveInteger"
      }
    },
    {
      "@id": "https://uor.foundation/schema/",
      "@type": "owl:Ontology",
      "owl:imports": [
        {
          "@id": "https://uor.foundation/u/"
        }
      ],
      "rdfs:comment": "Core value types and term language for the UOR ring substrate. Defines Datum (ring element), Term (syntactic expression), and the Ring container.",
      "rdfs:label": "UOR Schema",
      "uor:space": "kernel"
    },
    {
      "@id": "https://uor.foundation/schema/Datum",
      "@type": "owl:Class",
      "owl:disjointWith": [
        {
          "@id": "https://uor.foundation/schema/Term"
        }
      ],
      "rdfs:comment": "An element of the ring Z/(2^n)Z at a specific quantum level n. The primary semantic value type. Disjoint from Term: datums are values, terms are syntactic expressions that evaluate to datums.",
      "rdfs:label": "Datum",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/schema/Term",
      "@type": "owl:Class",
      "owl:disjointWith": [
        {
          "@id": "https://uor.foundation/schema/Datum"
        }
      ],
      "rdfs:comment": "A syntactic expression in the UOR term language. Terms are evaluated to produce Datums. Disjoint from Datum.",
      "rdfs:label": "Term",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/schema/Triad",
      "@type": "owl:Class",
      "rdfs:comment": "A three-component structure encoding an element's position in the UOR address space: stratum (ring layer), spectrum (bit pattern), and glyph (Braille address).",
      "rdfs:label": "Triad",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/schema/Literal",
      "@type": "owl:Class",
      "rdfs:comment": "A term that directly denotes a datum value. A Literal is a leaf node in the term language — it refers to a concrete Datum via schema:denotes without being a Datum itself.",
      "rdfs:label": "Literal",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/schema/Term"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/schema/Application",
      "@type": "owl:Class",
      "rdfs:comment": "A term formed by applying an operation to one or more argument terms. The application's value is the result of evaluating the operator on the evaluated arguments.",
      "rdfs:label": "Application",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/schema/Term"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/schema/Ring",
      "@type": "owl:Class",
      "rdfs:comment": "The ambient ring Z/(2^n)Z at a specific quantum level n. The Ring is the primary data structure of the UOR kernel. Its two generators (negation and complement) produce the dihedral group D_{2^n} that governs the invariance frame.",
      "rdfs:label": "Ring",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/schema/Q1Ring",
      "@type": "owl:Class",
      "rdfs:comment": "The concrete ring Z/(2^16)Z at quantum level 16. Subclass of schema:Ring. Carries 65,536 elements. Q1Ring is the first extension of the default Q0 ring and is the target of Amendment 26's universality proofs.",
      "rdfs:label": "Q1Ring",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/schema/Ring"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/schema/QuantumLevel",
      "@type": "owl:Class",
      "rdfs:comment": "A named quantum level Q_k at which the UOR ring operates. Level Q_k uses 8*(k+1) bits, 2^(8*(k+1)) states, and modulus 2^(8*(k+1)). The named individuals Q0-Q3 are the spec-defined reference levels. The class is open: Prism implementations operating at higher levels declare their own QuantumLevel individuals. The nextLevel property forms an unbounded chain Q0 -> Q1 -> Q2 -> ...",
      "rdfs:label": "QuantumLevel",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/schema/value",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The integer value of a datum element. For a Datum in Z/(2^n)Z, this is an integer in [0, 2^n).",
      "rdfs:domain": {
        "@id": "https://uor.foundation/schema/Datum"
      },
      "rdfs:label": "value",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#nonNegativeInteger"
      }
    },
    {
      "@id": "https://uor.foundation/schema/quantum",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The quantum level n of a datum, where the datum's ring is Z/(2^n)Z. Determines the bit width and modulus of the datum.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/schema/Datum"
      },
      "rdfs:label": "quantum",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#positiveInteger"
      }
    },
    {
      "@id": "https://uor.foundation/schema/stratum",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The ring-layer index of a datum, indicating its position in the stratification of Z/(2^n)Z.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/schema/Datum"
      },
      "rdfs:label": "stratum",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#nonNegativeInteger"
      }
    },
    {
      "@id": "https://uor.foundation/schema/spectrum",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The bit-pattern representation of a datum, encoding its position in the hypercube geometry of Z/(2^n)Z.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/schema/Datum"
      },
      "rdfs:label": "spectrum",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#string"
      }
    },
    {
      "@id": "https://uor.foundation/schema/glyph",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The Braille address associated with this datum, linking the algebraic value to its content-addressable identifier.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/schema/Datum"
      },
      "rdfs:label": "glyph",
      "rdfs:range": {
        "@id": "https://uor.foundation/u/Address"
      }
    },
    {
      "@id": "https://uor.foundation/schema/operator",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The operation applied in an Application term.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/schema/Application"
      },
      "rdfs:label": "operator",
      "rdfs:range": {
        "@id": "https://uor.foundation/op/Operation"
      }
    },
    {
      "@id": "https://uor.foundation/schema/argument",
      "@type": "owl:ObjectProperty",
      "rdfs:comment": "An argument term in an Application. The ordering of arguments follows rdf:List semantics.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/schema/Application"
      },
      "rdfs:label": "argument",
      "rdfs:range": {
        "@id": "https://uor.foundation/schema/Term"
      }
    },
    {
      "@id": "https://uor.foundation/schema/ringQuantum",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The bit width n of the ring Z/(2^n)Z. Distinct from schema:quantum on Datum — ringQuantum is the container's bit width; datum quantum is a membership property.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/schema/Ring"
      },
      "rdfs:label": "ringQuantum",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#positiveInteger"
      }
    },
    {
      "@id": "https://uor.foundation/schema/modulus",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The modulus 2^n of the ring. Equals 2 raised to the power of ringQuantum.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/schema/Ring"
      },
      "rdfs:label": "modulus",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#positiveInteger"
      }
    },
    {
      "@id": "https://uor.foundation/schema/generator",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The generator element π₁ (value = 1) of the ring. Under iterated successor application, π₁ generates all ring elements.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/schema/Ring"
      },
      "rdfs:label": "generator",
      "rdfs:range": {
        "@id": "https://uor.foundation/schema/Datum"
      }
    },
    {
      "@id": "https://uor.foundation/schema/negation",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The ring reflection involution: neg(x) = (-x) mod 2^n. One of the two generators of the dihedral group D_{2^n}.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/schema/Ring"
      },
      "rdfs:label": "negation",
      "rdfs:range": {
        "@id": "https://uor.foundation/op/Involution"
      }
    },
    {
      "@id": "https://uor.foundation/schema/complement",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The hypercube reflection involution: bnot(x) = (2^n - 1) ⊕ x. The second generator of the dihedral group D_{2^n}.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/schema/Ring"
      },
      "rdfs:label": "complement",
      "rdfs:range": {
        "@id": "https://uor.foundation/op/Involution"
      }
    },
    {
      "@id": "https://uor.foundation/schema/denotes",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The datum value that a Literal term denotes. Bridges the Term/Datum disjointness: a Literal refers to a Datum without being one. Evaluation of a Literal produces its denoted Datum.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/schema/Literal"
      },
      "rdfs:label": "denotes",
      "rdfs:range": {
        "@id": "https://uor.foundation/schema/Datum"
      }
    },
    {
      "@id": "https://uor.foundation/schema/quantumIndex",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The index k of this quantum level. Q0 has index 0, Q1 has index 1, etc.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/schema/QuantumLevel"
      },
      "rdfs:label": "quantumIndex",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#nonNegativeInteger"
      }
    },
    {
      "@id": "https://uor.foundation/schema/bitsWidth",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The bit width 8*(k+1) of this quantum level.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/schema/QuantumLevel"
      },
      "rdfs:label": "bitsWidth",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#positiveInteger"
      }
    },
    {
      "@id": "https://uor.foundation/schema/cycleSize",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The number of distinct states 2^(8*(k+1)) at this quantum level.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/schema/QuantumLevel"
      },
      "rdfs:label": "cycleSize",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#positiveInteger"
      }
    },
    {
      "@id": "https://uor.foundation/schema/nextLevel",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The next quantum level in the chain: Q_k -> Q_(k+1). The chain is unbounded; Q3 points to Q4, which is not a named individual in the spec but may be declared by Prism implementations.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/schema/QuantumLevel"
      },
      "rdfs:label": "nextLevel",
      "rdfs:range": {
        "@id": "https://uor.foundation/schema/QuantumLevel"
      }
    },
    {
      "@id": "https://uor.foundation/schema/levelSuccessor",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The predecessor quantum level in the chain: Q_(k+1) -> Q_k. Inverse of nextLevel. If nextLevel(Q_k) = Q_(k+1), then levelSuccessor(Q_(k+1)) = Q_k. Formalizes the chain extension protocol (QL_8).",
      "rdfs:domain": {
        "@id": "https://uor.foundation/schema/QuantumLevel"
      },
      "rdfs:label": "levelSuccessor",
      "rdfs:range": {
        "@id": "https://uor.foundation/schema/QuantumLevel"
      }
    },
    {
      "@id": "https://uor.foundation/schema/atQuantumLevel",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The quantum level at which this Ring instance operates. Links a concrete Ring individual to its QuantumLevel.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/schema/Ring"
      },
      "rdfs:label": "atQuantumLevel",
      "rdfs:range": {
        "@id": "https://uor.foundation/schema/QuantumLevel"
      }
    },
    {
      "@id": "https://uor.foundation/schema/Q1bitWidth",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "Bit width of the Q1 ring: 16.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/schema/Q1Ring"
      },
      "rdfs:label": "Q1bitWidth",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#positiveInteger"
      }
    },
    {
      "@id": "https://uor.foundation/schema/Q1capacity",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "Carrier set size of the Q1 ring: 65,536 elements.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/schema/Q1Ring"
      },
      "rdfs:label": "Q1capacity",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#positiveInteger"
      }
    },
    {
      "@id": "https://uor.foundation/schema/pi1",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/schema/Datum"
      ],
      "rdfs:comment": "The unique generator of R_n under successor. Value = 1 at every quantum level. Under iterated application of succ, π₁ generates every element of the ring.",
      "rdfs:label": "π₁",
      "schema:value": 1
    },
    {
      "@id": "https://uor.foundation/schema/zero",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/schema/Datum"
      ],
      "rdfs:comment": "The additive identity of the ring. Value = 0 at every quantum level. op:add(x, zero) = x for all x in R_n.",
      "rdfs:label": "zero",
      "schema:value": 0
    },
    {
      "@id": "https://uor.foundation/schema/Q0",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/schema/QuantumLevel"
      ],
      "rdfs:comment": "Quantum level 0: 8-bit ring Z/256Z, 256 states. The reference level for all ComputationCertificate proofs in the spec.",
      "rdfs:label": "Q0",
      "schema:bitsWidth": 8,
      "schema:cycleSize": 256,
      "schema:nextLevel": {
        "@id": "https://uor.foundation/schema/Q1"
      },
      "schema:quantumIndex": 0
    },
    {
      "@id": "https://uor.foundation/schema/Q1",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/schema/QuantumLevel"
      ],
      "rdfs:comment": "Quantum level 1: 16-bit ring Z/65536Z, 65,536 states.",
      "rdfs:label": "Q1",
      "schema:bitsWidth": 16,
      "schema:cycleSize": 65536,
      "schema:levelSuccessor": {
        "@id": "https://uor.foundation/schema/Q0"
      },
      "schema:nextLevel": {
        "@id": "https://uor.foundation/schema/Q2"
      },
      "schema:quantumIndex": 1
    },
    {
      "@id": "https://uor.foundation/schema/Q2",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/schema/QuantumLevel"
      ],
      "rdfs:comment": "Quantum level 2: 24-bit ring Z/16777216Z, 16,777,216 states.",
      "rdfs:label": "Q2",
      "schema:bitsWidth": 24,
      "schema:cycleSize": 16777216,
      "schema:levelSuccessor": {
        "@id": "https://uor.foundation/schema/Q1"
      },
      "schema:nextLevel": {
        "@id": "https://uor.foundation/schema/Q3"
      },
      "schema:quantumIndex": 2
    },
    {
      "@id": "https://uor.foundation/schema/Q3",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/schema/QuantumLevel"
      ],
      "rdfs:comment": "Quantum level 3: 32-bit ring Z/4294967296Z, 4,294,967,296 states. The highest named level in the spec. nextLevel is absent — Prism implementations may extend the chain.",
      "rdfs:label": "Q3",
      "schema:bitsWidth": 32,
      "schema:cycleSize": 4294967296,
      "schema:levelSuccessor": {
        "@id": "https://uor.foundation/schema/Q2"
      },
      "schema:quantumIndex": 3
    },
    {
      "@id": "https://uor.foundation/op/",
      "@type": "owl:Ontology",
      "owl:imports": [
        {
          "@id": "https://uor.foundation/schema/"
        }
      ],
      "rdfs:comment": "Ring operations, involutions, algebraic identities, and the dihedral symmetry group D_{2^n} generated by neg and bnot.",
      "rdfs:label": "UOR Operations",
      "uor:space": "kernel"
    },
    {
      "@id": "https://uor.foundation/op/Operation",
      "@type": "owl:Class",
      "rdfs:comment": "An operation on the ring Z/(2^n)Z. The root class for all UOR kernel operations.",
      "rdfs:label": "Operation",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/op/UnaryOp",
      "@type": "owl:Class",
      "rdfs:comment": "A unary operation on the ring: takes one datum and produces one datum.",
      "rdfs:label": "UnaryOp",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/op/Operation"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/op/BinaryOp",
      "@type": "owl:Class",
      "rdfs:comment": "A binary operation on the ring: takes two datums and produces one datum.",
      "rdfs:label": "BinaryOp",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/op/Operation"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/op/Involution",
      "@type": "owl:Class",
      "rdfs:comment": "A unary operation f such that f(f(x)) = x for all x in R_n. The two UOR involutions are neg (ring reflection) and bnot (hypercube reflection).",
      "rdfs:label": "Involution",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/op/UnaryOp"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/op/Identity",
      "@type": "owl:Class",
      "rdfs:comment": "An algebraic identity: a statement that two expressions are equal for all inputs. The critical identity is neg(bnot(x)) = succ(x) for all x in R_n.",
      "rdfs:label": "Identity",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/op/Group",
      "@type": "owl:Class",
      "rdfs:comment": "A group: a set with an associative binary operation, an identity element, and inverses for every element.",
      "rdfs:label": "Group",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/op/DihedralGroup",
      "@type": "owl:Class",
      "rdfs:comment": "The dihedral group D_{2^n} of order 2^(n+1), generated by the ring reflection (neg) and the hypercube reflection (bnot). This group governs the symmetry of the UOR type space.",
      "rdfs:label": "DihedralGroup",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/op/Group"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/op/VerificationDomain",
      "@type": "owl:Class",
      "rdfs:comment": "A named mathematical discipline through which an algebraic identity is established and grounded. Every op:Identity individual references at least one VerificationDomain via op:verificationDomain. The nine canonical domain individuals are kernel-level constants defined in op/.",
      "rdfs:label": "VerificationDomain",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/op/GeometricCharacter",
      "@type": "owl:Class",
      "rdfs:comment": "The geometric role of a ring operation in the UOR dual-geometry (ring + hypercube). Every op:Operation individual references exactly one GeometricCharacter via op:hasGeometricCharacter. The nine canonical individuals correspond to the action types of the dihedral group D_{2^n}.",
      "rdfs:label": "GeometricCharacter",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/op/QuantumLevelBinding",
      "@type": "owl:Class",
      "rdfs:comment": "A record linking an op:Identity individual to a specific quantum level at which it has been verified. Non-functional: one QuantumLevelBinding per (Identity, QuantumLevel) pair verified.",
      "rdfs:label": "QuantumLevelBinding",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/op/QuantumThermodynamicDomain",
      "@type": "owl:Class",
      "rdfs:comment": "A verification domain at the intersection of quantum superposition and classical thermodynamics. Identities in this domain require both SuperpositionDomain and Thermodynamic reasoning simultaneously.",
      "rdfs:label": "QuantumThermodynamicDomain",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/op/ValidityScopeKind",
      "@type": "owl:Class",
      "rdfs:comment": "Root class for validity scope individuals. Instances are the four named scope kinds: Universal, ParametricLower, ParametricRange, and LevelSpecific.",
      "rdfs:label": "ValidityScopeKind",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/op/arity",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The number of arguments this operation takes. 1 for unary operations, 2 for binary operations.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/op/Operation"
      },
      "rdfs:label": "arity",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#nonNegativeInteger"
      }
    },
    {
      "@id": "https://uor.foundation/op/hasGeometricCharacter",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The geometric role of this operation in the UOR ring and hypercube geometry. Functional: each operation has exactly one geometric character.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/op/Operation"
      },
      "rdfs:label": "hasGeometricCharacter",
      "rdfs:range": {
        "@id": "https://uor.foundation/op/GeometricCharacter"
      }
    },
    {
      "@id": "https://uor.foundation/op/geometricCharacterNote",
      "@type": "owl:AnnotationProperty",
      "rdfs:comment": "Human-readable description of the geometric role. Annotation only — not used for reasoning.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/op/Operation"
      },
      "rdfs:label": "geometricCharacterNote",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#string"
      }
    },
    {
      "@id": "https://uor.foundation/op/commutative",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "Whether this binary operation satisfies op(x,y) = op(y,x) for all x, y in R_n.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/op/BinaryOp"
      },
      "rdfs:label": "commutative",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#boolean"
      }
    },
    {
      "@id": "https://uor.foundation/op/associative",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "Whether this binary operation satisfies op(op(x,y),z) = op(x,op(y,z)) for all x, y, z in R_n.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/op/BinaryOp"
      },
      "rdfs:label": "associative",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#boolean"
      }
    },
    {
      "@id": "https://uor.foundation/op/identity",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The identity element of this binary operation: the value e such that op(x, e) = op(e, x) = x for all x in R_n.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/op/BinaryOp"
      },
      "rdfs:label": "identity",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#integer"
      }
    },
    {
      "@id": "https://uor.foundation/op/inverse",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The inverse operation: the operation inv_op such that op(x, inv_op(x)) = e for all x, where e is the identity.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/op/Operation"
      },
      "rdfs:label": "inverse",
      "rdfs:range": {
        "@id": "https://uor.foundation/op/Operation"
      }
    },
    {
      "@id": "https://uor.foundation/op/composedOf",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "Ordered list of operations this operation is composed from. Uses rdf:List to preserve application order (first element applied innermost). E.g., succ = neg ∘ bnot is encoded as [op:neg, op:bnot] meaning neg applied to the result of bnot.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/op/Operation"
      },
      "rdfs:label": "composedOf",
      "rdfs:range": {
        "@id": "http://www.w3.org/1999/02/22-rdf-syntax-ns#List"
      }
    },
    {
      "@id": "https://uor.foundation/op/lhs",
      "@type": "owl:AnnotationProperty",
      "rdfs:comment": "The left-hand side of an algebraic identity, expressed as a symbolic mathematical notation string (e.g., 'add(x, y)').",
      "rdfs:domain": {
        "@id": "https://uor.foundation/op/Identity"
      },
      "rdfs:label": "lhs",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#string"
      }
    },
    {
      "@id": "https://uor.foundation/op/rhs",
      "@type": "owl:AnnotationProperty",
      "rdfs:comment": "The right-hand side of an algebraic identity, expressed as a symbolic mathematical notation string (e.g., 'x').",
      "rdfs:domain": {
        "@id": "https://uor.foundation/op/Identity"
      },
      "rdfs:label": "rhs",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#string"
      }
    },
    {
      "@id": "https://uor.foundation/op/forAll",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The quantifier scope: the variable(s) over which this algebraic identity holds (e.g., 'x ∈ R_n').",
      "rdfs:domain": {
        "@id": "https://uor.foundation/op/Identity"
      },
      "rdfs:label": "forAll",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#string"
      }
    },
    {
      "@id": "https://uor.foundation/op/generatedBy",
      "@type": "owl:ObjectProperty",
      "rdfs:comment": "An operation that generates this group. The dihedral group D_{2^n} is generated by op:neg and op:bnot.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/op/Group"
      },
      "rdfs:label": "generatedBy",
      "rdfs:range": {
        "@id": "https://uor.foundation/op/Operation"
      }
    },
    {
      "@id": "https://uor.foundation/op/order",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The number of elements in the group. For D_{2^n}, the order is 2^(n+1).",
      "rdfs:domain": {
        "@id": "https://uor.foundation/op/Group"
      },
      "rdfs:label": "order",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#positiveInteger"
      }
    },
    {
      "@id": "https://uor.foundation/op/presentation",
      "@type": "owl:AnnotationProperty",
      "rdfs:comment": "The group presentation (generators and relations). Annotation only — not used for reasoning. Example: ⟨r, s | r^{2^n} = s² = e, srs = r⁻¹⟩",
      "rdfs:domain": {
        "@id": "https://uor.foundation/op/Group"
      },
      "rdfs:label": "presentation",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#string"
      }
    },
    {
      "@id": "https://uor.foundation/op/verificationDomain",
      "@type": "owl:ObjectProperty",
      "rdfs:comment": "The mathematical discipline(s) through which this identity is established. Range is op:VerificationDomain. Non-functional: composite identities (e.g. IT_7a–IT_7d) reference multiple domain individuals.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/op/Identity"
      },
      "rdfs:label": "verificationDomain",
      "rdfs:range": {
        "@id": "https://uor.foundation/op/VerificationDomain"
      }
    },
    {
      "@id": "https://uor.foundation/op/verificationPathNote",
      "@type": "owl:AnnotationProperty",
      "rdfs:comment": "Human-readable description of the verification path. Annotation only — not used for reasoning.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/op/Identity"
      },
      "rdfs:label": "verificationPathNote",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#string"
      }
    },
    {
      "@id": "https://uor.foundation/op/verifiedAtLevel",
      "@type": "owl:ObjectProperty",
      "rdfs:comment": "Links an Identity individual to a QuantumLevelBinding attesting verification at a specific quantum level. Non-functional: one binding per (Identity, QuantumLevel) pair.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/op/Identity"
      },
      "rdfs:label": "verifiedAtLevel",
      "rdfs:range": {
        "@id": "https://uor.foundation/op/QuantumLevelBinding"
      }
    },
    {
      "@id": "https://uor.foundation/op/bindingLevel",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The quantum level at which this QuantumLevelBinding was verified.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/op/QuantumLevelBinding"
      },
      "rdfs:label": "bindingLevel",
      "rdfs:range": {
        "@id": "https://uor.foundation/schema/QuantumLevel"
      }
    },
    {
      "@id": "https://uor.foundation/op/universallyValid",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "True iff this identity holds for all n ≥ 1 (proved symbolically by induction on the ring axioms, not just exhaustively at Q0). Identities that reference 8-bit-specific constants receive universallyValid = false.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/op/Identity"
      },
      "rdfs:label": "universallyValid",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#boolean"
      }
    },
    {
      "@id": "https://uor.foundation/op/enumVariant",
      "@type": "owl:AnnotationProperty",
      "rdfs:comment": "The canonical Rust enum variant name corresponding to this VerificationDomain individual. Provides formal alignment between the OWL individual and the generated Rust enum.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/op/VerificationDomain"
      },
      "rdfs:label": "enumVariant",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#string"
      }
    },
    {
      "@id": "https://uor.foundation/op/validityKind",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The structured validity scope of this identity, replacing the binary universallyValid flag. Required on all new Identity individuals.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/op/Identity"
      },
      "rdfs:label": "validityKind",
      "rdfs:range": {
        "@id": "https://uor.foundation/op/ValidityScopeKind"
      }
    },
    {
      "@id": "https://uor.foundation/op/validKMin",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "Minimum quantum level index k for ParametricLower and ParametricRange scopes.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/op/Identity"
      },
      "rdfs:label": "validKMin",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#nonNegativeInteger"
      }
    },
    {
      "@id": "https://uor.foundation/op/validKMax",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "Maximum quantum level index k (inclusive) for ParametricRange scope.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/op/Identity"
      },
      "rdfs:label": "validKMax",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#nonNegativeInteger"
      }
    },
    {
      "@id": "https://uor.foundation/op/Enumerative",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/VerificationDomain"
      ],
      "op:enumVariant": "Enumerative",
      "rdfs:comment": "Established by exhaustive traversal of R_n. Valid for all identities where the ring is finite.",
      "rdfs:label": "Enumerative"
    },
    {
      "@id": "https://uor.foundation/op/Algebraic",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/VerificationDomain"
      ],
      "op:enumVariant": "Algebraic",
      "rdfs:comment": "Established by equational reasoning from ring or group axioms. Covers derivations via associativity, commutativity, inverse laws, and group presentations.",
      "rdfs:label": "Algebraic"
    },
    {
      "@id": "https://uor.foundation/op/Geometric",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/VerificationDomain"
      ],
      "op:enumVariant": "Geometric",
      "rdfs:comment": "Established by isometry, symmetry, or GeometricCharacter arguments. Covers dihedral actions, fixed-point analysis, automorphism groups, and affine embeddings.",
      "rdfs:label": "Geometric"
    },
    {
      "@id": "https://uor.foundation/op/Analytical",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/VerificationDomain"
      ],
      "op:enumVariant": "Analytical",
      "rdfs:comment": "Established via discrete differential calculus or metric analysis. Covers ring/Hamming derivatives (DC_), metric divergence (AM_), and adiabatic scheduling (AR_).",
      "rdfs:label": "Analytical"
    },
    {
      "@id": "https://uor.foundation/op/Thermodynamic",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/VerificationDomain"
      ],
      "op:enumVariant": "Thermodynamic",
      "rdfs:comment": "Established via entropy, Landauer bounds, or Boltzmann distributions. Covers fiber entropy (TH_), reversible computation (RC_), and phase transitions.",
      "rdfs:label": "Thermodynamic"
    },
    {
      "@id": "https://uor.foundation/op/Topological",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/VerificationDomain"
      ],
      "op:enumVariant": "Topological",
      "rdfs:comment": "Established via simplicial homology, cohomology, or constraint nerve analysis. Covers homological algebra (HA_) and ψ-pipeline identities.",
      "rdfs:label": "Topological"
    },
    {
      "@id": "https://uor.foundation/op/Pipeline",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/VerificationDomain"
      ],
      "op:enumVariant": "Pipeline",
      "rdfs:comment": "Established by the inter-algebra map structure of the resolution pipeline. Covers φ-maps (phi_1–phi_6) and ψ-maps (psi_1–psi_6).",
      "rdfs:label": "Pipeline"
    },
    {
      "@id": "https://uor.foundation/op/IndexTheoretic",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/VerificationDomain"
      ],
      "op:enumVariant": "IndexTheoretic",
      "rdfs:comment": "Established by the composition of Analytical and Topological reasoning. The only domain requiring multiple op:verificationDomain assertions. Covers the UOR Index Theorem (IT_7a–IT_7d).",
      "rdfs:label": "IndexTheoretic"
    },
    {
      "@id": "https://uor.foundation/op/SuperpositionDomain",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/VerificationDomain"
      ],
      "op:enumVariant": "SuperpositionDomain",
      "rdfs:comment": "Established by superposition analysis of fiber states. Covers identities involving superposed (non-classical) fiber assignments where fibers carry complex amplitudes.",
      "rdfs:label": "SuperpositionDomain"
    },
    {
      "@id": "https://uor.foundation/op/QuantumThermodynamic",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/VerificationDomain"
      ],
      "op:enumVariant": "QuantumThermodynamic",
      "rdfs:comment": "Established by the intersection of quantum superposition analysis and classical thermodynamic reasoning. Covers identities relating von Neumann entropy of superposed states to Landauer costs of projective collapse (QM_).",
      "rdfs:label": "QuantumThermodynamic"
    },
    {
      "@id": "https://uor.foundation/op/Universal",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/ValidityScopeKind"
      ],
      "op:enumVariant": "Universal",
      "rdfs:comment": "Holds for all k in N. No minimum k constraint.",
      "rdfs:label": "Universal"
    },
    {
      "@id": "https://uor.foundation/op/ParametricLower",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/ValidityScopeKind"
      ],
      "op:enumVariant": "ParametricLower",
      "rdfs:comment": "Holds for all k >= k_min, where k_min is given by validKMin.",
      "rdfs:label": "ParametricLower"
    },
    {
      "@id": "https://uor.foundation/op/ParametricRange",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/ValidityScopeKind"
      ],
      "op:enumVariant": "ParametricRange",
      "rdfs:comment": "Holds for k_min <= k <= k_max. Both validKMin and validKMax required.",
      "rdfs:label": "ParametricRange"
    },
    {
      "@id": "https://uor.foundation/op/LevelSpecific",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/ValidityScopeKind"
      ],
      "op:enumVariant": "LevelSpecific",
      "rdfs:comment": "Holds only at exactly one level, given by a QuantumLevelBinding.",
      "rdfs:label": "LevelSpecific"
    },
    {
      "@id": "https://uor.foundation/op/RingReflection",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/GeometricCharacter"
      ],
      "rdfs:comment": "Reflection through the origin of the additive ring: neg(x) = -x mod 2^n. One of the two generators of D_{2^n}.",
      "rdfs:label": "RingReflection"
    },
    {
      "@id": "https://uor.foundation/op/HypercubeReflection",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/GeometricCharacter"
      ],
      "rdfs:comment": "Reflection through the centre of the hypercube: bnot(x) = (2^n-1) ⊕ x. The second generator of D_{2^n}.",
      "rdfs:label": "HypercubeReflection"
    },
    {
      "@id": "https://uor.foundation/op/Rotation",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/GeometricCharacter"
      ],
      "rdfs:comment": "Rotation by one step: succ(x) = (x+1) mod 2^n. The composition of the two reflections.",
      "rdfs:label": "Rotation"
    },
    {
      "@id": "https://uor.foundation/op/RotationInverse",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/GeometricCharacter"
      ],
      "rdfs:comment": "Rotation by one step in the reverse direction: pred(x) = (x-1) mod 2^n.",
      "rdfs:label": "RotationInverse"
    },
    {
      "@id": "https://uor.foundation/op/Translation",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/GeometricCharacter"
      ],
      "rdfs:comment": "Translation along the ring axis: add(x,y), sub(x,y). Preserves Hamming distance locally.",
      "rdfs:label": "Translation"
    },
    {
      "@id": "https://uor.foundation/op/Scaling",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/GeometricCharacter"
      ],
      "rdfs:comment": "Scaling along the ring axis: mul(x,y) = (x×y) mod 2^n.",
      "rdfs:label": "Scaling"
    },
    {
      "@id": "https://uor.foundation/op/HypercubeTranslation",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/GeometricCharacter"
      ],
      "rdfs:comment": "Translation along the hypercube axis: xor(x,y) = x ⊕ y. Preserves ring distance locally.",
      "rdfs:label": "HypercubeTranslation"
    },
    {
      "@id": "https://uor.foundation/op/HypercubeProjection",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/GeometricCharacter"
      ],
      "rdfs:comment": "Projection onto a hypercube face: and(x,y) = x ∧ y. Idempotent; collapses dimensions.",
      "rdfs:label": "HypercubeProjection"
    },
    {
      "@id": "https://uor.foundation/op/HypercubeJoin",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/GeometricCharacter"
      ],
      "rdfs:comment": "Join on the hypercube lattice: or(x,y) = x ∨ y. Idempotent; dual to projection.",
      "rdfs:label": "HypercubeJoin"
    },
    {
      "@id": "https://uor.foundation/op/neg",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Involution"
      ],
      "op:arity": 1,
      "op:hasGeometricCharacter": {
        "@id": "https://uor.foundation/op/RingReflection"
      },
      "rdfs:comment": "Ring reflection: neg(x) = (-x) mod 2^n. One of the two generators of the dihedral group D_{2^n}. neg(neg(x)) = x (involution property).",
      "rdfs:label": "neg"
    },
    {
      "@id": "https://uor.foundation/op/bnot",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Involution"
      ],
      "op:arity": 1,
      "op:hasGeometricCharacter": {
        "@id": "https://uor.foundation/op/HypercubeReflection"
      },
      "rdfs:comment": "Hypercube reflection: bnot(x) = (2^n - 1) ⊕ x (bitwise complement). The second generator of D_{2^n}. bnot(bnot(x)) = x.",
      "rdfs:label": "bnot"
    },
    {
      "@id": "https://uor.foundation/op/succ",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/UnaryOp"
      ],
      "op:arity": 1,
      "op:composedOf": {
        "@type": "rdf:List",
        "rdf:first": {
          "@id": "https://uor.foundation/op/neg"
        },
        "rdf:rest": {
          "@type": "rdf:List",
          "rdf:first": {
            "@id": "https://uor.foundation/op/bnot"
          },
          "rdf:rest": {
            "@id": "rdf:nil"
          }
        }
      },
      "op:hasGeometricCharacter": {
        "@id": "https://uor.foundation/op/Rotation"
      },
      "op:inverse": {
        "@id": "https://uor.foundation/op/pred"
      },
      "rdfs:comment": "Successor: succ(x) = neg(bnot(x)) = (x + 1) mod 2^n. The critical identity: succ is the composition neg ∘ bnot.",
      "rdfs:label": "succ"
    },
    {
      "@id": "https://uor.foundation/op/pred",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/UnaryOp"
      ],
      "op:arity": 1,
      "op:composedOf": {
        "@type": "rdf:List",
        "rdf:first": {
          "@id": "https://uor.foundation/op/bnot"
        },
        "rdf:rest": {
          "@type": "rdf:List",
          "rdf:first": {
            "@id": "https://uor.foundation/op/neg"
          },
          "rdf:rest": {
            "@id": "rdf:nil"
          }
        }
      },
      "op:hasGeometricCharacter": {
        "@id": "https://uor.foundation/op/RotationInverse"
      },
      "op:inverse": {
        "@id": "https://uor.foundation/op/succ"
      },
      "rdfs:comment": "Predecessor: pred(x) = bnot(neg(x)) = (x - 1) mod 2^n. The inverse of succ. pred is the composition bnot ∘ neg.",
      "rdfs:label": "pred"
    },
    {
      "@id": "https://uor.foundation/op/add",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/BinaryOp"
      ],
      "op:arity": 2,
      "op:associative": true,
      "op:commutative": true,
      "op:hasGeometricCharacter": {
        "@id": "https://uor.foundation/op/Translation"
      },
      "op:identity": 0,
      "op:inverse": {
        "@id": "https://uor.foundation/op/sub"
      },
      "rdfs:comment": "Ring addition: add(x, y) = (x + y) mod 2^n. Commutative, associative; identity element is 0.",
      "rdfs:label": "add"
    },
    {
      "@id": "https://uor.foundation/op/sub",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/BinaryOp"
      ],
      "op:arity": 2,
      "op:associative": false,
      "op:commutative": false,
      "op:hasGeometricCharacter": {
        "@id": "https://uor.foundation/op/Translation"
      },
      "rdfs:comment": "Ring subtraction: sub(x, y) = (x - y) mod 2^n. Not commutative, not associative.",
      "rdfs:label": "sub"
    },
    {
      "@id": "https://uor.foundation/op/mul",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/BinaryOp"
      ],
      "op:arity": 2,
      "op:associative": true,
      "op:commutative": true,
      "op:hasGeometricCharacter": {
        "@id": "https://uor.foundation/op/Scaling"
      },
      "op:identity": 1,
      "rdfs:comment": "Ring multiplication: mul(x, y) = (x × y) mod 2^n. Commutative, associative; identity element is 1.",
      "rdfs:label": "mul"
    },
    {
      "@id": "https://uor.foundation/op/xor",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/BinaryOp"
      ],
      "op:arity": 2,
      "op:associative": true,
      "op:commutative": true,
      "op:hasGeometricCharacter": {
        "@id": "https://uor.foundation/op/HypercubeTranslation"
      },
      "op:identity": 0,
      "rdfs:comment": "Bitwise exclusive or: xor(x, y) = x ⊕ y. Commutative, associative; identity element is 0.",
      "rdfs:label": "xor"
    },
    {
      "@id": "https://uor.foundation/op/and",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/BinaryOp"
      ],
      "op:arity": 2,
      "op:associative": true,
      "op:commutative": true,
      "op:hasGeometricCharacter": {
        "@id": "https://uor.foundation/op/HypercubeProjection"
      },
      "rdfs:comment": "Bitwise and: and(x, y) = x ∧ y. Commutative, associative.",
      "rdfs:label": "and"
    },
    {
      "@id": "https://uor.foundation/op/or",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/BinaryOp"
      ],
      "op:arity": 2,
      "op:associative": true,
      "op:commutative": true,
      "op:hasGeometricCharacter": {
        "@id": "https://uor.foundation/op/HypercubeJoin"
      },
      "rdfs:comment": "Bitwise or: or(x, y) = x ∨ y. Commutative, associative.",
      "rdfs:label": "or"
    },
    {
      "@id": "https://uor.foundation/op/criticalIdentity",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "x ∈ R_n",
      "op:lhs": {
        "@id": "https://uor.foundation/op/succ"
      },
      "op:rhs": {
        "@type": "rdf:List",
        "rdf:first": {
          "@id": "https://uor.foundation/op/neg"
        },
        "rdf:rest": {
          "@type": "rdf:List",
          "rdf:first": {
            "@id": "https://uor.foundation/op/bnot"
          },
          "rdf:rest": {
            "@id": "rdf:nil"
          }
        }
      },
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Enumerative"
      },
      "op:verificationPathNote": "exhaustive_enumeration(R_n)",
      "rdfs:comment": "The foundational theorem of the UOR kernel: neg(bnot(x)) = succ(x) for all x in R_n. This identity links the two involutions (neg and bnot) to the successor operation, making succ derivable from neg and bnot.",
      "rdfs:label": "Critical Identity"
    },
    {
      "@id": "https://uor.foundation/op/AD_1",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "d ∈ R_n",
      "op:lhs": "addresses(glyph(d))",
      "op:rhs": "d",
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Analytical"
      },
      "op:verificationPathNote": "Address → Ring → bijection",
      "rdfs:comment": "Addressing bijection: addresses(glyph(d)) = d. Round-trip from datum through glyph and back is identity.",
      "rdfs:label": "AD_1"
    },
    {
      "@id": "https://uor.foundation/op/AD_2",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "a ∈ Addr(R_n), ι : R_n → R_{n'}",
      "op:lhs": "glyph(ι(addresses(a)))",
      "op:rhs": "ι_addr(a)",
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Analytical"
      },
      "op:verificationPathNote": "Address → Ring → bijection",
      "rdfs:comment": "Embedding coherence: glyph(ι(addresses(a))) = ι_addr(a). The addressing diagram commutes through embeddings.",
      "rdfs:label": "AD_2"
    },
    {
      "@id": "https://uor.foundation/op/R_A1",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "x, y, z ∈ R_n",
      "op:lhs": "add(x, add(y, z))",
      "op:rhs": "add(add(x, y), z)",
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Enumerative"
      },
      "op:verificationPathNote": "exhaustive_enumeration(R_n)",
      "rdfs:comment": "Additive associativity: add(x, add(y, z)) = add(add(x, y), z).",
      "rdfs:label": "R_A1"
    },
    {
      "@id": "https://uor.foundation/op/R_A2",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "x ∈ R_n",
      "op:lhs": "add(x, 0)",
      "op:rhs": "x",
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Enumerative"
      },
      "op:verificationPathNote": "exhaustive_enumeration(R_n)",
      "rdfs:comment": "Additive identity: add(x, 0) = x.",
      "rdfs:label": "R_A2"
    },
    {
      "@id": "https://uor.foundation/op/R_A3",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "x ∈ R_n",
      "op:lhs": "add(x, neg(x))",
      "op:rhs": "0",
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Enumerative"
      },
      "op:verificationPathNote": "exhaustive_enumeration(R_n)",
      "rdfs:comment": "Additive inverse: add(x, neg(x)) = 0.",
      "rdfs:label": "R_A3"
    },
    {
      "@id": "https://uor.foundation/op/R_A4",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "x, y ∈ R_n",
      "op:lhs": "add(x, y)",
      "op:rhs": "add(y, x)",
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Enumerative"
      },
      "op:verificationPathNote": "exhaustive_enumeration(R_n)",
      "rdfs:comment": "Additive commutativity: add(x, y) = add(y, x).",
      "rdfs:label": "R_A4"
    },
    {
      "@id": "https://uor.foundation/op/R_A5",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "x, y ∈ R_n",
      "op:lhs": "sub(x, y)",
      "op:rhs": "add(x, neg(y))",
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Enumerative"
      },
      "op:verificationPathNote": "exhaustive_enumeration(R_n)",
      "rdfs:comment": "Subtraction definition: sub(x, y) = add(x, neg(y)).",
      "rdfs:label": "R_A5"
    },
    {
      "@id": "https://uor.foundation/op/R_A6",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "x ∈ R_n",
      "op:lhs": "neg(neg(x))",
      "op:rhs": "x",
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Enumerative"
      },
      "op:verificationPathNote": "exhaustive_enumeration(R_n)",
      "rdfs:comment": "Negation involution: neg(neg(x)) = x.",
      "rdfs:label": "R_A6"
    },
    {
      "@id": "https://uor.foundation/op/R_M1",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "x, y, z ∈ R_n",
      "op:lhs": "mul(x, mul(y, z))",
      "op:rhs": "mul(mul(x, y), z)",
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Enumerative"
      },
      "op:verificationPathNote": "exhaustive_enumeration(R_n)",
      "rdfs:comment": "Multiplicative associativity: mul(x, mul(y, z)) = mul(mul(x, y), z).",
      "rdfs:label": "R_M1"
    },
    {
      "@id": "https://uor.foundation/op/R_M2",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "x ∈ R_n",
      "op:lhs": "mul(x, 1)",
      "op:rhs": "x",
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Enumerative"
      },
      "op:verificationPathNote": "exhaustive_enumeration(R_n)",
      "rdfs:comment": "Multiplicative identity: mul(x, 1) = x.",
      "rdfs:label": "R_M2"
    },
    {
      "@id": "https://uor.foundation/op/R_M3",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "x, y ∈ R_n",
      "op:lhs": "mul(x, y)",
      "op:rhs": "mul(y, x)",
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Enumerative"
      },
      "op:verificationPathNote": "exhaustive_enumeration(R_n)",
      "rdfs:comment": "Multiplicative commutativity: mul(x, y) = mul(y, x).",
      "rdfs:label": "R_M3"
    },
    {
      "@id": "https://uor.foundation/op/R_M4",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "x, y, z ∈ R_n",
      "op:lhs": "mul(x, add(y, z))",
      "op:rhs": "add(mul(x, y), mul(x, z))",
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Enumerative"
      },
      "op:verificationPathNote": "exhaustive_enumeration(R_n)",
      "rdfs:comment": "Distributivity: mul(x, add(y, z)) = add(mul(x, y), mul(x, z)).",
      "rdfs:label": "R_M4"
    },
    {
      "@id": "https://uor.foundation/op/R_M5",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "x ∈ R_n",
      "op:lhs": "mul(x, 0)",
      "op:rhs": "0",
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Enumerative"
      },
      "op:verificationPathNote": "exhaustive_enumeration(R_n)",
      "rdfs:comment": "Annihilation: mul(x, 0) = 0.",
      "rdfs:label": "R_M5"
    },
    {
      "@id": "https://uor.foundation/op/B_1",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "x, y, z ∈ R_n",
      "op:lhs": "xor(x, xor(y, z))",
      "op:rhs": "xor(xor(x, y), z)",
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Enumerative"
      },
      "op:verificationPathNote": "exhaustive_enumeration(R_n)",
      "rdfs:comment": "XOR associativity: xor(x, xor(y, z)) = xor(xor(x, y), z).",
      "rdfs:label": "B_1"
    },
    {
      "@id": "https://uor.foundation/op/B_2",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "x ∈ R_n",
      "op:lhs": "xor(x, 0)",
      "op:rhs": "x",
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Enumerative"
      },
      "op:verificationPathNote": "exhaustive_enumeration(R_n)",
      "rdfs:comment": "XOR identity: xor(x, 0) = x.",
      "rdfs:label": "B_2"
    },
    {
      "@id": "https://uor.foundation/op/B_3",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "x ∈ R_n",
      "op:lhs": "xor(x, x)",
      "op:rhs": "0",
      "op:verificationDomain": {
