      },
      "op:verificationPathNote": "ProductType → constraint nerve Euler characteristic additivity",
      "rdfs:comment": "Product type Euler additivity: χ(N(C(A × B))) = χ(N(C(A))) + χ(N(C(B))).",
      "rdfs:label": "PT_3"
    },
    {
      "@id": "https://uor.foundation/op/PT_4",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "A, B: TypeDefinition",
      "op:lhs": "S(A × B)",
      "op:rhs": "S(A) + S(B)",
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Thermodynamic"
      },
