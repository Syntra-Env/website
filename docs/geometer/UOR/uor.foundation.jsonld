      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Algebraic"
      },
      "op:verificationPathNote": "FiberBudget → PrimitiveType → bit-fiber bijection",
      "rdfs:comment": "The fiber budget of a PrimitiveType at quantum level n is exactly n (one fiber per bit).",
      "rdfs:label": "QL_4"
    },
    {
      "@id": "https://uor.foundation/op/QL_5",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "CompleteType, n ≥ 1",
      "op:lhs": "resolution(CompleteType, n)",
      "op:rhs": "O(1) for all n ≥ 1",
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationDomain": {
