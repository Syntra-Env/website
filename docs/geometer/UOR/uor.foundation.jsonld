      "op:rhs": "max(fiberBudget(A), fiberBudget(B))",
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Algebraic"
      },
      "op:verificationPathNote": "SumType → FiberBudget max",
      "rdfs:comment": "Sum type fiber budget: fiberBudget(A + B) = max(fiberBudget(A), fiberBudget(B)).",
