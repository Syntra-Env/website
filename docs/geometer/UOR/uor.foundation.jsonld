        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "simplicial complex K",
      "op:lhs": "C(K)",
      "op:rhs": "ChainComplex",
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Topological"
      },
      "op:verificationPathNote": "SimplicialComplex → ChainFunctor → ChainComplex",
      "rdfs:comment": "ψ_2: SimplicialComplex → ChainComplex (chain functor). Maps a simplicial complex to its chain complex.",
      "rdfs:label": "psi_2"
    },
    {
      "@id": "https://uor.foundation/op/psi_3",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "chain complex C",
      "op:lhs": "H_k(C)",
      "op:rhs": "ker(∂_k) / im(∂_{k+1})",
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Topological"
      },
      "op:verificationPathNote": "ChainComplex → BoundaryOperator → HomologyGroup",
      "rdfs:comment": "ψ_3: ChainComplex → HomologyGroups (homology functor). Computes homology groups from a chain complex.",
      "rdfs:label": "psi_3"
    },
    {
      "@id": "https://uor.foundation/op/psi_5",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "chain complex C, ring R",
      "op:lhs": "C^k",
      "op:rhs": "Hom(C_k, R)",
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Topological"
      },
      "op:verificationPathNote": "ChainComplex → dual → CochainComplex",
      "rdfs:comment": "ψ_5: ChainComplex → CochainComplex (dualization functor). Dualizes a chain complex to obtain a cochain complex.",
      "rdfs:label": "psi_5"
    },
    {
      "@id": "https://uor.foundation/op/psi_6",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "cochain complex C",
      "op:lhs": "H^k(C)",
      "op:rhs": "ker(δ^k) / im(δ^{k-1})",
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Topological"
      },
      "op:verificationPathNote": "CochainComplex → CoboundaryOperator → CohomologyGroup",
      "rdfs:comment": "ψ_6: CochainComplex → CohomologyGroups (cohomology functor). Computes cohomology groups from a cochain complex.",
      "rdfs:label": "psi_6"
    },
    {
      "@id": "https://uor.foundation/op/D2n",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/DihedralGroup"
      ],
      "op:generatedBy": [
        {
          "@id": "https://uor.foundation/op/neg"
        },
        {
          "@id": "https://uor.foundation/op/bnot"
        }
      ],
      "op:presentation": "⟨r, s | r^{2^n} = s² = e, srs = r⁻¹⟩",
      "rdfs:comment": "The dihedral group of order 2^(n+1), generated by neg (ring reflection) and bnot (hypercube reflection). Every element of this group acts as an isometry on the type space 𝒯_n.",
      "rdfs:label": "D_{2^n}"
    },
    {
      "@id": "https://uor.foundation/op/surfaceSymmetry",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "G: GroundingMap, P: ProjectionMap, F: Frame, s: Literal, G.symbolConstraints = P.projectionOrder",
      "op:lhs": "P(Π(G(s)))",
      "op:rhs": "s' where type(s') ≡ type(s) under F.constraint",
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Pipeline"
      },
      "op:verificationPathNote": "GroundingMap → ResolutionPipeline → ProjectionMap: shared-frame condition guarantees type-equivalent neighbourhood",
      "rdfs:comment": "The Surface Symmetry Theorem: the composite P∘Π∘G is a well-typed morphism iff G and P share the same state:Frame F. When the shared-frame condition holds, the output lands in the type-equivalent neighbourhood of the source symbol.",
      "rdfs:label": "Surface Symmetry"
    },
    {
      "@id": "https://uor.foundation/op/CC_1",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "x ∈ R_n, T: CompleteType",
      "op:lhs": "resolution(x, T)",
      "op:rhs": "O(1) for CompleteType T",
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Pipeline"
      },
      "op:verificationPathNote": "CompleteType → CompletenessResolver → O(1) partition",
      "rdfs:comment": "Completeness implies O(1) resolution: a CompleteType T satisfies ∀ x ∈ R_n, resolution(x, T) terminates in O(1).",
      "rdfs:label": "CC_1"
    },
    {
      "@id": "https://uor.foundation/op/CC_2",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "T, T': ConstrainedType, T ⊆ T'",
      "op:lhs": "completeness(T)",
      "op:rhs": "implies completeness(T')",
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Algebraic"
      },
      "op:verificationPathNote": "ConstraintNerve → monotone under constraint addition",
      "rdfs:comment": "Completeness is monotone: if T ⊆ T' (T' has more constraints), then completeness(T) implies completeness(T').",
      "rdfs:label": "CC_2"
    },
    {
      "@id": "https://uor.foundation/op/CC_3",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "W₁, W₂: CompletenessWitness",
      "op:lhs": "fibersClosed(W₁) + fibersClosed(W₂)",
      "op:rhs": "= n for valid concat(W₁, W₂)",
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Algebraic"
      },
      "op:verificationPathNote": "CompletenessWitness → FiberBudget → audit trail",
      "rdfs:comment": "Witness composition: concat(W₁, W₂) is a valid audit trail iff W₁.fibersClosed + W₂.fibersClosed = n.",
      "rdfs:label": "CC_3"
    },
    {
      "@id": "https://uor.foundation/op/CC_4",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "CompletenessCandidate",
      "op:lhs": "CompletenessResolver",
      "op:rhs": "fix(ψ-pipeline, CompletenessCandidate)",
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Pipeline"
      },
      "op:verificationPathNote": "ψ-pipeline fixed point → CompletenessResolver uniqueness",
      "rdfs:comment": "The CompletenessResolver is the unique fixed point of the ψ-pipeline applied to a CompletenessCandidate.",
      "rdfs:label": "CC_4"
    },
    {
      "@id": "https://uor.foundation/op/CC_5",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "cert: CompletenessCertificate",
      "op:lhs": "cert.verified = true",
      "op:rhs": "implies χ(N(C)) = n ∧ ∀k: β_k = 0",
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Topological"
      },
      "op:verificationPathNote": "CompletenessCertificate → ConstraintNerve → Euler characteristic",
      "rdfs:comment": "CompletenessCertificate soundness: cert.verified = true implies χ(N(C)) = n and for all k: β_k = 0.",
      "rdfs:label": "CC_5"
    },
    {
      "@id": "https://uor.foundation/op/QL_1",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "x ∈ R_n, n ≥ 1",
      "op:lhs": "neg(bnot(x))",
      "op:rhs": "succ(x) in Z/(2ⁿ)Z",
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Algebraic"
      },
      "op:verificationPathNote": "Ring axioms → induction on n → universality",
      "rdfs:comment": "neg(bnot(x)) = succ(x) holds in Z/(2ⁿ)Z for all n ≥ 1. Universal form of the Critical Identity across all quantum levels.",
      "rdfs:label": "QL_1"
    },
    {
      "@id": "https://uor.foundation/op/QL_2",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "n ≥ 1",
      "op:lhs": "|D_{2ⁿ}|",
      "op:rhs": "2ⁿ⁺¹ for all n ≥ 1",
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Algebraic"
      },
      "op:verificationPathNote": "DihedralGroup → group order formula → universality",
      "rdfs:comment": "The dihedral group D_{2ⁿ} generated by neg and bnot has order 2ⁿ⁺¹ for all n ≥ 1.",
      "rdfs:label": "QL_2"
    },
    {
      "@id": "https://uor.foundation/op/QL_3",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "j ∈ R_n, n ≥ 1",
      "op:lhs": "P(j) = 2^{-j}",
      "op:rhs": "Boltzmann distribution at β* = ln 2, all n ≥ 1",
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Thermodynamic"
      },
      "op:verificationPathNote": "CascadeEntropy → Boltzmann distribution → universality",
      "rdfs:comment": "The cascade distribution P(j) = 2^{-j} is the Boltzmann distribution at β* = ln 2 for all n ≥ 1.",
      "rdfs:label": "QL_3"
    },
    {
      "@id": "https://uor.foundation/op/QL_4",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "PrimitiveType, n ≥ 1",
      "op:lhs": "fiberBudget(PrimitiveType, n)",
