    {
      "@id": "https://uor.foundation/op/GD_3",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "T: GeodesicTrace",
      "op:lhs": "Cost_geodesic(T)",
      "op:rhs": "freeCount_initial × k_B T × ln 2",
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Thermodynamic"
      },
      "op:verificationPathNote": "GD_2 × stepCount → Landauer bound TH_4 with equality",
      "rdfs:comment": "Total geodesic cost: Cost_geodesic(T) = freeCount_initial × k_B T ln 2 = TH_4.",
      "rdfs:label": "GD_3"
    },
    {
      "@id": "https://uor.foundation/op/GD_4",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "T, T': GeodesicTrace on same ConstrainedType",
      "op:lhs": "Cost(T) for geodesic T",
      "op:rhs": "= Cost(T') for any geodesic T' on same type",
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Analytical"
      },
      "op:verificationPathNote": "Equal-J_k permutation → cost invariance",
      "rdfs:comment": "Geodesic uniqueness up to step-order equivalence: all geodesics for the same ConstrainedType share stepCount and constraint set.",
      "rdfs:label": "GD_4"
    },
    {
      "@id": "https://uor.foundation/op/GD_5",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "T: ComputationTrace",
      "op:lhs": "isSubgeodesic(T)",
      "op:rhs": "∃ i: J_k(step_i) < max_{free} J_k(state_i)",
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Pipeline"
      },
      "op:verificationPathNote": "GeodesicValidator → step-by-step J_k check → violation detection",
      "rdfs:comment": "Subgeodesic detectability: a trace is sub-geodesic iff ∃ step i where J_k(step_i) < max_{free fibers} J_k(state_i).",
      "rdfs:label": "GD_5"
    },
    {
      "@id": "https://uor.foundation/op/QM_1",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "ψ: SuperposedFiberState",
      "op:lhs": "S_vonNeumann(ψ)",
      "op:rhs": "Cost_Landauer(collapse(ψ))",
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/QuantumThermodynamic"
      },
      "op:verificationPathNote": "Von Neumann entropy = Landauer erasure cost at β* = ln 2",
      "rdfs:comment": "Von Neumann–Landauer bridge: S_vonNeumann(ψ) = Cost_Landauer(collapse(ψ)).",
      "rdfs:label": "QM_1"
    },
    {
      "@id": "https://uor.foundation/op/QM_2",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "ψ: SuperposedFiberState",
      "op:lhs": "collapse(ψ)",
      "op:rhs": "apply(ResidueConstraint, collapsed_fiber)",
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Topological"
      },
      "op:verificationPathNote": "Projective collapse ≅ classical fiber-pinning → ψ-pipeline applies",
      "rdfs:comment": "Measurement as fiber topology change: projective collapse on a SuperposedFiberState is topologically equivalent to applying a ResidueConstraint that pins the collapsed fiber.",
      "rdfs:label": "QM_2"
    },
    {
      "@id": "https://uor.foundation/op/QM_3",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "ψ: single-fiber SuperposedFiberState",
      "op:lhs": "S_vN(ψ)",
      "op:rhs": "∈ [0, ln 2]",
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/QuantumThermodynamic"
      },
      "op:verificationPathNote": "Von Neumann entropy bounds → maximum at equal superposition",
      "rdfs:comment": "Superposition entropy bound: 0 ≤ S_vN(ψ) ≤ ln 2 for any single-fiber SuperposedFiberState.",
      "rdfs:label": "QM_3"
    },
    {
      "@id": "https://uor.foundation/op/QM_4",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "ψ: SuperposedFiberState",
      "op:lhs": "collapse(collapse(ψ))",
      "op:rhs": "collapse(ψ)",
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Algebraic"
      },
      "op:verificationPathNote": "CollapsedFiberState → re-measurement is no-op → stepCount = 0",
      "rdfs:comment": "Collapse idempotence: collapse(collapse(ψ)) = collapse(ψ). Measurement on an already-collapsed state is a no-op.",
      "rdfs:label": "QM_4"
    },
    {
      "@id": "https://uor.foundation/op/QM_5",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "SuperposedFiberState ψ",
      "op:lhs": "Σᵢ |αᵢ|²",
      "op:rhs": "1",
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/QuantumThermodynamic"
      },
      "op:verificationPathNote": "Born rule → probability axioms → normalization",
      "rdfs:comment": "Amplitude normalization (Born rule): the sum of squared amplitudes equals 1 for any well-formed SuperposedFiberState.",
      "rdfs:label": "QM_5"
    },
    {
      "@id": "https://uor.foundation/op/RC_6",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "SuperposedFiberState ψ",
      "op:lhs": "normalize(ψ)",
      "op:rhs": "ψ / sqrt(Σ |αᵢ|²)",
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/SuperpositionDomain"
      },
      "op:verificationPathNote": "Division by norm → idempotent normalization",
      "rdfs:comment": "Amplitude renormalization: a SuperposedFiberState can always be normalized to satisfy QM_5.",
      "rdfs:label": "RC_6"
    },
    {
      "@id": "https://uor.foundation/op/FPM_8",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "Partition P over R_n",
      "op:lhs": "|Irr| + |Red| + |Unit| + |Ext|",
      "op:rhs": "2ⁿ",
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Enumerative"
      },
      "op:verificationPathNote": "Exhaustive partition → cardinality sum → ring size",
      "rdfs:comment": "Partition exhaustiveness: the four component cardinalities sum to the ring size.",
      "rdfs:label": "FPM_8"
    },
    {
      "@id": "https://uor.foundation/op/FPM_9",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "TypeDefinition T, Datum x",
      "op:lhs": "x ∈ Ext(T)",
      "op:rhs": "x ∉ carrier(T)",
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Algebraic"
      },
      "op:verificationPathNote": "Carrier complement → context-dependent exterior",
      "rdfs:comment": "Exterior membership criterion: x is exterior iff x is not in the carrier of T.",
      "rdfs:label": "FPM_9"
    },
    {
      "@id": "https://uor.foundation/op/MN_8",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "ConstrainedType T with holonomyGroup",
      "op:lhs": "holonomyClassified(T)",
      "op:rhs": "isFlatType(T) xor isTwistedType(T)",
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Topological"
      },
      "op:verificationPathNote": "Holonomy group → flat iff trivial → bivalent classification",
      "rdfs:comment": "Holonomy classification covering: every ConstrainedType with a computed holonomy group is either flat or twisted, not both.",
      "rdfs:label": "MN_8"
    },
    {
      "@id": "https://uor.foundation/op/QL_8",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "QuantumLevel Q_k with nextLevel defined",
      "op:lhs": "levelSuccessor(nextLevel(Q_k))",
      "op:rhs": "Q_k",
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Algebraic"
      },
      "op:verificationPathNote": "Chain successor → left inverse → Q_k recovery",
      "rdfs:comment": "Quantum level chain inverse: levelSuccessor is the left inverse of nextLevel.",
      "rdfs:label": "QL_8"
    },
    {
      "@id": "https://uor.foundation/op/D_7",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "DihedralElement rᵃ sᵖ, rᵇ sᵠ in D_{2ⁿ}",
      "op:lhs": "compose(rᵃ sᵖ, rᵇ sᵠ)",
      "op:rhs": "r^((a + (-1)ᵖ b) mod 2ⁿ) s^(p xor q)",
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Geometric"
      },
      "op:verificationPathNote": "Dihedral presentation → semidirect product → composition formula",
      "rdfs:comment": "Dihedral composition rule: (rᵃ sᵖ)(rᵇ sᵠ) = r^(a + (-1)ᵖ b mod 2ⁿ) s^(p xor q).",
      "rdfs:label": "D_7"
    },
    {
      "@id": "https://uor.foundation/op/SP_1",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "Datum x",
      "op:lhs": "resolve_superposition(classical(x))",
      "op:rhs": "resolve_classical(x)",
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/SuperpositionDomain"
      },
      "op:verificationPathNote": "Classical datum → single fiber with amplitude 1 → classical path",
      "rdfs:comment": "Classical embedding: superposition resolution of a classical (non-superposed) datum reduces to classical resolution.",
      "rdfs:label": "SP_1"
    },
    {
      "@id": "https://uor.foundation/op/SP_2",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "SuperposedFiberState ψ",
      "op:lhs": "collapse(resolve_superposition(ψ))",
      "op:rhs": "resolve_classical(collapse(ψ))",
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/QuantumThermodynamic"
      },
      "op:verificationPathNote": "Projective collapse → classical fiber → resolution commutativity",
      "rdfs:comment": "Collapse–resolve commutativity: collapsing then resolving classically equals resolving in superposition then collapsing.",
      "rdfs:label": "SP_2"
    },
    {
      "@id": "https://uor.foundation/op/SP_3",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "SuperposedFiberState ψ",
      "op:lhs": "amplitudeVector(resolve_superposition(ψ))",
      "op:rhs": "normalized",
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/SuperpositionDomain"
      },
      "op:verificationPathNote": "ψ-pipeline → amplitude tracking → normalization invariant",
      "rdfs:comment": "Amplitude preservation: the SuperpositionResolver preserves the normalized amplitude vector during ψ-pipeline traversal.",
      "rdfs:label": "SP_3"
    },
    {
      "@id": "https://uor.foundation/op/SP_4",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "SuperposedFiberState ψ, fiber index k",
      "op:lhs": "P(collapse to fiber k)",
      "op:rhs": "|α_k|²",
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/QuantumThermodynamic"
      },
      "op:verificationPathNote": "Born rule → squared amplitude → outcome probability",
      "rdfs:comment": "Born rule outcome probability: the probability of collapsing to fiber k equals the squared amplitude of that fiber.",
      "rdfs:label": "SP_4"
    },
    {
      "@id": "https://uor.foundation/op/PT_2a",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "ProductType A × B",
      "op:lhs": "Π(A × B)",
      "op:rhs": "PartitionProduct(Π(A), Π(B))",
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Algebraic"
      },
      "op:verificationPathNote": "Product type → component-wise partition → tensor product",
      "rdfs:comment": "Product type partition tensor: the partition of a product type is the tensor product of the component partitions.",
      "rdfs:label": "PT_2a"
    },
    {
      "@id": "https://uor.foundation/op/PT_2b",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "SumType A + B",
      "op:lhs": "Π(A + B)",
      "op:rhs": "PartitionCoproduct(Π(A), Π(B))",
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Algebraic"
      },
      "op:verificationPathNote": "Sum type → variant partition → disjoint union coproduct",
      "rdfs:comment": "Sum type partition coproduct: the partition of a sum type is the coproduct of the variant partitions.",
      "rdfs:label": "PT_2b"
    },
    {
      "@id": "https://uor.foundation/op/GD_6",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "ComputationTrace trace",
      "op:lhs": "isGeodesic(trace)",
      "op:rhs": "isAR1Ordered(trace) ∧ isDC10Selected(trace)",
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Analytical"
      },
      "op:verificationPathNote": "Geodesic condition → AR_1 ordering + DC_10 selection → conjunction",
      "rdfs:comment": "Geodesic predicate decomposition: a trace is geodesic iff it is both AR_1-ordered and DC_10-selected.",
      "rdfs:label": "GD_6"
    },
    {
      "@id": "https://uor.foundation/op/QT_1",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "LiftChain from Q_j to Q_k",
      "op:lhs": "LiftChain(Q_j, Q_k) valid",
      "op:rhs": "every chainStep has trivial or resolved LiftObstruction",
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/IndexTheoretic"
      },
      "op:verificationPathNote": "LiftChain → chainStep → LiftObstruction resolution",
      "rdfs:comment": "LiftChain(Q_j, Q_k) is valid CompleteType tower iff every chainStep QuantumLift has trivial or resolved LiftObstruction.",
      "rdfs:label": "QT_1"
    },
    {
      "@id": "https://uor.foundation/op/QT_2",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "LiftChain",
      "op:lhs": "obstructionCount(chain)",
      "op:rhs": "<= chainLength(chain)",
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/IndexTheoretic"
      },
      "op:verificationPathNote": "LiftChain → ObstructionChain → obstructionCount ≤ chainLength",
      "rdfs:comment": "Obstruction count bound: the number of non-trivial LiftObstructions in a chain is at most the chain length.",
      "rdfs:label": "QT_2"
    },
    {
      "@id": "https://uor.foundation/op/QT_3",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "LiftChain with source Q_j, target Q_k",
      "op:lhs": "resolvedBasisSize(Q_k)",
      "op:rhs": "basisSize(Q_j) + chainLength + obstructionResolutionCost",
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/IndexTheoretic"
      },
      "op:verificationPathNote": "LiftChain → resolvedBasisSize accumulation formula",
      "rdfs:comment": "Resolved basis size formula: the basis size at Q_k equals basisSize(Q_j) + chainLength + obstructionResolutionCost.",
      "rdfs:label": "QT_3"
    },
    {
      "@id": "https://uor.foundation/op/QT_4",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "LiftChain",
      "op:lhs": "isFlat(chain)",
      "op:rhs": "obstructionCount = 0 iff HolonomyGroup trivial at every step",
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Topological"
      },
      "op:verificationPathNote": "LiftChain → ObstructionChain → isFlat ↔ trivial holonomy",
      "rdfs:comment": "Flat tower characterization: isFlat(chain) iff obstructionCount = 0 iff HolonomyGroup trivial at every step.",
      "rdfs:label": "QT_4"
    },
    {
      "@id": "https://uor.foundation/op/QT_5",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "Q_k for arbitrary k",
      "op:lhs": "LiftChainCertificate exists",
      "op:rhs": "CompleteType at Q_k satisfies IT_7d with witness chain",
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/IndexTheoretic"
      },
      "op:verificationPathNote": "LiftChainCertificate → certifiedChain → IT_7d compliance",
      "rdfs:comment": "LiftChainCertificate existence: a CompleteType at Q_k satisfies IT_7d with a witness chain.",
      "rdfs:label": "QT_5"
    },
    {
      "@id": "https://uor.foundation/op/QT_6",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "Single-step chains",
      "op:lhs": "QT_3 with chainLength=1, cost=0",
      "op:rhs": "reduces to QLS_3",
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/IndexTheoretic"
      },
      "op:verificationPathNote": "QT_3 specialization → chainLength=1 → QLS_3 identity",
      "rdfs:comment": "Single-step reduction: QT_3 with chainLength=1 and cost=0 reduces to QLS_3.",
      "rdfs:label": "QT_6"
    },
    {
      "@id": "https://uor.foundation/op/QT_7",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "LiftChain with isFlat = true",
      "op:lhs": "flat chain resolvedBasisSize(Q_k)",
      "op:rhs": "basisSize(Q_j) + (k - j)",
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/IndexTheoretic"
      },
      "op:verificationPathNote": "Flat LiftChain → zero obstruction cost → linear basis growth",
      "rdfs:comment": "Flat chain basis size: for flat chains, resolvedBasisSize(Q_k) = basisSize(Q_j) + (k - j).",
      "rdfs:label": "QT_7"
    },
    {
      "@id": "https://uor.foundation/op/CC_PINS",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "bit-pattern p in CarryConstraint",
      "op:lhs": "pinsFibers(CarryConstraint(p))",
      "op:rhs": "{k : p(k)=1} union {first-zero(p)}",
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Algebraic"
      },
      "op:verificationPathNote": "Ring carry propagation rule; exhaustive enum at Q0",
      "rdfs:comment": "Carry-constraint fiber-pinning map: pinsFibers(CarryConstraint(p)) equals the set of bit positions where p has a 1 plus the first-zero stopping position.",
      "rdfs:label": "CC_PINS"
    },
    {
      "@id": "https://uor.foundation/op/CC_COST_FIBER",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "bit-pattern p in CarryConstraint",
      "op:lhs": "|pinsFibers(CarryConstraint(p))|",
      "op:rhs": "popcount(p) + 1",
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Enumerative"
      },
      "op:verificationPathNote": "Exhaustive enumeration at Q0; refines cr_2",
      "rdfs:comment": "Carry-constraint cost-to-fiber count: the number of fibers pinned by a CarryConstraint equals popcount plus one for the stopping position.",
      "rdfs:label": "CC_COST_FIBER"
    },
    {
      "@id": "https://uor.foundation/op/jsat_RR",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "ResidueConstraint pairs over R_n",
      "op:lhs": "jointSat(Res(m1,r1), Res(m2,r2))",
      "op:rhs": "gcd(m1,m2) | (r1 - r2)",
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Algebraic"
      },
      "op:verificationPathNote": "Chinese Remainder Theorem; exhaustive enum at Q0",
      "rdfs:comment": "CRT joint satisfiability: two ResidueConstraints are jointly satisfiable iff the gcd of their moduli divides the difference of their residues.",
      "rdfs:label": "jsat_RR"
    },
    {
      "@id": "https://uor.foundation/op/jsat_CR",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "CarryConstraint, ResidueConstraint pairs",
      "op:lhs": "jointSat(Carry(p), Res(m,r))",
      "op:rhs": "pin-fiber intersection residue-class compatible",
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Algebraic"
      },
      "op:verificationPathNote": "Carry stopping rule + residue class intersection",
      "rdfs:comment": "Carry-residue joint satisfiability: a CarryConstraint and ResidueConstraint are jointly satisfiable iff the carry-pinned fibers are compatible with the residue class.",
      "rdfs:label": "jsat_CR"
    },
    {
      "@id": "https://uor.foundation/op/jsat_CC",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "CarryConstraint pairs over R_n",
      "op:lhs": "jointSat(Carry(p1), Carry(p2))",
      "op:rhs": "p1 AND p2 conflict-free",
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Enumerative"
      },
      "op:verificationPathNote": "Bit-pattern exhaustive enumeration at Q0",
      "rdfs:comment": "Carry-carry joint satisfiability: two CarryConstraints are jointly satisfiable iff their bit-patterns have no conflicting positions.",
      "rdfs:label": "jsat_CC"
    },
    {
      "@id": "https://uor.foundation/op/D_8",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "a in 0..2^n, p in {0,1}",
      "op:lhs": "(r^a s^p)^(-1)",
      "op:rhs": "r^(-(−1)^p a mod 2^n) s^p",
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Algebraic"
      },
      "op:verificationPathNote": "D_5 group presentation + D_7 composition",
      "rdfs:comment": "Dihedral inverse formula: the inverse of r^a s^p in D_(2^n) is r^(-(−1)^p a mod 2^n) s^p.",
      "rdfs:label": "D_8"
    },
    {
      "@id": "https://uor.foundation/op/D_9",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "k in Z/(2^n)Z",
      "op:lhs": "ord(r^k s^1)",
      "op:rhs": "2",
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Algebraic"
      },
      "op:verificationPathNote": "D_7: (r^k s)(r^k s) = r^0 s^0 = identity",
      "rdfs:comment": "Dihedral reflection order: every reflection element r^k s^1 in D_(2^n) has order 2.",
      "rdfs:label": "D_9"
    },
    {
      "@id": "https://uor.foundation/op/EXP_1",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "ConstrainedType C over R_n",
      "op:lhs": "carrier(C) is monotone",
      "op:rhs": "all residues of C = modulus - 1, no Carry/Depth",
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Algebraic"
      },
      "op:verificationPathNote": "Fiber lattice monotonicity + R_n bit structure",
      "rdfs:comment": "Monotone carrier characterization: a ConstrainedType has an upward-closed carrier iff every ResidueConstraint has residue = modulus - 1 and no CarryConstraint or DepthConstraint appears.",
      "rdfs:label": "EXP_1"
    },
    {
      "@id": "https://uor.foundation/op/EXP_2",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "QuantumLevel Q_n, n >= 1",
      "op:lhs": "count of monotone ConstrainedTypes at Q_n",
      "op:rhs": "2^n",
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Enumerative"
      },
      "op:verificationPathNote": "Principal filter count; exhaustive enum at Q0",
      "rdfs:comment": "Monotone constraint count: the number of expressible monotone ConstrainedTypes at quantum level Q_n is 2^n, corresponding to the principal filter count.",
      "rdfs:label": "EXP_2"
    },
    {
      "@id": "https://uor.foundation/op/EXP_3",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "SumType A + B",
      "op:lhs": "carrier(SumType(A,B))",
      "op:rhs": "coproduct(carrier(A), carrier(B))",
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Algebraic"
      },
      "op:verificationPathNote": "Definitional; architectural decision identity",
      "rdfs:comment": "SumType carrier semantics: the carrier of a SumType is the coproduct (disjoint union) of component carriers, not the set-theoretic union.",
      "rdfs:label": "EXP_3"
    },
    {
      "@id": "https://uor.foundation/op/ST_3",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "disjoint SumType A + B",
      "op:lhs": "chi(N(C(A+B)))",
      "op:rhs": "chi(N(C(A))) + chi(N(C(B)))",
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/IndexTheoretic"
      },
      "op:verificationPathNote": "Disjoint simplicial complex Euler formula",
      "rdfs:comment": "SumType Euler characteristic additivity: for a SumType with topologically disjoint component nerves, the Euler characteristic is additive.",
      "rdfs:label": "ST_3"
    },
    {
      "@id": "https://uor.foundation/op/ST_4",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "disjoint SumType A + B, k >= 0",
      "op:lhs": "beta_k(N(C(A+B)))",
      "op:rhs": "beta_k(N(C(A))) + beta_k(N(C(B)))",
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Topological"
      },
      "op:verificationPathNote": "Mayer-Vietoris for disjoint union",
      "rdfs:comment": "SumType Betti number additivity: for disjoint component nerves, all Betti numbers are additive.",
      "rdfs:label": "ST_4"
    },
    {
      "@id": "https://uor.foundation/op/ST_5",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "SumType A + B",
      "op:lhs": "CompleteType(A + B)",
      "op:rhs": "CompleteType(A) and CompleteType(B) and Q(A)=Q(B)",
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/IndexTheoretic"
      },
      "op:verificationPathNote": "ST_3 + ST_4 + IT_7d",
      "rdfs:comment": "SumType completeness transfer: a SumType A+B is CompleteType iff both A and B are CompleteType and they have equal quantum levels.",
      "rdfs:label": "ST_5"
    },
    {
      "@id": "https://uor.foundation/op/TS_8",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "first Betti number k >= 1, n-fiber type",
      "op:lhs": "min constraints for beta_1 = k",
      "op:rhs": "2k + 1",
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Pipeline"
      },
      "op:verificationPathNote": "Simplicial cycle construction; inductive on k",
      "rdfs:comment": "Betti-1 minimum constraint count: the minimum number of constraints needed to achieve first Betti number beta_1 = k in the constraint nerve is 2k + 1.",
      "rdfs:label": "TS_8"
    },
    {
      "@id": "https://uor.foundation/op/TS_9",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "QuantumLevel Q_n, any target signature",
      "op:lhs": "TypeSynthesisResolver terminates",
      "op:rhs": "within 2^n steps",
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Pipeline"
      },
      "op:verificationPathNote": "Finite constraint combination space; inductive on n",
      "rdfs:comment": "TypeSynthesisResolver termination: the resolver terminates in at most 2^n steps for any target signature at quantum level Q_n, returning either a ConstrainedType or a ForbiddenSignature certificate.",
      "rdfs:label": "TS_9"
    },
    {
      "@id": "https://uor.foundation/op/TS_10",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "topological signature sigma at Q_n",
      "op:lhs": "ForbiddenSignature(sigma)",
      "op:rhs": "no ConstrainedType with <= n constraints realises sigma",
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Algebraic"
      },
      "op:verificationPathNote": "Exhaustive enum at Q0; combinatorial bound",
      "rdfs:comment": "ForbiddenSignature membership criterion: a topological signature is a ForbiddenSignature iff no ConstrainedType with at most n constraints realises it at quantum level Q_n.",
      "rdfs:label": "TS_10"
    },
    {
      "@id": "https://uor.foundation/op/QT_8",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "LiftChain from Q_j to Q_k",
      "op:lhs": "ObstructionChain length from Q_j to Q_k",
      "op:rhs": "<= (k-j) * C(basisSize(Q_j), 3)",
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/IndexTheoretic"
      },
      "op:verificationPathNote": "QLS_2 + spectral sequence convergence bound",
      "rdfs:comment": "ObstructionChain length bound: the length of the ObstructionChain from Q_j to Q_k is at most (k-j) times C(basisSize(Q_j), 3).",
      "rdfs:label": "QT_8"
    },
    {
      "@id": "https://uor.foundation/op/QT_9",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "LiftChain of finite length",
      "op:lhs": "TowerCompletenessResolver terminates",
      "op:rhs": "within QT_8 bound",
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Pipeline"
      },
      "op:verificationPathNote": "Finite chain + QT_8 bound",
      "rdfs:comment": "TowerCompletenessResolver termination: the resolver terminates for any finite LiftChain within the QT_8 bound, producing a CompleteType certificate or a bounded ObstructionChain.",
      "rdfs:label": "QT_9"
    },
    {
      "@id": "https://uor.foundation/op/COEFF_1",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "ConstraintNerve N(C) at any quantum level",
      "op:lhs": "standard coefficient ring for psi-pipeline",
      "op:rhs": "Z/2Z",
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Algebraic"
      },
      "op:verificationPathNote": "Definitional; MN_7 consistency requirement",
      "rdfs:comment": "Standard coefficient ring: the coefficient ring for all psi-pipeline cohomology computations in uor.foundation is Z/2Z, consistent with MN_7.",
      "rdfs:label": "COEFF_1"
    },
    {
      "@id": "https://uor.foundation/op/GO_1",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "GluingObstruction c, cycle pair (C_i, C_j)",
      "op:lhs": "pinsFibers(killing constraint for obstruction c)",
      "op:rhs": "superset of pinsFibers(C_i) cap pinsFibers(C_j)",
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Topological"
      },
      "op:verificationPathNote": "Cohomology killing lemma; psi_6 output",
      "rdfs:comment": "GluingObstruction feedback: given a GluingObstruction class in H^1(N(C)), the killing RefinementSuggestion adds a constraint whose pinned fibers contain the intersection of the cycle-generating pair.",
      "rdfs:label": "GO_1"
    },
    {
      "@id": "https://uor.foundation/op/SR_6",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "saturated Session, new RelationQuery q",
      "op:lhs": "freeCount(q) after saturation",
      "op:rhs": "fibers of q not in BindingAccumulator",
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Algebraic"
      },
      "op:verificationPathNote": "SR_1 monotone accumulation + SC_2 formula",
      "rdfs:comment": "Saturation re-entry free count: for a session at full saturation, a new query q has freeCount equal to the number of q's fiber coordinates not already bound.",
      "rdfs:label": "SR_6"
    },
    {
      "@id": "https://uor.foundation/op/SR_7",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "SessionResolver, new query q",
      "op:lhs": "sigma after re-entry with query q",
      "op:rhs": "min(sigma, 1 - freeCount(q)/n)",
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Algebraic"
      },
      "op:verificationPathNote": "SC_2 definition + SR_1 monotonicity",
      "rdfs:comment": "Saturation degree degradation: after re-entry with query q, the saturation degree becomes min(current sigma, 1 - freeCount(q)/n).",
      "rdfs:label": "SR_7"
    },
    {
      "@id": "https://uor.foundation/op/QM_6",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "SuperposedFiberState over ConstrainedType T at Q_n",
      "op:lhs": "amplitude index set of SuperposedFiberState over T",
      "op:rhs": "monotone pinning trajectories consistent with T",
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/SuperpositionDomain"
      },
      "op:verificationPathNote": "Fiber lattice + constraint filter; enum at Q0-Q3",
      "rdfs:comment": "Amplitude index set characterization: the amplitude index set of a SuperposedFiberState over ConstrainedType T at Q_n is the set of monotone pinning trajectories consistent with T's constraints.",
      "rdfs:label": "QM_6"
    },
    {
      "@id": "https://uor.foundation/op/CIC_1",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "Transform T",
      "op:lhs": "valid(T) ∧ T: Transform",
      "op:rhs": "∃ c: TransformCertificate. certifies(c, T)",
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Pipeline"
      },
      "op:verificationPathNote": "Transform → TransformCertificate issuance",
      "rdfs:comment": "Certificate issuance: every valid Transform admits a TransformCertificate attesting correct source-to-target mapping.",
      "rdfs:label": "CIC_1"
    },
    {
      "@id": "https://uor.foundation/op/CIC_2",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "Isometry T",
      "op:lhs": "isometry(T) ∧ metric-preserving(T)",
      "op:rhs": "∃ c: IsometryCertificate. certifies(c, T)",
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Geometric"
      },
      "op:verificationPathNote": "Isometry → IsometryCertificate issuance",
      "rdfs:comment": "Certificate issuance: every metric-preserving Transform admits an IsometryCertificate attesting distance preservation.",
      "rdfs:label": "CIC_2"
    },
    {
      "@id": "https://uor.foundation/op/CIC_3",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "Involution f",
      "op:lhs": "f(f(x)) = x ∀ x ∈ R_n",
      "op:rhs": "∃ c: InvolutionCertificate. certifies(c, f)",
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Algebraic"
      },
      "op:verificationPathNote": "Involution → InvolutionCertificate issuance",
      "rdfs:comment": "Certificate issuance: every involutive operation f where f(f(x)) = x admits an InvolutionCertificate.",
      "rdfs:label": "CIC_3"
    },
    {
      "@id": "https://uor.foundation/op/CIC_4",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "SaturatedContext C",
      "op:lhs": "σ(C) = 1 ∧ freeCount = 0",
      "op:rhs": "∃ c: SaturationCertificate. certifies(c, C)",
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Thermodynamic"
      },
      "op:verificationPathNote": "SC_4 → SaturationCertificate issuance",
      "rdfs:comment": "Certificate issuance: full saturation (σ = 1, freeCount = 0) admits a SaturationCertificate.",
      "rdfs:label": "CIC_4"
    },
    {
      "@id": "https://uor.foundation/op/CIC_5",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "GeodesicTrace",
      "op:lhs": "AR_1-ordered ∧ DC_10-selected trace",
      "op:rhs": "∃ c: GeodesicCertificate. certifies(c, trace)",
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Pipeline"
      },
      "op:verificationPathNote": "GD_1 → GeodesicCertificate issuance",
      "rdfs:comment": "Certificate issuance: an AR_1-ordered and DC_10-selected trace admits a GeodesicCertificate.",
      "rdfs:label": "CIC_5"
    },
    {
      "@id": "https://uor.foundation/op/CIC_6",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "MeasurementEvent",
      "op:lhs": "S_vN = L_cost at β* = ln 2",
      "op:rhs": "∃ c: MeasurementCertificate. certifies(c, event)",
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/QuantumThermodynamic"
      },
      "op:verificationPathNote": "QM_1 → MeasurementCertificate issuance",
      "rdfs:comment": "Certificate issuance: a MeasurementEvent verifying the von Neumann–Landauer bridge at β* = ln 2 admits a MeasurementCertificate.",
      "rdfs:label": "CIC_6"
    },
    {
      "@id": "https://uor.foundation/op/CIC_7",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "MeasurementEvent with amplitude vector",
      "op:lhs": "P(k) = |α_k|² verified",
      "op:rhs": "∃ c: BornRuleVerification. certifies(c, event)",
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/QuantumThermodynamic"
      },
      "op:verificationPathNote": "QM_5 → BornRuleVerification issuance",
      "rdfs:comment": "Certificate issuance: a MeasurementEvent verifying P(outcome k) = |α_k|² admits a BornRuleVerification certificate.",
      "rdfs:label": "CIC_7"
    },
    {
      "@id": "https://uor.foundation/op/GC_1",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "GroundingMap with valid ProjectionMap",
      "op:lhs": "shared-frame grounding of symbol s",
      "op:rhs": "∃ c: GroundingCertificate. certifies(c, map)",
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Pipeline"
      },
      "op:verificationPathNote": "surfaceSymmetry → GroundingCertificate issuance",
      "rdfs:comment": "Certificate issuance: shared-frame grounding that lands in the type-equivalent neighbourhood admits a GroundingCertificate.",
      "rdfs:label": "GC_1"
    },
    {
      "@id": "https://uor.foundation/op/SR_8",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "S_A, S_B: Session at quantum level Q_k (k ≥ 0)",
      "op:lhs": "compose(S_A, S_B) valid at Q_k",
      "op:rhs": "∀ j ≤ k: ∀ a ∈ pinnedFibers(S_A, Q_j) ∩ pinnedFibers(S_B, Q_j): datum(S_A, a, Q_j) = datum(S_B, a, Q_j)",
      "op:universallyValid": false,
      "op:validKMin": 0,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/ParametricLower"
      },
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Algebraic"
      },
      "op:verificationPathNote": "SR_5 contradiction criterion extended over LiftChain tower Q_0…Q_k; base case k=0 is standard SR_5",
      "rdfs:comment": "Session composition validity: compose(S_A, S_B) is valid at Q_k iff all pinned-fiber intersections agree at every tower level Q_0 through Q_k.",
      "rdfs:label": "SR_8"
    },
    {
      "@id": "https://uor.foundation/op/SR_9",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "L_A, L_B: ContextLease on SharedContext C, L_A ≠ L_B",
      "op:lhs": "leasedFibers(L_A) ∩ leasedFibers(L_B)",
      "op:rhs": "= ∅",
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Algebraic"
      },
      "op:verificationPathNote": "ContextLease disjointness → FiberBudget partition → SR_1 per-session soundness",
      "rdfs:comment": "ContextLease disjointness: two distinct leases on the same SharedContext have non-overlapping fiber sets.",
      "rdfs:label": "SR_9"
    },
    {
      "@id": "https://uor.foundation/op/SR_10",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "SessionResolver R with ExecutionPolicy P, pending query set Q",
      "op:lhs": "finalState(R, P_1, Q)",
      "op:rhs": "= finalState(R, P_2, Q) for any P_1, P_2: ExecutionPolicy",
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Algebraic"
      },
      "op:verificationPathNote": "SR_1 monotonicity + SR_2 binding soundness → policy-invariant convergence",
      "rdfs:comment": "ExecutionPolicy confluence: different execution policies on the same pending query set produce the same final resolved state (Church-Rosser for session resolution).",
      "rdfs:label": "SR_10"
    },
    {
      "@id": "https://uor.foundation/op/MC_1",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "SharedContext C; leaseSet {L_1, …, L_k} covering all fibers of C",
      "op:lhs": "Σᵢ freeCount(leasedFibers(L_i))",
      "op:rhs": "= freeCount(C)",
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Algebraic"
      },
      "op:verificationPathNote": "SR_9 (pairwise disjoint leasedFibers) + F_3 (pinnedCount + freeCount = n) → partition additivity",
      "rdfs:comment": "Lease partition conserves total budget: the sum of freeCount over all leases equals the SharedContext freeCount.",
      "rdfs:label": "MC_1"
    },
    {
      "@id": "https://uor.foundation/op/MC_2",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "ContextLease L held by Session S; binding step i within S restricted to leasedFibers(L)",
      "op:lhs": "freeCount(B_{i+1} |_L)",
      "op:rhs": "≤ freeCount(B_i |_L)",
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Algebraic"
      },
      "op:verificationPathNote": "SR_9 → lease is fiber-disjoint → SR_1 holds within leasedFibers(L)",
      "rdfs:comment": "Per-lease binding monotonicity: within a leased sub-domain, freeCount decreases monotonically (SR_1 restricted to lease).",
      "rdfs:label": "MC_2"
    },
    {
      "@id": "https://uor.foundation/op/MC_3",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "S_A, S_B: Session; compose(S_A, S_B) valid (SR_8 satisfied)",
      "op:lhs": "freeCount(compose(S_A, S_B))",
      "op:rhs": "freeCount(S_A) + freeCount(S_B) − |pinnedFibers(S_A) ∩ pinnedFibers(S_B)|",
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Algebraic"
      },
      "op:verificationPathNote": "FL_3 (join = union of pinnings) + F_3 + inclusion-exclusion; SR_8 ensures datum consistency",
      "rdfs:comment": "General composition freeCount via inclusion-exclusion.",
      "rdfs:label": "MC_3"
    },
    {
      "@id": "https://uor.foundation/op/MC_4",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "S_A, S_B on ContextLeases L_A, L_B within SharedContext C; SR_9 holds",
      "op:lhs": "freeCount(compose(S_A, S_B))",
      "op:rhs": "= freeCount(S_A) + freeCount(S_B)",
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Algebraic"
      },
      "op:verificationPathNote": "MC_3 with |pinnedFibers(S_A) ∩ pinnedFibers(S_B)| = 0 by SR_9",
      "rdfs:comment": "Disjoint-lease composition is additive: the intersection term vanishes when leases are fiber-disjoint (SR_9).",
      "rdfs:label": "MC_4"
    },
    {
      "@id": "https://uor.foundation/op/MC_5",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "SessionResolver R; pending query set Q; ExecutionPolicy P_1, P_2",
      "op:lhs": "finalBindings(R, P_1, Q)",
      "op:rhs": "= finalBindings(R, P_2, Q)",
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Algebraic"
      },
      "op:verificationPathNote": "SR_10 (finalState equal) + SR_1 (idempotent pinning on FL_3) → binding-set equality",
      "rdfs:comment": "Policy-invariant final binding set: different execution policies produce identical FiberPinning records.",
      "rdfs:label": "MC_5"
    },
    {
      "@id": "https://uor.foundation/op/MC_6",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "SharedContext C; leases {L_1, …, L_k} pairwise disjoint (SR_9) and fully covering C; each S_i with freeCount = 0 within L_i",
      "op:lhs": "σ(compose(S_1, …, S_k))",
      "op:rhs": "= 1 (FullSaturation)",
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Algebraic"
      },
      "op:verificationPathNote": "SR_9 + MC_4 (inductive) + F_4 (isClosed) + SC_4 (σ = 1 ↔ freeCount = 0)",
      "rdfs:comment": "Full lease coverage implies composed saturation: k sessions on disjoint covering leases, each locally converged, produce a SaturatedContext via composition.",
      "rdfs:label": "MC_6"
    },
    {
      "@id": "https://uor.foundation/op/MC_7",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "q: RelationQuery; C* = compose(S_1, …, S_k) with σ(C*) = 1 by MC_6",
      "op:lhs": "stepCount(q, C*)",
      "op:rhs": "= 0",
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Pipeline"
      },
      "op:verificationPathNote": "MC_6 (σ = 1) → SC_4 (freeCount = 0) → SC_5 (stepCount = 0); O(1) is substrate-agnostic",
      "rdfs:comment": "Distributed O(1) resolution: a query against a composed SaturatedContext resolves in zero steps.",
      "rdfs:label": "MC_7"
    },
    {
      "@id": "https://uor.foundation/op/MC_8",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "SharedContext C with totalFibers = n; uniform partition into k leases",
      "op:lhs": "max_i stepCount(S_i to convergence within L_i)",
      "op:rhs": "≤ ⌈n/k⌉",
      "op:universallyValid": true,
      "op:validityKind": {
        "@id": "https://uor.foundation/op/Universal"
      },
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Algebraic"
      },
      "op:verificationPathNote": "F_2 (pin ops ≤ fiber count) + SR_9 (|leasedFibers(L_i)| = ⌈n/k⌉) → per-session bound",
      "rdfs:comment": "Parallelism bound: per-session resolution work is bounded by lease size, not by total fiber count n.",
      "rdfs:label": "MC_8"
    },
    {
      "@id": "https://uor.foundation/query/",
      "@type": "owl:Ontology",
      "owl:imports": [
        {
          "@id": "https://uor.foundation/schema/"
        },
        {
          "@id": "https://uor.foundation/u/"
        },
        {
          "@id": "https://uor.foundation/type/"
        },
        {
          "@id": "https://uor.foundation/partition/"
        },
        {
          "@id": "https://uor.foundation/morphism/"
        },
        {
          "@id": "https://uor.foundation/state/"
        }
      ],
      "rdfs:comment": "Information extraction queries. Users initiate queries; the kernel resolves them against the ring substrate.",
      "rdfs:label": "UOR Queries",
      "uor:space": "bridge"
    },
    {
      "@id": "https://uor.foundation/query/Query",
      "@type": "owl:Class",
      "rdfs:comment": "A request for information from the UOR kernel. The root abstraction for all query types.",
      "rdfs:label": "Query",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/query/CoordinateQuery",
      "@type": "owl:Class",
      "rdfs:comment": "A query for the ring-coordinate position of a datum: its stratum, spectrum, and address within the ring geometry.",
      "rdfs:label": "CoordinateQuery",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/query/Query"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/query/MetricQuery",
      "@type": "owl:Class",
      "rdfs:comment": "A query for a metric value between two datums: ring distance, Hamming distance, or their divergence (curvature).",
      "rdfs:label": "MetricQuery",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/query/Query"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/query/RepresentationQuery",
      "@type": "owl:Class",
      "rdfs:comment": "A query for the canonical representation of a datum or term: its normal form under the active resolver strategy.",
      "rdfs:label": "RepresentationQuery",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/query/Query"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/query/RelationQuery",
      "@type": "owl:Class",
      "rdfs:comment": "A Query with a known source address, a typed relation constraint, and an open target partition:FiberBudget. Represents any question of the form: given this source symbol and relation type, what is the target? The relation type is read from the observable coordinate triple (d_R, d_H, d_I) — not externally supplied. Applies across NLP, ARC-AGI grids, music, images, sensor streams, and logical formulae.",
      "rdfs:label": "RelationQuery",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/query/Query"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/query/CoordinateKind",
      "@type": "owl:Class",
      "rdfs:comment": "A classification of coordinate types that a CoordinateQuery can extract. Each CoordinateKind individual names a specific coordinate system (stratum, spectrum, address) replacing the string-valued query:coordinate property.",
      "rdfs:label": "CoordinateKind",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/query/SessionQuery",
      "@type": "owl:Class",
      "rdfs:comment": "A RelationQuery that explicitly declares its session membership, allowing the conformance suite to validate session-scoped fiber reduction across multi-turn Prism deployments.",
      "rdfs:label": "SessionQuery",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/query/RelationQuery"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/query/inputType",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The type of input the query accepts.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/query/Query"
      },
      "rdfs:label": "inputType",
      "rdfs:range": {
        "@id": "http://www.w3.org/2002/07/owl#Class"
      }
    },
    {
      "@id": "https://uor.foundation/query/outputType",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The type of output the query produces.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/query/Query"
      },
      "rdfs:label": "outputType",
      "rdfs:range": {
        "@id": "http://www.w3.org/2002/07/owl#Class"
      }
    },
    {
      "@id": "https://uor.foundation/query/hasCoordinateKind",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The typed coordinate kind this query extracts. Replaces the string-valued query:coordinate property with a typed reference to a CoordinateKind individual.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/query/CoordinateQuery"
      },
      "rdfs:label": "hasCoordinateKind",
      "rdfs:range": {
        "@id": "https://uor.foundation/query/CoordinateKind"
      }
    },
    {
      "@id": "https://uor.foundation/query/sourceAddress",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The ring address of the grounded source symbol.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/query/RelationQuery"
      },
      "rdfs:label": "sourceAddress",
      "rdfs:range": {
        "@id": "https://uor.foundation/u/Address"
      }
    },
    {
      "@id": "https://uor.foundation/query/relationType",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The transformation type, expressed as a type:CompositeConstraint composed from the primitive basis. At inference time this is the output of an observable coordinate read on example pairs — computed from (d_R, d_H, d_I). Not an externally supplied input; read from the representation space.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/query/RelationQuery"
      },
      "rdfs:label": "relationType",
      "rdfs:range": {
        "@id": "https://uor.foundation/type/Constraint"
      }
    },
    {
      "@id": "https://uor.foundation/query/targetFiber",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The open fiber budget for the unknown target. Begins fully free; closes to isClosed = true upon resolution.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/query/RelationQuery"
      },
      "rdfs:label": "targetFiber",
      "rdfs:range": {
        "@id": "https://uor.foundation/partition/FiberBudget"
      }
    },
    {
      "@id": "https://uor.foundation/query/groundingMap",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The GroundingMap that resolved the source symbol to its ring address.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/query/RelationQuery"
      },
      "rdfs:label": "groundingMap",
      "rdfs:range": {
        "@id": "https://uor.foundation/morphism/GroundingMap"
      }
    },
    {
      "@id": "https://uor.foundation/query/projectionMap",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The ProjectionMap that will render the resolved address neighbourhood back to surface symbols.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/query/RelationQuery"
      },
      "rdfs:label": "projectionMap",
      "rdfs:range": {
        "@id": "https://uor.foundation/morphism/ProjectionMap"
      }
    },
    {
      "@id": "https://uor.foundation/query/sessionContext",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "Accumulated session state carrying all state:Binding instances produced by prior queries. Each binding records a resolved address, its datum, and the type under which it was resolved. Prior bindings monotonically reduce the free fiber space for subsequent queries.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/query/RelationQuery"
      },
      "rdfs:label": "sessionContext",
      "rdfs:range": {
        "@id": "https://uor.foundation/state/Context"
      }
    },
    {
      "@id": "https://uor.foundation/query/sessionMembership",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The session this query belongs to.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/query/SessionQuery"
      },
      "rdfs:label": "sessionMembership",
      "rdfs:range": {
        "@id": "https://uor.foundation/state/Session"
      }
    },
    {
      "@id": "https://uor.foundation/query/StratumCoordinate",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/query/CoordinateKind"
      ],
      "rdfs:comment": "The stratum coordinate: the layer position of a datum within the ring's stratification.",
      "rdfs:label": "StratumCoordinate"
    },
    {
      "@id": "https://uor.foundation/query/SpectrumCoordinate",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/query/CoordinateKind"
      ],
      "rdfs:comment": "The spectrum coordinate: the spectral decomposition of a datum under the ring's Fourier analysis.",
      "rdfs:label": "SpectrumCoordinate"
    },
    {
      "@id": "https://uor.foundation/query/AddressCoordinate",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/query/CoordinateKind"
      ],
      "rdfs:comment": "The address coordinate: the content-addressable position of a datum in the Braille glyph encoding.",
      "rdfs:label": "AddressCoordinate"
    },
    {
      "@id": "https://uor.foundation/resolver/",
      "@type": "owl:Ontology",
      "owl:imports": [
        {
          "@id": "https://uor.foundation/schema/"
        },
        {
          "@id": "https://uor.foundation/query/"
        },
        {
          "@id": "https://uor.foundation/partition/"
        },
        {
          "@id": "https://uor.foundation/type/"
        }
      ],
      "rdfs:comment": "Type resolution strategies implementing the partition map Π : T_n → Part(R_n). Resolvers transform type declarations into ring partitions.",
      "rdfs:label": "UOR Resolvers",
      "uor:space": "bridge"
    },
    {
      "@id": "https://uor.foundation/resolver/Resolver",
      "@type": "owl:Class",
      "owl:disjointWith": [
        {
          "@id": "https://uor.foundation/resolver/ResolutionState"
        },
        {
          "@id": "https://uor.foundation/resolver/RefinementSuggestion"
        }
      ],
      "rdfs:comment": "A strategy for resolving a type declaration into a partition of the ring. The kernel dispatches to a specific resolver based on the type's structure.",
      "rdfs:label": "Resolver",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/resolver/DihedralFactorizationResolver",
      "@type": "owl:Class",
      "rdfs:comment": "Resolves types by factoring the ring under dihedral group action. Identifies orbits under D_{2^n} to determine irreducibility boundaries.",
      "rdfs:label": "DihedralFactorizationResolver",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/resolver/Resolver"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/resolver/CanonicalFormResolver",
      "@type": "owl:Class",
      "rdfs:comment": "Resolves types by computing canonical forms via term rewriting. Applies the critical identity and normalization rules to reduce terms to unique canonical representatives.",
      "rdfs:label": "CanonicalFormResolver",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/resolver/Resolver"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/resolver/EvaluationResolver",
      "@type": "owl:Class",
      "rdfs:comment": "Resolves types by direct evaluation: applies operations to enumerate ring elements and classify them as irreducible, reducible, unit, or exterior.",
      "rdfs:label": "EvaluationResolver",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/resolver/Resolver"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/resolver/ResolutionState",
      "@type": "owl:Class",
      "owl:disjointWith": [
        {
          "@id": "https://uor.foundation/resolver/Resolver"
        },
        {
          "@id": "https://uor.foundation/resolver/RefinementSuggestion"
        }
      ],
      "rdfs:comment": "The current state of an iterative resolution: tracks how many iterations have been performed, whether the resolution is complete, and the current fiber deficit.",
      "rdfs:label": "ResolutionState",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/resolver/RefinementSuggestion",
      "@type": "owl:Class",
      "owl:disjointWith": [
        {
          "@id": "https://uor.foundation/resolver/Resolver"
        },
        {
          "@id": "https://uor.foundation/resolver/ResolutionState"
        }
      ],
      "rdfs:comment": "A suggestion from the resolver for how to refine an incomplete resolution: which metric axis to explore, which class to narrow to, and which fibers to target.",
      "rdfs:label": "RefinementSuggestion",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/resolver/ComplexityClass",
      "@type": "owl:Class",
      "rdfs:comment": "A computational complexity classification for resolvers. Each resolver's asymptotic runtime is typed as a named ComplexityClass individual rather than a free string.",
      "rdfs:label": "ComplexityClass",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/resolver/ConstraintNerve",
      "@type": "owl:Class",
      "rdfs:comment": "The simplicial complex whose vertices are constraints and where a k-simplex exists iff the corresponding k+1 constraints have nonempty intersection. The nerve's topology governs resolution convergence: trivial homology ↔ smooth convergence, non-trivial homology ↔ potential stalls.",
      "rdfs:label": "ConstraintNerve",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        },
        {
          "@id": "https://uor.foundation/homology/SimplicialComplex"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/resolver/CompletenessResolver",
      "@type": "owl:Class",
      "rdfs:comment": "A specialisation of Resolver driving the completeness certification loop. Accepts a CompletenessCandidate, runs the ψ-pipeline (reading nerveEulerCharacteristic from ResolutionState), and either issues a CompletenessCertificate or produces a RefinementSuggestion.",
      "rdfs:label": "CompletenessResolver",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/resolver/Resolver"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/resolver/QuantumLevelResolver",
      "@type": "owl:Class",
      "rdfs:comment": "A Resolver parameterised by quantum level. The same resolver strategy runs at any quantum level n ≥ 1 by substituting the appropriate R_n ring.",
      "rdfs:label": "QuantumLevelResolver",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/resolver/Resolver"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/resolver/SessionResolver",
      "@type": "owl:Class",
      "rdfs:comment": "A Resolver that maintains a BindingAccumulator across multiple RelationQuery evaluations. The top-level resolver for multi-turn Prism deployments.",
      "rdfs:label": "SessionResolver",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/resolver/Resolver"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/resolver/TypeSynthesisResolver",
      "@type": "owl:Class",
      "rdfs:comment": "A Resolver that runs the ψ-pipeline in inverse mode. Accepts a TypeSynthesisGoal and returns a TypeSynthesisResult. Internally maintains a ConstraintSearchState tracking which constraint combinations have been explored and which Betti profiles they realise.",
      "rdfs:label": "TypeSynthesisResolver",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/resolver/Resolver"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/resolver/ConstraintSearchState",
      "@type": "owl:Class",
      "rdfs:comment": "Internal resolver state tracking the boundary of explored constraint combinations during synthesis. Carries exploredCount, currentCandidate, and a link to the best SynthesisSignature achieved so far.",
      "rdfs:label": "ConstraintSearchState",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/resolver/IncrementalCompletenessResolver",
      "@type": "owl:Class",
      "rdfs:comment": "A Resolver that determines whether a CompleteType T at Q_n lifts to a CompleteType at Q_{n+1} without re-running the full ψ-pipeline from scratch. It computes the SpectralSequencePage sequence, reads the LiftObstruction, and either confirms the lift or returns a LiftRefinementSuggestion.",
      "rdfs:label": "IncrementalCompletenessResolver",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/resolver/Resolver"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/resolver/LiftRefinementSuggestion",
      "@type": "owl:Class",
      "rdfs:comment": "A RefinementSuggestion produced when a QuantumLift has a non-trivial LiftObstruction. Specialises RefinementSuggestion with liftFiberPosition (the new bit position n+1) and obstructionClass.",
      "rdfs:label": "LiftRefinementSuggestion",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/resolver/RefinementSuggestion"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/resolver/MonodromyResolver",
      "@type": "owl:Class",
      "rdfs:comment": "A Resolver that computes the HolonomyGroup of a ConstrainedType by enumerating closed paths in the constraint nerve and accumulating DihedralElement values. Outputs a MonodromyClass and classifies the type as FlatType or TwistedType.",
      "rdfs:label": "MonodromyResolver",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/resolver/Resolver"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/resolver/JacobianGuidedResolver",
      "@type": "owl:Class",
      "rdfs:comment": "A resolver that uses the Jacobian matrix to guide constraint selection, implementing DC_10: select the constraint that maximises total curvature reduction.",
      "rdfs:label": "JacobianGuidedResolver",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/resolver/Resolver"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/resolver/SuperpositionResolver",
      "@type": "owl:Class",
      "rdfs:comment": "A resolver that handles superposed fiber states, computing amplitudes and determining when superposition collapses to a classical fiber assignment (Amendment 32).",
      "rdfs:label": "SuperpositionResolver",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/resolver/Resolver"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/resolver/SaturationAwareResolver",
      "@type": "owl:Class",
      "rdfs:comment": "A resolver that exploits accumulated session bindings at full saturation (σ = 1) to provide O(1) resolution via direct coordinate reads (SC_5).",
      "rdfs:label": "SaturationAwareResolver",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/resolver/Resolver"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/resolver/GeodesicValidator",
      "@type": "owl:Class",
      "rdfs:comment": "A resolver that validates whether a ComputationTrace satisfies the dual geodesic condition (AR_1-ordered and DC_10-selected). Produces GeodesicViolation individuals on failure.",
      "rdfs:label": "GeodesicValidator",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/resolver/Resolver"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/resolver/MeasurementResolver",
      "@type": "owl:Class",
      "rdfs:comment": "A resolver that handles projective collapse of SuperposedFiberState components. Issues MeasurementCertificate upon successful collapse with QM_1 verification.",
      "rdfs:label": "MeasurementResolver",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/resolver/Resolver"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/resolver/TowerCompletenessResolver",
      "@type": "owl:Class",
      "rdfs:comment": "A Resolver that constructs a LiftChain from liftSourceLevel to an arbitrary liftTargetLevel Q_k by iterating IncrementalCompletenessResolver step by step.",
      "rdfs:label": "TowerCompletenessResolver",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/resolver/Resolver"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/resolver/ExecutionPolicy",
      "@type": "owl:Class",
      "owl:disjointWith": [
        {
          "@id": "https://uor.foundation/resolver/Resolver"
        },
        {
          "@id": "https://uor.foundation/resolver/ResolutionState"
        },
        {
          "@id": "https://uor.foundation/resolver/RefinementSuggestion"
        }
      ],
      "rdfs:comment": "A strategy class that defines how a SessionResolver orders pending RelationQuery instances for dispatch. The policy reads the targetFiber.freeCount of each pending query and applies an ordering function.",
      "rdfs:label": "ExecutionPolicy",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/resolver/ExecutionPolicyKind",
      "@type": "owl:Class",
      "rdfs:comment": "A typed controlled vocabulary for ExecutionPolicy individuals. Follows the SessionBoundaryType pattern: a single class with named individuals rather than a subclass hierarchy.",
      "rdfs:label": "ExecutionPolicyKind",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/resolver/inputType",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The type of input this resolver accepts.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/resolver/Resolver"
      },
      "rdfs:label": "inputType",
      "rdfs:range": {
        "@id": "https://uor.foundation/type/TypeDefinition"
      }
    },
    {
      "@id": "https://uor.foundation/resolver/outputType",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The type of output this resolver produces. For all UOR resolvers, the output is a partition:Partition.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/resolver/Resolver"
      },
      "rdfs:label": "outputType",
      "rdfs:range": {
        "@id": "https://uor.foundation/partition/Partition"
      }
    },
    {
      "@id": "https://uor.foundation/resolver/strategy",
      "@type": "owl:AnnotationProperty",
      "rdfs:comment": "A human-readable description of the resolution strategy this resolver implements.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/resolver/Resolver"
      },
      "rdfs:label": "strategy",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#string"
      }
    },
    {
      "@id": "https://uor.foundation/resolver/resolutionState",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The current resolution state of this resolver.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/resolver/Resolver"
      },
      "rdfs:label": "resolutionState",
      "rdfs:range": {
        "@id": "https://uor.foundation/resolver/ResolutionState"
      }
    },
    {
      "@id": "https://uor.foundation/resolver/isComplete",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "Whether this resolution is complete: all fibers are pinned and the partition is fully determined.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/resolver/ResolutionState"
      },
      "rdfs:label": "isComplete",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#boolean"
      }
    },
    {
      "@id": "https://uor.foundation/resolver/iterationCount",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The number of refinement iterations performed so far.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/resolver/ResolutionState"
      },
      "rdfs:label": "iterationCount",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#nonNegativeInteger"
      }
    },
    {
      "@id": "https://uor.foundation/resolver/fiberDeficit",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The fiber budget showing the remaining unpinned fibers. When all fibers are pinned, the deficit is zero and resolution is complete.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/resolver/ResolutionState"
      },
      "rdfs:label": "fiberDeficit",
      "rdfs:range": {
        "@id": "https://uor.foundation/partition/FiberBudget"
      }
    },
    {
      "@id": "https://uor.foundation/resolver/suggestion",
      "@type": "owl:ObjectProperty",
      "rdfs:comment": "A refinement suggestion for advancing this resolution.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/resolver/ResolutionState"
      },
      "rdfs:label": "suggestion",
      "rdfs:range": {
        "@id": "https://uor.foundation/resolver/RefinementSuggestion"
      }
    },
    {
      "@id": "https://uor.foundation/resolver/suggestedAxis",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The metric axis this suggestion recommends exploring.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/resolver/RefinementSuggestion"
      },
      "rdfs:label": "suggestedAxis",
      "rdfs:range": {
        "@id": "https://uor.foundation/type/MetricAxis"
      }
    },
    {
      "@id": "https://uor.foundation/resolver/suggestedClass",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The constraint class this suggestion recommends applying.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/resolver/RefinementSuggestion"
      },
      "rdfs:label": "suggestedClass",
      "rdfs:range": {
        "@id": "http://www.w3.org/2002/07/owl#Class"
      }
    },
    {
      "@id": "https://uor.foundation/resolver/targetFibers",
      "@type": "owl:ObjectProperty",
      "rdfs:comment": "The fiber coordinates this suggestion targets for pinning.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/resolver/RefinementSuggestion"
      },
      "rdfs:label": "targetFibers",
      "rdfs:range": {
        "@id": "https://uor.foundation/partition/FiberCoordinate"
      }
    },
    {
      "@id": "https://uor.foundation/resolver/convergenceRate",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The rate at which fibers are being pinned per iteration. A higher rate indicates faster convergence toward a complete resolution.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/resolver/ResolutionState"
      },
      "rdfs:label": "convergenceRate",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#decimal"
      }
    },
    {
      "@id": "https://uor.foundation/resolver/hasComplexityClass",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The computational complexity class of this resolver. Replaces the string-valued resolver:complexity property.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/resolver/Resolver"
      },
      "rdfs:label": "hasComplexityClass",
      "rdfs:range": {
        "@id": "https://uor.foundation/resolver/ComplexityClass"
      }
    },
    {
      "@id": "https://uor.foundation/resolver/constraintNerve",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The constraint nerve associated with this resolution state.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/resolver/ResolutionState"
      },
      "rdfs:label": "constraintNerve",
      "rdfs:range": {
        "@id": "https://uor.foundation/resolver/ConstraintNerve"
      }
    },
    {
      "@id": "https://uor.foundation/resolver/residualEntropy",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The residual Shannon entropy of the resolution state: S = freeCount × ln 2. Measures remaining uncertainty.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/resolver/ResolutionState"
      },
      "rdfs:label": "residualEntropy",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#decimal"
      }
    },
    {
      "@id": "https://uor.foundation/resolver/topologicallyComplete",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "Whether all Betti numbers of the constraint nerve are zero, indicating no topological obstructions to resolution.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/resolver/ResolutionState"
      },
      "rdfs:label": "topologicallyComplete",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#boolean"
      }
    },
    {
      "@id": "https://uor.foundation/resolver/nerveEulerCharacteristic",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The Euler characteristic χ(N(C)) of the active constraint nerve at this resolution state. IT_7d requires this value to equal n (the quantum level) for resolution to be complete. Cached here to avoid recomputing the full ψ pipeline on each iteration check.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/resolver/ResolutionState"
      },
      "rdfs:label": "nerveEulerCharacteristic",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#integer"
      }
    },
    {
      "@id": "https://uor.foundation/resolver/completenessTarget",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The CompletenessCandidate this resolver is certifying.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/resolver/CompletenessResolver"
      },
      "rdfs:label": "completenessTarget",
      "rdfs:range": {
        "@id": "https://uor.foundation/type/CompletenessCandidate"
      }
    },
    {
      "@id": "https://uor.foundation/resolver/quantumLevel",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The quantum level this resolver instance is configured for.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/resolver/QuantumLevelResolver"
      },
      "rdfs:label": "quantumLevel",
      "rdfs:range": {
        "@id": "https://uor.foundation/schema/QuantumLevel"
      }
    },
    {
      "@id": "https://uor.foundation/resolver/sessionAccumulator",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The BindingAccumulator this session resolver maintains across multiple RelationQuery evaluations.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/resolver/SessionResolver"
      },
      "rdfs:label": "sessionAccumulator",
      "rdfs:range": {
        "@id": "https://uor.foundation/state/BindingAccumulator"
      }
    },
    {
      "@id": "https://uor.foundation/resolver/synthesisGoal",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The goal this type synthesis resolver is working to achieve.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/resolver/TypeSynthesisResolver"
      },
      "rdfs:label": "synthesisGoal",
      "rdfs:range": {
        "@id": "https://uor.foundation/type/TypeSynthesisGoal"
      }
    },
    {
      "@id": "https://uor.foundation/resolver/exploredCount",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "Number of constraint combinations evaluated so far during synthesis.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/resolver/ConstraintSearchState"
      },
      "rdfs:label": "exploredCount",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#nonNegativeInteger"
      }
    },
    {
      "@id": "https://uor.foundation/resolver/currentCandidate",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The type candidate currently being evaluated during synthesis.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/resolver/ConstraintSearchState"
      },
      "rdfs:label": "currentCandidate",
      "rdfs:range": {
        "@id": "https://uor.foundation/type/ConstrainedType"
      }
    },
    {
      "@id": "https://uor.foundation/resolver/liftTarget",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The QuantumLift this incremental completeness resolver is evaluating.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/resolver/IncrementalCompletenessResolver"
      },
      "rdfs:label": "liftTarget",
      "rdfs:range": {
        "@id": "https://uor.foundation/type/QuantumLift"
      }
    },
    {
      "@id": "https://uor.foundation/resolver/liftFiberPosition",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The new fiber position at Q_{n+1} that the lift refinement suggestion targets.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/resolver/LiftRefinementSuggestion"
      },
      "rdfs:label": "liftFiberPosition",
      "rdfs:range": {
        "@id": "https://uor.foundation/partition/FiberCoordinate"
      }
    },
    {
      "@id": "https://uor.foundation/resolver/obstructionClass",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The obstruction class this lift refinement suggestion is designed to kill.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/resolver/LiftRefinementSuggestion"
      },
      "rdfs:label": "obstructionClass",
      "rdfs:range": {
        "@id": "https://uor.foundation/observable/LiftObstructionClass"
      }
    },
    {
      "@id": "https://uor.foundation/resolver/monodromyTarget",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The type whose holonomy this monodromy resolver is computing.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/resolver/MonodromyResolver"
      },
      "rdfs:label": "monodromyTarget",
      "rdfs:range": {
        "@id": "https://uor.foundation/type/ConstrainedType"
      }
    },
    {
      "@id": "https://uor.foundation/resolver/holonomyResult",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The HolonomyGroup produced by this monodromy resolver run.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/resolver/MonodromyResolver"
      },
      "rdfs:label": "holonomyResult",
      "rdfs:range": {
        "@id": "https://uor.foundation/observable/HolonomyGroup"
      }
    },
    {
      "@id": "https://uor.foundation/resolver/guidingJacobian",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The Jacobian observable guiding constraint selection at this resolution state (DC_10).",
      "rdfs:domain": {
        "@id": "https://uor.foundation/resolver/ResolutionState"
      },
      "rdfs:label": "guidingJacobian",
      "rdfs:range": {
        "@id": "https://uor.foundation/observable/Jacobian"
      }
    },
    {
      "@id": "https://uor.foundation/resolver/usedSaturation",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "Whether this resolver used the saturation shortcut (SC_5) to bypass the ψ-pipeline and return a direct coordinate read.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/resolver/SaturationAwareResolver"
      },
      "rdfs:label": "usedSaturation",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#boolean"
      }
    },
    {
      "@id": "https://uor.foundation/resolver/validateGeodesic",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The GeodesicTrace being validated by this GeodesicValidator.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/resolver/GeodesicValidator"
      },
      "rdfs:label": "validateGeodesic",
      "rdfs:range": {
        "@id": "https://uor.foundation/trace/GeodesicTrace"
      }
    },
    {
      "@id": "https://uor.foundation/resolver/collapseAmplitude",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The amplitude of the SuperposedFiberState prior to projective collapse by this MeasurementResolver.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/resolver/MeasurementResolver"
      },
      "rdfs:label": "collapseAmplitude",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#decimal"
      }
    },
    {
      "@id": "https://uor.foundation/resolver/collapsedFiber",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The fiber index that was collapsed (pinned to a classical value) by the projective measurement.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/resolver/MeasurementResolver"
      },
      "rdfs:label": "collapsedFiber",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#nonNegativeInteger"
      }
    },
    {
      "@id": "https://uor.foundation/resolver/measurementOutcome",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The classical value obtained from the projective collapse. Either 0 or 1 for a single-fiber measurement.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/resolver/MeasurementResolver"
      },
      "rdfs:label": "measurementOutcome",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#nonNegativeInteger"
      }
    },
    {
      "@id": "https://uor.foundation/resolver/amplitudeVector",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The amplitude vector of all branches maintained by this SuperpositionResolver during ψ-pipeline traversal. Encoded as a comma-separated list of decimal amplitudes. Must satisfy Σ|αᵢ|² = 1 (QM_5) after normalization.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/resolver/SuperpositionResolver"
      },
      "rdfs:label": "amplitudeVector",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#string"
      }
    },
    {
      "@id": "https://uor.foundation/resolver/priorAmplitudeVector",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The full vector of all branch amplitudes before projective collapse. Recorded by the MeasurementResolver to enable Born rule verification (QM_5): P(outcome k) = |α_k|².",
      "rdfs:domain": {
        "@id": "https://uor.foundation/resolver/MeasurementResolver"
      },
      "rdfs:label": "priorAmplitudeVector",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#string"
      }
    },
    {
      "@id": "https://uor.foundation/resolver/towerSourceLevel",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The level at which the tower starts.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/resolver/TowerCompletenessResolver"
      },
      "rdfs:label": "towerSourceLevel",
      "rdfs:range": {
        "@id": "https://uor.foundation/schema/QuantumLevel"
      }
    },
    {
      "@id": "https://uor.foundation/resolver/towerTargetLevel",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The level to which the tower is being built.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/resolver/TowerCompletenessResolver"
      },
      "rdfs:label": "towerTargetLevel",
      "rdfs:range": {
        "@id": "https://uor.foundation/schema/QuantumLevel"
      }
    },
    {
      "@id": "https://uor.foundation/resolver/currentChain",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The LiftChain under construction.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/resolver/TowerCompletenessResolver"
      },
      "rdfs:label": "currentChain",
      "rdfs:range": {
        "@id": "https://uor.foundation/type/LiftChain"
      }
    },
    {
      "@id": "https://uor.foundation/resolver/towerStepResolver",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The IncrementalCompletenessResolver used for each single-step lift.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/resolver/TowerCompletenessResolver"
      },
      "rdfs:label": "towerStepResolver",
      "rdfs:range": {
        "@id": "https://uor.foundation/resolver/IncrementalCompletenessResolver"
      }
    },
    {
      "@id": "https://uor.foundation/resolver/executionPolicy",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The ordering strategy this resolver applies to pending queries. Defaults to FifoPolicy if unset.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/resolver/SessionResolver"
      },
      "rdfs:label": "executionPolicy",
      "rdfs:range": {
        "@id": "https://uor.foundation/resolver/ExecutionPolicy"
      }
    },
    {
      "@id": "https://uor.foundation/resolver/ConstantTime",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/resolver/ComplexityClass"
      ],
      "rdfs:comment": "O(1) complexity — the resolver runs in constant time regardless of ring size.",
      "rdfs:label": "ConstantTime"
    },
    {
      "@id": "https://uor.foundation/resolver/LogarithmicTime",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/resolver/ComplexityClass"
      ],
      "rdfs:comment": "O(log n) complexity — the resolver runs in logarithmic time in the quantum level.",
      "rdfs:label": "LogarithmicTime"
    },
    {
      "@id": "https://uor.foundation/resolver/LinearTime",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/resolver/ComplexityClass"
      ],
      "rdfs:comment": "O(n) complexity — the resolver runs in time linear in the quantum level.",
      "rdfs:label": "LinearTime"
    },
    {
      "@id": "https://uor.foundation/resolver/ExponentialTime",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/resolver/ComplexityClass"
      ],
      "rdfs:comment": "O(2^n) complexity — the resolver runs in time exponential in the quantum level.",
      "rdfs:label": "ExponentialTime"
    },
    {
      "@id": "https://uor.foundation/resolver/FifoPolicy",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/resolver/ExecutionPolicyKind"
      ],
      "rdfs:comment": "Process queries in arrival order. The implicit pre-Amendment 48 behavior.",
      "rdfs:label": "FifoPolicy"
    },
    {
      "@id": "https://uor.foundation/resolver/MinFreeCountFirst",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/resolver/ExecutionPolicyKind"
      ],
      "rdfs:comment": "Process the query with the smallest targetFiber.freeCount first. Favors cheapest resolutions, accelerating early saturation gain.",
      "rdfs:label": "MinFreeCountFirst"
    },
    {
      "@id": "https://uor.foundation/resolver/MaxFreeCountFirst",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/resolver/ExecutionPolicyKind"
      ],
      "rdfs:comment": "Process the query with the largest targetFiber.freeCount first. Favors hardest resolutions, maximizing information gain per step.",
      "rdfs:label": "MaxFreeCountFirst"
    },
    {
      "@id": "https://uor.foundation/resolver/DisjointFirst",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/resolver/ExecutionPolicyKind"
      ],
      "rdfs:comment": "Process queries whose targetFiber is disjoint from all other pending queries' fiber sets first. Minimizes contention when operating against a SharedContext.",
      "rdfs:label": "DisjointFirst"
    },
    {
      "@id": "https://uor.foundation/type/",
      "@type": "owl:Ontology",
      "owl:imports": [
        {
          "@id": "https://uor.foundation/schema/"
        },
        {
          "@id": "https://uor.foundation/u/"
        },
        {
          "@id": "https://uor.foundation/op/"
        }
      ],
      "rdfs:comment": "Runtime type declarations that parameterize the resolution pipeline. Types are declared by Prism applications and resolved to partitions of the ring.",
      "rdfs:label": "UOR Type System",
      "uor:space": "user"
    },
    {
      "@id": "https://uor.foundation/type/TypeDefinition",
      "@type": "owl:Class",
      "owl:disjointWith": [
        {
          "@id": "https://uor.foundation/type/Constraint"
        },
        {
          "@id": "https://uor.foundation/type/MetricAxis"
        }
      ],
      "rdfs:comment": "A runtime type declaration. The root class for all UOR types. Each TypeDefinition, when resolved, produces a partition of the ring at the specified quantum level.",
      "rdfs:label": "TypeDefinition",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/type/PrimitiveType",
      "@type": "owl:Class",
      "rdfs:comment": "A primitive type defined by a fixed bit width. The carrier is the entire ring Z/(2^n)Z at the specified quantum level.",
      "rdfs:label": "PrimitiveType",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/type/TypeDefinition"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/type/ProductType",
      "@type": "owl:Class",
      "rdfs:comment": "A product (Cartesian) type formed from multiple component types. The carrier is the product of the component carriers.",
      "rdfs:label": "ProductType",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/type/TypeDefinition"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/type/SumType",
      "@type": "owl:Class",
      "rdfs:comment": "A sum (disjoint union) type formed from multiple variant types. The carrier is the disjoint union of the variant carriers.",
      "rdfs:label": "SumType",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/type/TypeDefinition"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/type/ConstrainedType",
      "@type": "owl:Class",
      "rdfs:comment": "A type formed by constraining a base type with a predicate. The carrier is the subset of the base carrier satisfying the constraint.",
      "rdfs:label": "ConstrainedType",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/type/TypeDefinition"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/type/Constraint",
      "@type": "owl:Class",
      "owl:disjointWith": [
        {
          "@id": "https://uor.foundation/type/TypeDefinition"
        },
        {
          "@id": "https://uor.foundation/type/MetricAxis"
        }
      ],
      "rdfs:comment": "A composable predicate that refines a type by pinning one or more fiber coordinates. Constraints are the parameterization mechanism for ConstrainedType.",
      "rdfs:label": "Constraint",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/type/ResidueConstraint",
      "@type": "owl:Class",
      "owl:disjointWith": [
        {
          "@id": "https://uor.foundation/type/CarryConstraint"
        },
        {
          "@id": "https://uor.foundation/type/DepthConstraint"
        },
        {
          "@id": "https://uor.foundation/type/CompositeConstraint"
        }
      ],
      "rdfs:comment": "A constraint based on residue class membership: x ≡ r (mod m). Pins fibers corresponding to the residue pattern.",
      "rdfs:label": "ResidueConstraint",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/type/Constraint"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/type/CarryConstraint",
      "@type": "owl:Class",
      "owl:disjointWith": [
        {
          "@id": "https://uor.foundation/type/ResidueConstraint"
        },
        {
          "@id": "https://uor.foundation/type/DepthConstraint"
        },
        {
          "@id": "https://uor.foundation/type/CompositeConstraint"
        }
      ],
      "rdfs:comment": "A constraint based on carry propagation patterns in ring arithmetic. Pins fibers corresponding to carry positions.",
      "rdfs:label": "CarryConstraint",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/type/Constraint"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/type/DepthConstraint",
      "@type": "owl:Class",
      "owl:disjointWith": [
        {
          "@id": "https://uor.foundation/type/ResidueConstraint"
        },
        {
          "@id": "https://uor.foundation/type/CarryConstraint"
        },
        {
          "@id": "https://uor.foundation/type/CompositeConstraint"
        }
      ],
      "rdfs:comment": "A constraint on factorization depth: the minimum and maximum number of irreducible factors. Pins fibers by bounding the factorization tree depth.",
      "rdfs:label": "DepthConstraint",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/type/Constraint"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/type/CompositeConstraint",
      "@type": "owl:Class",
      "owl:disjointWith": [
        {
          "@id": "https://uor.foundation/type/ResidueConstraint"
        },
        {
          "@id": "https://uor.foundation/type/CarryConstraint"
        },
        {
          "@id": "https://uor.foundation/type/DepthConstraint"
        }
      ],
      "rdfs:comment": "A constraint formed by composing two or more simpler constraints. The composite pins the union of fibers pinned by its components.",
      "rdfs:label": "CompositeConstraint",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/type/Constraint"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/type/MetricAxis",
      "@type": "owl:Class",
      "owl:disjointWith": [
        {
          "@id": "https://uor.foundation/type/TypeDefinition"
        },
        {
          "@id": "https://uor.foundation/type/Constraint"
        }
      ],
      "rdfs:comment": "A classification axis for constraints by their geometric effect. The three axes — vertical (ring/additive), horizontal (Hamming/bitwise), diagonal (incompatibility) — form the tri-metric coordinate system of UOR.",
      "rdfs:label": "MetricAxis",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/type/CompleteType",
      "@type": "owl:Class",
      "rdfs:comment": "A TypeDefinition certified to satisfy the UOR completeness criterion (IT_7d): its constraint nerve N(C) has Euler characteristic χ = n and all Betti numbers β_k = 0. A CompleteType guarantees that resolution closes the fiber budget in O(1) — no iterative refinement is required. Completeness is attested by a cert:CompletenessCertificate linked via cert:certifiedType.",
      "rdfs:label": "CompleteType",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/type/TypeDefinition"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/type/CompletenessCandidate",
      "@type": "owl:Class",
      "owl:disjointWith": [
        {
          "@id": "https://uor.foundation/type/CompleteType"
        }
      ],
      "rdfs:comment": "A ConstrainedType actively undergoing the completeness certification pipeline. Links to the resolver:ResolutionState tracking the current iteration and to the resolver:ConstraintNerve being computed. Disjoint from CompleteType (which is already certified).",
      "rdfs:label": "CompletenessCandidate",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/type/ConstrainedType"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/type/CompletenessWitness",
      "@type": "owl:Class",
      "rdfs:comment": "A record of a single fiber-closing event: one constraint application that reduced the FiberBudget deficit. Carries the applied constraint and the fibersClosed count. Forms the ordered audit trail between ConstrainedType and CompleteType.",
      "rdfs:label": "CompletenessWitness",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/type/TypeSynthesisGoal",
      "@type": "owl:Class",
      "rdfs:comment": "A specification of the desired topological properties of a type to be synthesised. Carries a target Euler characteristic (targetEulerCharacteristic) and a target Betti profile (zero or more targetBettiNumber assertions). The minimal goal for O(1) resolution is: targetEulerCharacteristic = n and all targetBettiNumber = 0 — the IT_7d profile.",
      "rdfs:label": "TypeSynthesisGoal",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/type/TypeSynthesisResult",
      "@type": "owl:Class",
      "rdfs:comment": "The output of a TypeSynthesisResolver run. Contains the SynthesizedType, the realised topological signature (as a SynthesisSignature), and the SynthesisTrace recording the construction steps.",
      "rdfs:label": "TypeSynthesisResult",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/type/SynthesizedType",
      "@type": "owl:Class",
      "rdfs:comment": "A ConstrainedType produced by the TypeSynthesisResolver. Distinguished from a hand-authored ConstrainedType by the presence of a type:synthesisResult link. May or may not be a CompleteType, depending on the synthesis goal.",
      "rdfs:label": "SynthesizedType",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/type/ConstrainedType"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/type/MinimalConstraintBasis",
      "@type": "owl:Class",
      "rdfs:comment": "The minimal set of constraints in the SynthesizedType's constraint set that is sufficient to realise the target topological signature. The minimality criterion is that removing any single member changes the realised signature.",
      "rdfs:label": "MinimalConstraintBasis",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/type/QuantumLift",
      "@type": "owl:Class",
      "rdfs:comment": "A ConstrainedType T' over R_{n+1} obtained by extending a ConstrainedType T over R_n. Carries a link to the base type (liftBase), the quantum level it lifts to (liftTargetLevel), and the LiftObstruction (if the lift fails to transfer completeness). A QuantumLift is a CompleteType iff its LiftObstruction is trivial.",
      "rdfs:label": "QuantumLift",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/type/LiftObstruction",
      "@type": "owl:Class",
      "rdfs:comment": "The algebraic obstruction to a QuantumLift inheriting the completeness of its base type. Computed as the image of the spectral sequence differential d_2. If trivial (zero), the base type's completeness lifts. If non-trivial, at least one additional constraint is needed at the new quantum level.",
      "rdfs:label": "LiftObstruction",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/type/TwistedType",
      "@type": "owl:Class",
      "owl:disjointWith": [
        {
          "@id": "https://uor.foundation/type/FlatType"
        }
      ],
      "rdfs:comment": "A ConstrainedType whose HolonomyGroup is non-trivial — at least one closed constraint path produces a non-identity dihedral element. A TwistedType may still be a CompleteType (IT_7d is a homological, not holonomic, criterion), but its resolution paths require tracking dihedral accumulation.",
      "rdfs:label": "TwistedType",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/type/ConstrainedType"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/type/FlatType",
      "@type": "owl:Class",
      "owl:disjointWith": [
        {
          "@id": "https://uor.foundation/type/TwistedType"
        }
      ],
      "rdfs:comment": "A ConstrainedType whose HolonomyGroup is trivial — all closed constraint paths have identity monodromy. The constraint configuration is topologically flat: resolution is path-independent.",
      "rdfs:label": "FlatType",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/type/ConstrainedType"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/type/SuperposedFiberState",
      "@type": "owl:Class",
      "rdfs:comment": "A type representing a superposition of fiber states where fibers carry complex amplitudes rather than binary pinned/free assignments. Ontological realisation of RC_5 (Amendment 32).",
      "rdfs:label": "SuperposedFiberState",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/type/TypeDefinition"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/type/ForbiddenSignature",
      "@type": "owl:Class",
      "rdfs:comment": "A topological signature (χ, β_k) that is formally impossible to achieve for any ConstrainedType. Witnessed by an ImpossibilityWitness in proof/.",
      "rdfs:label": "ForbiddenSignature",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/type/CollapsedFiberState",
      "@type": "owl:Class",
      "rdfs:comment": "A fiber state that has undergone projective collapse from a SuperposedFiberState to a definitive classical value. Topologically equivalent to a classically pinned fiber (QM_2).",
      "rdfs:label": "CollapsedFiberState",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/type/LiftChain",
      "@type": "owl:Class",
      "rdfs:comment": "An ordered composition of QuantumLift steps from liftSourceLevel (Q_j) to liftTargetLevel (Q_k) for any j < k. The canonical object certifying type completeness at arbitrary Q_k.",
      "rdfs:label": "LiftChain",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/type/ObstructionChain",
      "@type": "owl:Class",
      "rdfs:comment": "The complete ordered sequence of LiftObstruction records encountered and resolved along a LiftChain. An empty ObstructionChain means the tower is flat.",
      "rdfs:label": "ObstructionChain",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/type/bitWidth",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The bit width of a primitive type (the quantum level n). The carrier is Z/(2^n)Z.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/type/PrimitiveType"
      },
      "rdfs:label": "bitWidth",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#positiveInteger"
      }
    },
    {
      "@id": "https://uor.foundation/type/component",
      "@type": "owl:ObjectProperty",
      "rdfs:comment": "A component type in a product type.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/type/ProductType"
      },
      "rdfs:label": "component",
      "rdfs:range": {
        "@id": "https://uor.foundation/type/TypeDefinition"
      }
    },
    {
      "@id": "https://uor.foundation/type/baseType",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The base type that a constrained type restricts.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/type/ConstrainedType"
      },
      "rdfs:label": "baseType",
      "rdfs:range": {
        "@id": "https://uor.foundation/type/TypeDefinition"
      }
    },
    {
      "@id": "https://uor.foundation/type/constraint",
      "@type": "owl:DatatypeProperty",
      "rdfs:comment": "The constraint predicate applied to the base type. Expressed as a string in the Prism constraint language. Deprecated in favor of type:hasConstraint (Amendment 10), which provides typed object references to Constraint individuals. Retained for backwards compatibility.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/type/ConstrainedType"
      },
      "rdfs:label": "constraint",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#string"
      }
    },
    {
      "@id": "https://uor.foundation/type/contentAddress",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The content-derived address of this type definition, uniquely identifying the type in the UOR address space.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/type/TypeDefinition"
      },
      "rdfs:label": "contentAddress",
      "rdfs:range": {
        "@id": "https://uor.foundation/u/Address"
      }
    },
    {
      "@id": "https://uor.foundation/type/hasConstraint",
      "@type": "owl:ObjectProperty",
      "rdfs:comment": "A typed constraint object applied to this constrained type. Replaces the deprecated string-based type:constraint property.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/type/ConstrainedType"
      },
      "rdfs:label": "hasConstraint",
      "rdfs:range": {
        "@id": "https://uor.foundation/type/Constraint"
      }
    },
    {
      "@id": "https://uor.foundation/type/modulus",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The modulus m of a residue constraint: x ≡ r (mod m).",
      "rdfs:domain": {
        "@id": "https://uor.foundation/type/ResidueConstraint"
      },
      "rdfs:label": "modulus",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#positiveInteger"
      }
    },
    {
      "@id": "https://uor.foundation/type/residue",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The residue value r of a residue constraint: x ≡ r (mod m).",
      "rdfs:domain": {
        "@id": "https://uor.foundation/type/ResidueConstraint"
      },
      "rdfs:label": "residue",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#nonNegativeInteger"
      }
    },
    {
      "@id": "https://uor.foundation/type/carryPattern",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The carry propagation pattern of a carry constraint, expressed as a binary string (e.g., '1010').",
      "rdfs:domain": {
        "@id": "https://uor.foundation/type/CarryConstraint"
      },
      "rdfs:label": "carryPattern",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#string"
      }
    },
    {
      "@id": "https://uor.foundation/type/minDepth",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The minimum factorization depth required by a depth constraint.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/type/DepthConstraint"
      },
      "rdfs:label": "minDepth",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#nonNegativeInteger"
      }
    },
    {
      "@id": "https://uor.foundation/type/maxDepth",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The maximum factorization depth allowed by a depth constraint.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/type/DepthConstraint"
      },
      "rdfs:label": "maxDepth",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#nonNegativeInteger"
      }
    },
    {
      "@id": "https://uor.foundation/type/composedFrom",
      "@type": "owl:ObjectProperty",
      "rdfs:comment": "A component constraint of this composite constraint.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/type/CompositeConstraint"
      },
      "rdfs:label": "composedFrom",
      "rdfs:range": {
        "@id": "https://uor.foundation/type/Constraint"
      }
    },
    {
      "@id": "https://uor.foundation/type/metricAxis",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The metric axis along which this constraint operates: vertical (ring), horizontal (Hamming), or diagonal (incompatibility).",
      "rdfs:domain": {
        "@id": "https://uor.foundation/type/Constraint"
      },
      "rdfs:label": "metricAxis",
      "rdfs:range": {
        "@id": "https://uor.foundation/type/MetricAxis"
      }
    },
    {
      "@id": "https://uor.foundation/type/pinsFibers",
      "@type": "owl:ObjectProperty",
      "rdfs:comment": "A fiber coordinate that this constraint pins when applied.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/type/Constraint"
      },
      "rdfs:label": "pinsFibers",
      "rdfs:range": {
        "@id": "https://uor.foundation/partition/FiberCoordinate"
      }
    },
    {
      "@id": "https://uor.foundation/type/affectsAxis",
      "@type": "owl:ObjectProperty",
      "rdfs:comment": "The metric axis that this operation affects. Replaces the string-valued type:axisSignature property with a typed reference to MetricAxis individuals. Non-functional: an operation may affect multiple axes.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/op/Operation"
      },
      "rdfs:label": "affectsAxis",
      "rdfs:range": {
        "@id": "https://uor.foundation/type/MetricAxis"
      }
    },
    {
      "@id": "https://uor.foundation/type/axisSignatureNote",
      "@type": "owl:AnnotationProperty",
      "rdfs:comment": "Human-readable annotation of the operation's axis signature (e.g., 'V', 'H', 'VH'). Demoted from a datatype property to an annotation property by Amendment 23.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/op/Operation"
      },
      "rdfs:label": "axisSignatureNote",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#string"
      }
    },
    {
      "@id": "https://uor.foundation/type/crossingCost",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The cost of applying this constraint in terms of axis crossings: the number of metric boundaries that must be traversed.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/type/Constraint"
      },
      "rdfs:label": "crossingCost",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#nonNegativeInteger"
      }
    },
    {
      "@id": "https://uor.foundation/type/completenessCandidate",
      "@type": "owl:ObjectProperty",
      "rdfs:comment": "The ConstrainedType being evaluated for completeness by this CompletenessCandidate.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/type/CompletenessCandidate"
      },
      "rdfs:label": "completenessCandidate",
      "rdfs:range": {
        "@id": "https://uor.foundation/type/ConstrainedType"
      }
    },
    {
      "@id": "https://uor.foundation/type/candidateNerve",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The constraint nerve being computed for this candidate. The CompletenessResolver reads χ(N(C)) from this nerve at each iteration via resolver:nerveEulerCharacteristic.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/type/CompletenessCandidate"
      },
      "rdfs:label": "candidateNerve",
      "rdfs:range": {
        "@id": "https://uor.foundation/resolver/ConstraintNerve"
      }
    },
    {
      "@id": "https://uor.foundation/type/witnessConstraint",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The constraint applied in this witness step.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/type/CompletenessWitness"
      },
      "rdfs:label": "witnessConstraint",
      "rdfs:range": {
        "@id": "https://uor.foundation/type/Constraint"
      }
    },
    {
      "@id": "https://uor.foundation/type/fibersClosed",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "Number of fibers closed by this witness step.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/type/CompletenessWitness"
      },
      "rdfs:label": "fibersClosed",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#nonNegativeInteger"
      }
    },
    {
      "@id": "https://uor.foundation/type/targetEulerCharacteristic",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The target χ(N(C)) value. For O(1) resolution: set equal to n (the quantum level).",
      "rdfs:domain": {
        "@id": "https://uor.foundation/type/TypeSynthesisGoal"
      },
      "rdfs:label": "targetEulerCharacteristic",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#integer"
      }
    },
    {
      "@id": "https://uor.foundation/type/targetBettiNumber",
      "@type": "owl:DatatypeProperty",
      "rdfs:comment": "Non-functional. Each assertion specifies a target Betti number value for a given homological degree. Multiple assertions permitted, one per degree.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/type/TypeSynthesisGoal"
      },
      "rdfs:label": "targetBettiNumber",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#nonNegativeInteger"
      }
    },
    {
      "@id": "https://uor.foundation/type/synthesisResult",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "Links a SynthesizedType back to the synthesis run that produced it.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/type/SynthesizedType"
      },
      "rdfs:label": "synthesisResult",
      "rdfs:range": {
        "@id": "https://uor.foundation/type/TypeSynthesisResult"
      }
    },
    {
      "@id": "https://uor.foundation/type/basisConstraint",
      "@type": "owl:ObjectProperty",
      "rdfs:comment": "Non-functional. One assertion per constraint in the minimal basis.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/type/MinimalConstraintBasis"
      },
      "rdfs:label": "basisConstraint",
      "rdfs:range": {
        "@id": "https://uor.foundation/type/Constraint"
      }
    },
    {
      "@id": "https://uor.foundation/type/basisSize",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The cardinality of the minimal basis. The theoretical lower bound is n (one constraint per fiber).",
      "rdfs:domain": {
        "@id": "https://uor.foundation/type/MinimalConstraintBasis"
      },
      "rdfs:label": "basisSize",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#nonNegativeInteger"
      }
    },
    {
      "@id": "https://uor.foundation/type/liftBase",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The base type being lifted to the next quantum level.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/type/QuantumLift"
      },
      "rdfs:label": "liftBase",
      "rdfs:range": {
        "@id": "https://uor.foundation/type/ConstrainedType"
      }
    },
    {
      "@id": "https://uor.foundation/type/liftTargetLevel",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The quantum level this lift targets.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/type/QuantumLift"
      },
      "rdfs:label": "liftTargetLevel",
      "rdfs:range": {
        "@id": "https://uor.foundation/schema/QuantumLevel"
      }
    },
    {
      "@id": "https://uor.foundation/type/liftObstruction",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The LiftObstruction for this lift. Trivial (zero class) iff the lift inherits completeness.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/type/QuantumLift"
      },
      "rdfs:label": "liftObstruction",
      "rdfs:range": {
        "@id": "https://uor.foundation/type/LiftObstruction"
      }
    },
    {
      "@id": "https://uor.foundation/type/obstructionTrivial",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "True iff the obstruction class is zero — the base type's completeness transfers to the lifted quantum level without additional constraints.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/type/LiftObstruction"
      },
      "rdfs:label": "obstructionTrivial",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#boolean"
      }
    },
    {
      "@id": "https://uor.foundation/type/obstructionFiber",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The fiber at the new quantum level where the obstruction is located. Ranges over the new bit position introduced at Q_{n+1}.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/type/LiftObstruction"
      },
      "rdfs:label": "obstructionFiber",
      "rdfs:range": {
        "@id": "https://uor.foundation/partition/FiberCoordinate"
      }
    },
    {
      "@id": "https://uor.foundation/type/holonomyGroup",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The HolonomyGroup of this type. Computed by the MonodromyResolver.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/type/ConstrainedType"
      },
      "rdfs:label": "holonomyGroup",
      "rdfs:range": {
        "@id": "https://uor.foundation/observable/HolonomyGroup"
      }
    },
    {
      "@id": "https://uor.foundation/type/monodromyClass",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The MonodromyClass classifying this type as flat or twisted.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/type/ConstrainedType"
      },
      "rdfs:label": "monodromyClass",
      "rdfs:range": {
        "@id": "https://uor.foundation/observable/MonodromyClass"
      }
    },
    {
      "@id": "https://uor.foundation/type/amplitude",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The amplitude coefficient for this superposed fiber state.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/type/SuperposedFiberState"
      },
      "rdfs:label": "amplitude",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#decimal"
      }
    },
    {
      "@id": "https://uor.foundation/type/targetForbidden",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "Whether the target signature of this TypeSynthesisGoal is a ForbiddenSignature. If true, synthesis is provably impossible.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/type/TypeSynthesisGoal"
      },
      "rdfs:label": "targetForbidden",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#boolean"
      }
    },
    {
      "@id": "https://uor.foundation/type/collapsedFrom",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The SuperposedFiberState from which this CollapsedFiberState was produced by projective measurement.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/type/CollapsedFiberState"
      },
      "rdfs:label": "collapsedFrom",
      "rdfs:range": {
        "@id": "https://uor.foundation/type/SuperposedFiberState"
      }
    },
    {
      "@id": "https://uor.foundation/type/survivingAmplitude",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The amplitude of the surviving branch after projective collapse. |α|² is the probability of this outcome under the Born rule.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/type/CollapsedFiberState"
      },
      "rdfs:label": "survivingAmplitude",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#decimal"
      }
    },
    {
      "@id": "https://uor.foundation/type/normalizationVerified",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "Whether the amplitude vector of this SuperposedFiberState satisfies the normalization condition Σ|αᵢ|² = 1 (QM_5). Set by the SuperpositionResolver after verification.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/type/SuperposedFiberState"
      },
      "rdfs:label": "normalizationVerified",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#boolean"
      }
    },
    {
      "@id": "https://uor.foundation/type/holonomyClassified",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "Whether this ConstrainedType has been classified as FlatType or TwistedType by the MonodromyResolver. The MN_8 identity guarantees this is a bivalent classification: holonomyClassified(T) iff isFlatType(T) xor isTwistedType(T).",
      "rdfs:domain": {
        "@id": "https://uor.foundation/type/ConstrainedType"
      },
      "rdfs:label": "holonomyClassified",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#boolean"
      }
    },
    {
      "@id": "https://uor.foundation/type/liftSourceLevel",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The quantum level at the base of the chain.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/type/LiftChain"
      },
      "rdfs:label": "liftSourceLevel",
      "rdfs:range": {
        "@id": "https://uor.foundation/schema/QuantumLevel"
      }
    },
    {
      "@id": "https://uor.foundation/type/chainLength",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The number of QuantumLift steps in the chain (k - j).",
      "rdfs:domain": {
        "@id": "https://uor.foundation/type/LiftChain"
      },
      "rdfs:label": "chainLength",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#nonNegativeInteger"
      }
    },
    {
      "@id": "https://uor.foundation/type/chainStep",
      "@type": "owl:ObjectProperty",
      "rdfs:comment": "A QuantumLift step in this chain. Non-functional: one per step.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/type/LiftChain"
      },
      "rdfs:label": "chainStep",
      "rdfs:range": {
        "@id": "https://uor.foundation/type/QuantumLift"
      }
    },
    {
      "@id": "https://uor.foundation/type/chainObstructionProfile",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The full obstruction history of this chain.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/type/LiftChain"
      },
      "rdfs:label": "chainObstructionProfile",
      "rdfs:range": {
        "@id": "https://uor.foundation/type/ObstructionChain"
      }
    },
    {
      "@id": "https://uor.foundation/type/resolvedBasisSize",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The basis size of the CompleteType at the chain target level.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/type/LiftChain"
      },
      "rdfs:label": "resolvedBasisSize",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#nonNegativeInteger"
      }
    },
    {
      "@id": "https://uor.foundation/type/obstructionAt",
      "@type": "owl:ObjectProperty",
      "rdfs:comment": "A non-trivial LiftObstruction in this chain. Non-functional.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/type/ObstructionChain"
      },
      "rdfs:label": "obstructionAt",
      "rdfs:range": {
        "@id": "https://uor.foundation/type/LiftObstruction"
      }
    },
    {
      "@id": "https://uor.foundation/type/obstructionCount",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "Total number of non-trivial LiftObstruction records.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/type/ObstructionChain"
      },
      "rdfs:label": "obstructionCount",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#nonNegativeInteger"
      }
    },
    {
      "@id": "https://uor.foundation/type/isFlat",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "True iff obstructionCount = 0 (flat tower).",
      "rdfs:domain": {
        "@id": "https://uor.foundation/type/ObstructionChain"
      },
      "rdfs:label": "isFlat",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#boolean"
      }
    },
    {
      "@id": "https://uor.foundation/type/verticalAxis",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/type/MetricAxis"
      ],
      "rdfs:comment": "The vertical (ring/additive) metric axis. Constraints on this axis operate through ring arithmetic: residue classes, divisibility, and additive structure.",
      "rdfs:label": "verticalAxis"
    },
    {
      "@id": "https://uor.foundation/type/horizontalAxis",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/type/MetricAxis"
      ],
      "rdfs:comment": "The horizontal (Hamming/bitwise) metric axis. Constraints on this axis operate through bitwise structure: carry patterns, bit positions, and Hamming distance.",
      "rdfs:label": "horizontalAxis"
    },
    {
      "@id": "https://uor.foundation/type/diagonalAxis",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/type/MetricAxis"
      ],
      "rdfs:comment": "The diagonal (incompatibility) metric axis. Constraints on this axis measure the gap between ring and Hamming metrics — the curvature of UOR geometry.",
      "rdfs:label": "diagonalAxis"
    },
    {
      "@id": "https://uor.foundation/partition/",
      "@type": "owl:Ontology",
      "owl:imports": [
        {
          "@id": "https://uor.foundation/schema/"
        },
        {
          "@id": "https://uor.foundation/type/"
        }
      ],
      "rdfs:comment": "Irreducibility partitions produced by type resolution. A partition divides the ring into four disjoint components: Irreducible, Reducible, Units, and Exterior.",
      "rdfs:label": "UOR Partitions",
      "uor:space": "bridge"
    },
    {
      "@id": "https://uor.foundation/partition/Partition",
      "@type": "owl:Class",
      "rdfs:comment": "A four-component partition of R_n produced by resolving a type declaration. The four components — Irreducible, Reducible, Units, Exterior — are mutually disjoint and exhaustive over the carrier.",
      "rdfs:label": "Partition",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/partition/Component",
      "@type": "owl:Class",
      "owl:disjointWith": [
        {
          "@id": "https://uor.foundation/partition/FiberCoordinate"
        },
        {
          "@id": "https://uor.foundation/partition/FiberBudget"
        }
      ],
      "rdfs:comment": "A single component of a partition: a set of datum values belonging to one of the four categories.",
      "rdfs:label": "Component",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/partition/IrreducibleSet",
      "@type": "owl:Class",
      "owl:disjointWith": [
        {
          "@id": "https://uor.foundation/partition/ReducibleSet"
        },
        {
          "@id": "https://uor.foundation/partition/UnitSet"
        },
        {
          "@id": "https://uor.foundation/partition/ExteriorSet"
        }
      ],
      "rdfs:comment": "The set of irreducible elements under the active type: elements whose only factorizations involve units or themselves. Analogous to prime elements in a ring.",
      "rdfs:label": "IrreducibleSet",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/partition/Component"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/partition/ReducibleSet",
      "@type": "owl:Class",
      "owl:disjointWith": [
        {
          "@id": "https://uor.foundation/partition/IrreducibleSet"
        },
        {
          "@id": "https://uor.foundation/partition/UnitSet"
        },
        {
          "@id": "https://uor.foundation/partition/ExteriorSet"
        }
      ],
      "rdfs:comment": "The set of reducible non-unit elements: elements that can be expressed as a product of two or more non-unit elements.",
      "rdfs:label": "ReducibleSet",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/partition/Component"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/partition/UnitSet",
      "@type": "owl:Class",
      "owl:disjointWith": [
        {
          "@id": "https://uor.foundation/partition/IrreducibleSet"
        },
        {
          "@id": "https://uor.foundation/partition/ReducibleSet"
        },
        {
          "@id": "https://uor.foundation/partition/ExteriorSet"
        }
      ],
      "rdfs:comment": "The set of invertible elements (units) in the carrier: elements with a multiplicative inverse. In Z/(2^n)Z, the units are the odd integers.",
      "rdfs:label": "UnitSet",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/partition/Component"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/partition/ExteriorSet",
      "@type": "owl:Class",
      "owl:disjointWith": [
        {
          "@id": "https://uor.foundation/partition/IrreducibleSet"
        },
        {
          "@id": "https://uor.foundation/partition/ReducibleSet"
        },
        {
          "@id": "https://uor.foundation/partition/UnitSet"
        }
      ],
      "rdfs:comment": "Elements of R_n that fall outside the active carrier — i.e., outside the type's domain. These are ring elements that do not participate in the current type resolution.",
      "rdfs:label": "ExteriorSet",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/partition/Component"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/partition/FiberCoordinate",
      "@type": "owl:Class",
      "owl:disjointWith": [
        {
          "@id": "https://uor.foundation/partition/FiberBudget"
        },
        {
          "@id": "https://uor.foundation/partition/Component"
        }
      ],
      "rdfs:comment": "A single fiber coordinate in the iterated Z/2Z fibration. Each fiber represents one binary degree of freedom in the ring's structure. The total number of fibers equals the quantum level n.",
      "rdfs:label": "FiberCoordinate",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/partition/FiberBudget",
      "@type": "owl:Class",
      "owl:disjointWith": [
        {
          "@id": "https://uor.foundation/partition/FiberCoordinate"
        },
        {
          "@id": "https://uor.foundation/partition/Component"
        }
      ],
      "rdfs:comment": "The fiber budget for a partition: an accounting of how many fibers are pinned (determined by constraints) versus free (still available for further refinement). A closed budget means all fibers are pinned and the type is fully resolved.",
      "rdfs:label": "FiberBudget",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/partition/FiberPinning",
      "@type": "owl:Class",
      "rdfs:comment": "A record of a single fiber being pinned by a constraint. Links a specific fiber coordinate to the constraint that determined its value.",
      "rdfs:label": "FiberPinning",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/partition/PartitionProduct",
      "@type": "owl:Class",
      "owl:disjointWith": [
        {
          "@id": "https://uor.foundation/partition/PartitionCoproduct"
        }
      ],
      "rdfs:comment": "The tensor product of two partitions: partition(A × B) = partition(A) ⊗ partition(B). The four-component structure combines component-wise under the product type construction (PT_2a). Carries leftFactor and rightFactor links to the operand partitions.",
      "rdfs:label": "PartitionProduct",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/partition/PartitionCoproduct",
      "@type": "owl:Class",
      "owl:disjointWith": [
        {
          "@id": "https://uor.foundation/partition/PartitionProduct"
        }
      ],
      "rdfs:comment": "The coproduct (disjoint union) of two partitions: partition(A + B) = partition(A) ⊕ partition(B). The four-component structure combines via disjoint union under the sum type construction (PT_2b). Carries leftSummand and rightSummand links to the operand partitions.",
      "rdfs:label": "PartitionCoproduct",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/partition/irreducibles",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The irreducible component of this partition.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/partition/Partition"
      },
      "rdfs:label": "irreducibles",
      "rdfs:range": {
        "@id": "https://uor.foundation/partition/IrreducibleSet"
      }
    },
    {
      "@id": "https://uor.foundation/partition/reducibles",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The reducible component of this partition.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/partition/Partition"
      },
      "rdfs:label": "reducibles",
      "rdfs:range": {
        "@id": "https://uor.foundation/partition/ReducibleSet"
      }
    },
    {
      "@id": "https://uor.foundation/partition/units",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The units component of this partition.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/partition/Partition"
      },
      "rdfs:label": "units",
      "rdfs:range": {
        "@id": "https://uor.foundation/partition/UnitSet"
      }
    },
    {
      "@id": "https://uor.foundation/partition/exterior",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The exterior component of this partition.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/partition/Partition"
      },
      "rdfs:label": "exterior",
      "rdfs:range": {
        "@id": "https://uor.foundation/partition/ExteriorSet"
      }
    },
    {
      "@id": "https://uor.foundation/partition/member",
      "@type": "owl:ObjectProperty",
      "rdfs:comment": "A datum value belonging to this partition component.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/partition/Component"
      },
      "rdfs:label": "member",
      "rdfs:range": {
        "@id": "https://uor.foundation/schema/Datum"
      }
    },
    {
      "@id": "https://uor.foundation/partition/cardinality",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The number of elements in this partition component. The cardinalities of the four components must sum to 2^n.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/partition/Component"
      },
      "rdfs:label": "cardinality",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#nonNegativeInteger"
      }
    },
    {
      "@id": "https://uor.foundation/partition/density",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The irreducible density of this partition: |Irr| / |A|, where A is the active carrier.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/partition/Partition"
      },
      "rdfs:label": "density",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#decimal"
      }
    },
    {
      "@id": "https://uor.foundation/partition/sourceType",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The type declaration that was resolved to produce this partition.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/partition/Partition"
      },
      "rdfs:label": "sourceType",
      "rdfs:range": {
        "@id": "https://uor.foundation/type/TypeDefinition"
      }
    },
    {
      "@id": "https://uor.foundation/partition/quantum",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The quantum level n at which this partition was computed. The ring has 2^n elements at this level.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/partition/Partition"
      },
      "rdfs:label": "quantum",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#positiveInteger"
      }
    },
    {
      "@id": "https://uor.foundation/partition/fiberPosition",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The zero-based position of this fiber coordinate within the iterated fibration. Position 0 is the least significant bit; position n-1 is the most significant.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/partition/FiberCoordinate"
      },
      "rdfs:label": "fiberPosition",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#nonNegativeInteger"
      }
    },
    {
      "@id": "https://uor.foundation/partition/fiberState",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The current state of this fiber coordinate: 'pinned' if determined by a constraint, 'free' if still available for refinement.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/partition/FiberCoordinate"
      },
      "rdfs:label": "fiberState",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#string"
      }
    },
    {
      "@id": "https://uor.foundation/partition/fiberBudget",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The fiber budget associated with this partition.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/partition/Partition"
      },
      "rdfs:label": "fiberBudget",
      "rdfs:range": {
        "@id": "https://uor.foundation/partition/FiberBudget"
      }
    },
    {
      "@id": "https://uor.foundation/partition/totalFibers",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The total number of fiber coordinates in this budget, equal to the quantum level n.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/partition/FiberBudget"
      },
      "rdfs:label": "totalFibers",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#nonNegativeInteger"
      }
    },
    {
      "@id": "https://uor.foundation/partition/pinnedCount",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The number of fiber coordinates currently pinned by constraints.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/partition/FiberBudget"
      },
      "rdfs:label": "pinnedCount",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#nonNegativeInteger"
      }
    },
    {
      "@id": "https://uor.foundation/partition/freeCount",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The number of fiber coordinates still free (not yet pinned). Equals totalFibers - pinnedCount.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/partition/FiberBudget"
      },
      "rdfs:label": "freeCount",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#nonNegativeInteger"
      }
    },
    {
      "@id": "https://uor.foundation/partition/isClosed",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "Whether all fibers in this budget are pinned. A closed budget means the type is fully resolved and the partition is complete.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/partition/FiberBudget"
      },
      "rdfs:label": "isClosed",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#boolean"
      }
    },
    {
      "@id": "https://uor.foundation/partition/hasFiber",
      "@type": "owl:ObjectProperty",
      "rdfs:comment": "A fiber coordinate belonging to this budget.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/partition/FiberBudget"
      },
      "rdfs:label": "hasFiber",
      "rdfs:range": {
        "@id": "https://uor.foundation/partition/FiberCoordinate"
      }
    },
    {
      "@id": "https://uor.foundation/partition/pinnedBy",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The constraint that pins this fiber coordinate.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/partition/FiberPinning"
      },
      "rdfs:label": "pinnedBy",
      "rdfs:range": {
        "@id": "https://uor.foundation/type/Constraint"
      }
    },
    {
      "@id": "https://uor.foundation/partition/pinsCoordinate",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The fiber coordinate that this pinning determines.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/partition/FiberPinning"
      },
      "rdfs:label": "pinsCoordinate",
      "rdfs:range": {
        "@id": "https://uor.foundation/partition/FiberCoordinate"
      }
    },
    {
      "@id": "https://uor.foundation/partition/hasPinning",
      "@type": "owl:ObjectProperty",
      "rdfs:comment": "A fiber pinning record in this budget.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/partition/FiberBudget"
      },
      "rdfs:label": "hasPinning",
      "rdfs:range": {
        "@id": "https://uor.foundation/partition/FiberPinning"
      }
    },
    {
      "@id": "https://uor.foundation/partition/ancillaFiber",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "An ancilla fiber coordinate paired with this fiber for reversible computation (RC_1–RC_4 ancilla model).",
      "rdfs:domain": {
        "@id": "https://uor.foundation/partition/FiberCoordinate"
      },
      "rdfs:label": "ancillaFiber",
      "rdfs:range": {
        "@id": "https://uor.foundation/partition/FiberCoordinate"
      }
    },
    {
      "@id": "https://uor.foundation/partition/reversibleStrategy",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "True when this fiber budget uses a reversible computation strategy preserving information through ancilla fibers.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/partition/FiberBudget"
      },
      "rdfs:label": "reversibleStrategy",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#boolean"
      }
    },
    {
      "@id": "https://uor.foundation/partition/exteriorCriteria",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The formal membership criterion for this ExteriorSet: x ∈ Ext(T) iff x ∉ carrier(T). The ExteriorSet is context-dependent on the active type T (FPM_9).",
      "rdfs:domain": {
        "@id": "https://uor.foundation/partition/ExteriorSet"
      },
      "rdfs:label": "exteriorCriteria",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#string"
      }
    },
    {
      "@id": "https://uor.foundation/partition/isExhaustive",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "Whether the four components of this partition are exhaustive over R_n: |Irr| + |Red| + |Unit| + |Ext| = 2^n (FPM_8). Set by the kernel after verification.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/partition/Partition"
      },
      "rdfs:label": "isExhaustive",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#boolean"
      }
    },
    {
      "@id": "https://uor.foundation/partition/leftFactor",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The left operand partition of this tensor product.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/partition/PartitionProduct"
      },
      "rdfs:label": "leftFactor",
      "rdfs:range": {
        "@id": "https://uor.foundation/partition/Partition"
      }
    },
    {
      "@id": "https://uor.foundation/partition/rightFactor",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The right operand partition of this tensor product.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/partition/PartitionProduct"
      },
      "rdfs:label": "rightFactor",
      "rdfs:range": {
        "@id": "https://uor.foundation/partition/Partition"
      }
    },
    {
      "@id": "https://uor.foundation/partition/leftSummand",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The left operand partition of this coproduct.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/partition/PartitionCoproduct"
      },
      "rdfs:label": "leftSummand",
      "rdfs:range": {
        "@id": "https://uor.foundation/partition/Partition"
      }
    },
    {
      "@id": "https://uor.foundation/partition/rightSummand",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The right operand partition of this coproduct.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/partition/PartitionCoproduct"
      },
      "rdfs:label": "rightSummand",
      "rdfs:range": {
        "@id": "https://uor.foundation/partition/Partition"
      }
    },
    {
      "@id": "https://uor.foundation/observable/",
      "@type": "owl:Ontology",
      "owl:imports": [
        {
          "@id": "https://uor.foundation/op/"
        },
        {
          "@id": "https://uor.foundation/schema/"
        },
        {
          "@id": "https://uor.foundation/partition/"
        },
        {
          "@id": "https://uor.foundation/type/"
        }
      ],
      "rdfs:comment": "Observable quantities and metrics computed by the UOR kernel. Includes ring-metric, Hamming-metric, curvature, holonomy, and catastrophe-theoretic observables.",
      "rdfs:label": "UOR Observables",
      "uor:space": "bridge"
    },
    {
      "@id": "https://uor.foundation/observable/Observable",
      "@type": "owl:Class",
      "rdfs:comment": "A measurable quantity in the UOR Framework. All observables are kernel-computed and user-consumed.",
      "rdfs:label": "Observable",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/observable/StratumObservable",
      "@type": "owl:Class",
      "rdfs:comment": "An observable measuring stratum-level properties: position within the ring's layer structure.",
      "rdfs:label": "StratumObservable",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/observable/Observable"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/observable/MetricObservable",
      "@type": "owl:Class",
      "rdfs:comment": "An observable measuring geometric distance between ring elements under a specific metric.",
      "rdfs:label": "MetricObservable",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/observable/Observable"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/observable/PathObservable",
      "@type": "owl:Class",
      "rdfs:comment": "An observable measuring properties of paths through the ring: path length, total variation, winding number.",
      "rdfs:label": "PathObservable",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/observable/Observable"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/observable/CascadeObservable",
      "@type": "owl:Class",
      "rdfs:comment": "An observable measuring cascade properties: the length and count of operation sequences.",
      "rdfs:label": "CascadeObservable",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/observable/Observable"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/observable/CatastropheObservable",
      "@type": "owl:Class",
      "rdfs:comment": "An observable measuring catastrophe-theoretic properties: thresholds at which qualitative changes occur in the partition.",
      "rdfs:label": "CatastropheObservable",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/observable/Observable"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/observable/CurvatureObservable",
      "@type": "owl:Class",
      "rdfs:comment": "An observable measuring the curvature of the UOR geometry: the gap between ring-isometry and Hamming-isometry for a given transform.",
      "rdfs:label": "CurvatureObservable",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/observable/Observable"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/observable/HolonomyObservable",
      "@type": "owl:Class",
      "rdfs:comment": "An observable measuring holonomy: the accumulated transformation when traversing a closed path in the ring.",
      "rdfs:label": "HolonomyObservable",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/observable/Observable"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/observable/RingMetric",
      "@type": "owl:Class",
      "rdfs:comment": "Distance between two ring elements under the ring metric: d_R(x, y) = |x - y| mod 2^n.",
      "rdfs:label": "RingMetric",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/observable/MetricObservable"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/observable/HammingMetric",
      "@type": "owl:Class",
      "rdfs:comment": "Distance between two ring elements under the Hamming metric: the number of bit positions where they differ.",
      "rdfs:label": "HammingMetric",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/observable/MetricObservable"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/observable/IncompatibilityMetric",
      "@type": "owl:Class",
      "rdfs:comment": "The metric incompatibility between two ring elements: the divergence between their ring-metric and Hamming-metric distances, measuring geometric curvature.",
      "rdfs:label": "IncompatibilityMetric",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/observable/MetricObservable"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/observable/StratumValue",
      "@type": "owl:Class",
      "rdfs:comment": "The stratum index of a ring element.",
      "rdfs:label": "StratumValue",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/observable/StratumObservable"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/observable/StratumDelta",
      "@type": "owl:Class",
      "rdfs:comment": "The difference in stratum between two ring elements.",
      "rdfs:label": "StratumDelta",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/observable/StratumObservable"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/observable/StratumTrajectory",
      "@type": "owl:Class",
      "rdfs:comment": "The sequence of strata traversed by a path through the ring.",
      "rdfs:label": "StratumTrajectory",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/observable/StratumObservable"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/observable/PathLength",
      "@type": "owl:Class",
      "rdfs:comment": "The length of a path through the ring, measured in operation steps.",
      "rdfs:label": "PathLength",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/observable/PathObservable"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/observable/TotalVariation",
      "@type": "owl:Class",
      "rdfs:comment": "The total variation of a path: the sum of metric distances between consecutive elements.",
      "rdfs:label": "TotalVariation",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/observable/PathObservable"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/observable/WindingNumber",
      "@type": "owl:Class",
      "rdfs:comment": "The winding number of a closed path: the number of times the path wraps around the ring.",
      "rdfs:label": "WindingNumber",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/observable/PathObservable"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/observable/CascadeLength",
      "@type": "owl:Class",
      "rdfs:comment": "The number of operation applications in an operation cascade.",
      "rdfs:label": "CascadeLength",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/observable/CascadeObservable"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/observable/CascadeCount",
      "@type": "owl:Class",
      "rdfs:comment": "The number of distinct cascades in a computation.",
      "rdfs:label": "CascadeCount",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/observable/CascadeObservable"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/observable/CatastropheThreshold",
      "@type": "owl:Class",
      "rdfs:comment": "A critical value at which a qualitative change occurs in the partition structure.",
      "rdfs:label": "CatastropheThreshold",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/observable/CatastropheObservable"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/observable/CatastropheCount",
      "@type": "owl:Class",
      "rdfs:comment": "The number of catastrophe events (qualitative partition changes) in a computation.",
      "rdfs:label": "CatastropheCount",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/observable/CatastropheObservable"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/observable/Commutator",
      "@type": "owl:Class",
      "rdfs:comment": "The commutator [f, g](x) = f(g(x)) - g(f(x)) of two operations, measuring their non-commutativity.",
      "rdfs:label": "Commutator",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/observable/CurvatureObservable"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/observable/CurvatureFlux",
      "@type": "owl:Class",
      "rdfs:comment": "The integrated curvature over a region of type space: the total metric incompatibility accumulated.",
      "rdfs:label": "CurvatureFlux",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/observable/CurvatureObservable"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/observable/Monodromy",
      "@type": "owl:Class",
      "rdfs:comment": "The monodromy of a closed path: the net transformation accumulated when traversing a loop in the type space.",
      "rdfs:label": "Monodromy",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/observable/HolonomyObservable"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/observable/ParallelTransport",
      "@type": "owl:Class",
      "rdfs:comment": "The parallel transport of a vector along a path: the canonical lift of the path to the tangent bundle of the ring.",
      "rdfs:label": "ParallelTransport",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/observable/HolonomyObservable"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/observable/DihedralElement",
      "@type": "owl:Class",
      "rdfs:comment": "An element of the dihedral group D_{2^n} acting on the type space. Each dihedral element induces an isometry of 𝒯_n.",
      "rdfs:label": "DihedralElement",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/observable/HolonomyObservable"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/observable/MeasurementUnit",
      "@type": "owl:Class",
      "rdfs:comment": "A unit of measurement for observable quantities. Each MeasurementUnit individual names a specific unit (bits, ring steps, dimensionless) replacing the string-valued observable:unit property.",
      "rdfs:label": "MeasurementUnit",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/observable/Jacobian",
      "@type": "owl:Class",
      "rdfs:comment": "Fiber-by-fiber curvature decomposition. J_k measures the discrete derivative of the incompatibility metric at fiber position k: J_k = |d_R(x, succ(x)) - d_H(x, succ(x))| restricted to position k.",
      "rdfs:label": "Jacobian",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/observable/CurvatureObservable"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/observable/TopologicalObservable",
      "@type": "owl:Class",
      "rdfs:comment": "An observable measuring a topological invariant of the resolution space. Topological observables are invariant under continuous deformations of the constraint configuration.",
      "rdfs:label": "TopologicalObservable",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/observable/Observable"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/observable/BettiNumber",
      "@type": "owl:Class",
      "rdfs:comment": "The rank of a homology group of the constraint nerve. β_k = rank(H_k(N(C))) counts the k-dimensional holes in the constraint configuration.",
      "rdfs:label": "BettiNumber",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/observable/TopologicalObservable"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/observable/SpectralGap",
      "@type": "owl:Class",
      "rdfs:comment": "The smallest positive eigenvalue of the constraint nerve Laplacian. Controls the convergence rate of iterative resolution: larger gap = faster convergence.",
      "rdfs:label": "SpectralGap",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/observable/TopologicalObservable"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/observable/ThermoObservable",
      "@type": "owl:Class",
      "rdfs:comment": "An observable measuring thermodynamic properties of the resolution process: residual entropy, Landauer cost, and cascade distribution statistics.",
      "rdfs:label": "ThermoObservable",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/observable/Observable"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/observable/ResidualEntropy",
      "@type": "owl:Class",
      "rdfs:comment": "S_residual: the residual Shannon entropy of the fiber distribution after partial resolution. Computed as S = (Σ κ_k − χ(N(C))) × ln 2 (IT_7b). Unit: Nats.",
      "rdfs:label": "ResidualEntropy",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/observable/ThermoObservable"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/observable/LandauerCost",
      "@type": "owl:Class",
      "rdfs:comment": "The minimum thermodynamic cost (in units of k_B T ln 2) of erasing one bit of fiber uncertainty. The UOR ring operates at β* = ln 2 — the Landauer temperature.",
      "rdfs:label": "LandauerCost",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/observable/ThermoObservable"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/observable/CascadeEntropy",
      "@type": "owl:Class",
      "rdfs:comment": "The Shannon entropy of the cascade distribution P(j) = 2^{−j}. At the Landauer temperature, this equals ln 2 per cascade step — each step erases exactly one bit of fiber uncertainty.",
      "rdfs:label": "CascadeEntropy",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/observable/ThermoObservable"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/observable/SynthesisSignature",
      "@type": "owl:Class",
      "rdfs:comment": "A named topological signature: a pair (realised Euler characteristic, realised Betti profile). Linked from TypeSynthesisResult. Allows comparison between the goal signature and the actually achieved signature.",
      "rdfs:label": "SynthesisSignature",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/observable/SpectralSequencePage",
      "@type": "owl:Class",
      "rdfs:comment": "A single page E_r of the quantum level spectral sequence. Carries the page index r and the differential d_r. The sequence converges when all differentials vanish — typically by E_3 for simple constraint configurations.",
      "rdfs:label": "SpectralSequencePage",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/observable/LiftObstructionClass",
      "@type": "owl:Class",
      "rdfs:comment": "The cohomology class in H^2(N(C(T))) representing the LiftObstruction for a specific QuantumLift. The class is zero iff the obstruction is trivial. When non-zero, it indexes the specific fiber pair at Q_{n+1} that cannot be closed by the lifted constraint set alone.",
      "rdfs:label": "LiftObstructionClass",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/observable/MonodromyClass",
      "@type": "owl:Class",
      "rdfs:comment": "A classification of a type's holonomy: the subgroup of D_{2^n} generated by all Monodromy observables computed over closed paths in the type's constraint nerve. Trivial iff every closed constraint path returns to its starting fiber assignment without net dihedral transformation.",
      "rdfs:label": "MonodromyClass",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/observable/HolonomyGroup",
      "@type": "owl:Class",
      "rdfs:comment": "The holonomy group of a ConstrainedType: the group of all Monodromy elements achievable by closed paths in the constraint nerve. Always a subgroup of D_{2^n}. Trivial iff the type has trivial monodromy everywhere; equals D_{2^n} iff paths involving both neg and bnot involutions are present.",
      "rdfs:label": "HolonomyGroup",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/observable/ClosedConstraintPath",
      "@type": "owl:Class",
      "rdfs:comment": "A sequence of constraint applications forming a closed loop in the constraint nerve — beginning and ending at the same fiber assignment. The Monodromy of the loop is the net DihedralElement accumulated when traversing it.",
      "rdfs:label": "ClosedConstraintPath",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/observable/PhaseBoundaryType",
      "@type": "owl:Class",
      "rdfs:comment": "A classification of phase boundary in the catastrophe diagram: period boundary (g divides 2^n − 1) or power-of-two boundary (g = 2^k).",
      "rdfs:label": "PhaseBoundaryType",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/observable/AchievabilityStatus",
      "@type": "owl:Class",
      "rdfs:comment": "The achievability classification of a topological signature in the morphospace. Either Achievable (verified by EmpiricalVerification) or Forbidden (witnessed by ImpossibilityWitness).",
      "rdfs:label": "AchievabilityStatus",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/observable/value",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The numeric value of an observable measurement.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/observable/Observable"
      },
      "rdfs:label": "value",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#decimal"
      }
    },
    {
      "@id": "https://uor.foundation/observable/source",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The source object of this measurement (datum, partition, or path start point).",
      "rdfs:domain": {
        "@id": "https://uor.foundation/observable/Observable"
      },
      "rdfs:label": "source",
      "rdfs:range": {
        "@id": "http://www.w3.org/2002/07/owl#Thing"
      }
    },
    {
      "@id": "https://uor.foundation/observable/target",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The target object of this measurement (for metrics and path-end measurements).",
      "rdfs:domain": {
        "@id": "https://uor.foundation/observable/Observable"
      },
      "rdfs:label": "target",
      "rdfs:range": {
        "@id": "http://www.w3.org/2002/07/owl#Thing"
      }
    },
    {
      "@id": "https://uor.foundation/observable/hasUnit",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The measurement unit of this observable. Replaces the string-valued observable:unit property with a typed reference to a MeasurementUnit individual.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/observable/Observable"
      },
      "rdfs:label": "hasUnit",
      "rdfs:range": {
        "@id": "https://uor.foundation/observable/MeasurementUnit"
      }
    },
    {
      "@id": "https://uor.foundation/observable/fiberPosition",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The fiber position k at which this Jacobian entry is measured.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/observable/Jacobian"
      },
      "rdfs:label": "fiberPosition",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#nonNegativeInteger"
      }
    },
    {
      "@id": "https://uor.foundation/observable/derivativeValue",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The discrete derivative value at this fiber position.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/observable/Jacobian"
      },
      "rdfs:label": "derivativeValue",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#decimal"
      }
    },
    {
      "@id": "https://uor.foundation/observable/dimension",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The dimension k of the topological observable (e.g., the degree of the Betti number or the dimension of the spectral gap).",
      "rdfs:domain": {
        "@id": "https://uor.foundation/observable/TopologicalObservable"
      },
      "rdfs:label": "dimension",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#nonNegativeInteger"
      }
    },
    {
      "@id": "https://uor.foundation/observable/realisedEuler",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The Euler characteristic actually achieved by this synthesis signature.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/observable/SynthesisSignature"
      },
      "rdfs:label": "realisedEuler",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#integer"
      }
    },
    {
      "@id": "https://uor.foundation/observable/realisedBetti",
      "@type": "owl:DatatypeProperty",
      "rdfs:comment": "Non-functional. Realised Betti number values, one assertion per homological degree.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/observable/SynthesisSignature"
      },
      "rdfs:label": "realisedBetti",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#nonNegativeInteger"
      }
    },
    {
      "@id": "https://uor.foundation/observable/pageIndex",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The page r of this spectral sequence page. r=1 is the initial page; convergence is declared when all d_r are zero.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/observable/SpectralSequencePage"
      },
      "rdfs:label": "pageIndex",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#nonNegativeInteger"
      }
    },
    {
      "@id": "https://uor.foundation/observable/differentialIsZero",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "True iff d_r = 0 on this page — no further corrections to the lifted homology.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/observable/SpectralSequencePage"
      },
      "rdfs:label": "differentialIsZero",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#boolean"
      }
    },
    {
      "@id": "https://uor.foundation/observable/convergedAt",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The page index r at which the spectral sequence converged (all subsequent differentials zero).",
      "rdfs:domain": {
        "@id": "https://uor.foundation/observable/SpectralSequencePage"
      },
      "rdfs:label": "convergedAt",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#nonNegativeInteger"
      }
    },
    {
      "@id": "https://uor.foundation/observable/obstructionClass",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The cohomology class in H^2(N(C(T))) representing this obstruction.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/observable/LiftObstructionClass"
      },
      "rdfs:label": "obstructionClass",
      "rdfs:range": {
        "@id": "https://uor.foundation/cohomology/CohomologyGroup"
      }
    },
    {
      "@id": "https://uor.foundation/observable/monodromyLoop",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The closed path that generates this monodromy value.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/observable/Monodromy"
      },
      "rdfs:label": "monodromyLoop",
      "rdfs:range": {
        "@id": "https://uor.foundation/observable/ClosedConstraintPath"
      }
    },
    {
      "@id": "https://uor.foundation/observable/monodromyElement",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The dihedral element g in D_{2^n} accumulated when traversing the loop. The monodromy is trivial iff this element is the group identity.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/observable/Monodromy"
      },
      "rdfs:label": "monodromyElement",
      "rdfs:range": {
        "@id": "https://uor.foundation/observable/DihedralElement"
      }
    },
    {
      "@id": "https://uor.foundation/observable/isTrivialMonodromy",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "True iff the monodromyElement is the identity in D_{2^n}.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/observable/Monodromy"
      },
      "rdfs:label": "isTrivialMonodromy",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#boolean"
      }
    },
    {
      "@id": "https://uor.foundation/observable/holonomyGroup",
      "@type": "owl:ObjectProperty",
      "rdfs:comment": "Non-functional. The generators of the holonomy group: one DihedralElement per generating monodromy.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/observable/HolonomyGroup"
      },
      "rdfs:label": "holonomyGroup",
      "rdfs:range": {
        "@id": "https://uor.foundation/observable/DihedralElement"
      }
    },
    {
      "@id": "https://uor.foundation/observable/holonomyGroupOrder",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The order of the holonomy group as a subgroup of D_{2^n}. For a FlatType: 1. For full dihedral holonomy: 2^{n+1}.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/observable/HolonomyGroup"
      },
      "rdfs:label": "holonomyGroupOrder",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#positiveInteger"
      }
    },
    {
      "@id": "https://uor.foundation/observable/pathLength",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The number of constraint application steps in this closed path.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/observable/ClosedConstraintPath"
      },
      "rdfs:label": "pathLength",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#nonNegativeInteger"
      }
    },
    {
      "@id": "https://uor.foundation/observable/pathConstraints",
      "@type": "owl:ObjectProperty",
      "rdfs:comment": "Non-functional. The ordered sequence of constraints traversed. One assertion per step.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/observable/ClosedConstraintPath"
      },
      "rdfs:label": "pathConstraints",
      "rdfs:range": {
        "@id": "https://uor.foundation/type/Constraint"
      }
    },
    {
      "@id": "https://uor.foundation/observable/dihedralElementValue",
      "@type": "owl:ObjectProperty",
      "rdfs:comment": "Non-functional. One assertion per generator in the normal form of the element — the sequence of neg and/or bnot operations that realises this dihedral element when composed.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/observable/DihedralElement"
      },
      "rdfs:label": "dihedralElementValue",
      "rdfs:range": {
        "@id": "https://uor.foundation/op/Operation"
      }
    },
    {
      "@id": "https://uor.foundation/observable/isIdentityElement",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "True iff this element is the group identity (the trivial monodromy value).",
      "rdfs:domain": {
        "@id": "https://uor.foundation/observable/DihedralElement"
      },
      "rdfs:label": "isIdentityElement",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#boolean"
      }
    },
    {
      "@id": "https://uor.foundation/observable/elementOrder",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The order of this element in D_{2^n}: the smallest k >= 1 such that g^k = id. For neg and bnot: order 2.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/observable/DihedralElement"
      },
      "rdfs:label": "elementOrder",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#positiveInteger"
      }
    },
    {
      "@id": "https://uor.foundation/observable/hardnessEstimate",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "An estimated computational hardness for a ThermoObservable, connecting thermodynamic cost to complexity (TH_9 realisation).",
      "rdfs:domain": {
        "@id": "https://uor.foundation/observable/ThermoObservable"
      },
      "rdfs:label": "hardnessEstimate",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#decimal"
      }
    },
    {
      "@id": "https://uor.foundation/observable/phaseN",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The ring dimension coordinate n in the (n, g) catastrophe phase diagram (PD_1 n-coordinate).",
      "rdfs:domain": {
        "@id": "https://uor.foundation/observable/CatastropheObservable"
      },
      "rdfs:label": "phaseN",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#positiveInteger"
      }
    },
    {
      "@id": "https://uor.foundation/observable/phaseG",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The group-order coordinate g in the (n, g) catastrophe phase diagram (PD_1 g-coordinate).",
      "rdfs:domain": {
        "@id": "https://uor.foundation/observable/CatastropheObservable"
      },
      "rdfs:label": "phaseG",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#positiveInteger"
      }
    },
    {
      "@id": "https://uor.foundation/observable/onResonanceLine",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "True when g divides 2^n − 1, placing this observable on a resonance line in the phase diagram (PD_4).",
      "rdfs:domain": {
        "@id": "https://uor.foundation/observable/CatastropheObservable"
      },
      "rdfs:label": "onResonanceLine",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#boolean"
      }
    },
    {
      "@id": "https://uor.foundation/observable/phaseBoundaryType",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The type of phase boundary at this point in the catastrophe diagram: PeriodBoundary or PowerOfTwoBoundary (PD_2).",
      "rdfs:domain": {
        "@id": "https://uor.foundation/observable/CatastropheObservable"
      },
      "rdfs:label": "phaseBoundaryType",
      "rdfs:range": {
        "@id": "https://uor.foundation/observable/PhaseBoundaryType"
      }
    },
    {
      "@id": "https://uor.foundation/observable/achievabilityStatus",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The achievability classification of this observable's topological signature in the morphospace.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/observable/SynthesisSignature"
      },
      "rdfs:label": "achievabilityStatus",
      "rdfs:range": {
        "@id": "https://uor.foundation/observable/AchievabilityStatus"
      }
    },
    {
      "@id": "https://uor.foundation/observable/isAchievable",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "Whether this signature has been empirically verified as achievable at some quantum level.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/observable/SynthesisSignature"
      },
      "rdfs:label": "isAchievable",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#boolean"
      }
    },
    {
      "@id": "https://uor.foundation/observable/isForbidden",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "Whether this signature has been formally proven impossible by an ImpossibilityWitness.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/observable/SynthesisSignature"
      },
      "rdfs:label": "isForbidden",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#boolean"
      }
    },
    {
      "@id": "https://uor.foundation/observable/achievabilityWitness",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The proof individual (ImpossibilityWitness or EmpiricalVerification) that grounds this signature's achievability classification.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/observable/SynthesisSignature"
      },
      "rdfs:label": "achievabilityWitness",
      "rdfs:range": {
        "@id": "https://uor.foundation/proof/Proof"
      }
    },
    {
      "@id": "https://uor.foundation/observable/rotationExponent",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The rotation exponent k ∈ \\[0, 2^n) of this dihedral element in the standard representation r^k s^s. Together with reflectionBit, uniquely identifies the element within D_\\{2^n\\}.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/observable/DihedralElement"
      },
      "rdfs:label": "rotationExponent",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#nonNegativeInteger"
      }
    },
    {
      "@id": "https://uor.foundation/observable/reflectionBit",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The reflection flag s ∈ \\{0,1\\} of this dihedral element. False = pure rotation (r^k), true = reflection (r^k·s). D_7 defines composition: (r^a s^p)(r^b s^q) = r^(a + (-1)^p b) s^(p XOR q).",
      "rdfs:domain": {
        "@id": "https://uor.foundation/observable/DihedralElement"
      },
      "rdfs:label": "reflectionBit",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#boolean"
      }
    },
    {
      "@id": "https://uor.foundation/observable/Bits",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/observable/MeasurementUnit"
      ],
      "rdfs:comment": "Information-theoretic unit: the measurement is in bits (e.g., Hamming weight, entropy).",
      "rdfs:label": "Bits"
    },
    {
      "@id": "https://uor.foundation/observable/RingSteps",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/observable/MeasurementUnit"
      ],
      "rdfs:comment": "Ring-arithmetic unit: the measurement is in ring distance steps (|x - y| mod 2^n).",
      "rdfs:label": "RingSteps"
    },
    {
      "@id": "https://uor.foundation/observable/Dimensionless",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/observable/MeasurementUnit"
      ],
      "rdfs:comment": "Dimensionless unit: the measurement is a pure number (e.g., winding number, Betti number, spectral gap).",
      "rdfs:label": "Dimensionless"
    },
    {
      "@id": "https://uor.foundation/observable/Nats",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/observable/MeasurementUnit"
      ],
      "rdfs:comment": "Natural information unit: entropy measured in nats (using natural logarithm). S_residual is expressed in nats when computed as (Σ κ_k − χ) × ln 2.",
      "rdfs:label": "Nats"
    },
    {
      "@id": "https://uor.foundation/observable/PeriodBoundary",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/observable/PhaseBoundaryType"
      ],
      "rdfs:comment": "A phase boundary where g divides 2^n − 1, meaning g is a period of the multiplicative structure of R_n.",
      "rdfs:label": "PeriodBoundary"
    },
    {
      "@id": "https://uor.foundation/observable/PowerOfTwoBoundary",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/observable/PhaseBoundaryType"
      ],
      "rdfs:comment": "A phase boundary where g = 2^k, meaning g aligns with the binary stratification of R_n.",
      "rdfs:label": "PowerOfTwoBoundary"
    },
    {
      "@id": "https://uor.foundation/observable/Achievable",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/observable/AchievabilityStatus"
      ],
      "rdfs:comment": "The signature has been empirically verified as achievable at some quantum level by an EmpiricalVerification record.",
      "rdfs:label": "Achievable"
    },
    {
      "@id": "https://uor.foundation/observable/Forbidden",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/observable/AchievabilityStatus"
      ],
      "rdfs:comment": "The signature has been formally proven impossible by an ImpossibilityWitness deriving from MS_1, MS_2, or other impossibility theorems.",
      "rdfs:label": "Forbidden"
    },
    {
      "@id": "https://uor.foundation/homology/",
      "@type": "owl:Ontology",
      "owl:imports": [
        {
          "@id": "https://uor.foundation/schema/"
        },
        {
          "@id": "https://uor.foundation/type/"
        },
        {
          "@id": "https://uor.foundation/resolver/"
        },
        {
          "@id": "https://uor.foundation/partition/"
        },
        {
          "@id": "https://uor.foundation/observable/"
        },
        {
          "@id": "https://uor.foundation/op/"
        }
      ],
      "rdfs:comment": "Simplicial complexes, chain complexes, boundary operators, and homology groups for structural reasoning.",
      "rdfs:label": "UOR Homology",
      "uor:space": "bridge"
    },
    {
      "@id": "https://uor.foundation/homology/Simplex",
      "@type": "owl:Class",
      "rdfs:comment": "A k-simplex: a finite set of k+1 vertices drawn from constraint objects.",
      "rdfs:label": "Simplex",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/homology/SimplicialComplex",
      "@type": "owl:Class",
      "rdfs:comment": "A simplicial complex: a set of simplices closed under taking faces.",
      "rdfs:label": "SimplicialComplex",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/homology/FaceMap",
      "@type": "owl:Class",
      "rdfs:comment": "A face map d_i: removes vertex i from a simplex, producing a face.",
      "rdfs:label": "FaceMap",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/homology/ChainGroup",
      "@type": "owl:Class",
      "rdfs:comment": "A free abelian group generated by k-simplices (the k-th chain group C_k).",
      "rdfs:label": "ChainGroup",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/homology/BoundaryOperator",
      "@type": "owl:Class",
      "rdfs:comment": "The boundary operator ∂_k: C_k → C_{k-1}. Satisfies ∂² = 0.",
      "rdfs:label": "BoundaryOperator",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/homology/ChainComplex",
      "@type": "owl:Class",
      "rdfs:comment": "A chain complex: a sequence of chain groups connected by boundary operators.",
      "rdfs:label": "ChainComplex",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/homology/HomologyGroup",
      "@type": "owl:Class",
      "rdfs:comment": "The k-th homology group H_k = ker(∂_k) / im(∂_{k+1}). Measures k-dimensional holes.",
      "rdfs:label": "HomologyGroup",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/homology/NerveFunctor",
      "@type": "owl:Class",
      "rdfs:comment": "The nerve functor N: maps a set of constraints to a simplicial complex.",
      "rdfs:label": "NerveFunctor",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/homology/ChainFunctor",
      "@type": "owl:Class",
      "rdfs:comment": "The chain functor C: maps a simplicial complex to a chain complex.",
      "rdfs:label": "ChainFunctor",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/homology/dimension",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The dimension k of a simplex (number of vertices minus one).",
      "rdfs:domain": {
        "@id": "https://uor.foundation/homology/Simplex"
      },
      "rdfs:label": "dimension",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#integer"
      }
    },
    {
      "@id": "https://uor.foundation/homology/vertex",
      "@type": "owl:ObjectProperty",
      "rdfs:comment": "A vertex of this simplex, drawn from the set of constraint objects.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/homology/Simplex"
      },
      "rdfs:label": "vertex",
      "rdfs:range": {
        "@id": "https://uor.foundation/type/Constraint"
      }
    },
    {
      "@id": "https://uor.foundation/homology/vertexCount",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The number of vertices in this simplex (dimension + 1).",
      "rdfs:domain": {
        "@id": "https://uor.foundation/homology/Simplex"
      },
      "rdfs:label": "vertexCount",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#positiveInteger"
      }
    },
    {
      "@id": "https://uor.foundation/homology/isFaceOf",
      "@type": "owl:ObjectProperty",
      "rdfs:comment": "Indicates that this simplex is a face of another simplex.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/homology/Simplex"
      },
      "rdfs:label": "isFaceOf",
      "rdfs:range": {
        "@id": "https://uor.foundation/homology/Simplex"
      }
    },
    {
      "@id": "https://uor.foundation/homology/pinIntersection",
      "@type": "owl:ObjectProperty",
      "rdfs:comment": "A fiber coordinate in the partition whose intersection pins this simplex.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/homology/Simplex"
      },
      "rdfs:label": "pinIntersection",
      "rdfs:range": {
        "@id": "https://uor.foundation/partition/FiberCoordinate"
      }
    },
    {
      "@id": "https://uor.foundation/homology/hasSimplex",
      "@type": "owl:ObjectProperty",
      "rdfs:comment": "A simplex belonging to this simplicial complex.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/homology/SimplicialComplex"
      },
      "rdfs:label": "hasSimplex",
      "rdfs:range": {
        "@id": "https://uor.foundation/homology/Simplex"
      }
    },
    {
      "@id": "https://uor.foundation/homology/maxDimension",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The maximum dimension of any simplex in this simplicial complex.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/homology/SimplicialComplex"
      },
      "rdfs:label": "maxDimension",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#integer"
      }
    },
    {
      "@id": "https://uor.foundation/homology/eulerCharacteristic",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The Euler characteristic of this simplicial complex: the alternating sum of simplex counts by dimension.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/homology/SimplicialComplex"
      },
      "rdfs:label": "eulerCharacteristic",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#integer"
      }
    },
    {
      "@id": "https://uor.foundation/homology/simplicialVertexCount",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The total number of vertices (0-simplices) in this simplicial complex.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/homology/SimplicialComplex"
      },
      "rdfs:label": "simplicialVertexCount",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#nonNegativeInteger"
      }
    },
    {
      "@id": "https://uor.foundation/homology/removesVertex",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The index i of the vertex removed by this face map d_i.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/homology/FaceMap"
      },
      "rdfs:label": "removesVertex",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#nonNegativeInteger"
      }
    },
    {
      "@id": "https://uor.foundation/homology/sourceSimplex",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The source simplex of this face map.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/homology/FaceMap"
      },
      "rdfs:label": "sourceSimplex",
      "rdfs:range": {
        "@id": "https://uor.foundation/homology/Simplex"
      }
    },
    {
      "@id": "https://uor.foundation/homology/targetFace",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The target face (result simplex) of this face map.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/homology/FaceMap"
      },
      "rdfs:label": "targetFace",
      "rdfs:range": {
        "@id": "https://uor.foundation/homology/Simplex"
      }
    },
    {
      "@id": "https://uor.foundation/homology/degree",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The degree k of this chain group (the dimension of its generating simplices).",
      "rdfs:domain": {
        "@id": "https://uor.foundation/homology/ChainGroup"
      },
      "rdfs:label": "degree",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#integer"
      }
    },
    {
      "@id": "https://uor.foundation/homology/rank",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The rank of a free abelian group (number of generators).",
      "rdfs:label": "rank",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#nonNegativeInteger"
      }
    },
    {
      "@id": "https://uor.foundation/homology/generatedBy",
      "@type": "owl:ObjectProperty",
      "rdfs:comment": "A simplex that generates this chain group.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/homology/ChainGroup"
      },
      "rdfs:label": "generatedBy",
      "rdfs:range": {
        "@id": "https://uor.foundation/homology/Simplex"
      }
    },
    {
      "@id": "https://uor.foundation/homology/sourceGroup",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The source chain group C_k of this boundary operator.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/homology/BoundaryOperator"
      },
      "rdfs:label": "sourceGroup",
      "rdfs:range": {
        "@id": "https://uor.foundation/homology/ChainGroup"
      }
    },
    {
      "@id": "https://uor.foundation/homology/targetGroup",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The target chain group C_{k-1} of this boundary operator.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/homology/BoundaryOperator"
      },
      "rdfs:label": "targetGroup",
      "rdfs:range": {
        "@id": "https://uor.foundation/homology/ChainGroup"
      }
    },
    {
      "@id": "https://uor.foundation/homology/satisfiesBoundarySquaredZero",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "Whether this boundary operator satisfies the fundamental property ∂² = 0.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/homology/BoundaryOperator"
      },
      "rdfs:label": "satisfiesBoundarySquaredZero",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#boolean"
      }
    },
    {
      "@id": "https://uor.foundation/homology/hasChainGroup",
      "@type": "owl:ObjectProperty",
      "rdfs:comment": "A chain group belonging to this chain complex.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/homology/ChainComplex"
      },
      "rdfs:label": "hasChainGroup",
      "rdfs:range": {
        "@id": "https://uor.foundation/homology/ChainGroup"
      }
    },
    {
      "@id": "https://uor.foundation/homology/hasBoundary",
      "@type": "owl:ObjectProperty",
      "rdfs:comment": "A boundary operator belonging to this chain complex.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/homology/ChainComplex"
      },
      "rdfs:label": "hasBoundary",
      "rdfs:range": {
        "@id": "https://uor.foundation/homology/BoundaryOperator"
      }
    },
    {
      "@id": "https://uor.foundation/homology/homologyDegree",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The degree k of this homology group H_k.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/homology/HomologyGroup"
      },
      "rdfs:label": "homologyDegree",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#integer"
      }
    },
    {
      "@id": "https://uor.foundation/homology/bettiNumber",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The Betti number β_k = rank(H_k): the rank of this homology group.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/homology/HomologyGroup"
      },
      "rdfs:label": "bettiNumber",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#nonNegativeInteger"
      }
    },
    {
      "@id": "https://uor.foundation/homology/groundedIn",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The homology group that grounds this Betti number observable.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/observable/BettiNumber"
      },
      "rdfs:label": "groundedIn",
      "rdfs:range": {
        "@id": "https://uor.foundation/homology/HomologyGroup"
      }
    },
    {
      "@id": "https://uor.foundation/homology/laplacianOf",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The chain complex whose Laplacian determines this spectral gap.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/observable/SpectralGap"
      },
      "rdfs:label": "laplacianOf",
      "rdfs:range": {
        "@id": "https://uor.foundation/homology/ChainComplex"
      }
    },
    {
      "@id": "https://uor.foundation/homology/homologicalAnalysis",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The chain complex used for homological analysis of a resolution state.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/resolver/ResolutionState"
      },
      "rdfs:label": "homologicalAnalysis",
      "rdfs:range": {
        "@id": "https://uor.foundation/homology/ChainComplex"
      }
    },
    {
      "@id": "https://uor.foundation/homology/boundarySquaredZero",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "c ∈ C_{k+1}",
      "op:lhs": "∂_k(∂_{k+1}(c))",
      "op:rhs": "0",
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Topological"
      },
      "op:verificationPathNote": "ChainComplex → BoundaryOperator → ∂² = 0",
      "rdfs:comment": "∂² = 0: the boundary of a boundary is zero.",
      "rdfs:label": "boundarySquaredZero"
    },
    {
      "@id": "https://uor.foundation/homology/nerveFunctorN",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/homology/NerveFunctor"
      ],
      "rdfs:comment": "The nerve functor N: constraints → simplicial complex.",
      "rdfs:label": "nerveFunctorN"
    },
    {
      "@id": "https://uor.foundation/homology/chainFunctorC",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/homology/ChainFunctor"
      ],
      "rdfs:comment": "The chain functor C: simplicial complex → chain complex.",
      "rdfs:label": "chainFunctorC"
    },
    {
      "@id": "https://uor.foundation/homology/psi_4",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "simplicial complex K",
      "op:lhs": "β_k(K)",
      "op:rhs": "rank(H_k(K))",
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Topological"
      },
      "op:verificationPathNote": "HomologyGroup → rank → BettiNumber",
      "rdfs:comment": "ψ_4: HomologyGroups → BettiNumbers (extraction functor).",
      "rdfs:label": "psi_4"
    },
    {
      "@id": "https://uor.foundation/homology/indexBridge",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "finite simplicial complex K",
      "op:lhs": "χ(K)",
      "op:rhs": "Σ_k (-1)^k β_k",
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Topological"
      },
      "op:verificationPathNote": "SimplicialComplex → ChainComplex → HomologyGroup → BettiNumber → alternating sum",
      "rdfs:comment": "Index bridge: connects Euler characteristic to alternating Betti sum.",
      "rdfs:label": "indexBridge"
    },
    {
      "@id": "https://uor.foundation/cohomology/",
      "@type": "owl:Ontology",
      "owl:imports": [
        {
          "@id": "https://uor.foundation/schema/"
        },
        {
          "@id": "https://uor.foundation/homology/"
        },
        {
          "@id": "https://uor.foundation/resolver/"
        },
        {
          "@id": "https://uor.foundation/observable/"
        },
        {
          "@id": "https://uor.foundation/partition/"
        }
      ],
      "rdfs:comment": "Cochain complexes, sheaf cohomology, and local-to-global obstruction detection.",
      "rdfs:label": "UOR Cohomology",
      "uor:space": "bridge"
    },
    {
      "@id": "https://uor.foundation/cohomology/CochainGroup",
      "@type": "owl:Class",
      "rdfs:comment": "A cochain group: the dual of a chain group, maps chains to coefficients.",
      "rdfs:label": "CochainGroup",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/cohomology/CoboundaryOperator",
      "@type": "owl:Class",
      "rdfs:comment": "The coboundary operator δ^k: C^k → C^{k+1}. Satisfies δ² = 0.",
      "rdfs:label": "CoboundaryOperator",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/cohomology/CochainComplex",
      "@type": "owl:Class",
      "rdfs:comment": "A cochain complex: a sequence of cochain groups connected by coboundary operators.",
      "rdfs:label": "CochainComplex",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/cohomology/CohomologyGroup",
      "@type": "owl:Class",
      "rdfs:comment": "The k-th cohomology group H^k = ker(δ^k) / im(δ^{k-1}). Measures k-dimensional obstructions.",
      "rdfs:label": "CohomologyGroup",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/cohomology/Sheaf",
      "@type": "owl:Class",
      "rdfs:comment": "A sheaf F over a simplicial complex: assigns data to each simplex with restriction maps.",
      "rdfs:label": "Sheaf",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/cohomology/Stalk",
      "@type": "owl:Class",
      "rdfs:comment": "A stalk F_σ: the local data of a sheaf at a simplex σ.",
      "rdfs:label": "Stalk",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/cohomology/Section",
      "@type": "owl:Class",
      "rdfs:comment": "A global section of a sheaf: a consistent choice of local data across all simplices.",
      "rdfs:label": "Section",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/cohomology/LocalSection",
      "@type": "owl:Class",
      "rdfs:comment": "A local section: a consistent choice of data over a subcomplex.",
      "rdfs:label": "LocalSection",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/cohomology/Section"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/cohomology/RestrictionMap",
      "@type": "owl:Class",
      "rdfs:comment": "A restriction map ρ_{σ,τ}: maps data from a simplex to a face.",
      "rdfs:label": "RestrictionMap",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/cohomology/GluingObstruction",
      "@type": "owl:Class",
      "rdfs:comment": "A gluing obstruction: a cohomology class that detects when local sections fail to glue.",
      "rdfs:label": "GluingObstruction",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/cohomology/cochainDegree",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The degree k of this cochain group C^k.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/cohomology/CochainGroup"
      },
      "rdfs:label": "cochainDegree",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#integer"
      }
    },
    {
      "@id": "https://uor.foundation/cohomology/cochainRank",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The rank (dimension) of this cochain group.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/cohomology/CochainGroup"
      },
      "rdfs:label": "cochainRank",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#nonNegativeInteger"
      }
    },
    {
      "@id": "https://uor.foundation/cohomology/dualOf",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The chain group that this cochain group is dual to.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/cohomology/CochainGroup"
      },
      "rdfs:label": "dualOf",
      "rdfs:range": {
        "@id": "https://uor.foundation/homology/ChainGroup"
      }
    },
    {
      "@id": "https://uor.foundation/cohomology/coboundarySource",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The source cochain group of this coboundary operator.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/cohomology/CoboundaryOperator"
      },
      "rdfs:label": "coboundarySource",
      "rdfs:range": {
        "@id": "https://uor.foundation/cohomology/CochainGroup"
      }
    },
    {
      "@id": "https://uor.foundation/cohomology/coboundaryTarget",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The target cochain group of this coboundary operator.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/cohomology/CoboundaryOperator"
      },
      "rdfs:label": "coboundaryTarget",
      "rdfs:range": {
        "@id": "https://uor.foundation/cohomology/CochainGroup"
      }
    },
    {
      "@id": "https://uor.foundation/cohomology/satisfiesCoboundarySquaredZero",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "Whether this coboundary operator satisfies δ² = 0.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/cohomology/CoboundaryOperator"
      },
      "rdfs:label": "satisfiesCoboundarySquaredZero",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#boolean"
      }
    },
    {
      "@id": "https://uor.foundation/cohomology/hasCochainGroup",
      "@type": "owl:ObjectProperty",
      "rdfs:comment": "A cochain group belonging to this cochain complex.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/cohomology/CochainComplex"
      },
      "rdfs:label": "hasCochainGroup",
      "rdfs:range": {
        "@id": "https://uor.foundation/cohomology/CochainGroup"
      }
    },
    {
      "@id": "https://uor.foundation/cohomology/hasCoboundary",
      "@type": "owl:ObjectProperty",
      "rdfs:comment": "A coboundary operator belonging to this cochain complex.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/cohomology/CochainComplex"
      },
      "rdfs:label": "hasCoboundary",
      "rdfs:range": {
        "@id": "https://uor.foundation/cohomology/CoboundaryOperator"
      }
    },
    {
      "@id": "https://uor.foundation/cohomology/cohomologyDegree",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The degree k of this cohomology group H^k.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/cohomology/CohomologyGroup"
      },
      "rdfs:label": "cohomologyDegree",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#integer"
      }
    },
    {
      "@id": "https://uor.foundation/cohomology/cohomologyRank",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The rank (dimension) of this cohomology group.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/cohomology/CohomologyGroup"
      },
      "rdfs:label": "cohomologyRank",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#nonNegativeInteger"
      }
    },
    {
      "@id": "https://uor.foundation/cohomology/sheafOver",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The simplicial complex that this sheaf is defined over.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/cohomology/Sheaf"
      },
      "rdfs:label": "sheafOver",
      "rdfs:range": {
        "@id": "https://uor.foundation/homology/SimplicialComplex"
      }
    },
    {
      "@id": "https://uor.foundation/cohomology/coefficientIn",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The coefficient ring of this sheaf.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/cohomology/Sheaf"
      },
      "rdfs:label": "coefficientIn",
      "rdfs:range": {
        "@id": "https://uor.foundation/schema/Ring"
      }
    },
    {
      "@id": "https://uor.foundation/cohomology/hasStalks",
      "@type": "owl:ObjectProperty",
      "rdfs:comment": "A stalk belonging to this sheaf.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/cohomology/Sheaf"
      },
      "rdfs:label": "hasStalks",
