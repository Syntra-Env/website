      "op:rhs": "freeCount(C) × ln 2 / n",
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Thermodynamic"
      },
      "op:verificationPathNote": "TH_1 → normalized entropy per fiber → context temperature",
      "rdfs:comment": "Context temperature: T_ctx(C) = freeCount(C) × ln 2 / n.",
      "rdfs:label": "SC_1"
    },
    {
      "@id": "https://uor.foundation/op/SC_2",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "C: Context, n = fiberBudget",
      "op:lhs": "σ(C)",
      "op:rhs": "(n − freeCount(C)) / n",
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Algebraic"
      },
      "op:verificationPathNote": "Definitional: normalized coldness of context",
      "rdfs:comment": "Saturation degree: σ(C) = (n − freeCount(C)) / n.",
      "rdfs:label": "SC_2"
    },
    {
      "@id": "https://uor.foundation/op/SC_3",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "i in Session S",
      "op:lhs": "σ(B_{i+1})",
      "op:rhs": "≥ σ(B_i)",
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Algebraic"
      },
      "op:verificationPathNote": "SR_1 → order-reversing definition of SC_2 → monotone cooling",
      "rdfs:comment": "Saturation monotonicity: σ(B_{i+1}) ≥ σ(B_i) for all i in a Session.",
      "rdfs:label": "SC_3"
    },
    {
