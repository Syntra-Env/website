      },
      "op:verificationPathNote": "CompleteType → O(1) resolution → quantum-level-agnostic",
      "rdfs:comment": "Resolution complexity for a CompleteType is O(1) for all n ≥ 1.",
      "rdfs:label": "QL_5"
    },
    {
      "@id": "https://uor.foundation/op/QL_6",
      "@type": [
        "owl:NamedIndividual",
