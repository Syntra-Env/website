      "rdfs:label": "PT_4"
    },
    {
      "@id": "https://uor.foundation/op/ST_1",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "A, B: TypeDefinition",
