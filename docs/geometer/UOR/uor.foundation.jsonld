    },
    {
      "@id": "https://uor.foundation/op/ST_2",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "A, B: TypeDefinition",
      "op:lhs": "S(A + B)",
      "op:rhs": "ln 2 + max(S(A), S(B))",
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Thermodynamic"
      },
      "op:verificationPathNote": "SumType → entropy with binary choice overhead",
      "rdfs:comment": "Sum type entropy: S(A + B) = ln 2 + max(S(A), S(B)).",
      "rdfs:label": "ST_2"
    },
    {
      "@id": "https://uor.foundation/op/SC_1",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "C: Context, n = fiberBudget",
