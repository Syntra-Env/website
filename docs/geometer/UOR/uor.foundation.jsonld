      }
    },
    {
      "@id": "https://uor.foundation/cohomology/stalkAt",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The simplex at which this stalk is located.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/cohomology/Stalk"
      },
      "rdfs:label": "stalkAt",
      "rdfs:range": {
        "@id": "https://uor.foundation/homology/Simplex"
      }
    },
    {
      "@id": "https://uor.foundation/cohomology/restrictsFrom",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The source simplex of this restriction map.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/cohomology/RestrictionMap"
      },
      "rdfs:label": "restrictsFrom",
      "rdfs:range": {
        "@id": "https://uor.foundation/homology/Simplex"
      }
    },
    {
      "@id": "https://uor.foundation/cohomology/restrictsTo",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The target simplex (face) of this restriction map.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/cohomology/RestrictionMap"
      },
      "rdfs:label": "restrictsTo",
      "rdfs:range": {
        "@id": "https://uor.foundation/homology/Simplex"
      }
    },
    {
      "@id": "https://uor.foundation/cohomology/hasGlobalSection",
      "@type": "owl:ObjectProperty",
      "rdfs:comment": "A global section of this sheaf.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/cohomology/Sheaf"
      },
      "rdfs:label": "hasGlobalSection",
      "rdfs:range": {
        "@id": "https://uor.foundation/cohomology/Section"
      }
    },
    {
      "@id": "https://uor.foundation/cohomology/obstructionClass",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The cohomology class that this gluing obstruction represents.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/cohomology/GluingObstruction"
      },
      "rdfs:label": "obstructionClass",
      "rdfs:range": {
        "@id": "https://uor.foundation/cohomology/CohomologyGroup"
      }
    },
    {
      "@id": "https://uor.foundation/cohomology/addressesSuggestion",
      "@type": "owl:ObjectProperty",
      "rdfs:comment": "The refinement suggestion that, if applied, would resolve this gluing obstruction. Computed by the kernel when ψ₆ detects H^1 ≠ 0: the obstruction class indexes the fiber pair that is incompatible, and the suggestion targets that pair with a new bridging constraint.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/cohomology/GluingObstruction"
      },
      "rdfs:label": "addressesSuggestion",
      "rdfs:range": {
        "@id": "https://uor.foundation/resolver/RefinementSuggestion"
      }
    },
    {
      "@id": "https://uor.foundation/cohomology/sheafAnalysis",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The sheaf analysis associated with a resolution state.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/resolver/ResolutionState"
      },
      "rdfs:label": "sheafAnalysis",
      "rdfs:range": {
        "@id": "https://uor.foundation/cohomology/Sheaf"
      }
    },
    {
      "@id": "https://uor.foundation/cohomology/coboundarySquaredZero",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "f ∈ C^k",
      "op:lhs": "δ^{k+1}(δ^k(f))",
      "op:rhs": "0",
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Topological"
      },
      "op:verificationPathNote": "CochainComplex → CoboundaryOperator → δ² = 0",
      "rdfs:comment": "δ² = 0: the coboundary of a coboundary is zero.",
      "rdfs:label": "coboundarySquaredZero"
    },
    {
      "@id": "https://uor.foundation/cohomology/deRhamDuality",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "simplicial complex K, ring R",
      "op:lhs": "H^k(K; R)",
      "op:rhs": "Hom(H_k(K), R)",
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Topological"
      },
      "op:verificationPathNote": "CohomologyGroup ≅ dual(HomologyGroup)",
      "rdfs:comment": "Discrete de Rham duality: H^k ≅ Hom(H_k, R).",
      "rdfs:label": "deRhamDuality"
    },
    {
      "@id": "https://uor.foundation/cohomology/sheafCohomologyBridge",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "constant sheaf F_R over K",
      "op:lhs": "H^k(K; F_R)",
      "op:rhs": "H^k(K; R)",
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Topological"
      },
      "op:verificationPathNote": "Sheaf → constant coefficient → CochainComplex",
      "rdfs:comment": "Sheaf cohomology equals simplicial cohomology for constant sheaves.",
      "rdfs:label": "sheafCohomologyBridge"
    },
    {
      "@id": "https://uor.foundation/cohomology/localGlobalPrinciple",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "sheaf F over K",
      "op:lhs": "H^1(K; F) = 0",
      "op:rhs": "all local sections glue",
      "op:verificationDomain": {
        "@id": "https://uor.foundation/op/Topological"
      },
      "op:verificationPathNote": "CohomologyGroup → GluingObstruction → vanishing",
      "rdfs:comment": "Local-global principle: H^1(K; F) = 0 implies all local sections glue to global sections.",
      "rdfs:label": "localGlobalPrinciple"
    },
    {
      "@id": "https://uor.foundation/proof/",
      "@type": "owl:Ontology",
      "owl:imports": [
        {
          "@id": "https://uor.foundation/schema/"
        },
        {
          "@id": "https://uor.foundation/op/"
        },
        {
          "@id": "https://uor.foundation/derivation/"
        },
        {
          "@id": "https://uor.foundation/observable/"
        }
      ],
      "rdfs:comment": "Kernel-produced verification proofs attesting to algebraic properties of UOR objects and operations.",
      "rdfs:label": "UOR Proofs",
      "uor:space": "bridge"
    },
    {
      "@id": "https://uor.foundation/proof/Proof",
      "@type": "owl:Class",
      "rdfs:comment": "A kernel-produced attestation that a given algebraic property holds. The root class for all proof types.",
      "rdfs:label": "Proof",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/proof/CoherenceProof",
      "@type": "owl:Class",
      "rdfs:comment": "A proof of coherence: the type system and ring structure are mutually consistent at a given quantum level.",
      "rdfs:label": "CoherenceProof",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/proof/Proof"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/proof/ComputationCertificate",
      "@type": "owl:Class",
      "rdfs:comment": "A proof confirmed by exhaustive execution over R_n at a specific quantum level. The kernel ran the identity against all 2^n inputs and observed that it holds. The proof:atQuantumLevel property records the level; proof:witness links to the WitnessData. CriticalIdentityProof is a subclass of ComputationCertificate.",
      "rdfs:label": "ComputationCertificate",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/proof/Proof"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/proof/AxiomaticDerivation",
      "@type": "owl:Class",
      "rdfs:comment": "A proof that follows from previously established axioms or definitions by equational, structural, or topological reasoning. The proof:derivationWitness property links to a derivation:Derivation individual recording the rewrite chain. All pipeline, constraint, observable, and topological identities are AxiomaticDerivations.",
      "rdfs:label": "AxiomaticDerivation",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/proof/Proof"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/proof/CriticalIdentityProof",
      "@type": "owl:Class",
      "rdfs:comment": "A proof of the critical identity: neg(bnot(x)) = succ(x) for all x in R_n. This is the foundational theorem of the UOR kernel.",
      "rdfs:label": "CriticalIdentityProof",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/proof/ComputationCertificate"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/proof/WitnessData",
      "@type": "owl:Class",
      "rdfs:comment": "Supporting data for a proof: specific examples, counter-examples checked, or intermediate computation results.",
      "rdfs:label": "WitnessData",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/proof/EmpiricalVerification",
      "@type": "owl:Class",
      "rdfs:comment": "A proof grounded in empirical verification across a bounded range of quantum levels, rather than axiomatic derivation or exhaustive computation. Used for identities like AR_5 whose forAll quantifier is 'empirical, Q0--Q4'.",
      "rdfs:label": "EmpiricalVerification",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/proof/Proof"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/proof/ImpossibilityWitness",
      "@type": "owl:Class",
      "rdfs:comment": "A formal witness that a topological signature (χ, β_k) is impossible to achieve for any ConstrainedType. Carries the algebraic reason and the verification domain grounding the impossibility.",
      "rdfs:label": "ImpossibilityWitness",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/proof/Proof"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/proof/MorphospaceRecord",
      "@type": "owl:Class",
      "rdfs:comment": "A formal record of a morphospace boundary point — either an achievable or forbidden topological signature. Aggregated by MorphospaceBoundary to form the queryable morphospace map.",
      "rdfs:label": "MorphospaceRecord",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/proof/MorphospaceBoundary",
      "@type": "owl:Class",
      "rdfs:comment": "An aggregate of ImpossibilityWitness and EmpiricalVerification instances forming the queryable morphospace map. SPARQL over this structure answers achievability queries in O(1).",
      "rdfs:label": "MorphospaceBoundary",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/proof/InductiveProof",
      "@type": "owl:Class",
      "rdfs:comment": "A proof by structural induction on the quantum level index k. Carries a base case proof, an inductive step proof, and the minimum k for which the induction holds.",
      "rdfs:label": "InductiveProof",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/proof/Proof"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/proof/verified",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "Whether this proof has been verified by the kernel.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/proof/Proof"
      },
      "rdfs:label": "verified",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#boolean"
      }
    },
    {
      "@id": "https://uor.foundation/proof/timestamp",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The time at which this proof was produced.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/proof/Proof"
      },
      "rdfs:label": "timestamp",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#dateTime"
      }
    },
    {
      "@id": "https://uor.foundation/proof/witness",
      "@type": "owl:ObjectProperty",
      "rdfs:comment": "Supporting witness data for this proof.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/proof/Proof"
      },
      "rdfs:label": "witness",
      "rdfs:range": {
        "@id": "https://uor.foundation/proof/WitnessData"
      }
    },
    {
      "@id": "https://uor.foundation/proof/criticalIdentity",
      "@type": "owl:AnnotationProperty",
      "rdfs:comment": "Human-readable statement of the critical identity proven. E.g., 'neg(bnot(x)) = succ(x) for all x in R_n'. Annotation only — proof:provesIdentity is the typed reference.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/proof/CriticalIdentityProof"
      },
      "rdfs:label": "criticalIdentity",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#string"
      }
    },
    {
      "@id": "https://uor.foundation/proof/x",
      "@type": "owl:DatatypeProperty",
      "rdfs:comment": "A specific input value used as a witness for the critical identity check.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/proof/WitnessData"
      },
      "rdfs:label": "x",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#integer"
      }
    },
    {
      "@id": "https://uor.foundation/proof/bnot_x",
      "@type": "owl:DatatypeProperty",
      "rdfs:comment": "The value bnot(x) for a witness x.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/proof/WitnessData"
      },
      "rdfs:label": "bnot_x",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#integer"
      }
    },
    {
      "@id": "https://uor.foundation/proof/neg_bnot_x",
      "@type": "owl:DatatypeProperty",
      "rdfs:comment": "The value neg(bnot(x)) for a witness x.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/proof/WitnessData"
      },
      "rdfs:label": "neg_bnot_x",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#integer"
      }
    },
    {
      "@id": "https://uor.foundation/proof/succ_x",
      "@type": "owl:DatatypeProperty",
      "rdfs:comment": "The value succ(x) for a witness x.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/proof/WitnessData"
      },
      "rdfs:label": "succ_x",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#integer"
      }
    },
    {
      "@id": "https://uor.foundation/proof/holds",
      "@type": "owl:DatatypeProperty",
      "rdfs:comment": "Whether the identity neg(bnot(x)) = succ(x) holds for this specific witness.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/proof/WitnessData"
      },
      "rdfs:label": "holds",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#boolean"
      }
    },
    {
      "@id": "https://uor.foundation/proof/provesIdentity",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The algebraic identity this proof establishes. Provides a canonical object reference alongside the existing proof:criticalIdentity string property, which remains for human readability.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/proof/Proof"
      },
      "rdfs:label": "provesIdentity",
      "rdfs:range": {
        "@id": "https://uor.foundation/op/Identity"
      }
    },
    {
      "@id": "https://uor.foundation/proof/atQuantumLevel",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The quantum level at which this computation certificate was produced. A ComputationCertificate at schema:Q0 confirms the identity holds for all 256 inputs of R_8. A certificate at schema:Q1 confirms it for all 65,536 inputs of R_16.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/proof/ComputationCertificate"
      },
      "rdfs:label": "atQuantumLevel",
      "rdfs:range": {
        "@id": "https://uor.foundation/schema/QuantumLevel"
      }
    },
    {
      "@id": "https://uor.foundation/proof/quantumNote",
      "@type": "owl:AnnotationProperty",
      "rdfs:comment": "Human-readable quantum level note, e.g. 'n=8, 256 inputs'. Annotation only — proof:atQuantumLevel is the typed assertion.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/proof/ComputationCertificate"
      },
      "rdfs:label": "quantumNote",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#string"
      }
    },
    {
      "@id": "https://uor.foundation/proof/universalScope",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "True when this axiomatic derivation holds for all quantum levels by the definition of Z/(2^n)Z. False when the derivation depends on a property specific to a particular ring size. All current AxiomaticDerivation individuals in the spec carry universalScope true.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/proof/AxiomaticDerivation"
      },
      "rdfs:label": "universalScope",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#boolean"
      }
    },
    {
      "@id": "https://uor.foundation/proof/derivationWitness",
      "@type": "owl:ObjectProperty",
      "rdfs:comment": "The derivation chain that witnesses this axiomatic derivation. Links a proof:AxiomaticDerivation to the derivation:Derivation individual recording the rewrite sequence. Optional at the spec level — the conformance suite requires only that the proof individual exists; full derivation chains live in generated artifacts.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/proof/AxiomaticDerivation"
      },
      "rdfs:label": "derivationWitness",
      "rdfs:range": {
        "@id": "https://uor.foundation/derivation/Derivation"
      }
    },
    {
      "@id": "https://uor.foundation/proof/quantumLevelRange",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The range of quantum levels over which this empirical verification was conducted (e.g., 'Q0-Q4').",
      "rdfs:domain": {
        "@id": "https://uor.foundation/proof/EmpiricalVerification"
      },
      "rdfs:label": "quantumLevelRange",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#string"
      }
    },
    {
      "@id": "https://uor.foundation/proof/verificationMethod",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The empirical method used for verification (e.g., 'exhaustive enumeration over Z/(2^n)Z for n=8,16,32,64').",
      "rdfs:domain": {
        "@id": "https://uor.foundation/proof/EmpiricalVerification"
      },
      "rdfs:label": "verificationMethod",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#string"
      }
    },
    {
      "@id": "https://uor.foundation/proof/verifiedAt",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The timestamp at which empirical verification was conducted.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/proof/EmpiricalVerification"
      },
      "rdfs:label": "verifiedAt",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#dateTime"
      }
    },
    {
      "@id": "https://uor.foundation/proof/forbidsSignature",
      "@type": "owl:AnnotationProperty",
      "rdfs:comment": "The topological signature (χ, β_k) that this ImpossibilityWitness formally forbids, expressed as a symbolic notation string (e.g., 'β₀ = 0').",
      "rdfs:domain": {
        "@id": "https://uor.foundation/proof/ImpossibilityWitness"
      },
      "rdfs:label": "forbidsSignature",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#string"
      }
    },
    {
      "@id": "https://uor.foundation/proof/impossibilityReason",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "Human-readable statement of the algebraic reason the signature is impossible (e.g., 'β₀ = 0 violates MS_1').",
      "rdfs:domain": {
        "@id": "https://uor.foundation/proof/ImpossibilityWitness"
      },
      "rdfs:label": "impossibilityReason",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#string"
      }
    },
    {
      "@id": "https://uor.foundation/proof/impossibilityDomain",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The verification domain grounding the impossibility (e.g., Pipeline for β₀ = 0, Algebraic for χ > n).",
      "rdfs:domain": {
        "@id": "https://uor.foundation/proof/ImpossibilityWitness"
      },
      "rdfs:label": "impossibilityDomain",
      "rdfs:range": {
        "@id": "https://uor.foundation/op/VerificationDomain"
      }
    },
    {
      "@id": "https://uor.foundation/proof/achievabilityStatus",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The achievability classification of a proof-linked observable signature: Achievable or Forbidden.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/proof/EmpiricalVerification"
      },
      "rdfs:label": "achievabilityStatus",
      "rdfs:range": {
        "@id": "https://uor.foundation/observable/AchievabilityStatus"
      }
    },
    {
      "@id": "https://uor.foundation/proof/verifiedAtLevel",
      "@type": "owl:ObjectProperty",
      "rdfs:comment": "The specific quantum level at which an empirical verification or impossibility witness was established.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/proof/Proof"
      },
      "rdfs:label": "verifiedAtLevel",
      "rdfs:range": {
        "@id": "https://uor.foundation/schema/QuantumLevel"
      }
    },
    {
      "@id": "https://uor.foundation/proof/morphospaceRecord",
      "@type": "owl:ObjectProperty",
      "rdfs:comment": "Links a MorphospaceBoundary to one of its constituent MorphospaceRecord individuals.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/proof/MorphospaceBoundary"
      },
      "rdfs:label": "morphospaceRecord",
      "rdfs:range": {
        "@id": "https://uor.foundation/proof/MorphospaceRecord"
      }
    },
    {
      "@id": "https://uor.foundation/proof/boundaryType",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "Whether this MorphospaceRecord represents an impossibility boundary (from below) or an achievability boundary (from above).",
      "rdfs:domain": {
        "@id": "https://uor.foundation/proof/MorphospaceRecord"
