      },
      "op:verificationPathNote": "AD_1/AD_2 → bijection → all quantum levels",
      "rdfs:comment": "Content addressing is a bijection for all n ≥ 1 (AD_1/AD_2 universality).",
      "rdfs:label": "QL_6"
    },
    {
      "@id": "https://uor.foundation/op/QL_7",
