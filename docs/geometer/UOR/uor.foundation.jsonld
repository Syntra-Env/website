      "proof:provesIdentity": {
        "@id": "https://uor.foundation/op/MC_6"
      },
      "proof:universalScope": true,
      "proof:verified": true,
      "rdfs:comment": "Proof of MC_6: full lease coverage implies composed saturation.",
      "rdfs:label": "prf_MC_6"
    },
    {
      "@id": "https://uor.foundation/proof/prf_MC_7",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/proof/AxiomaticDerivation"
      ],
      "proof:provesIdentity": {
        "@id": "https://uor.foundation/op/MC_7"
      },
      "proof:universalScope": true,
      "proof:verified": true,
      "rdfs:comment": "Proof of MC_7: distributed O(1) resolution.",
      "rdfs:label": "prf_MC_7"
    },
    {
      "@id": "https://uor.foundation/proof/prf_MC_8",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/proof/AxiomaticDerivation"
      ],
      "proof:provesIdentity": {
        "@id": "https://uor.foundation/op/MC_8"
      },
      "proof:universalScope": true,
      "proof:verified": true,
      "rdfs:comment": "Proof of MC_8: parallelism bound on per-session resolution work.",
      "rdfs:label": "prf_MC_8"
    },
    {
      "@id": "https://uor.foundation/derivation/",
      "@type": "owl:Ontology",
      "owl:imports": [
        {
          "@id": "https://uor.foundation/observable/"
        },
        {
          "@id": "https://uor.foundation/op/"
        },
        {
          "@id": "https://uor.foundation/resolver/"
        },
        {
          "@id": "https://uor.foundation/schema/"
        },
        {
          "@id": "https://uor.foundation/type/"
        }
      ],
      "rdfs:comment": "Computation witnesses recording term rewriting sequences from original terms to their canonical forms.",
      "rdfs:label": "UOR Derivations",
      "uor:space": "bridge"
    },
    {
      "@id": "https://uor.foundation/derivation/Derivation",
      "@type": "owl:Class",
      "rdfs:comment": "A complete term rewriting witness: the full sequence of rewrite steps transforming an original term into its canonical form.",
      "rdfs:label": "Derivation",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/derivation/DerivationStep",
      "@type": "owl:Class",
      "rdfs:comment": "An abstract step in a derivation. Concrete subclasses are RewriteStep (term-level rewriting) and RefinementStep (type-level refinement).",
      "rdfs:label": "DerivationStep",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/derivation/RewriteStep",
      "@type": "owl:Class",
      "rdfs:comment": "A single rewrite step in a derivation: the application of one rewrite rule to transform a term.",
      "rdfs:label": "RewriteStep",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/derivation/DerivationStep"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/derivation/RefinementStep",
      "@type": "owl:Class",
      "rdfs:comment": "A type-level refinement step: the application of a constraint to narrow a type, pinning additional fiber coordinates. Complements RewriteStep (term-level) in the derivation hierarchy.",
      "rdfs:label": "RefinementStep",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/derivation/DerivationStep"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/derivation/RewriteRule",
      "@type": "owl:Class",
      "rdfs:comment": "A named rewrite rule that can be applied in a derivation step. Each RewriteRule individual represents a specific algebraic law or normalization strategy used during term rewriting.",
      "rdfs:label": "RewriteRule",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/derivation/TermMetrics",
      "@type": "owl:Class",
      "rdfs:comment": "Metrics describing the size and complexity of a term.",
      "rdfs:label": "TermMetrics",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/derivation/SynthesisStep",
      "@type": "owl:Class",
      "rdfs:comment": "A single step in the construction of a SynthesizedType: one constraint added to the synthesis candidate and the resulting change in the constraint nerve's topological signature. Ordered by derivation:stepIndex. Analogous to derivation:RewriteStep in the forward pipeline.",
      "rdfs:label": "SynthesisStep",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/derivation/SynthesisCheckpoint",
      "@type": "owl:Class",
      "rdfs:comment": "A persistent snapshot of a ConstraintSearchState at a specific SynthesisStep, allowing a TypeSynthesisResolver to resume exploration after interruption. Essential at Q1+ scale where exhaustive synthesis is computationally significant.",
      "rdfs:label": "SynthesisCheckpoint",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/derivation/originalTerm",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The term at the start of the derivation, before any rewriting.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/derivation/Derivation"
      },
      "rdfs:label": "originalTerm",
      "rdfs:range": {
        "@id": "https://uor.foundation/schema/Term"
      }
    },
    {
      "@id": "https://uor.foundation/derivation/canonicalTerm",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The canonical form produced at the end of the derivation.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/derivation/Derivation"
      },
      "rdfs:label": "canonicalTerm",
      "rdfs:range": {
        "@id": "https://uor.foundation/schema/Term"
      }
    },
    {
      "@id": "https://uor.foundation/derivation/result",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The datum value obtained by evaluating the canonical term.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/derivation/Derivation"
      },
      "rdfs:label": "result",
      "rdfs:range": {
        "@id": "https://uor.foundation/schema/Datum"
      }
    },
    {
      "@id": "https://uor.foundation/derivation/step",
      "@type": "owl:ObjectProperty",
      "rdfs:comment": "A rewrite step in this derivation.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/derivation/Derivation"
      },
      "rdfs:label": "step",
      "rdfs:range": {
        "@id": "https://uor.foundation/derivation/RewriteStep"
      }
    },
    {
      "@id": "https://uor.foundation/derivation/termMetrics",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "Metrics for the canonical term produced by this derivation.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/derivation/Derivation"
      },
      "rdfs:label": "termMetrics",
      "rdfs:range": {
        "@id": "https://uor.foundation/derivation/TermMetrics"
      }
    },
    {
      "@id": "https://uor.foundation/derivation/from",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The term before this rewrite step.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/derivation/RewriteStep"
      },
      "rdfs:label": "from",
      "rdfs:range": {
        "@id": "https://uor.foundation/schema/Term"
      }
    },
    {
      "@id": "https://uor.foundation/derivation/to",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The term after this rewrite step.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/derivation/RewriteStep"
      },
      "rdfs:label": "to",
      "rdfs:range": {
        "@id": "https://uor.foundation/schema/Term"
      }
    },
    {
      "@id": "https://uor.foundation/derivation/hasRewriteRule",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The typed rewrite rule applied in this step. Provides a structured reference to a named RewriteRule individual, complementing the string-valued derivation:rule property.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/derivation/RewriteStep"
      },
      "rdfs:label": "hasRewriteRule",
      "rdfs:range": {
        "@id": "https://uor.foundation/derivation/RewriteRule"
      }
    },
    {
      "@id": "https://uor.foundation/derivation/groundedIn",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The algebraic identity that grounds this rewrite rule. Links a RewriteRule to the op:Identity individual that justifies its application.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/derivation/RewriteRule"
      },
      "rdfs:label": "groundedIn",
      "rdfs:range": {
        "@id": "https://uor.foundation/op/Identity"
      }
    },
    {
      "@id": "https://uor.foundation/derivation/stepCount",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The total number of rewrite steps in this derivation.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/derivation/TermMetrics"
      },
      "rdfs:label": "stepCount",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#nonNegativeInteger"
      }
    },
    {
      "@id": "https://uor.foundation/derivation/termSize",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The number of nodes in the canonical term's syntax tree.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/derivation/TermMetrics"
      },
      "rdfs:label": "termSize",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#nonNegativeInteger"
      }
    },
    {
      "@id": "https://uor.foundation/derivation/previousType",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The type before this refinement step was applied.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/derivation/RefinementStep"
      },
      "rdfs:label": "previousType",
      "rdfs:range": {
        "@id": "https://uor.foundation/type/TypeDefinition"
      }
    },
    {
      "@id": "https://uor.foundation/derivation/appliedConstraint",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The constraint that was applied in this refinement step.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/derivation/RefinementStep"
      },
      "rdfs:label": "appliedConstraint",
      "rdfs:range": {
        "@id": "https://uor.foundation/type/Constraint"
      }
    },
    {
      "@id": "https://uor.foundation/derivation/refinedType",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The type after this refinement step was applied.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/derivation/RefinementStep"
      },
      "rdfs:label": "refinedType",
      "rdfs:range": {
        "@id": "https://uor.foundation/type/TypeDefinition"
      }
    },
    {
      "@id": "https://uor.foundation/derivation/fibersClosed",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The number of fiber coordinates pinned by this refinement step.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/derivation/RefinementStep"
      },
      "rdfs:label": "fibersClosed",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#nonNegativeInteger"
      }
    },
    {
      "@id": "https://uor.foundation/derivation/stepIndex",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "Zero-based sequential index of this step within the synthesis derivation.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/derivation/SynthesisStep"
      },
      "rdfs:label": "stepIndex",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#nonNegativeInteger"
      }
    },
    {
      "@id": "https://uor.foundation/derivation/addedConstraint",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The constraint added in this synthesis step.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/derivation/SynthesisStep"
      },
      "rdfs:label": "addedConstraint",
      "rdfs:range": {
        "@id": "https://uor.foundation/type/Constraint"
      }
    },
    {
      "@id": "https://uor.foundation/derivation/signatureBefore",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The constraint nerve signature before this synthesis step.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/derivation/SynthesisStep"
      },
      "rdfs:label": "signatureBefore",
      "rdfs:range": {
        "@id": "https://uor.foundation/observable/SynthesisSignature"
      }
    },
    {
      "@id": "https://uor.foundation/derivation/signatureAfter",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The constraint nerve signature after this synthesis step.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/derivation/SynthesisStep"
      },
      "rdfs:label": "signatureAfter",
      "rdfs:range": {
        "@id": "https://uor.foundation/observable/SynthesisSignature"
      }
    },
    {
      "@id": "https://uor.foundation/derivation/checkpointStep",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The SynthesisStep at which this checkpoint was taken.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/derivation/SynthesisCheckpoint"
      },
      "rdfs:label": "checkpointStep",
      "rdfs:range": {
        "@id": "https://uor.foundation/derivation/SynthesisStep"
      }
    },
    {
      "@id": "https://uor.foundation/derivation/checkpointState",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The ConstraintSearchState snapshot captured by this checkpoint.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/derivation/SynthesisCheckpoint"
      },
      "rdfs:label": "checkpointState",
      "rdfs:range": {
        "@id": "https://uor.foundation/resolver/ConstraintSearchState"
      }
    },
    {
      "@id": "https://uor.foundation/derivation/towerCheckpoint",
      "@type": "owl:ObjectProperty",
      "rdfs:comment": "Links a TowerCompletenessResolver to a SynthesisCheckpoint issued at each completed step. Cross-namespace bridge property: domain is resolver:TowerCompletenessResolver.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/resolver/TowerCompletenessResolver"
      },
      "rdfs:label": "towerCheckpoint",
      "rdfs:range": {
        "@id": "https://uor.foundation/derivation/SynthesisCheckpoint"
      }
    },
    {
      "@id": "https://uor.foundation/derivation/CriticalIdentityRule",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/derivation/RewriteRule"
      ],
      "derivation:groundedIn": {
        "@id": "https://uor.foundation/op/criticalIdentity"
      },
      "rdfs:comment": "The rewrite rule applying the critical identity: neg(bnot(x)) → succ(x). Grounded in op:criticalIdentity.",
      "rdfs:label": "CriticalIdentityRule"
    },
    {
      "@id": "https://uor.foundation/derivation/InvolutionRule",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/derivation/RewriteRule"
      ],
      "rdfs:comment": "The rewrite rule applying involution cancellation: f(f(x)) → x for any involution f.",
      "rdfs:label": "InvolutionRule"
    },
    {
      "@id": "https://uor.foundation/derivation/AssociativityRule",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/derivation/RewriteRule"
      ],
      "rdfs:comment": "The rewrite rule applying associativity to re-bracket nested binary operations.",
      "rdfs:label": "AssociativityRule"
    },
    {
      "@id": "https://uor.foundation/derivation/CommutativityRule",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/derivation/RewriteRule"
      ],
      "rdfs:comment": "The rewrite rule applying commutativity to reorder operands of commutative operations.",
      "rdfs:label": "CommutativityRule"
    },
    {
      "@id": "https://uor.foundation/derivation/IdentityElementRule",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/derivation/RewriteRule"
      ],
      "rdfs:comment": "The rewrite rule eliminating identity elements: add(x, 0) → x, mul(x, 1) → x, xor(x, 0) → x.",
      "rdfs:label": "IdentityElementRule"
    },
    {
      "@id": "https://uor.foundation/derivation/NormalizationRule",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/derivation/RewriteRule"
      ],
      "rdfs:comment": "The rewrite rule normalizing compound expressions to canonical ordering (e.g., sorting operands by address).",
      "rdfs:label": "NormalizationRule"
    },
    {
      "@id": "https://uor.foundation/trace/",
      "@type": "owl:Ontology",
      "owl:imports": [
        {
          "@id": "https://uor.foundation/schema/"
        },
        {
          "@id": "https://uor.foundation/op/"
        },
        {
          "@id": "https://uor.foundation/cert/"
        },
        {
          "@id": "https://uor.foundation/observable/"
        }
      ],
      "rdfs:comment": "Execution traces recording the sequence of kernel operations, intermediate results, and accumulated metrics for a computation.",
      "rdfs:label": "UOR Computation Traces",
      "uor:space": "bridge"
    },
    {
      "@id": "https://uor.foundation/trace/ComputationTrace",
      "@type": "owl:Class",
      "rdfs:comment": "A complete record of a kernel computation: the input, output, every operation step, and accumulated metrics.",
      "rdfs:label": "ComputationTrace",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/trace/ComputationStep",
      "@type": "owl:Class",
      "rdfs:comment": "A single step in a computation trace: one operation applied to produce one output from one or more inputs.",
      "rdfs:label": "ComputationStep",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/trace/TraceMetrics",
      "@type": "owl:Class",
      "rdfs:comment": "Summary metrics for a computation trace: total steps, accumulated ring distance, and accumulated Hamming distance.",
      "rdfs:label": "TraceMetrics",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/trace/GeodesicTrace",
      "@type": "owl:Class",
      "rdfs:comment": "A computation trace that satisfies the dual geodesic condition (GD_1): AR_1-ordered and DC_10-selected. The path of least dissipation through the resolution landscape.",
      "rdfs:label": "GeodesicTrace",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/trace/ComputationTrace"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/trace/GeodesicViolation",
      "@type": "owl:Class",
      "rdfs:comment": "A record of a geodesic condition violation at a specific step of a computation trace. Produced by GeodesicValidator when J_k(step_i) < max_\\{free\\} J_k(state_i).",
      "rdfs:label": "GeodesicViolation",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/trace/MeasurementEvent",
      "@type": "owl:Class",
      "rdfs:comment": "A specialized computation step recording a single projective collapse of a SuperposedFiberState. Carries pre-collapse entropy and post-collapse Landauer cost (QM_1).",
      "rdfs:label": "MeasurementEvent",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/trace/ComputationStep"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/trace/MeasurementOutcome",
      "@type": "owl:Class",
      "rdfs:comment": "A single outcome of a projective measurement on a SuperposedFiberState, recording the classical fiber index (outcomeValue) and its Born-rule probability |α_k|² (outcomeProbability). Multiple outcomes form the probability distribution of a measurement.",
      "rdfs:label": "MeasurementOutcome",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/trace/input",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The input datum of this computation.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/trace/ComputationTrace"
      },
      "rdfs:label": "input",
      "rdfs:range": {
        "@id": "https://uor.foundation/schema/Datum"
      }
    },
    {
      "@id": "https://uor.foundation/trace/output",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The output datum of this computation.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/trace/ComputationTrace"
      },
      "rdfs:label": "output",
      "rdfs:range": {
        "@id": "https://uor.foundation/schema/Datum"
      }
    },
    {
      "@id": "https://uor.foundation/trace/step",
      "@type": "owl:ObjectProperty",
      "rdfs:comment": "A computation step in this trace.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/trace/ComputationTrace"
      },
      "rdfs:label": "step",
      "rdfs:range": {
        "@id": "https://uor.foundation/trace/ComputationStep"
      }
    },
    {
      "@id": "https://uor.foundation/trace/monodromy",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The monodromy accumulated by this computation: the net dihedral group element produced by the full operation sequence.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/trace/ComputationTrace"
      },
      "rdfs:label": "monodromy",
      "rdfs:range": {
        "@id": "https://uor.foundation/observable/DihedralElement"
      }
    },
    {
      "@id": "https://uor.foundation/trace/from",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The input datum of this computation step.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/trace/ComputationStep"
      },
      "rdfs:label": "from",
      "rdfs:range": {
        "@id": "https://uor.foundation/schema/Datum"
      }
    },
    {
      "@id": "https://uor.foundation/trace/to",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The output datum of this computation step.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/trace/ComputationStep"
      },
      "rdfs:label": "to",
      "rdfs:range": {
        "@id": "https://uor.foundation/schema/Datum"
      }
    },
    {
      "@id": "https://uor.foundation/trace/operation",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The operation applied in this computation step.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/trace/ComputationStep"
      },
      "rdfs:label": "operation",
      "rdfs:range": {
        "@id": "https://uor.foundation/op/Operation"
      }
    },
    {
      "@id": "https://uor.foundation/trace/index",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The zero-based sequential index of this step within its trace.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/trace/ComputationStep"
      },
      "rdfs:label": "index",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#nonNegativeInteger"
      }
    },
    {
      "@id": "https://uor.foundation/trace/stepCount",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "Total number of computation steps in this trace.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/trace/TraceMetrics"
      },
      "rdfs:label": "stepCount",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#nonNegativeInteger"
      }
    },
    {
      "@id": "https://uor.foundation/trace/totalRingDistance",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "Total ring-metric distance accumulated across all steps.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/trace/TraceMetrics"
      },
      "rdfs:label": "totalRingDistance",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#nonNegativeInteger"
      }
    },
    {
      "@id": "https://uor.foundation/trace/totalHammingDistance",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "Total Hamming-metric distance accumulated across all steps.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/trace/TraceMetrics"
      },
      "rdfs:label": "totalHammingDistance",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#nonNegativeInteger"
      }
    },
    {
      "@id": "https://uor.foundation/trace/certifiedBy",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The certificate that attests to the correctness of this computation trace.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/trace/ComputationTrace"
      },
      "rdfs:label": "certifiedBy",
      "rdfs:range": {
        "@id": "https://uor.foundation/cert/Certificate"
      }
    },
    {
      "@id": "https://uor.foundation/trace/residualEntropy",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The residual entropy observable remaining after this computation trace, linking to the ThermoObservable taxonomy (TH_9 connection).",
      "rdfs:domain": {
        "@id": "https://uor.foundation/trace/ComputationTrace"
      },
      "rdfs:label": "residualEntropy",
      "rdfs:range": {
        "@id": "https://uor.foundation/observable/ResidualEntropy"
      }
    },
    {
      "@id": "https://uor.foundation/trace/isGeodesic",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "Whether this computation trace satisfies the dual geodesic condition (GD_1): AR_1-ordered and DC_10-selected.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/trace/ComputationTrace"
      },
      "rdfs:label": "isGeodesic",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#boolean"
      }
    },
    {
      "@id": "https://uor.foundation/trace/geodesicCertificate",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The GeodesicCertificate attesting that this trace satisfied both GD_1 conditions.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/trace/GeodesicTrace"
      },
      "rdfs:label": "geodesicCertificate",
      "rdfs:range": {
        "@id": "https://uor.foundation/cert/GeodesicCertificate"
      }
    },
    {
      "@id": "https://uor.foundation/trace/geodesicViolation",
      "@type": "owl:ObjectProperty",
      "rdfs:comment": "A GeodesicViolation record indicating where the trace deviated from the geodesic condition.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/trace/ComputationTrace"
      },
      "rdfs:label": "geodesicViolation",
      "rdfs:range": {
        "@id": "https://uor.foundation/trace/GeodesicViolation"
      }
    },
    {
      "@id": "https://uor.foundation/trace/stepEntropyCost",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The entropy cost of a single computation step. On a geodesic, this equals ln 2 for every step (GD_2).",
      "rdfs:domain": {
        "@id": "https://uor.foundation/trace/ComputationStep"
      },
      "rdfs:label": "stepEntropyCost",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#decimal"
      }
    },
    {
      "@id": "https://uor.foundation/trace/cumulativeEntropyCost",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The total entropy cost accumulated across all steps of a trace. On a geodesic, equals freeCount_initial × ln 2 (GD_3).",
      "rdfs:domain": {
        "@id": "https://uor.foundation/trace/ComputationTrace"
      },
      "rdfs:label": "cumulativeEntropyCost",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#decimal"
      }
    },
    {
      "@id": "https://uor.foundation/trace/jacobianAtStep",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The Jacobian value J_k at this step, used by the GeodesicValidator to check DC_10 maximality.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/trace/ComputationStep"
      },
      "rdfs:label": "jacobianAtStep",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#decimal"
      }
    },
    {
      "@id": "https://uor.foundation/trace/adiabaticallyOrdered",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "Whether the step sequence of this trace follows the AR_1 adiabatic ordering (decreasing freeCount × cost-per-fiber).",
      "rdfs:domain": {
        "@id": "https://uor.foundation/trace/ComputationTrace"
      },
      "rdfs:label": "adiabaticallyOrdered",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#boolean"
      }
    },
    {
      "@id": "https://uor.foundation/trace/violationReason",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "Human-readable description of why a geodesic violation occurred, citing the step index and the unused higher-J_k option.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/trace/GeodesicViolation"
      },
      "rdfs:label": "violationReason",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#string"
      }
    },
    {
      "@id": "https://uor.foundation/trace/measurementEvent",
      "@type": "owl:ObjectProperty",
      "rdfs:comment": "A MeasurementEvent step within this computation trace.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/trace/ComputationTrace"
      },
      "rdfs:label": "measurementEvent",
      "rdfs:range": {
        "@id": "https://uor.foundation/trace/MeasurementEvent"
      }
    },
    {
      "@id": "https://uor.foundation/trace/preCollapseEntropy",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The von Neumann entropy S_vN of the SuperposedFiberState before projective collapse.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/trace/MeasurementEvent"
      },
      "rdfs:label": "preCollapseEntropy",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#decimal"
      }
    },
    {
      "@id": "https://uor.foundation/trace/postCollapseLandauerCost",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The Landauer cost incurred by the projective collapse. Equals preCollapseEntropy at β* = ln 2 (QM_1).",
      "rdfs:domain": {
        "@id": "https://uor.foundation/trace/MeasurementEvent"
      },
      "rdfs:label": "postCollapseLandauerCost",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#decimal"
      }
    },
    {
      "@id": "https://uor.foundation/trace/collapseStep",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The step index within the enclosing ComputationTrace at which this projective collapse occurred.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/trace/MeasurementEvent"
      },
      "rdfs:label": "collapseStep",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#nonNegativeInteger"
      }
    },
    {
      "@id": "https://uor.foundation/trace/amplitudeVector",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The full pre-collapse amplitude vector of all branches at the time of measurement. Enables Born rule verification (QM_5): P(outcome k) = |α_k|² / Σ|αᵢ|².",
      "rdfs:domain": {
        "@id": "https://uor.foundation/trace/MeasurementEvent"
      },
      "rdfs:label": "amplitudeVector",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#string"
      }
    },
    {
      "@id": "https://uor.foundation/trace/isAR1Ordered",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "Whether this computation trace has steps ordered by the AR_1 adiabatic metric (decreasing freeCount × cost-per-fiber). One of the two sub-predicates of isGeodesic (GD_6).",
      "rdfs:domain": {
        "@id": "https://uor.foundation/trace/ComputationTrace"
      },
      "rdfs:label": "isAR1Ordered",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#boolean"
      }
    },
    {
      "@id": "https://uor.foundation/trace/isDC10Selected",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "Whether each step of this computation trace was selected by the DC_10 Jacobian criterion (maximal J_k among free fibers). One of the two sub-predicates of isGeodesic (GD_6).",
      "rdfs:domain": {
        "@id": "https://uor.foundation/trace/ComputationTrace"
      },
      "rdfs:label": "isDC10Selected",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#boolean"
      }
    },
    {
      "@id": "https://uor.foundation/trace/outcomeValue",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The classical fiber index selected by projective collapse in this measurement outcome.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/trace/MeasurementOutcome"
      },
      "rdfs:label": "outcomeValue",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#nonNegativeInteger"
      }
    },
    {
      "@id": "https://uor.foundation/trace/outcomeProbability",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The Born-rule probability of this measurement outcome: |α_k|² where α_k is the amplitude of the collapsed fiber.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/trace/MeasurementOutcome"
      },
      "rdfs:label": "outcomeProbability",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#decimal"
      }
    },
    {
      "@id": "https://uor.foundation/trace/geodesic_Q0",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/trace/GeodesicTrace"
      ],
      "rdfs:comment": "Canonical geodesic trace at quantum level Q0 (n=8). Demonstrates GD_1 through GD_3 at the base level.",
      "rdfs:label": "geodesic_Q0",
      "trace:adiabaticallyOrdered": true,
      "trace:isGeodesic": true
    },
    {
      "@id": "https://uor.foundation/trace/geodesic_Q1",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/trace/GeodesicTrace"
      ],
      "rdfs:comment": "Canonical geodesic trace at quantum level Q1 (n=16). Demonstrates geodesic scaling from Q0 to Q1.",
      "rdfs:label": "geodesic_Q1",
      "trace:adiabaticallyOrdered": true,
      "trace:isGeodesic": true
    },
    {
      "@id": "https://uor.foundation/trace/geodesic_Q2",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/trace/GeodesicTrace"
      ],
      "rdfs:comment": "Canonical geodesic trace at quantum level Q2 (n=32). Demonstrates geodesic scaling from Q1 to Q2.",
      "rdfs:label": "geodesic_Q2",
      "trace:adiabaticallyOrdered": true,
      "trace:isGeodesic": true
    },
    {
      "@id": "https://uor.foundation/trace/geodesic_Q3",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/trace/GeodesicTrace"
      ],
      "rdfs:comment": "Canonical geodesic trace at quantum level Q3 (n=64). Demonstrates geodesic scaling from Q2 to Q3.",
      "rdfs:label": "geodesic_Q3",
      "trace:adiabaticallyOrdered": true,
      "trace:isGeodesic": true
    },
    {
      "@id": "https://uor.foundation/trace/collapse_equal_superposition",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/trace/MeasurementEvent"
      ],
      "rdfs:comment": "Canonical measurement event: collapse of an equal superposition (|α|² = 0.5). Maximum von Neumann entropy S_vN = ln 2. Maximum Landauer cost per QM_1.",
      "rdfs:label": "collapse_equal_superposition",
      "trace:postCollapseLandauerCost": "0.693147",
      "trace:preCollapseEntropy": "0.693147"
    },
    {
      "@id": "https://uor.foundation/trace/collapse_biased",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/trace/MeasurementEvent"
      ],
      "rdfs:comment": "Canonical measurement event: collapse of a biased superposition (|α|² = 0.9). Lower entropy than equal superposition. Demonstrates QM_3 bound.",
      "rdfs:label": "collapse_biased",
      "trace:postCollapseLandauerCost": "0.325083",
      "trace:preCollapseEntropy": "0.325083"
    },
    {
      "@id": "https://uor.foundation/trace/collapse_classical",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/trace/MeasurementEvent"
      ],
      "rdfs:comment": "Canonical measurement event: collapse of a classical state (|α|² = 1). Zero entropy, zero Landauer cost. Demonstrates QM_4 idempotence.",
      "rdfs:label": "collapse_classical",
      "trace:postCollapseLandauerCost": "0.0",
      "trace:preCollapseEntropy": "0.0"
    },
    {
      "@id": "https://uor.foundation/cert/",
      "@type": "owl:Ontology",
      "owl:imports": [
        {
          "@id": "https://uor.foundation/op/"
        },
        {
          "@id": "https://uor.foundation/proof/"
        },
        {
          "@id": "https://uor.foundation/schema/"
        },
        {
          "@id": "https://uor.foundation/type/"
        }
      ],
      "rdfs:comment": "Kernel-produced attestation certificates for transforms, isometries, and involutions. Each certificate verifies that a specific structural property holds.",
      "rdfs:label": "UOR Certificates",
      "uor:space": "bridge"
    },
    {
      "@id": "https://uor.foundation/cert/Certificate",
      "@type": "owl:Class",
      "rdfs:comment": "A kernel-produced attestation. The root class for all certificate types.",
      "rdfs:label": "Certificate",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/cert/TransformCertificate",
      "@type": "owl:Class",
      "rdfs:comment": "A certificate attesting to the properties of a morphism:Transform. Certifies that the transform maps source to target correctly.",
      "rdfs:label": "TransformCertificate",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/cert/Certificate"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/cert/IsometryCertificate",
      "@type": "owl:Class",
      "rdfs:comment": "A certificate attesting that a morphism:Isometry preserves metric distances. Certifies the transform is a metric isometry with respect to the specified metric.",
      "rdfs:label": "IsometryCertificate",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/cert/Certificate"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/cert/InvolutionCertificate",
      "@type": "owl:Class",
      "rdfs:comment": "A certificate attesting that an operation is an involution: f(f(x)) = x for all x in R_n.",
      "rdfs:label": "InvolutionCertificate",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/cert/Certificate"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/cert/CompletenessCertificate",
      "@type": "owl:Class",
      "rdfs:comment": "A certificate attesting that a type:CompleteType satisfies IT_7d: its constraint nerve has χ = n and all Betti numbers β_k = 0. Issued by the kernel after running the full ψ pipeline on the type's constraint set.",
      "rdfs:label": "CompletenessCertificate",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/cert/Certificate"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/cert/CompletenessAuditTrail",
      "@type": "owl:Class",
      "rdfs:comment": "An ordered collection of CompletenessWitness records belonging to a CompletenessCertificate. Provides full provenance of the certification process: every constraint applied, every fiber closed, in sequence.",
      "rdfs:label": "CompletenessAuditTrail",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/cert/SaturationCertificate",
      "@type": "owl:Class",
      "rdfs:comment": "A certificate attesting that a state:SaturatedContext has reached full saturation (σ = 1, freeCount = 0, S = 0, T_ctx = 0) per SC_4. The session-layer dual of CompletenessCertificate.",
      "rdfs:label": "SaturationCertificate",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/cert/Certificate"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/cert/GeodesicCertificate",
      "@type": "owl:Class",
      "rdfs:comment": "A certificate attesting that a trace:GeodesicTrace satisfies both GD_1 conditions: AR_1-ordered and DC_10-selected. Transforms ComputationTrace from descriptive to normative.",
      "rdfs:label": "GeodesicCertificate",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/cert/Certificate"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/cert/MeasurementCertificate",
      "@type": "owl:Class",
      "rdfs:comment": "A certificate attesting that a trace:MeasurementEvent respected the von Neumann–Landauer bridge (QM_1): preCollapseEntropy = postCollapseLandauerCost at β* = ln 2.",
      "rdfs:label": "MeasurementCertificate",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/cert/Certificate"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/cert/GeodesicEvidenceBundle",
      "@type": "owl:Class",
      "rdfs:comment": "A structured evidence bundle attesting that each sub-predicate of the geodesic condition (GD_6) holds independently: isAR1Ordered and isDC10Selected. Linked from GeodesicCertificate via evidenceBundle.",
      "rdfs:label": "GeodesicEvidenceBundle",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/cert/BornRuleVerification",
      "@type": "owl:Class",
      "rdfs:comment": "A certificate attesting that a MeasurementEvent outcome probability matches the Born rule: P(outcome k) = |α_k|² (QM_5). Linked from MeasurementCertificate to provide probability distribution verification.",
      "rdfs:label": "BornRuleVerification",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/cert/Certificate"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/cert/LiftChainCertificate",
      "@type": "owl:Class",
      "rdfs:comment": "A kernel-issued certificate attesting that a LiftChain from liftSourceLevel to liftTargetLevel is complete.",
      "rdfs:label": "LiftChainCertificate",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/cert/Certificate"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/cert/ChainAuditTrail",
      "@type": "owl:Class",
      "rdfs:comment": "An ordered collection of per-step evidence records for a LiftChainCertificate.",
      "rdfs:label": "ChainAuditTrail",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/cert/transformType",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The type of transform this certificate attests to (e.g., 'isometry', 'embedding', 'action').",
      "rdfs:domain": {
        "@id": "https://uor.foundation/cert/TransformCertificate"
      },
      "rdfs:label": "transformType",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#string"
      }
    },
    {
      "@id": "https://uor.foundation/cert/method",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The verification method used to produce this certificate (e.g., 'exhaustive_check', 'symbolic_proof', 'sampling').",
      "rdfs:domain": {
        "@id": "https://uor.foundation/cert/Certificate"
      },
      "rdfs:label": "method",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#string"
      }
    },
    {
      "@id": "https://uor.foundation/cert/operation",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The operation this certificate applies to.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/cert/InvolutionCertificate"
      },
      "rdfs:label": "operation",
      "rdfs:range": {
        "@id": "https://uor.foundation/op/Operation"
      }
    },
    {
      "@id": "https://uor.foundation/cert/verified",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "Whether this certificate has been verified by the kernel.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/cert/Certificate"
      },
      "rdfs:label": "verified",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#boolean"
      }
    },
    {
      "@id": "https://uor.foundation/cert/quantum",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The quantum level at which this certificate was produced.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/cert/Certificate"
      },
      "rdfs:label": "quantum",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#positiveInteger"
      }
    },
    {
      "@id": "https://uor.foundation/cert/timestamp",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The time at which this certificate was issued.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/cert/Certificate"
      },
      "rdfs:label": "timestamp",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#dateTime"
      }
    },
    {
      "@id": "https://uor.foundation/cert/certifies",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The resource this certificate attests to. Links a certificate to the observable, transform, or other entity it covers.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/cert/Certificate"
      },
      "rdfs:label": "certifies",
      "rdfs:range": {
        "@id": "http://www.w3.org/2002/07/owl#Thing"
      }
    },
    {
      "@id": "https://uor.foundation/cert/certifiedType",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The TypeDefinition whose completeness this certificate attests. The kernel issues this certificate after running the ψ pipeline on the type's constraint set and confirming IT_7d.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/cert/CompletenessCertificate"
      },
      "rdfs:label": "certifiedType",
      "rdfs:range": {
        "@id": "https://uor.foundation/type/CompleteType"
      }
    },
    {
      "@id": "https://uor.foundation/cert/auditTrail",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The audit trail attesting the certification provenance. Links a CompletenessCertificate to its ordered sequence of CompletenessWitness records.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/cert/CompletenessCertificate"
      },
      "rdfs:label": "auditTrail",
      "rdfs:range": {
        "@id": "https://uor.foundation/cert/CompletenessAuditTrail"
      }
    },
    {
      "@id": "https://uor.foundation/cert/witnessCount",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "Total number of witness steps in this audit trail.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/cert/CompletenessAuditTrail"
      },
      "rdfs:label": "witnessCount",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#nonNegativeInteger"
      }
    },
    {
      "@id": "https://uor.foundation/cert/certifiedSaturation",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The SaturatedContext whose full saturation this certificate attests. Uses IRI string (cert cannot import state).",
      "rdfs:domain": {
        "@id": "https://uor.foundation/cert/SaturationCertificate"
      },
      "rdfs:label": "certifiedSaturation",
      "rdfs:range": {
        "@id": "https://uor.foundation/state/SaturatedContext"
      }
    },
    {
      "@id": "https://uor.foundation/cert/saturationWitness",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The SaturationWitness providing step-by-step evidence of the saturation process.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/cert/SaturationCertificate"
      },
      "rdfs:label": "saturationWitness",
      "rdfs:range": {
        "@id": "https://uor.foundation/state/SaturationWitness"
      }
    },
    {
      "@id": "https://uor.foundation/cert/certifiedGeodesic",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The GeodesicTrace whose geodesic status this certificate attests. Uses IRI string (cert cannot import trace).",
      "rdfs:domain": {
        "@id": "https://uor.foundation/cert/GeodesicCertificate"
      },
      "rdfs:label": "certifiedGeodesic",
      "rdfs:range": {
        "@id": "https://uor.foundation/trace/GeodesicTrace"
      }
    },
    {
      "@id": "https://uor.foundation/cert/geodesicTrace",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The computation trace that this GeodesicCertificate covers. Redundant with certifiedGeodesic but expresses the inverse direction for queryability.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/cert/GeodesicCertificate"
      },
      "rdfs:label": "geodesicTrace",
      "rdfs:range": {
        "@id": "https://uor.foundation/trace/GeodesicTrace"
      }
    },
    {
      "@id": "https://uor.foundation/cert/certifiedMeasurement",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The MeasurementEvent whose QM_1 compliance this certificate attests. Uses IRI string (cert cannot import trace).",
      "rdfs:domain": {
        "@id": "https://uor.foundation/cert/MeasurementCertificate"
      },
      "rdfs:label": "certifiedMeasurement",
      "rdfs:range": {
        "@id": "https://uor.foundation/trace/MeasurementEvent"
      }
    },
    {
      "@id": "https://uor.foundation/cert/vonNeumannEntropy",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The von Neumann entropy S_vN of the pre-measurement SuperposedFiberState, recorded by this certificate.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/cert/MeasurementCertificate"
      },
      "rdfs:label": "vonNeumannEntropy",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#decimal"
      }
    },
    {
      "@id": "https://uor.foundation/cert/landauerCost",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The Landauer cost incurred by the projective collapse, recorded by this certificate. Equals vonNeumannEntropy at β* = ln 2 per QM_1.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/cert/MeasurementCertificate"
      },
      "rdfs:label": "landauerCost",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#decimal"
      }
    },
    {
      "@id": "https://uor.foundation/cert/evidenceBundle",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The GeodesicEvidenceBundle attesting to the decomposed sub-predicates (isAR1Ordered, isDC10Selected) of this GeodesicCertificate's geodesic claim.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/cert/GeodesicCertificate"
      },
      "rdfs:label": "evidenceBundle",
      "rdfs:range": {
        "@id": "https://uor.foundation/cert/GeodesicEvidenceBundle"
      }
    },
    {
      "@id": "https://uor.foundation/cert/bornRuleVerified",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "Whether this BornRuleVerification certificate confirms that all outcome probabilities match the Born rule (QM_5): P(k) = |α_k|² for every fiber k.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/cert/BornRuleVerification"
      },
      "rdfs:label": "bornRuleVerified",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#boolean"
      }
    },
    {
      "@id": "https://uor.foundation/cert/certifiedChain",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The LiftChain this certificate attests to.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/cert/LiftChainCertificate"
      },
      "rdfs:label": "certifiedChain",
      "rdfs:range": {
        "@id": "https://uor.foundation/type/LiftChain"
      }
    },
    {
      "@id": "https://uor.foundation/cert/chainAuditTrail",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The ordered per-step evidence for this certificate.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/cert/LiftChainCertificate"
      },
      "rdfs:label": "chainAuditTrail",
      "rdfs:range": {
        "@id": "https://uor.foundation/cert/ChainAuditTrail"
      }
    },
    {
      "@id": "https://uor.foundation/cert/targetLevel",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The quantum level Q_k at which the certificate was issued.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/cert/LiftChainCertificate"
      },
      "rdfs:label": "targetLevel",
      "rdfs:range": {
        "@id": "https://uor.foundation/schema/QuantumLevel"
      }
    },
    {
      "@id": "https://uor.foundation/cert/sourceLevel",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The quantum level Q_j from which the tower was started.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/cert/LiftChainCertificate"
      },
      "rdfs:label": "sourceLevel",
      "rdfs:range": {
        "@id": "https://uor.foundation/schema/QuantumLevel"
      }
    },
    {
      "@id": "https://uor.foundation/cert/chainStepCount",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "Number of lift steps in this ChainAuditTrail. Must equal chainLength of the certified LiftChain. Distinct from witnessCount (domain-locked to CompletenessAuditTrail).",
      "rdfs:domain": {
        "@id": "https://uor.foundation/cert/ChainAuditTrail"
      },
      "rdfs:label": "chainStepCount",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#nonNegativeInteger"
      }
    },
    {
      "@id": "https://uor.foundation/cert/isAR1Ordered",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "True iff the linked GeodesicTrace is ordered by the AR_1 canonical rewriting rule (smallest lexicographic representative first).",
      "rdfs:domain": {
        "@id": "https://uor.foundation/cert/GeodesicEvidenceBundle"
      },
      "rdfs:label": "isAR1Ordered",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#boolean"
      }
    },
    {
      "@id": "https://uor.foundation/cert/isDC10Selected",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "True iff each constraint in the trace was selected by the DC_10 Jacobian oracle at the step where it was applied.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/cert/GeodesicEvidenceBundle"
      },
      "rdfs:label": "isDC10Selected",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#boolean"
      }
    },
    {
      "@id": "https://uor.foundation/morphism/",
      "@type": "owl:Ontology",
      "owl:imports": [
        {
          "@id": "https://uor.foundation/schema/"
        },
        {
          "@id": "https://uor.foundation/type/"
        },
        {
          "@id": "https://uor.foundation/op/"
        },
        {
          "@id": "https://uor.foundation/observable/"
        },
        {
          "@id": "https://uor.foundation/partition/"
        },
        {
          "@id": "https://uor.foundation/trace/"
        },
        {
          "@id": "https://uor.foundation/homology/"
        },
        {
          "@id": "https://uor.foundation/u/"
        },
        {
          "@id": "https://uor.foundation/derivation/"
        },
        {
          "@id": "https://uor.foundation/cert/"
        }
      ],
      "rdfs:comment": "Runtime abstractions for maps between UOR objects: transforms, isometries, embeddings, and group actions. The foundation provides the vocabulary; Prism writes the sentences.",
      "rdfs:label": "UOR Transforms and Morphisms",
      "uor:space": "user"
    },
    {
      "@id": "https://uor.foundation/morphism/Transform",
      "@type": "owl:Class",
      "owl:disjointWith": [
        {
          "@id": "https://uor.foundation/morphism/CompositionLaw"
        }
      ],
      "rdfs:comment": "A map between UOR objects. The root abstraction: source, target, and optionally what structure (if any) is preserved. This is what cert:TransformCertificate certifies.",
      "rdfs:label": "Transform",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/morphism/Isometry",
      "@type": "owl:Class",
      "owl:disjointWith": [
        {
          "@id": "https://uor.foundation/morphism/Composition"
        }
      ],
      "rdfs:comment": "A transform that preserves metric structure with respect to a specified metric. In UOR, isometry is metric-relative: neg is a ring isometry, bnot is a Hamming isometry. A transform can be an isometry with respect to one metric but not the other. This is what cert:IsometryCertificate certifies.",
      "rdfs:label": "Isometry",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/morphism/Transform"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/morphism/Embedding",
      "@type": "owl:Class",
      "owl:disjointWith": [
        {
          "@id": "https://uor.foundation/morphism/Composition"
        }
      ],
      "rdfs:comment": "An injective, structure-preserving transform across quantum levels. The canonical instance is the level embedding ι : R_n → R_{n'} (n < n'), which preserves addition, multiplication, and content addressing.",
      "rdfs:label": "Embedding",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/morphism/Transform"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/morphism/Action",
      "@type": "owl:Class",
      "rdfs:comment": "The mechanism by which a group applies transforms systematically to a set. Each group element induces a transform of the set. The dihedral action on type space is an action by isometries — every element of D_{2^n} produces an isometric transform of 𝒯_n.",
      "rdfs:label": "Action",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/morphism/Composition",
      "@type": "owl:Class",
      "owl:disjointWith": [
        {
          "@id": "https://uor.foundation/morphism/Isometry"
        },
        {
          "@id": "https://uor.foundation/morphism/Embedding"
        },
        {
          "@id": "https://uor.foundation/morphism/Identity"
        }
      ],
      "rdfs:comment": "A transform formed by composing two or more transforms sequentially. The categorical composition operation that turns transforms into a category.",
      "rdfs:label": "Composition",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/morphism/Transform"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/morphism/Identity",
      "@type": "owl:Class",
      "owl:disjointWith": [
        {
          "@id": "https://uor.foundation/morphism/Composition"
        }
      ],
      "rdfs:comment": "The identity transform on a type: maps every element to itself. The categorical identity morphism.",
      "rdfs:label": "Identity",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/morphism/Transform"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/morphism/CompositionLaw",
      "@type": "owl:Class",
      "owl:disjointWith": [
        {
          "@id": "https://uor.foundation/morphism/Transform"
        }
      ],
      "rdfs:comment": "A law governing how operations compose. Records whether the composition is associative, commutative, and what the result operation is. The critical composition law (neg ∘ bnot = succ) is the foundational instance.",
      "rdfs:label": "CompositionLaw",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/morphism/GroundingMap",
      "@type": "owl:Class",
      "owl:disjointWith": [
        {
          "@id": "https://uor.foundation/morphism/ProjectionMap"
        }
      ],
      "rdfs:comment": "A Transform mapping a surface symbol (any schema:Literal) to its ring datum (a schema:Datum) via the content-addressing bijection. Typed, derivation-witnessed, constraint-preserving map from surface to coordinate. Applies identically across NLP tokens, ARC-AGI grid cells, MIDI notes, pixels, sensor readings, and logical propositions.",
      "rdfs:label": "GroundingMap",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/morphism/Transform"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/morphism/ProjectionMap",
      "@type": "owl:Class",
      "owl:disjointWith": [
        {
          "@id": "https://uor.foundation/morphism/GroundingMap"
        }
      ],
      "rdfs:comment": "A Transform mapping a resolved partition:Partition (address neighbourhood) to an ordered sequence of surface symbols. Output ordering determined by the active state:Frame — the same constraint frame that decomposed the input symbol sequence.",
      "rdfs:label": "ProjectionMap",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/morphism/Transform"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/morphism/GroundingCertificate",
      "@type": "owl:Class",
      "rdfs:comment": "A certificate attesting that a specific grounding round-trip (P∘Π∘G) satisfied the shared-frame condition and landed in the type-equivalent neighbourhood of the source symbol. Witnesses the Surface Symmetry Theorem (op:surfaceSymmetry) for one specific symbol instance.",
      "rdfs:label": "GroundingCertificate",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/cert/Certificate"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/morphism/TopologicalDelta",
      "@type": "owl:Class",
      "rdfs:comment": "A topological delta: records changes in topological invariants (Betti numbers, Euler characteristic, nerve structure) before and after a morphism.",
      "rdfs:label": "TopologicalDelta",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/morphism/source",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The domain of the transform.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/morphism/Transform"
      },
      "rdfs:label": "source",
      "rdfs:range": {
        "@id": "http://www.w3.org/2002/07/owl#Thing"
      }
    },
    {
      "@id": "https://uor.foundation/morphism/target",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The codomain of the transform.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/morphism/Transform"
      },
      "rdfs:label": "target",
      "rdfs:range": {
        "@id": "http://www.w3.org/2002/07/owl#Thing"
      }
    },
    {
      "@id": "https://uor.foundation/morphism/preserves",
      "@type": "owl:ObjectProperty",
      "rdfs:comment": "The structure preserved by this transform (if any). E.g., a ring homomorphism preserves addition and multiplication.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/morphism/Transform"
      },
      "rdfs:label": "preserves",
      "rdfs:range": {
        "@id": "http://www.w3.org/2002/07/owl#Thing"
      }
    },
    {
      "@id": "https://uor.foundation/morphism/preservesMetric",
      "@type": "owl:ObjectProperty",
      "rdfs:comment": "The specific metric this isometry preserves. Points to observable:RingMetric or observable:HammingMetric. A transform that preserves both is an isometry of the full UOR geometry. A transform that preserves one but not the other has nontrivial curvature — observable:CurvatureObservable measures this gap.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/morphism/Isometry"
      },
      "rdfs:label": "preservesMetric",
      "rdfs:range": {
        "@id": "https://uor.foundation/observable/MetricObservable"
      }
    },
    {
      "@id": "https://uor.foundation/morphism/sourceQuantum",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The quantum level n of the source ring for an embedding.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/morphism/Embedding"
      },
      "rdfs:label": "sourceQuantum",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#positiveInteger"
      }
    },
    {
      "@id": "https://uor.foundation/morphism/targetQuantum",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The quantum level n' of the target ring for an embedding. Must satisfy n' > n (embeddings go to larger rings).",
      "rdfs:domain": {
        "@id": "https://uor.foundation/morphism/Embedding"
      },
      "rdfs:label": "targetQuantum",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#positiveInteger"
      }
    },
    {
      "@id": "https://uor.foundation/morphism/group",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The group acting in this group action.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/morphism/Action"
      },
      "rdfs:label": "group",
      "rdfs:range": {
        "@id": "https://uor.foundation/op/Group"
      }
    },
    {
      "@id": "https://uor.foundation/morphism/actingOn",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The set being acted upon by this group action.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/morphism/Action"
      },
      "rdfs:label": "actingOn",
      "rdfs:range": {
        "@id": "http://www.w3.org/2002/07/owl#Thing"
      }
    },
    {
      "@id": "https://uor.foundation/morphism/actionIsometry",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "Whether every transform induced by this action is an isometry. True for the dihedral action on 𝒯_n (Frame Theorem).",
      "rdfs:domain": {
        "@id": "https://uor.foundation/morphism/Action"
      },
      "rdfs:label": "actionIsometry",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#boolean"
      }
    },
    {
      "@id": "https://uor.foundation/morphism/trace",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The computation trace that realized this transform at runtime. A Transform is an abstraction; a trace is the kernel's record of how it was executed via concrete operations.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/morphism/Transform"
      },
      "rdfs:label": "trace",
      "rdfs:range": {
        "@id": "https://uor.foundation/trace/ComputationTrace"
      }
    },
    {
      "@id": "https://uor.foundation/morphism/composesWith",
      "@type": "owl:ObjectProperty",
      "rdfs:comment": "A transform that this transform can be composed with. The target of this transform must match the source of the composed transform.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/morphism/Transform"
      },
      "rdfs:label": "composesWith",
      "rdfs:range": {
        "@id": "https://uor.foundation/morphism/Transform"
      }
    },
    {
      "@id": "https://uor.foundation/morphism/compositionResult",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The transform that results from this composition.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/morphism/Composition"
      },
      "rdfs:label": "compositionResult",
      "rdfs:range": {
        "@id": "https://uor.foundation/morphism/Transform"
      }
    },
    {
      "@id": "https://uor.foundation/morphism/compositionComponents",
      "@type": "owl:ObjectProperty",
      "rdfs:comment": "A component transform of this composition.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/morphism/Composition"
      },
      "rdfs:label": "compositionComponents",
      "rdfs:range": {
        "@id": "https://uor.foundation/morphism/Transform"
      }
    },
    {
      "@id": "https://uor.foundation/morphism/identityOn",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The type on which this identity transform acts.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/morphism/Identity"
      },
      "rdfs:label": "identityOn",
      "rdfs:range": {
        "@id": "https://uor.foundation/type/TypeDefinition"
      }
    },
    {
      "@id": "https://uor.foundation/morphism/compositionOrder",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The number of component transforms in a composition.",
      "rdfs:label": "compositionOrder",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#nonNegativeInteger"
      }
    },
    {
      "@id": "https://uor.foundation/morphism/isAssociative",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "Whether this composition law is associative.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/morphism/CompositionLaw"
      },
      "rdfs:label": "isAssociative",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#boolean"
      }
    },
    {
      "@id": "https://uor.foundation/morphism/isCommutative",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "Whether this composition law is commutative.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/morphism/CompositionLaw"
      },
      "rdfs:label": "isCommutative",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#boolean"
      }
    },
    {
      "@id": "https://uor.foundation/morphism/lawComponents",
      "@type": "owl:ObjectProperty",
      "rdfs:comment": "An operation that is a component of this composition law.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/morphism/CompositionLaw"
      },
      "rdfs:label": "lawComponents",
      "rdfs:range": {
        "@id": "https://uor.foundation/op/Operation"
      }
    },
    {
      "@id": "https://uor.foundation/morphism/lawResult",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The operation that results from this composition law.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/morphism/CompositionLaw"
      },
      "rdfs:label": "lawResult",
      "rdfs:range": {
        "@id": "https://uor.foundation/op/Operation"
      }
    },
    {
      "@id": "https://uor.foundation/morphism/preservesStructure",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "A human-readable description of the structure this transform preserves (e.g., 'ring homomorphism', 'metric isometry').",
      "rdfs:domain": {
        "@id": "https://uor.foundation/morphism/Transform"
      },
      "rdfs:label": "preservesStructure",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#string"
      }
    },
    {
      "@id": "https://uor.foundation/morphism/addressCoherence",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "Certificate that this embedding's addressing diagram commutes: glyph ∘ ι ∘ addresses is well-defined and injective.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/morphism/Embedding"
      },
      "rdfs:label": "addressCoherence",
      "rdfs:range": {
        "@id": "https://uor.foundation/op/Identity"
      }
    },
    {
      "@id": "https://uor.foundation/morphism/bettisBefore",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "Betti numbers before the morphism.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/morphism/TopologicalDelta"
      },
      "rdfs:label": "bettisBefore",
      "rdfs:range": {
        "@id": "https://uor.foundation/observable/BettiNumber"
      }
    },
    {
      "@id": "https://uor.foundation/morphism/bettisAfter",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "Betti numbers after the morphism.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/morphism/TopologicalDelta"
      },
      "rdfs:label": "bettisAfter",
      "rdfs:range": {
        "@id": "https://uor.foundation/observable/BettiNumber"
      }
    },
    {
      "@id": "https://uor.foundation/morphism/eulerBefore",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "Euler characteristic before the morphism.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/morphism/TopologicalDelta"
      },
      "rdfs:label": "eulerBefore",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#integer"
      }
    },
    {
      "@id": "https://uor.foundation/morphism/eulerAfter",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "Euler characteristic after the morphism.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/morphism/TopologicalDelta"
      },
      "rdfs:label": "eulerAfter",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#integer"
      }
    },
    {
      "@id": "https://uor.foundation/morphism/nerveBefore",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "Constraint nerve (simplicial complex) before the morphism.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/morphism/TopologicalDelta"
      },
      "rdfs:label": "nerveBefore",
      "rdfs:range": {
        "@id": "https://uor.foundation/homology/SimplicialComplex"
      }
    },
    {
      "@id": "https://uor.foundation/morphism/nerveAfter",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "Constraint nerve (simplicial complex) after the morphism.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/morphism/TopologicalDelta"
      },
      "rdfs:label": "nerveAfter",
      "rdfs:range": {
        "@id": "https://uor.foundation/homology/SimplicialComplex"
      }
    },
    {
      "@id": "https://uor.foundation/morphism/surfaceSymbol",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The surface symbol that is the source of this grounding.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/morphism/GroundingMap"
      },
      "rdfs:label": "surfaceSymbol",
      "rdfs:range": {
        "@id": "https://uor.foundation/schema/Literal"
      }
    },
    {
      "@id": "https://uor.foundation/morphism/groundedAddress",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The resolved ring address that is the target of this grounding.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/morphism/GroundingMap"
      },
      "rdfs:label": "groundedAddress",
      "rdfs:range": {
        "@id": "https://uor.foundation/u/Address"
      }
    },
    {
      "@id": "https://uor.foundation/morphism/groundingDerivation",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The derivation witnessing the content-addressing computation that produced the grounded address from the surface symbol.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/morphism/GroundingMap"
      },
      "rdfs:label": "groundingDerivation",
      "rdfs:range": {
        "@id": "https://uor.foundation/derivation/Derivation"
      }
    },
    {
      "@id": "https://uor.foundation/morphism/symbolConstraints",
      "@type": "owl:ObjectProperty",
      "rdfs:comment": "A typed attribute preserved by this grounding. Non-functional: one assertion per active constraint axis (vertical, horizontal, diagonal).",
      "rdfs:domain": {
        "@id": "https://uor.foundation/morphism/GroundingMap"
      },
      "rdfs:label": "symbolConstraints",
      "rdfs:range": {
        "@id": "https://uor.foundation/type/Constraint"
      }
    },
    {
      "@id": "https://uor.foundation/morphism/projectionFrame",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The active frame — shared with the grounding that produced the query. The shared-frame condition (Surface Symmetry Theorem) requires G and P to reference the same frame.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/morphism/ProjectionMap"
      },
      "rdfs:label": "projectionFrame",
      "rdfs:range": {
        "@id": "https://uor.foundation/state/Frame"
      }
    },
    {
      "@id": "https://uor.foundation/morphism/projectionSource",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The resolved partition (address neighbourhood) that this map projects back to surface symbols.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/morphism/ProjectionMap"
      },
      "rdfs:label": "projectionSource",
      "rdfs:range": {
        "@id": "https://uor.foundation/partition/Partition"
      }
    },
    {
      "@id": "https://uor.foundation/morphism/projectionOrder",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "Ordering constraint determining the output symbol sequence. Domain-specific: syntactic position (NLP), row-major scan (ARC), temporal sequence (music).",
      "rdfs:domain": {
        "@id": "https://uor.foundation/morphism/ProjectionMap"
      },
      "rdfs:label": "projectionOrder",
      "rdfs:range": {
        "@id": "https://uor.foundation/type/CompositeConstraint"
      }
    },
    {
      "@id": "https://uor.foundation/morphism/roundTripCoherence",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "Completeness criterion: does projecting the grounded source address recover a symbol in the same type class as the input? True iff the shared-frame condition holds.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/morphism/ProjectionMap"
      },
      "rdfs:label": "roundTripCoherence",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#boolean"
      }
    },
    {
      "@id": "https://uor.foundation/morphism/groundingCertMap",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The GroundingMap used in this certified round-trip.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/morphism/GroundingCertificate"
      },
      "rdfs:label": "groundingCertMap",
      "rdfs:range": {
        "@id": "https://uor.foundation/morphism/GroundingMap"
      }
    },
    {
      "@id": "https://uor.foundation/morphism/groundingCertProjection",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The ProjectionMap used in this certified round-trip.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/morphism/GroundingCertificate"
      },
      "rdfs:label": "groundingCertProjection",
      "rdfs:range": {
        "@id": "https://uor.foundation/morphism/ProjectionMap"
      }
    },
    {
      "@id": "https://uor.foundation/morphism/groundingCertSourceSymbol",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The surface symbol that entered the grounding boundary.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/morphism/GroundingCertificate"
      },
      "rdfs:label": "groundingCertSourceSymbol",
      "rdfs:range": {
        "@id": "https://uor.foundation/schema/Literal"
      }
    },
    {
      "@id": "https://uor.foundation/morphism/groundingCertAddress",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The ring address the symbol was grounded to.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/morphism/GroundingCertificate"
      },
      "rdfs:label": "groundingCertAddress",
      "rdfs:range": {
        "@id": "https://uor.foundation/u/Address"
      }
    },
    {
      "@id": "https://uor.foundation/morphism/criticalComposition",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/morphism/CompositionLaw"
      ],
      "morphism:isAssociative": false,
      "morphism:isCommutative": false,
      "morphism:lawComponents": [
        {
          "@id": "https://uor.foundation/op/neg"
        },
        {
          "@id": "https://uor.foundation/op/bnot"
        }
      ],
      "morphism:lawResult": {
        "@id": "https://uor.foundation/op/succ"
      },
      "rdfs:comment": "The critical composition law: neg ∘ bnot = succ. This is the operational form of the critical identity theorem. The composition of the two involutions (neg, bnot) yields the successor operation. Non-associative and non-commutative.",
      "rdfs:label": "criticalComposition"
    },
    {
      "@id": "https://uor.foundation/state/",
      "@type": "owl:Ontology",
      "owl:imports": [
        {
          "@id": "https://uor.foundation/u/"
        },
        {
          "@id": "https://uor.foundation/schema/"
        },
        {
          "@id": "https://uor.foundation/type/"
        },
        {
          "@id": "https://uor.foundation/partition/"
        },
        {
          "@id": "https://uor.foundation/trace/"
        },
        {
          "@id": "https://uor.foundation/morphism/"
        },
        {
          "@id": "https://uor.foundation/cert/"
        }
      ],
      "rdfs:comment": "Parameterized address spaces, context management, binding lifecycle, and state transitions. The user-space overlay onto the kernel's read-only ring substrate.",
      "rdfs:label": "UOR State",
      "uor:space": "user"
    },
    {
      "@id": "https://uor.foundation/state/Context",
      "@type": "owl:Class",
      "owl:disjointWith": [
        {
          "@id": "https://uor.foundation/state/Binding"
        },
        {
          "@id": "https://uor.foundation/state/Frame"
        },
        {
          "@id": "https://uor.foundation/state/Transition"
        }
      ],
      "rdfs:comment": "A bounded set of populated UOR addresses. The parameter space for a resolution cycle. Contexts hold bindings that map addresses to datum values.",
      "rdfs:label": "Context",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/state/Binding",
      "@type": "owl:Class",
      "owl:disjointWith": [
        {
          "@id": "https://uor.foundation/state/Context"
        },
        {
          "@id": "https://uor.foundation/state/Frame"
        },
        {
          "@id": "https://uor.foundation/state/Transition"
        }
      ],
      "rdfs:comment": "The association of a datum value with an address in a context. The write primitive: creating a binding populates an address.",
      "rdfs:label": "Binding",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/state/Frame",
      "@type": "owl:Class",
      "owl:disjointWith": [
        {
          "@id": "https://uor.foundation/state/Context"
        },
        {
          "@id": "https://uor.foundation/state/Binding"
        },
        {
          "@id": "https://uor.foundation/state/Transition"
        }
      ],
      "rdfs:comment": "The visibility boundary determining which bindings are in scope for a given resolution. A frame is a view into a context: it selects which bindings the resolver sees.",
      "rdfs:label": "Frame",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/state/Transition",
      "@type": "owl:Class",
      "owl:disjointWith": [
        {
          "@id": "https://uor.foundation/state/Context"
        },
        {
          "@id": "https://uor.foundation/state/Binding"
        },
        {
          "@id": "https://uor.foundation/state/Frame"
        }
      ],
      "rdfs:comment": "A state change: the transformation of one context into another through binding or unbinding. The sequence of transitions is the application's computation history.",
      "rdfs:label": "Transition",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/state/SessionBoundaryType",
      "@type": "owl:Class",
      "rdfs:comment": "A typed controlled vocabulary for session boundary reasons. Each individual names a specific reason a context-reset boundary was triggered during a multi-turn session.",
      "rdfs:label": "SessionBoundaryType",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/state/Session",
      "@type": "owl:Class",
      "rdfs:comment": "A bounded sequence of RelationQuery/response pairs sharing a common state:Context. Sessions are the unit of coherent multi-turn reasoning in Prism.",
      "rdfs:label": "Session",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/state/BindingAccumulator",
      "@type": "owl:Class",
      "rdfs:comment": "The mutable accumulator that appends state:Binding instances to a state:Context as each RelationQuery resolves. Tracks monotonic reduction of aggregate free fiber space.",
      "rdfs:label": "BindingAccumulator",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/state/SessionBoundary",
      "@type": "owl:Class",
      "rdfs:comment": "Marks a context-reset event within a session stream. Records why the context was reset and provides a clean state:Context for subsequent queries.",
      "rdfs:label": "SessionBoundary",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/state/SaturatedContext",
      "@type": "owl:Class",
      "rdfs:comment": "A context that has reached full saturation: σ = 1, freeCount = 0, S = 0, T_ctx = 0 (SC_4). The ground state of the type system. All subsequent queries resolve in O(1) via SC_5.",
      "rdfs:label": "SaturatedContext",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/state/Context"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/state/SaturationWitness",
      "@type": "owl:Class",
      "rdfs:comment": "Step-by-step evidence of the saturation process: records which bindings were applied, in what order, to reach full saturation.",
      "rdfs:label": "SaturationWitness",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/state/DomainSaturationRecord",
      "@type": "owl:Class",
      "rdfs:comment": "An informational/monitoring record tracking the saturation progress of a specific domain within a context. Carries no formal authority — purely observational.",
      "rdfs:label": "DomainSaturationRecord",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/state/SaturationPhase",
      "@type": "owl:Class",
      "rdfs:comment": "A typed controlled vocabulary for the three phases of context saturation: Unsaturated (σ = 0), PartialSaturation (0 < σ < 1), and FullSaturation (σ = 1).",
      "rdfs:label": "SaturationPhase",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/state/SharedContext",
      "@type": "owl:Class",
      "rdfs:comment": "A Context visible to more than one Session simultaneously. Holds a set of ContextLease instances that partition its fiber coordinates among active sessions. Lease disjointness (SR_9) prevents concurrent write conflicts.",
      "rdfs:label": "SharedContext",
      "rdfs:subClassOf": [
        {
          "@id": "https://uor.foundation/state/Context"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/state/ContextLease",
      "@type": "owl:Class",
      "owl:disjointWith": [
        {
          "@id": "https://uor.foundation/state/Context"
        },
        {
          "@id": "https://uor.foundation/state/Binding"
        },
        {
          "@id": "https://uor.foundation/state/Frame"
        },
        {
          "@id": "https://uor.foundation/state/Transition"
        }
      ],
      "rdfs:comment": "A bounded, exclusive claim on a set of fiber coordinates within a SharedContext, held by exactly one Session. When the session closes or hits a SessionBoundary, the lease is released and its fibers become available for re-leasing.",
      "rdfs:label": "ContextLease",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/state/SessionComposition",
      "@type": "owl:Class",
      "rdfs:comment": "Records that a Session was formed by merging the binding sets of two or more predecessor sessions. Valid only if all predecessor binding sets pass the cross-session consistency check (SR_8). An invalid composition attempt produces a ContradictionBoundary on the target session.",
      "rdfs:label": "SessionComposition",
      "rdfs:subClassOf": [
        {
          "@id": "http://www.w3.org/2002/07/owl#Thing"
        }
      ]
    },
    {
      "@id": "https://uor.foundation/state/address",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The UOR address being bound in this binding.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/state/Binding"
      },
      "rdfs:label": "address",
      "rdfs:range": {
        "@id": "https://uor.foundation/u/Address"
      }
    },
    {
      "@id": "https://uor.foundation/state/content",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The datum value bound to the address in this binding.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/state/Binding"
      },
      "rdfs:label": "content",
      "rdfs:range": {
        "@id": "https://uor.foundation/schema/Datum"
      }
    },
    {
      "@id": "https://uor.foundation/state/boundType",
      "@type": "owl:ObjectProperty",
      "rdfs:comment": "The type under which this binding's datum is resolved.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/state/Binding"
      },
      "rdfs:label": "boundType",
      "rdfs:range": {
        "@id": "https://uor.foundation/type/TypeDefinition"
      }
    },
    {
      "@id": "https://uor.foundation/state/timestamp",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The time at which this binding was created.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/state/Binding"
      },
      "rdfs:label": "timestamp",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#dateTime"
      }
    },
    {
      "@id": "https://uor.foundation/state/binding",
      "@type": "owl:ObjectProperty",
      "rdfs:comment": "A binding held in this context.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/state/Context"
      },
      "rdfs:label": "binding",
      "rdfs:range": {
        "@id": "https://uor.foundation/state/Binding"
      }
    },
    {
      "@id": "https://uor.foundation/state/capacity",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The maximum number of bindings this context can hold.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/state/Context"
      },
      "rdfs:label": "capacity",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#positiveInteger"
      }
    },
    {
      "@id": "https://uor.foundation/state/contentAddress",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The content-derived address of this context, uniquely identifying its current state in the UOR address space.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/state/Context"
      },
      "rdfs:label": "contentAddress",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#string"
      }
    },
    {
      "@id": "https://uor.foundation/state/quantum",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The quantum level of this context's address space.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/state/Context"
      },
      "rdfs:label": "quantum",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#positiveInteger"
      }
    },
    {
      "@id": "https://uor.foundation/state/activeBindings",
      "@type": "owl:ObjectProperty",
      "rdfs:comment": "The bindings currently in scope for this frame.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/state/Frame"
      },
      "rdfs:label": "activeBindings",
      "rdfs:range": {
        "@id": "https://uor.foundation/state/Binding"
      }
    },
    {
      "@id": "https://uor.foundation/state/context",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The context this frame is a view of.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/state/Frame"
      },
      "rdfs:label": "context",
      "rdfs:range": {
        "@id": "https://uor.foundation/state/Context"
      }
    },
    {
      "@id": "https://uor.foundation/state/constraint",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The type:Constraint determining which bindings from the context are visible in this frame. The resolver applies this constraint to filter the context's binding set, producing the frame's active bindings. An absent constraint means all bindings are visible.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/state/Frame"
      },
      "rdfs:label": "constraint",
      "rdfs:range": {
        "@id": "https://uor.foundation/type/Constraint"
      }
    },
    {
      "@id": "https://uor.foundation/state/from",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The context before this transition.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/state/Transition"
      },
      "rdfs:label": "from",
      "rdfs:range": {
        "@id": "https://uor.foundation/state/Context"
      }
    },
    {
      "@id": "https://uor.foundation/state/to",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The context after this transition.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/state/Transition"
      },
      "rdfs:label": "to",
      "rdfs:range": {
        "@id": "https://uor.foundation/state/Context"
      }
    },
    {
      "@id": "https://uor.foundation/state/addedBindings",
      "@type": "owl:ObjectProperty",
      "rdfs:comment": "Bindings added to the context in this transition.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/state/Transition"
      },
      "rdfs:label": "addedBindings",
      "rdfs:range": {
        "@id": "https://uor.foundation/state/Binding"
      }
    },
    {
      "@id": "https://uor.foundation/state/removedBindings",
      "@type": "owl:ObjectProperty",
      "rdfs:comment": "Bindings removed from the context in this transition.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/state/Transition"
      },
      "rdfs:label": "removedBindings",
      "rdfs:range": {
        "@id": "https://uor.foundation/state/Binding"
      }
    },
    {
      "@id": "https://uor.foundation/state/trace",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The computation trace recording the kernel operations that effected this state transition.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/state/Transition"
      },
      "rdfs:label": "trace",
      "rdfs:range": {
        "@id": "https://uor.foundation/trace/ComputationTrace"
      }
    },
    {
      "@id": "https://uor.foundation/state/topologicalSnapshot",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "A snapshot of topological invariants at this transition point.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/state/Transition"
      },
      "rdfs:label": "topologicalSnapshot",
      "rdfs:range": {
        "@id": "https://uor.foundation/morphism/TopologicalDelta"
      }
    },
    {
      "@id": "https://uor.foundation/state/sessionBindings",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The shared context holding all bindings accumulated across the queries in this session.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/state/Session"
      },
      "rdfs:label": "sessionBindings",
      "rdfs:range": {
        "@id": "https://uor.foundation/state/Context"
      }
    },
    {
      "@id": "https://uor.foundation/state/sessionQueries",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The number of RelationQuery evaluations completed in this session.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/state/Session"
      },
      "rdfs:label": "sessionQueries",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#nonNegativeInteger"
      }
    },
    {
      "@id": "https://uor.foundation/state/aggregateFiberDeficit",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The aggregate FiberBudget deficit across all accumulated bindings: the total remaining free fibers that have not yet been closed by resolution. Decreases monotonically as the session progresses.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/state/BindingAccumulator"
      },
      "rdfs:label": "aggregateFiberDeficit",
      "rdfs:range": {
        "@id": "https://uor.foundation/partition/FiberBudget"
      }
    },
    {
      "@id": "https://uor.foundation/state/accumulatedBindings",
      "@type": "owl:ObjectProperty",
      "rdfs:comment": "A binding accumulated by this accumulator from a resolved RelationQuery.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/state/BindingAccumulator"
      },
      "rdfs:label": "accumulatedBindings",
      "rdfs:range": {
        "@id": "https://uor.foundation/state/Binding"
      }
    },
    {
      "@id": "https://uor.foundation/state/boundaryReason",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "A human-readable description of why this session boundary was triggered.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/state/SessionBoundary"
      },
      "rdfs:label": "boundaryReason",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#string"
      }
    },
    {
      "@id": "https://uor.foundation/state/boundaryType",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The typed reason category for this session boundary.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/state/SessionBoundary"
      },
      "rdfs:label": "boundaryType",
      "rdfs:range": {
        "@id": "https://uor.foundation/state/SessionBoundaryType"
      }
    },
    {
      "@id": "https://uor.foundation/state/priorContext",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The state:Context that was active before this boundary reset.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/state/SessionBoundary"
      },
      "rdfs:label": "priorContext",
      "rdfs:range": {
        "@id": "https://uor.foundation/state/Context"
      }
    },
    {
      "@id": "https://uor.foundation/state/freshContext",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The clean state:Context produced after this boundary reset, ready for subsequent queries.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/state/SessionBoundary"
      },
      "rdfs:label": "freshContext",
      "rdfs:range": {
        "@id": "https://uor.foundation/state/Context"
      }
    },
    {
      "@id": "https://uor.foundation/state/saturationDegree",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The saturation degree σ ∈ \\[0, 1\\] of this context. Defined by SC_2: σ = (n − freeCount) / n.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/state/Context"
      },
      "rdfs:label": "saturationDegree",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#decimal"
      }
    },
    {
      "@id": "https://uor.foundation/state/contextTemperature",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The context temperature T_ctx ∈ \\[0, ln 2\\]. Defined by SC_1: T_ctx = freeCount × ln 2 / n. At σ = 1, T_ctx = 0.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/state/Context"
      },
      "rdfs:label": "contextTemperature",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#decimal"
      }
    },
    {
      "@id": "https://uor.foundation/state/isSaturated",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "Whether this context has reached full saturation (σ = 1). Equivalent to freeCount = 0, S = 0, T_ctx = 0 per SC_4.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/state/Context"
      },
      "rdfs:label": "isSaturated",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#boolean"
      }
    },
    {
      "@id": "https://uor.foundation/state/saturationPhase",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The current saturation phase of this context: Unsaturated, PartialSaturation, or FullSaturation.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/state/Context"
      },
      "rdfs:label": "saturationPhase",
      "rdfs:range": {
        "@id": "https://uor.foundation/state/SaturationPhase"
      }
    },
    {
      "@id": "https://uor.foundation/state/saturationCertificate",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The SaturationCertificate attesting that this context has reached full saturation.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/state/SaturatedContext"
      },
      "rdfs:label": "saturationCertificate",
      "rdfs:range": {
        "@id": "https://uor.foundation/cert/SaturationCertificate"
      }
    },
    {
      "@id": "https://uor.foundation/state/witnessBinding",
      "@type": "owl:ObjectProperty",
      "rdfs:comment": "A binding that contributed to the saturation process, recorded in this SaturationWitness.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/state/SaturationWitness"
      },
      "rdfs:label": "witnessBinding",
      "rdfs:range": {
        "@id": "https://uor.foundation/state/Binding"
      }
    },
    {
      "@id": "https://uor.foundation/state/witnessStep",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The step index at which a particular binding was applied during the saturation process.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/state/SaturationWitness"
      },
      "rdfs:label": "witnessStep",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#nonNegativeInteger"
      }
    },
    {
      "@id": "https://uor.foundation/state/residualFreeCount",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The number of free (unbound) fibers remaining in this context. At saturation, residualFreeCount = 0.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/state/Context"
      },
      "rdfs:label": "residualFreeCount",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#nonNegativeInteger"
      }
    },
    {
      "@id": "https://uor.foundation/state/saturatedContext",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The SaturatedContext that this DomainSaturationRecord monitors.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/state/DomainSaturationRecord"
      },
      "rdfs:label": "saturatedContext",
      "rdfs:range": {
        "@id": "https://uor.foundation/state/SaturatedContext"
      }
    },
    {
      "@id": "https://uor.foundation/state/saturatedDomain",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The domain within the context being tracked by this DomainSaturationRecord.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/state/DomainSaturationRecord"
      },
      "rdfs:label": "saturatedDomain",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#string"
      }
    },
    {
      "@id": "https://uor.foundation/state/domainFreeCount",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The number of free fibers remaining in the specific domain tracked by this DomainSaturationRecord.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/state/DomainSaturationRecord"
      },
      "rdfs:label": "domainFreeCount",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#nonNegativeInteger"
      }
    },
    {
      "@id": "https://uor.foundation/state/leasedFibers",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The subset of fibers claimed by this lease. Must be disjoint from all other active leases on the same SharedContext (SR_9).",
      "rdfs:domain": {
        "@id": "https://uor.foundation/state/ContextLease"
      },
      "rdfs:label": "leasedFibers",
      "rdfs:range": {
        "@id": "https://uor.foundation/partition/FiberBudget"
      }
    },
    {
      "@id": "https://uor.foundation/state/leaseHolder",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The Session that holds this lease.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/state/ContextLease"
      },
      "rdfs:label": "leaseHolder",
      "rdfs:range": {
        "@id": "https://uor.foundation/state/Session"
      }
    },
    {
      "@id": "https://uor.foundation/state/leaseSet",
      "@type": "owl:ObjectProperty",
      "rdfs:comment": "A currently active ContextLease on this SharedContext.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/state/SharedContext"
      },
      "rdfs:label": "leaseSet",
      "rdfs:range": {
        "@id": "https://uor.foundation/state/ContextLease"
      }
    },
    {
      "@id": "https://uor.foundation/state/composedFrom",
      "@type": "owl:ObjectProperty",
      "rdfs:comment": "A predecessor session contributing bindings to this composition. Non-functional: one composition may merge two or more sessions.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/state/SessionComposition"
      },
      "rdfs:label": "composedFrom",
      "rdfs:range": {
        "@id": "https://uor.foundation/state/Session"
      }
    },
    {
      "@id": "https://uor.foundation/state/compositionCompatible",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "Whether all predecessor binding sets passed the SR_8 consistency check. If false, the composition is invalid and must not be used as a session context.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/state/SessionComposition"
      },
      "rdfs:label": "compositionCompatible",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#boolean"
      }
    },
    {
      "@id": "https://uor.foundation/state/compositionResult",
      "@type": [
        "owl:ObjectProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "The merged Context produced by a valid composition. Only present when compositionCompatible = true.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/state/SessionComposition"
      },
      "rdfs:label": "compositionResult",
      "rdfs:range": {
        "@id": "https://uor.foundation/state/Context"
      }
    },
    {
      "@id": "https://uor.foundation/state/towerConsistencyVerified",
      "@type": [
        "owl:DatatypeProperty",
        "owl:FunctionalProperty"
      ],
      "rdfs:comment": "Whether the LiftChain tower consistency check (SR_8 parametric extension) was performed across all Q_0 through Q_k levels. Required for compositions involving sessions at Q_1 or higher.",
      "rdfs:domain": {
        "@id": "https://uor.foundation/state/SessionComposition"
      },
      "rdfs:label": "towerConsistencyVerified",
      "rdfs:range": {
        "@id": "http://www.w3.org/2001/XMLSchema#boolean"
      }
    },
    {
      "@id": "https://uor.foundation/state/ExplicitReset",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/state/SessionBoundaryType"
      ],
      "rdfs:comment": "The caller explicitly requested a context reset. All accumulated bindings are discarded.",
      "rdfs:label": "ExplicitReset"
    },
    {
      "@id": "https://uor.foundation/state/ConvergenceBoundary",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/state/SessionBoundaryType"
      ],
      "rdfs:comment": "The session resolver determined that no further queries can reduce the aggregate fiber deficit.",
      "rdfs:label": "ConvergenceBoundary"
    },
    {
      "@id": "https://uor.foundation/state/ContradictionBoundary",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/state/SessionBoundaryType"
      ],
      "rdfs:comment": "A new query produced a type contradiction with an accumulated binding. Context must reset before resolution can continue.",
      "rdfs:label": "ContradictionBoundary"
    },
    {
      "@id": "https://uor.foundation/state/Unsaturated",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/state/SaturationPhase"
      ],
      "rdfs:comment": "The context has σ = 0: no bindings accumulated, all fibers are free. The initial phase of every session.",
      "rdfs:label": "Unsaturated"
    },
    {
      "@id": "https://uor.foundation/state/PartialSaturation",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/state/SaturationPhase"
      ],
      "rdfs:comment": "The context has 0 < σ < 1: some fibers are pinned by accumulated bindings, but free fibers remain. The accumulation phase.",
      "rdfs:label": "PartialSaturation"
    },
    {
      "@id": "https://uor.foundation/state/FullSaturation",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/state/SaturationPhase"
      ],
      "rdfs:comment": "The context has σ = 1: all fibers are pinned, freeCount = 0. The ground state. All subsequent queries resolve in O(1) via SC_5.",
      "rdfs:label": "FullSaturation"
    },
    {
      "@id": "https://uor.foundation/state/ground_state",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/state/SaturatedContext"
      ],
      "rdfs:comment": "The canonical ground-state witness: a SaturatedContext at σ = 1, freeCount = 0, T_ctx = 0, S = 0 (SC_4). Demonstrates that full saturation is achievable and O(1) resolution (SC_5) is realized.",
      "rdfs:label": "ground_state",
      "state:contextTemperature": "0.0",
      "state:isSaturated": true,
      "state:residualFreeCount": 0,
      "state:saturationDegree": "1.0",
      "state:saturationPhase": {
        "@id": "https://uor.foundation/state/FullSaturation"
      }
    }
  ]
}