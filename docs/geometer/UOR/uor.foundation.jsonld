      "rdfs:label": "SC_7"
    },
    {
      "@id": "https://uor.foundation/op/MS_1",
      "@type": [
        "owl:NamedIndividual",
        "https://uor.foundation/op/Identity"
      ],
      "op:forAll": "C: non-empty ConstrainedType",
